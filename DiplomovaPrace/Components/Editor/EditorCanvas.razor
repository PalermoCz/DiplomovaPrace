    private Dictionary<string, List<SchematicNodeEntity>> BuildFacilityChildrenLookup(IEnumerable<SchematicNodeEntity> nodes)
    {
        var childrenByParent = new Dictionary<string, List<SchematicNodeEntity>>(StringComparer.OrdinalIgnoreCase);

        foreach (var node in nodes)
        {
            if (string.IsNullOrWhiteSpace(node.ParentNodeKey))
            {
                continue;
            }

            if (!childrenByParent.TryGetValue(node.ParentNodeKey, out var children))
            {
                children = [];
                childrenByParent[node.ParentNodeKey] = children;
            }

            children.Add(node);
        }

        foreach (var children in childrenByParent.Values)
        {
            children.Sort((left, right) => StringComparer.OrdinalIgnoreCase.Compare(left.NodeKey, right.NodeKey));
        }

        return childrenByParent;
    }

    private Dictionary<string, int> BuildFacilityDepthLookup(
        IReadOnlyList<SchematicNodeEntity> nodes,
        IReadOnlyDictionary<string, List<SchematicNodeEntity>> childrenByParent)
    {
        var depthByNodeKey = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var nodeByKey = nodes.ToDictionary(node => node.NodeKey, StringComparer.OrdinalIgnoreCase);

        var rootNodes = nodes
            .Where(node => string.IsNullOrWhiteSpace(node.ParentNodeKey) || !nodeByKey.ContainsKey(node.ParentNodeKey))
            .OrderBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var queue = new Queue<(string NodeKey, int Depth)>();
        foreach (var root in rootNodes)
        {
            queue.Enqueue((root.NodeKey, 0));
        }

        while (queue.Count > 0)
        {
            var (nodeKey, depth) = queue.Dequeue();
            if (depthByNodeKey.TryGetValue(nodeKey, out var knownDepth) && knownDepth <= depth)
            {
                continue;
            }

            depthByNodeKey[nodeKey] = depth;

            if (!childrenByParent.TryGetValue(nodeKey, out var children))
            {
                continue;
            }

            foreach (var child in children)
            {
                queue.Enqueue((child.NodeKey, depth + 1));
            }
        }

        var maxDepth = depthByNodeKey.Values.DefaultIfEmpty(0).Max();
        foreach (var node in nodes.OrderBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase))
        {
            if (!depthByNodeKey.ContainsKey(node.NodeKey))
            {
                maxDepth++;
                depthByNodeKey[node.NodeKey] = maxDepth;
            }
        }

        return depthByNodeKey;
    }

    private static int GetFacilityDepth(IReadOnlyDictionary<string, int> depthByNodeKey, string nodeKey)
    {
        return depthByNodeKey.TryGetValue(nodeKey, out var depth) ? depth : 0;
    }

    private static List<FacilityRenderLink> BuildFacilityRenderLinks(
        IReadOnlyList<SchematicNodeEntity> positionedNodes,
        IReadOnlyDictionary<string, SchematicNodeEntity> nodeByKey,
        IEnumerable<SchematicEdgeEntity> explicitEdges,
        IReadOnlyDictionary<string, List<SchematicNodeEntity>> childrenByParent)
    {
        var links = new List<FacilityRenderLink>();
        var seenLinkKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var edge in explicitEdges)
        {
            if (!nodeByKey.ContainsKey(edge.SourceNodeKey) || !nodeByKey.ContainsKey(edge.TargetNodeKey))
            {
                continue;
            }

            var linkKey = BuildLinkKey(edge.SourceNodeKey, edge.TargetNodeKey);
            if (!seenLinkKeys.Add(linkKey))
            {
                continue;
            }

            links.Add(new FacilityRenderLink(edge.SourceNodeKey, edge.TargetNodeKey, IsExplicitEdge: true));
        }

        foreach (var (parentNodeKey, children) in childrenByParent)
        {
            if (!nodeByKey.ContainsKey(parentNodeKey))
            {
                continue;
            }

            foreach (var child in children)
            {
                if (!nodeByKey.ContainsKey(child.NodeKey))
                {
                    continue;
                }

                var linkKey = BuildLinkKey(parentNodeKey, child.NodeKey);
                if (!seenLinkKeys.Add(linkKey))
                {
                    continue;
                }

                links.Add(new FacilityRenderLink(parentNodeKey, child.NodeKey, IsExplicitEdge: false));
            }
        }

        links.Sort((left, right) =>
        {
            if (!nodeByKey.TryGetValue(left.SourceNodeKey, out var leftSource) || !nodeByKey.TryGetValue(right.SourceNodeKey, out var rightSource))
            {
                return StringComparer.OrdinalIgnoreCase.Compare(left.SourceNodeKey, right.SourceNodeKey);
            }

            var leftX = leftSource.XHint.GetValueOrDefault();
            var rightX = rightSource.XHint.GetValueOrDefault();
            var xCompare = leftX.CompareTo(rightX);
            if (xCompare != 0)
            {
                return xCompare;
            }

            var leftY = leftSource.YHint.GetValueOrDefault();
            var rightY = rightSource.YHint.GetValueOrDefault();
            var yCompare = leftY.CompareTo(rightY);
            if (yCompare != 0)
            {
                return yCompare;
            }

            return StringComparer.OrdinalIgnoreCase.Compare(left.SourceNodeKey, right.SourceNodeKey);
        });

        return links;
    }

    private static string BuildLinkKey(string sourceNodeKey, string targetNodeKey)
    {
        return $"{sourceNodeKey}|{targetNodeKey}";
    }

    private string BuildOrthogonalLinkPath(SchematicNodeEntity sourceNode, SchematicNodeEntity targetNode)
    {
        var sourceX = sourceNode.XHint!.Value * ViewBoxWidth;
        var sourceY = sourceNode.YHint!.Value * ViewBoxHeight;
        var targetX = targetNode.XHint!.Value * ViewBoxWidth;
        var targetY = targetNode.YHint!.Value * ViewBoxHeight;

        var sourceArea = ResolveFacilityAreaKey(sourceNode);
        var targetArea = ResolveFacilityAreaKey(targetNode);
        var sourceIsBackbone = IsBackboneNodeType(sourceNode);
        var targetIsBackbone = IsBackboneNodeType(targetNode);
        var sourceIsUtility = IsUtilityBranchNodeType(sourceNode);
        var targetIsUtility = IsUtilityBranchNodeType(targetNode);

        var utilityBusY = ViewBoxHeight * 0.27;
        var areaBusY = ViewBoxHeight * 0.30;

        if (!string.IsNullOrWhiteSpace(sourceArea)
            && string.Equals(sourceArea, targetArea, StringComparison.OrdinalIgnoreCase)
            && !sourceIsBackbone
            && !targetIsBackbone)
        {
            var insideAreaMidX = sourceX <= targetX
                ? Math.Min(targetX - 10, sourceX + 20)
                : Math.Max(targetX + 10, sourceX - 20);
            return $"M {Fmt(sourceX)} {Fmt(sourceY)} L {Fmt(insideAreaMidX)} {Fmt(sourceY)} L {Fmt(insideAreaMidX)} {Fmt(targetY)} L {Fmt(targetX)} {Fmt(targetY)}";
        }

        if (sourceIsBackbone && targetIsUtility)
        {
            var elbowY = Math.Min(targetY - 14, utilityBusY - 8);
            return $"M {Fmt(sourceX)} {Fmt(sourceY)} L {Fmt(sourceX)} {Fmt(elbowY)} L {Fmt(targetX)} {Fmt(elbowY)} L {Fmt(targetX)} {Fmt(targetY)}";
        }

        if (sourceIsUtility && targetIsBackbone)
        {
            var elbowY = Math.Max(targetY + 14, utilityBusY - 8);
            return $"M {Fmt(sourceX)} {Fmt(sourceY)} L {Fmt(sourceX)} {Fmt(elbowY)} L {Fmt(targetX)} {Fmt(elbowY)} L {Fmt(targetX)} {Fmt(targetY)}";
        }

        if (sourceIsBackbone && !targetIsBackbone)
        {
            return $"M {Fmt(sourceX)} {Fmt(sourceY)} L {Fmt(sourceX)} {Fmt(areaBusY)} L {Fmt(targetX)} {Fmt(areaBusY)} L {Fmt(targetX)} {Fmt(targetY)}";
        }

        if (!sourceIsBackbone && targetIsBackbone)
        {
            return $"M {Fmt(sourceX)} {Fmt(sourceY)} L {Fmt(sourceX)} {Fmt(areaBusY)} L {Fmt(targetX)} {Fmt(areaBusY)} L {Fmt(targetX)} {Fmt(targetY)}";
        }

        if (sourceIsUtility || targetIsUtility)
        {
            var branchDropY = Math.Max(utilityBusY + 10, Math.Min(sourceY, targetY) + 10);
            return $"M {Fmt(sourceX)} {Fmt(sourceY)} L {Fmt(sourceX)} {Fmt(branchDropY)} L {Fmt(targetX)} {Fmt(branchDropY)} L {Fmt(targetX)} {Fmt(targetY)}";
        }

        var elbowX = (sourceX + targetX) / 2d;
        return $"M {Fmt(sourceX)} {Fmt(sourceY)} L {Fmt(elbowX)} {Fmt(sourceY)} L {Fmt(elbowX)} {Fmt(targetY)} L {Fmt(targetX)} {Fmt(targetY)}";
    }

    private List<FacilityAreaBlock> BuildFacilityAreaBlocks(IReadOnlyList<SchematicNodeEntity> nodes)
    {
        var width = ViewBoxWidth;
        var height = ViewBoxHeight;
        var blocks = new List<FacilityAreaBlock>();
        var nodesByArea = nodes
            .Select(node => (Node: node, Area: ResolveFacilityAreaKey(node)))
            .Where(item => !string.IsNullOrWhiteSpace(item.Area))
            .GroupBy(item => item.Area!, StringComparer.OrdinalIgnoreCase);

        foreach (var areaGroup in nodesByArea)
        {
            var coordinates = areaGroup
                .Where(item => item.Node.XHint.HasValue && item.Node.YHint.HasValue)
                .Select(item => (X: item.Node.XHint!.Value, Y: item.Node.YHint!.Value))
                .ToList();

            if (coordinates.Count == 0)
            {
                continue;
            }

            var (label, fill, stroke, order) = GetAreaVisual(areaGroup.Key);
            var minX = coordinates.Min(point => point.X);
            var maxX = coordinates.Max(point => point.X);
            var minY = coordinates.Min(point => point.Y);
            var maxY = coordinates.Max(point => point.Y);

            var minWidth = areaGroup.Key.Equals("offices", StringComparison.OrdinalIgnoreCase)
                ? width * 0.24
                : width * 0.50;
            var minHeight = areaGroup.Key.Equals("offices", StringComparison.OrdinalIgnoreCase)
                ? height * 0.14
                : height * 0.14;
            var horizontalPadding = areaGroup.Key.Equals("offices", StringComparison.OrdinalIgnoreCase)
                ? width * 0.028
                : width * 0.044;
            var verticalPaddingTop = height * 0.028;
            var verticalPaddingBottom = height * 0.028;

            var areaX = Math.Max(20, (minX * width) - horizontalPadding);
            var areaY = Math.Max(58, (minY * height) - verticalPaddingTop);
            var areaWidth = Math.Max(minWidth, ((maxX - minX) * width) + (horizontalPadding * 2));
            var areaHeight = Math.Max(minHeight, ((maxY - minY) * height) + verticalPaddingTop + verticalPaddingBottom);

            var maxWidth = (width - 24) - areaX;
            areaWidth = Math.Max(220, Math.Min(areaWidth, maxWidth));
            areaHeight = Math.Min(areaHeight, Math.Min(200, height * 0.36));

            blocks.Add(new FacilityAreaBlock(areaGroup.Key, label, fill, stroke, areaX, areaY, areaWidth, areaHeight, order));
        }

        return blocks
            .OrderBy(block => block.Order)
            .ThenBy(block => block.AreaKey, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private BackboneBand? BuildBackboneBand(IReadOnlyList<SchematicNodeEntity> nodes)
    {
        var width = ViewBoxWidth;
        var height = ViewBoxHeight;
        var backboneNodes = nodes
            .Where(IsBackboneNodeType)
            .Where(node => node.XHint.HasValue && node.YHint.HasValue)
            .ToList();

        if (backboneNodes.Count == 0)
        {
            return null;
        }

        var minX = backboneNodes.Min(node => node.XHint!.Value * width);
        var maxX = backboneNodes.Max(node => node.XHint!.Value * width);
        var minY = backboneNodes.Min(node => node.YHint!.Value * height);
        var maxY = backboneNodes.Max(node => node.YHint!.Value * height);

        var x = Math.Max(14, minX - 52);
        var y = Math.Max(14, minY - 30);
        var bandWidth = Math.Max(width * 0.80, (maxX - minX) + 126);
        var bandHeight = Math.Max(50, (maxY - minY) + 64);

        if (x + bandWidth > width - 12)
        {
            bandWidth = (width - 12) - x;
        }

        return new BackboneBand(x, y, bandWidth, bandHeight);
    }

    private List<SubtreeBand> BuildSubtreeBands(
        IReadOnlyList<SchematicNodeEntity> nodes,
        IReadOnlySet<string> selectedSubtreeNodeKeys)
    {
        var width = ViewBoxWidth;
        var height = ViewBoxHeight;
        if (selectedSubtreeNodeKeys.Count == 0)
        {
            return [];
        }

        var bands = new List<SubtreeBand>();
        var groupedByArea = nodes
            .Where(node => selectedSubtreeNodeKeys.Contains(node.NodeKey))
            .Select(node => (Node: node, Area: ResolveFacilityAreaKey(node)))
            .Where(item => !string.IsNullOrWhiteSpace(item.Area)
                && item.Node.XHint.HasValue
                && item.Node.YHint.HasValue)
            .GroupBy(item => item.Area!, StringComparer.OrdinalIgnoreCase);

        foreach (var areaGroup in groupedByArea)
        {
            var coordinates = areaGroup
                .Select(item => (X: item.Node.XHint!.Value * width, Y: item.Node.YHint!.Value * height))
                .ToList();

            if (coordinates.Count == 0)
            {
                continue;
            }

            var minX = coordinates.Min(point => point.X);
            var maxX = coordinates.Max(point => point.X);
            var minY = coordinates.Min(point => point.Y);
            var maxY = coordinates.Max(point => point.Y);

            var x = Math.Max(0, minX - 14);
            var y = Math.Max(0, minY - 12);
            var bandWidth = Math.Max(58, (maxX - minX) + 28);
            var bandHeight = Math.Max(34, (maxY - minY) + 22);
            bands.Add(new SubtreeBand(x, y, bandWidth, bandHeight));
        }

        return bands;
    }

    private static string? ResolveFacilityAreaKey(SchematicNodeEntity node)
    {
        if (IsBackboneNodeType(node))
        {
            return null;
        }

        var zone = node.Zone?.Trim().ToLowerInvariant();
        var combined = $"{node.NodeKey} {node.Label} {zone}".ToLowerInvariant();

        if (combined.Contains("emission"))
        {
            return "emission_lab";
        }

        if (combined.Contains("design") || combined.Contains("ds_"))
        {
            return "design_studio";
        }

        if (combined.Contains("workshop") || combined.Contains("robotlab"))
        {
            return "workshop";
        }

        if (combined.Contains("office"))
        {
            return "offices";
        }

        return null;
    }

    private static (string Label, string Fill, string Stroke, int Order) GetAreaVisual(string areaKey)
    {
        return areaKey.ToLowerInvariant() switch
        {
            "emission_lab" => ("Emission Lab", "#dcfce7", "#15803d", 0),
            "design_studio" => ("Design Studio", "#e0f2fe", "#0369a1", 1),
            "workshop" => ("Workshop", "#fef3c7", "#b45309", 2),
            "offices" => ("Office Building", "#e2e8f0", "#334155", 3),
            _ => (areaKey, "#f1f5f9", "#475569", 8)
        };
    }

    private static bool IsBackboneNodeType(SchematicNodeEntity node)
    {
        var nodeType = node.NodeType?.Trim();
        if (string.IsNullOrWhiteSpace(nodeType))
        {
            return false;
        }

        return nodeType.Equals("grid", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("site", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("building", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("transformer", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsUtilityBranchNodeType(SchematicNodeEntity node)
    {
        var nodeType = node.NodeType?.Trim();
        if (string.IsNullOrWhiteSpace(nodeType))
        {
            return false;
        }

        return nodeType.Equals("generator_pv", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("generator_chp", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("utility_cooling", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("utility_heating", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsAreaAnchorNode(SchematicNodeEntity node)
    {
        return string.Equals(node.NodeType, "zone", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDistributionNode(
        SchematicNodeEntity node,
        bool hasChildren,
        bool isAreaAnchorNode,
        bool isBackboneNode,
        bool isUtilityNode)
    {
        if (isAreaAnchorNode || isBackboneNode || isUtilityNode)
        {
            return false;
        }

        if (hasChildren)
        {
            return true;
        }

        var nodeType = node.NodeType?.Trim();
        return string.Equals(nodeType, "subzone", StringComparison.OrdinalIgnoreCase)
            || string.Equals(nodeType, "distribution", StringComparison.OrdinalIgnoreCase)
            || string.Equals(nodeType, "branch", StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrWhiteSpace(nodeType) && nodeType.EndsWith("_branch", StringComparison.OrdinalIgnoreCase));
    }

    private static bool IsRectFacilityNode(
        SchematicNodeEntity node,
        bool isAreaAnchorNode,
        bool isBackboneNode,
        bool isUtilityNode)
    {
        if (isBackboneNode)
        {
            return true;
        }

        if (isUtilityNode)
        {
            return false;
        }

        return string.Equals(node.NodeType, "site", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(node.NodeType, "building", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(node.NodeType, "grid", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(node.NodeType, "transformer", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetFacilityNodeSymbol(SchematicNodeEntity node, bool isAreaAnchorNode, bool isDistributionNode, bool hasChildren)
    {
        var nodeType = node.NodeType?.Trim();
        if (string.IsNullOrWhiteSpace(nodeType))
        {
            return hasChildren ? "ND" : "EP";
        }

        if (isAreaAnchorNode)
        {
            return "IN";
        }

        if (nodeType.Equals("grid", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("site", StringComparison.OrdinalIgnoreCase)
            || nodeType.Equals("building", StringComparison.OrdinalIgnoreCase))
        {
            return "G";
        }

        if (nodeType.Equals("transformer", StringComparison.OrdinalIgnoreCase))
        {
            return "T";
        }

        if (nodeType.Equals("generator_pv", StringComparison.OrdinalIgnoreCase))
        {
            return "PV";
        }

        if (nodeType.Equals("generator_chp", StringComparison.OrdinalIgnoreCase))
        {
            return "CHP";
        }

        if (nodeType.Equals("utility_cooling", StringComparison.OrdinalIgnoreCase))
        {
            return "C";
        }

        if (nodeType.Equals("utility_heating", StringComparison.OrdinalIgnoreCase))
        {
            return "H";
        }

        if (nodeType.Equals("server", StringComparison.OrdinalIgnoreCase))
        {
            return "SV";
        }

        if (nodeType.Equals("subzone", StringComparison.OrdinalIgnoreCase) || isDistributionNode)
        {
            return "SW";
        }

        return hasChildren ? "ND" : "EP";
    }

    private static double EstimateLabelWidth(string label)
    {
        var normalizedLength = Math.Clamp(label.Length, 5, 30);
        return normalizedLength * 7.6;
    }

    private LabelPlacement GetFacilityLabelPlacement(
        SchematicNodeEntity node,
        double cx,
        double cy,
        double nodeSize,
        double labelWidth,
        bool isBackboneNode,
        bool isUtilityNode,
        bool isAreaAnchorNode,
        bool isDistributionNode)
    {
        var normalizedX = node.XHint.GetValueOrDefault();
        var normalizedY = node.YHint.GetValueOrDefault();

        if (isBackboneNode)
        {
            // Transformer: alternate labels above/below to reduce crowding
            var transformerBelow = string.Equals(node.NodeType, "transformer", StringComparison.OrdinalIgnoreCase)
                && normalizedX >= 0.38 && normalizedX < 0.79;
            if (transformerBelow)
            {
                var y = cy + nodeSize + 16;
                var boxX = cx - (labelWidth / 2) - 4;
                return new LabelPlacement(cx, y, "middle", boxX, cy + nodeSize + 5);
            }

            var upperY = cy - nodeSize - 10;
            // Edge-aware: prevent right overflow for right-side backbone nodes
            if (normalizedX > 0.72)
            {
                return new LabelPlacement(cx, upperY, "end", cx - labelWidth - 8, cy - nodeSize - 21);
            }
            // Edge-aware: prevent left overflow for ext_grid at far left
            if (normalizedX < 0.16)
            {
                return new LabelPlacement(cx + nodeSize + 6, upperY, "start", cx + nodeSize + 2, cy - nodeSize - 21);
            }
            var upperBoxX = cx - (labelWidth / 2) - 4;
            return new LabelPlacement(cx, upperY, "middle", upperBoxX, cy - nodeSize - 21);
        }

        if (isUtilityNode)
        {
            var y = cy + nodeSize + 17;
            var boxX = cx - (labelWidth / 2) - 4;
            return new LabelPlacement(cx, y, "middle", boxX, cy + nodeSize + 6);
        }

        if (isAreaAnchorNode)
        {
            var x = cx + nodeSize + 13;
            return new LabelPlacement(x, cy + 4, "start", x - 4, cy - 8);
        }

        if (isDistributionNode)
        {
            if (normalizedX < 0.62)
            {
                var x = cx + nodeSize + 11;
                return new LabelPlacement(x, cy + 4, "start", x - 4, cy - 8);
            }

            var leftX = cx - nodeSize - 11;
            return new LabelPlacement(leftX, cy + 4, "end", leftX - labelWidth - 4, cy - 8);
        }

        if (normalizedY > 0.80)
        {
            var y = cy - nodeSize - 8;
            var boxX = cx - (labelWidth / 2) - 4;
            return new LabelPlacement(cx, y, "middle", boxX, cy - nodeSize - 19);
        }

        if (normalizedX < 0.82)
        {
            var x = cx + nodeSize + 11;
            return new LabelPlacement(x, cy + 4, "start", x - 4, cy - 8);
        }

        var fallbackX = cx - nodeSize - 11;
        return new LabelPlacement(fallbackX, cy + 4, "end", fallbackX - labelWidth - 4, cy - 8);
    }

    private sealed record FacilityRenderLink(string SourceNodeKey, string TargetNodeKey, bool IsExplicitEdge);

    private sealed record FacilityAreaBlock(string AreaKey, string Label, string Fill, string Stroke, double X, double Y, double Width, double Height, int Order);

    private sealed record BackboneBand(double X, double Y, double Width, double Height);

    private sealed record SubtreeBand(double X, double Y, double Width, double Height);

    private sealed record LabelPlacement(double X, double Y, string Anchor, double BoxX, double BoxY);

    private static string GetDeviceSymbol(DeviceType type) => type switch
    {
        DeviceType.TemperatureSensor => "T",
        DeviceType.HumiditySensor    => "H",
        DeviceType.Light             => "L",
        DeviceType.HVAC              => "A",
        DeviceType.MotionSensor      => "M",
        DeviceType.DoorSensor        => "D",
        _                            => "?"
    };

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        try 
        { 
            await JSRuntime.InvokeVoidAsync("editorCanvas.dispose", _svgId); 
        }
        catch { /* ignorujeme chybu, komponenta už pravděpodobně neexistuje v DOMu */ }
        
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }
}
