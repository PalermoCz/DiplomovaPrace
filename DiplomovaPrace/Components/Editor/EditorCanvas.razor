@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@*
 * SVG canvas pro konfigurační editor.
 * JS (editor.js) obsluhuje pan/zoom/drawing/drag a volá JSInvokable metody.
 * Blazor renderuje statický obsah SVG z konfigurace.
 * Blazor nikdy nenastavuje 'transform' na #<id>-content — JS transform přežívá re-rendery.
 *@

<svg id="@_svgId" class="editor-svg"
     viewBox="0 0 @Fmt(ViewBoxWidth) @Fmt(ViewBoxHeight)">

    @* Definice: mřížkový vzor *@
    @if (ShowGrid)
    {
        <defs>
            <pattern id="smallGrid-@_svgId" width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#e2e8f0" stroke-width="0.5" />
            </pattern>
            <pattern id="grid-@_svgId" width="100" height="100" patternUnits="userSpaceOnUse">
                <rect width="100" height="100" fill="url(#smallGrid-@_svgId)" />
                <path d="M 100 0 L 0 0 0 100" fill="none" stroke="#cbd5e0" stroke-width="1" />
            </pattern>
        </defs>
    }

    @* Pozadí — zachytává mouseeventy přes JS *@
    <rect class="editor-bg"
          x="0" y="0"
          width="@Fmt(ViewBoxWidth)" height="@Fmt(ViewBoxHeight)"
          fill="@(ShowGrid ? "url(#grid-" + _svgId + ")" : "#f8f9fa")"
          stroke="none" />

    @* Content group — JS sem zapisuje pan/zoom transform *@
    <g id="@(_svgId + "-content")">

        @if (Floor is not null)
        {
            @* Vnější rámeček podlaží *@
            <rect x="20" y="20"
                  width="@Fmt(ViewBoxWidth - 40)"
                  height="@Fmt(ViewBoxHeight - 40)"
                  fill="none" stroke="#b0bec5" stroke-width="1" rx="4"
                  stroke-dasharray="6,3"
                  pointer-events="none" />

            @foreach (var room in Floor.Rooms.Where(r => !r.IsDeleted))
            {
                var isRoomSelected = SelectedElementId == room.Id;
                <g data-room-id="@room.Id">
                    <rect class="editor-room-rect"
                          x="@Fmt(room.Geometry.X)"
                          y="@Fmt(room.Geometry.Y)"
                          width="@Fmt(room.Geometry.Width)"
                          height="@Fmt(room.Geometry.Height)"
                          fill="@(isRoomSelected ? "#dbeafe" : "#f0f4f8")"
                          stroke="@(isRoomSelected ? "#2980b9" : "#78909c")"
                          stroke-width="@(isRoomSelected ? "2.5" : "1.5")"
                          rx="4" />

                    @((MarkupString)$"<text x=\"{Fmt(room.Geometry.X + room.Geometry.Width / 2)}\" " +
                        $"y=\"{Fmt(room.Geometry.Y + 16)}\" " +
                        $"text-anchor=\"middle\" class=\"room-label\" pointer-events=\"none\">{EscapeXml(room.Name)}</text>")

                    @* Zařízení v místnosti *@
                    @foreach (var device in room.Devices.Where(d => !d.IsDeleted))
                    {
                        var isDeviceSelected = SelectedElementId == device.Id;
                        var color = StateColorMapper.GetDeviceColor(device.Type, null);
                        var symbol = GetDeviceSymbol(device.Type);
                        var label = device.DisplaySettings.LabelOverride ?? device.Name;

                        <g data-device-id="@device.Id">
                            <circle cx="@Fmt(device.Position.X)"
                                    cy="@Fmt(device.Position.Y)"
                                    r="13"
                                    fill="@color"
                                    stroke="@(isDeviceSelected ? "#fff" : "#455a64")"
                                    stroke-width="@(isDeviceSelected ? "3" : "1.5")" />

                            @((MarkupString)$"<text x=\"{Fmt(device.Position.X)}\" " +
                                $"y=\"{Fmt(device.Position.Y + 4)}\" " +
                                $"text-anchor=\"middle\" class=\"device-symbol\" fill=\"white\" " +
                                $"font-size=\"11\" font-weight=\"bold\" pointer-events=\"none\">{EscapeXml(symbol)}</text>")

                            @if (device.DisplaySettings.ShowValue && device.DisplaySettings.Unit is not null)
                            {
                                @((MarkupString)$"<text x=\"{Fmt(device.Position.X)}\" " +
                                    $"y=\"{Fmt(device.Position.Y + 27)}\" " +
                                    $"text-anchor=\"middle\" class=\"device-value\" font-size=\"9\" " +
                                    $"pointer-events=\"none\">{EscapeXml(device.DisplaySettings.Unit)}</text>")
                            }
                        </g>
                    }
                </g>
            }
        }
        else
        {
            @* Prázdný canvas — informační text *@
            @((MarkupString)$"<text x=\"{Fmt(ViewBoxWidth / 2)}\" y=\"{Fmt(ViewBoxHeight / 2 - 10)}\" " +
                $"text-anchor=\"middle\" font-size=\"16\" fill=\"#9ca3af\" pointer-events=\"none\">Žádné patro</text>")
            @((MarkupString)$"<text x=\"{Fmt(ViewBoxWidth / 2)}\" y=\"{Fmt(ViewBoxHeight / 2 + 14)}\" " +
                $"text-anchor=\"middle\" font-size=\"11\" fill=\"#b0bec5\" pointer-events=\"none\">Přidejte patro v postranním panelu</text>")
        }

    </g>
</svg>

@code {
    [Parameter] public FloorConfig? Floor { get; set; }
    [Parameter] public EditorTool ActiveTool { get; set; }
    [Parameter] public string? SelectedElementId { get; set; }
    [Parameter] public bool ShowGrid { get; set; }

    [Parameter] public EventCallback<RoomGeometry> OnRoomCreated { get; set; }
    [Parameter] public EventCallback<(string DeviceId, DevicePosition Pos)> OnDeviceMoved { get; set; }
    [Parameter] public EventCallback<(string Id, EditorSelectionType Type)> OnElementSelected { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnCanvasClicked { get; set; }
    [Parameter] public EventCallback<(string Id, EditorSelectionType Type)> OnDeleteRequested { get; set; }

    private readonly string _svgId = "editor-canvas-svg";
    private DotNetObjectReference<EditorCanvas>? _dotNetRef;
    private bool _jsInitialized;
    private EditorTool _prevTool;
    private string? _prevFloorId;

    private double ViewBoxWidth  => Floor?.ViewBoxWidth  ?? 800;
    private double ViewBoxHeight => Floor?.ViewBoxHeight ?? 300;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("editorCanvas.init", _svgId, _dotNetRef);
            await JSRuntime.InvokeVoidAsync("editorCanvas.setTool", ActiveTool.ToString());
            _prevTool = ActiveTool;
            _prevFloorId = Floor?.Id;
            _jsInitialized = true;
            return;
        }

        if (!_jsInitialized) return;

        // Změna nástroje
        if (ActiveTool != _prevTool)
        {
            _prevTool = ActiveTool;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setTool", ActiveTool.ToString());
        }

        // Změna patra — resetuj zoom/pan
        if (Floor?.Id != _prevFloorId)
        {
            _prevFloorId = Floor?.Id;
            await JSRuntime.InvokeVoidAsync("editorCanvas.resetView");
        }

        // Vždy znovu aplikuj JS transform (Blazor ho nemění, ale pro jistotu)
        await JSRuntime.InvokeVoidAsync("editorCanvas.reapplyTransform");
    }

    // ── JSInvokable — volají je JS event handlery ─────────────────────────

    [JSInvokable]
    public async Task JsOnRoomDrawn(double x, double y, double width, double height) =>
        await OnRoomCreated.InvokeAsync(new RoomGeometry(x, y, width, height));

    [JSInvokable]
    public async Task JsOnDeviceDragEnd(string deviceId, double x, double y) =>
        await OnDeviceMoved.InvokeAsync((deviceId, new DevicePosition(x, y)));

    [JSInvokable]
    public async Task JsOnElementClicked(string id, string typeName)
    {
        if (!Enum.TryParse<EditorSelectionType>(typeName, out var type))
            type = EditorSelectionType.None;
        await OnElementSelected.InvokeAsync((id, type));
    }

    [JSInvokable]
    public async Task JsOnCanvasClicked(double x, double y) =>
        await OnCanvasClicked.InvokeAsync((x, y));

    [JSInvokable]
    public async Task JsOnDeleteClicked(string id, string typeName)
    {
        if (!Enum.TryParse<EditorSelectionType>(typeName, out var type))
            type = EditorSelectionType.None;
        await OnDeleteRequested.InvokeAsync((id, type));
    }

    // ── Helpers ──────────────────────────────────────────────────────────

    public async Task ResetViewAsync() =>
        await JSRuntime.InvokeVoidAsync("editorCanvas.resetView");

    private static string Fmt(double v) =>
        v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string EscapeXml(string? s) =>
        string.IsNullOrEmpty(s) ? "" :
        s.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("\"", "&quot;");

    private static string GetDeviceSymbol(DeviceType type) => type switch
    {
        DeviceType.TemperatureSensor => "T",
        DeviceType.HumiditySensor    => "H",
        DeviceType.Light             => "L",
        DeviceType.HVAC              => "A",
        DeviceType.MotionSensor      => "M",
        DeviceType.DoorSensor        => "D",
        _                            => "?"
    };

    public async ValueTask DisposeAsync()
    {
        if (_jsInitialized)
        {
            try { await JSRuntime.InvokeVoidAsync("editorCanvas.dispose", _svgId); }
            catch { /* komponenta mohla být odpojena dříve než JS */ }
        }
        _dotNetRef?.Dispose();
    }
}
