@using DiplomovaPrace.Persistence.Schematic
@using DiplomovaPrace.Services
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@*
 * SVG canvas pro konfigurační editor.
 * JS (editor.js) obsluhuje pan/zoom/drawing/drag a volá JSInvokable metody.
 * Blazor renderuje statický obsah SVG z konfigurace.
 * Blazor nikdy nenastavuje 'transform' na #<id>-content — JS transform přežívá re-rendery.
 *
 * Validační chyby: místnosti s chybami mají červený obrys, zařízení s varováním žlutý.
 *@

<svg id="@_svgId" class="editor-svg"
     viewBox="0 0 @Fmt(ViewBoxWidth) @Fmt(ViewBoxHeight)"
     style="background-color: #e9ecef;">

    @* Content group — JS sem zapisuje pan/zoom transform *@
    <g id="@(_svgId + "-content")">

        @if (Facility is not null)
        {
            var positionedNodes = Facility.Nodes
                .Where(node => node.XHint.HasValue && node.YHint.HasValue)
                .ToList();
            var nodeByKey = positionedNodes.ToDictionary(node => node.NodeKey, StringComparer.OrdinalIgnoreCase);
            var childrenByParentKey = BuildFacilityChildrenLookup(positionedNodes);
            var depthByNodeKey = BuildFacilityDepthLookup(positionedNodes, childrenByParentKey);
            var hasAnySelection = SelectedElementIds.Count > 0;
            var subtreeBounds = BuildSelectedSubtreeBounds(nodeByKey, depthByNodeKey, childrenByParentKey);

            @* Bílé pozadí facility *@
            <rect x="0" y="0"
                  width="@Fmt(ViewBoxWidth)" height="@Fmt(ViewBoxHeight)"
                  fill="white" class="floor-background" pointer-events="none" />

            @if (subtreeBounds is not null)
            {
                <rect x="@Fmt(subtreeBounds.X)"
                      y="@Fmt(subtreeBounds.Y)"
                      width="@Fmt(subtreeBounds.Width)"
                      height="@Fmt(subtreeBounds.Height)"
                      rx="16"
                      fill="#dbeafe"
                      fill-opacity="0.28"
                      stroke="#60a5fa"
                      stroke-width="2"
                      stroke-dasharray="8 5"
                      pointer-events="none" />
            }

            @* Vykreslení hran *@
            @foreach (var edge in Facility.Edges)
            {
                if (!nodeByKey.TryGetValue(edge.SourceNodeKey, out var sourceNode) || !nodeByKey.TryGetValue(edge.TargetNodeKey, out var targetNode))
                {
                    continue;
                }

                var edgeIsInSelectedSubtree = SelectedSubtreeNodeKeys.Contains(edge.SourceNodeKey) && SelectedSubtreeNodeKeys.Contains(edge.TargetNodeKey);
                var edgeTouchesSelection = SelectedElementIds.Contains(edge.SourceNodeKey) || SelectedElementIds.Contains(edge.TargetNodeKey);

                var edgeStroke = edgeIsInSelectedSubtree
                    ? "#3b82f6"
                    : edgeTouchesSelection
                        ? "#60a5fa"
                        : "#cbd5e1";
                var edgeStrokeWidth = edgeIsInSelectedSubtree
                    ? "3.6"
                    : edgeTouchesSelection
                        ? "2.8"
                        : "1.9";
                var edgeOpacity = hasAnySelection && !edgeTouchesSelection && !edgeIsInSelectedSubtree
                    ? "0.25"
                    : edgeIsInSelectedSubtree
                        ? "0.92"
                        : "0.68";

                <line x1="@Fmt(sourceNode.XHint!.Value * ViewBoxWidth)"
                      y1="@Fmt(sourceNode.YHint!.Value * ViewBoxHeight)"
                      x2="@Fmt(targetNode.XHint!.Value * ViewBoxWidth)"
                      y2="@Fmt(targetNode.YHint!.Value * ViewBoxHeight)"
                      stroke="@edgeStroke"
                      stroke-width="@edgeStrokeWidth"
                      stroke-opacity="@edgeOpacity"
                      stroke-linecap="round" />
            }

            @* Vykreslení uzlů *@
            @foreach (var node in positionedNodes
                .OrderBy(node => GetFacilityDepth(depthByNodeKey, node.NodeKey))
                .ThenBy(node => node.YHint))
            {
                var isFocusNode = IsFocusElement(node.NodeKey);
                var isSelectionNode = SelectedElementIds.Contains(node.NodeKey);
                var isSubtreeNode = SelectedSubtreeNodeKeys.Contains(node.NodeKey);
                var hasChildren = childrenByParentKey.TryGetValue(node.NodeKey, out var children) && children.Count > 0;
                var depth = GetFacilityDepth(depthByNodeKey, node.NodeKey);
                var cx = node.XHint!.Value * ViewBoxWidth;
                var cy = node.YHint!.Value * ViewBoxHeight;
                var isRectNode = IsRectFacilityNode(node, depth, hasChildren);
                var nodeSize = hasChildren ? (depth == 0 ? 20d : 18d) : 15d;
                var symbol = GetFacilityNodeSymbol(node.NodeType);
                var nodeRole = FacilityNodeSemantics.ResolveRole(node.NodeKey, node.NodeType, node.Label);
                var nodeRoleLabel = FacilityNodeSemantics.GetRoleLabel(nodeRole);
                var nodeOpacity = 1d;
                var labelOpacity = 1d;

                NodeDeviationSeverity? alertSeverity = null;
                if (TryGetEnergyAlertSeverity(node.NodeKey, out var severity))
                {
                    alertSeverity = severity;
                }

                var (fillColor, strokeColor, textColor) = GetFacilityNodePalette(alertSeverity);
                if (alertSeverity is null)
                {
                    strokeColor = GetFacilityRoleAccent(nodeRole);
                }

                var labelColor = hasChildren ? "#1e293b" : "#475569";
                var labelWeight = hasChildren ? "650" : "540";
                var strokeW = "2.2";
                var haloStroke = "none";
                var haloStrokeWidth = "0";
                var haloDashArray = string.Empty;

                if (hasAnySelection && !isSelectionNode && !isFocusNode && !isSubtreeNode)
                {
                    nodeOpacity = 0.5;
                    labelOpacity = 0.48;
                }

                if (isSubtreeNode && !isSelectionNode && !isFocusNode)
                {
                    strokeColor = "#60a5fa";
                    strokeW = "3.1";
                    labelColor = "#1d4ed8";
                    labelWeight = "620";
                }

                if (isSelectionNode)
                {
                    strokeColor = "#1d4ed8";
                    strokeW = "4.4";
                    haloStroke = "#93c5fd";
                    haloStrokeWidth = "7";

                    if (alertSeverity is null)
                    {
                        fillColor = "#2563eb";
                        textColor = "white";
                    }
                    else if (alertSeverity == NodeDeviationSeverity.Elevated)
                    {
                        textColor = "#1f2937";
                    }
                    else
                    {
                        textColor = "white";
                    }

                    labelColor = "#1e3a8a";
                    labelWeight = "700";
                }

                if (isFocusNode)
                {
                    if (!isSelectionNode)
                    {
                        strokeColor = "#334155";
                        strokeW = "3.6";
                    }

                    haloStroke = "#0f172a";
                    haloStrokeWidth = "2.4";
                    haloDashArray = "6 4";
                    labelColor = "#0f172a";
                }

                var labelText = node.Label ?? node.NodeKey;
                var labelWidth = EstimateLabelWidth(labelText);
                var placeLabelRight = node.XHint.Value < 0.84;
                var labelX = placeLabelRight ? cx + nodeSize + 12 : cx - nodeSize - 12;
                var labelY = cy + 4;
                var labelAnchor = placeLabelRight ? "start" : "end";
                var labelBoxX = placeLabelRight ? labelX - 4 : labelX - labelWidth - 4;

                <g data-node-key="@node.NodeKey" opacity="@Fmt(nodeOpacity)">
                    <title>@($"{labelText} - {nodeRoleLabel}")</title>
                    @if (haloStrokeWidth != "0")
                    {
                        @if (isRectNode)
                        {
                            <rect x="@Fmt(cx - nodeSize - 3)" y="@Fmt(cy - nodeSize - 3)"
                                  width="@Fmt((nodeSize + 3) * 2)" height="@Fmt((nodeSize + 3) * 2)" rx="9"
                                  fill="none" stroke="@haloStroke" stroke-width="@haloStrokeWidth" stroke-dasharray="@haloDashArray" pointer-events="none" />
                        }
                        else
                        {
                            <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="@Fmt(nodeSize + 4)"
                                    fill="none" stroke="@haloStroke" stroke-width="@haloStrokeWidth" stroke-dasharray="@haloDashArray" pointer-events="none" />
                        }
                    }

                    @if (isRectNode)
                    {
                        <rect x="@Fmt(cx - nodeSize)" y="@Fmt(cy - nodeSize)" width="@Fmt(nodeSize * 2)" height="@Fmt(nodeSize * 2)" rx="7"
                              fill="@fillColor" stroke="@strokeColor" stroke-width="@strokeW" />
                    }
                    else
                    {
                        <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="@Fmt(nodeSize)"
                                fill="@fillColor" stroke="@strokeColor" stroke-width="@strokeW" />
                    }

                    <text x="@Fmt(cx)" y="@Fmt(cy + 4)" text-anchor="middle" font-size="10" font-weight="700" fill="@textColor" pointer-events="none">
                        @symbol
                    </text>

                    <rect x="@Fmt(labelBoxX)" y="@Fmt(cy - 8)" width="@Fmt(labelWidth + 8)" height="16" rx="6"
                          fill="white" fill-opacity="0.88" stroke="#e2e8f0" stroke-width="1" pointer-events="none" opacity="@Fmt(labelOpacity)" />

                    <text x="@Fmt(labelX)" y="@Fmt(labelY)" text-anchor="@labelAnchor" font-size="11" font-weight="@labelWeight" fill="@labelColor" pointer-events="none" opacity="@Fmt(labelOpacity)">
                        @EscapeXml(labelText)
                    </text>
                </g>
            }
        }
        else if (Floor is not null)
        {
            @* Definice grid patternu UVNITŘ content group → škáluje se zoomem *@
            @if (ShowGrid)
            {
                <defs>
                    <pattern id="smallGrid-@_svgId" width="20" height="20" patternUnits="userSpaceOnUse">
                        <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#e2e8f0" stroke-width="0.5" />
                    </pattern>
                    <pattern id="grid-@_svgId" width="100" height="100" patternUnits="userSpaceOnUse">
                        <rect width="100" height="100" fill="url(#smallGrid-@_svgId)" />
                        <path d="M 100 0 L 0 0 0 100" fill="none" stroke="#cbd5e0" stroke-width="1" />
                    </pattern>
                </defs>
            }

            @* Bílé pozadí patra — v prostoru patra, zoumuje spolu s obsahem *@
            <rect x="0" y="0"
                  width="@Fmt(ViewBoxWidth)" height="@Fmt(ViewBoxHeight)"
                  fill="white" class="floor-background" pointer-events="none" />

            @* Grid overlay — podmíněně, uvnitř content group → zoumuje *@
            @if (ShowGrid)
            {
                <rect x="0" y="0"
                      width="@Fmt(ViewBoxWidth)" height="@Fmt(ViewBoxHeight)"
                      fill="url(#grid-@_svgId)" pointer-events="none" />
            }

            @foreach (var room in Floor.Rooms.Where(r => !r.IsDeleted))
            {
                var isRoomSelected = IsElementSelected(room.Id);
                var roomIssues = ValidationIssues.Where(i => i.RoomId == room.Id).ToList();
                var hasRoomError   = roomIssues.Any(i => i.Type == IssueType.Error);
                var hasRoomWarning = roomIssues.Any(i => i.Type == IssueType.Warning);

                var strokeColor = isRoomSelected ? "#2980b9"
                    : hasRoomError   ? "#dc2626"
                    : hasRoomWarning ? "#d97706"
                    : "#78909c";
                var strokeWidth = isRoomSelected || hasRoomError ? "2.5" : "1.5";
                var fillColor   = isRoomSelected   ? "#dbeafe"
                    : hasRoomError   ? "#fee2e2"
                    : hasRoomWarning ? "#fffbeb"
                    : "#f0f4f8";

                <g data-room-id="@room.Id">
                    <rect class="editor-room-rect"
                          x="@Fmt(room.Geometry.X)"
                          y="@Fmt(room.Geometry.Y)"
                          width="@Fmt(room.Geometry.Width)"
                          height="@Fmt(room.Geometry.Height)"
                          fill="@fillColor"
                          stroke="@strokeColor"
                          stroke-width="@strokeWidth"
                          rx="4" />

                    @((MarkupString)$"<text x=\"{Fmt(room.Geometry.X + room.Geometry.Width / 2)}\" " +
                        $"y=\"{Fmt(room.Geometry.Y + 16)}\" " +
                        $"text-anchor=\"middle\" class=\"room-label\" pointer-events=\"none\">{EscapeXml(room.Name)}</text>")

                    @* Zařízení v místnosti *@
                    @foreach (var device in room.Devices.Where(d => !d.IsDeleted))
                    {
                        var isDeviceSelected = IsElementSelected(device.Id);
                        var deviceIssues = ValidationIssues.Where(i => i.DeviceId == device.Id).ToList();
                        var hasDeviceWarning = deviceIssues.Any();

                        var color = StateColorMapper.GetDeviceColor(device.Type, null);
                        var symbol = GetDeviceSymbol(device.Type);
                        var label = device.DisplaySettings.LabelOverride ?? device.Name;

                        var devStroke = isDeviceSelected ? "#fff"
                            : hasDeviceWarning ? "#d97706"
                            : "#455a64";
                        var devStrokeW = isDeviceSelected || hasDeviceWarning ? "3" : "1.5";

                        <g data-device-id="@device.Id">
                            <circle cx="@Fmt(device.Position.X)"
                                    cy="@Fmt(device.Position.Y)"
                                    r="13"
                                    fill="@color"
                                    stroke="@devStroke"
                                    stroke-width="@devStrokeW" />

                            @((MarkupString)$"<text x=\"{Fmt(device.Position.X)}\" " +
                                $"y=\"{Fmt(device.Position.Y + 4)}\" " +
                                $"text-anchor=\"middle\" class=\"device-symbol\" fill=\"white\" " +
                                $"font-size=\"11\" font-weight=\"bold\" pointer-events=\"none\">{EscapeXml(symbol)}</text>")

                            @if (device.DisplaySettings.ShowValue && device.DisplaySettings.Unit is not null)
                            {
                                @((MarkupString)$"<text x=\"{Fmt(device.Position.X)}\" " +
                                    $"y=\"{Fmt(device.Position.Y + 27)}\" " +
                                    $"text-anchor=\"middle\" class=\"device-value\" font-size=\"9\" " +
                                    $"pointer-events=\"none\">{EscapeXml(device.DisplaySettings.Unit)}</text>")
                            }
                        </g>
                    }
                </g>
            }
        }
        else
        {
            @* Prázdný canvas — informační text *@
            @((MarkupString)$"<text x=\"{Fmt(ViewBoxWidth / 2)}\" y=\"{Fmt(ViewBoxHeight / 2 - 10)}\" " +
                $"text-anchor=\"middle\" font-size=\"16\" fill=\"#9ca3af\" pointer-events=\"none\">Žádná data</text>")
            @((MarkupString)$"<text x=\"{Fmt(ViewBoxWidth / 2)}\" y=\"{Fmt(ViewBoxHeight / 2 + 14)}\" " +
                $"text-anchor=\"middle\" font-size=\"11\" fill=\"#b0bec5\" pointer-events=\"none\">Načtěte patro nebo facility</text>")
        }

    </g>
</svg>

@code {
    [Parameter] public FacilityEntity? Facility { get; set; }
    [Parameter] public FloorConfig? Floor { get; set; }
    [Parameter] public EditorTool ActiveTool { get; set; }
    [Parameter] public string? SelectedElementId { get; set; }
    [Parameter] public IReadOnlySet<string> SelectedElementIds { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlySet<string> SelectedSubtreeNodeKeys { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public bool ShowGrid { get; set; }
    [Parameter] public IReadOnlyList<ValidationIssue> ValidationIssues { get; set; } = [];
    [Parameter] public IReadOnlyDictionary<string, NodeDeviationSeverity> FacilityNodeAlertSeverities { get; set; } = new Dictionary<string, NodeDeviationSeverity>();

    [Parameter] public EventCallback<RoomGeometry> OnRoomCreated { get; set; }
    [Parameter] public EventCallback<(string DeviceId, DevicePosition Pos)> OnDeviceMoved { get; set; }
    [Parameter] public EventCallback<(string Id, EditorSelectionType Type)> OnElementSelected { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnCanvasClicked { get; set; }
    [Parameter] public EventCallback<(string Id, EditorSelectionType Type)> OnDeleteRequested { get; set; }
    [Parameter] public EventCallback<string> OnKeyboardShortcut { get; set; }

    private readonly string _svgId = "editor-canvas-svg";
    private DotNetObjectReference<EditorCanvas>? _dotNetRef;
    private bool _jsInitialized;
    private bool _isDisposed;
    private EditorTool _prevTool;
    private string? _prevFloorId;
    private int? _prevFacilityId;
    private double _prevWidth;
    private double _prevHeight;
    private bool _prevShowGrid;

    private double ViewBoxWidth  { get {
        if (Facility != null) return 1200;
        return Floor?.ViewBoxWidth ?? 800;
    } }
    private double ViewBoxHeight { get {
        if (Facility != null) return 800;
        return Floor?.ViewBoxHeight ?? 300;
    } }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed) return;

        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try 
            {
                await JSRuntime.InvokeVoidAsync("editorCanvas.init", _svgId, _dotNetRef);
                
                if (_isDisposed) 
                {
                    // Komponenta byla zničena v průběhu JS inicializace.
                    await JSRuntime.InvokeVoidAsync("editorCanvas.dispose", _svgId);
                    return;
                }

                await JSRuntime.InvokeVoidAsync("editorCanvas.setTool", ActiveTool.ToString());
                await JSRuntime.InvokeVoidAsync("editorCanvas.setFloorBounds", ViewBoxWidth, ViewBoxHeight);
                await JSRuntime.InvokeVoidAsync("editorCanvas.setGrid", ShowGrid, 20);
                
                _prevTool     = ActiveTool;
                _prevFloorId  = Floor?.Id;
                _prevFacilityId = Facility?.Id;
                _prevWidth    = ViewBoxWidth;
                _prevHeight   = ViewBoxHeight;
                _prevShowGrid = ShowGrid;
                _jsInitialized = true;
            }
            catch { /* ignorujeme případné chyby padající z odpojené stránky */ }
            return;
        }

        if (!_jsInitialized || _isDisposed) return;

        if (ActiveTool != _prevTool)
        {
            _prevTool = ActiveTool;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setTool", ActiveTool.ToString());
        }

        if (Floor?.Id != _prevFloorId || Facility?.Id != _prevFacilityId)
        {
            _prevFloorId = Floor?.Id;
            _prevFacilityId = Facility?.Id;
            await JSRuntime.InvokeVoidAsync("editorCanvas.resetView");
        }

        // Aktualizuj hranice patra při změně rozměrů
        if (ViewBoxWidth != _prevWidth || ViewBoxHeight != _prevHeight)
        {
            _prevWidth  = ViewBoxWidth;
            _prevHeight = ViewBoxHeight;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setFloorBounds", ViewBoxWidth, ViewBoxHeight);
        }

        // Synchronizuj stav mřížky do JS (snap-to-grid)
        if (ShowGrid != _prevShowGrid)
        {
            _prevShowGrid = ShowGrid;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setGrid", ShowGrid, 20);
        }

        await JSRuntime.InvokeVoidAsync("editorCanvas.reapplyTransform");
    }

    // ── JSInvokable — volají je JS event handlery ─────────────────────────

    [JSInvokable]
    public async Task JsOnRoomDrawn(double x, double y, double width, double height) =>
        await OnRoomCreated.InvokeAsync(new RoomGeometry(x, y, width, height));

    [JSInvokable]
    public async Task JsOnDeviceDragEnd(string deviceId, double x, double y) =>
        await OnDeviceMoved.InvokeAsync((deviceId, new DevicePosition(x, y)));

    [JSInvokable]
    public async Task JsOnElementClicked(string id, string typeName)
    {
        if (!Enum.TryParse<EditorSelectionType>(typeName, out var type))
            type = EditorSelectionType.None;
        await OnElementSelected.InvokeAsync((id, type));
    }

    [JSInvokable]
    public async Task JsOnCanvasClicked(double x, double y) =>
        await OnCanvasClicked.InvokeAsync((x, y));

    [JSInvokable]
    public async Task JsOnDeleteClicked(string id, string typeName)
    {
        if (!Enum.TryParse<EditorSelectionType>(typeName, out var type))
            type = EditorSelectionType.None;
        await OnDeleteRequested.InvokeAsync((id, type));
    }

    /// <summary>Volá se z JS pro klávesové zkratky (Ctrl+Z, Ctrl+Y).</summary>
    [JSInvokable]
    public async Task JsOnKeyboardShortcut(string shortcut) =>
        await OnKeyboardShortcut.InvokeAsync(shortcut);

    // ── Helpers ──────────────────────────────────────────────────────────

    public async Task ResetViewAsync() =>
        await JSRuntime.InvokeVoidAsync("editorCanvas.resetView");

    private static string Fmt(double v) =>
        v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string EscapeXml(string? s) =>
        string.IsNullOrEmpty(s) ? "" :
        s.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("\"", "&quot;");

    private bool IsFocusElement(string elementId)
    {
        return !string.IsNullOrEmpty(SelectedElementId) && string.Equals(SelectedElementId, elementId, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsElementSelected(string elementId)
    {
        if (IsFocusElement(elementId))
        {
            return true;
        }

        return SelectedElementIds.Contains(elementId);
    }

    private bool TryGetEnergyAlertSeverity(string nodeKey, out NodeDeviationSeverity severity)
    {
        severity = default;

        // weather_main je explanatory uzel, ne energetický alert node.
        if (string.Equals(nodeKey, "weather_main", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!IsEnergyAlertNode(nodeKey))
        {
            return false;
        }

        return FacilityNodeAlertSeverities.TryGetValue(nodeKey, out severity);
    }

    private static bool IsEnergyAlertNode(string nodeKey)
    {
        return nodeKey is "pv_main" or "chp_main" or "cooling_main" or "heating_main";
    }

    private static (string Fill, string Stroke, string Text) GetFacilityNodePalette(NodeDeviationSeverity? severity)
    {
        return severity switch
        {
            NodeDeviationSeverity.High => ("#f87171", "#b91c1c", "white"),
            NodeDeviationSeverity.Elevated => ("#fcd34d", "#b45309", "#1f2937"),
            _ => ("#f1f5f9", "#475569", "#334155")
        };
    }

    private static string GetFacilityRoleAccent(FacilityNodeRole role)
    {
        return role switch
        {
            FacilityNodeRole.GridTransformer => "#1d4ed8",
            FacilityNodeRole.EnergyProduction => "#15803d",
            FacilityNodeRole.HvacCoolingVentilation => "#0f766e",
            FacilityNodeRole.TestingSimulation => "#c2410c",
            FacilityNodeRole.PowerDistribution => "#475569",
            FacilityNodeRole.ServersItCooling => "#111827",
            _ => "#475569"
        };
    }

    private Dictionary<string, List<SchematicNodeEntity>> BuildFacilityChildrenLookup(IEnumerable<SchematicNodeEntity> nodes)
    {
        var childrenByParent = new Dictionary<string, List<SchematicNodeEntity>>(StringComparer.OrdinalIgnoreCase);

        foreach (var node in nodes)
        {
            if (string.IsNullOrWhiteSpace(node.ParentNodeKey))
            {
                continue;
            }

            if (!childrenByParent.TryGetValue(node.ParentNodeKey, out var children))
            {
                children = [];
                childrenByParent[node.ParentNodeKey] = children;
            }

            children.Add(node);
        }

        foreach (var children in childrenByParent.Values)
        {
            children.Sort((left, right) => StringComparer.OrdinalIgnoreCase.Compare(left.NodeKey, right.NodeKey));
        }

        return childrenByParent;
    }

    private Dictionary<string, int> BuildFacilityDepthLookup(
        IReadOnlyList<SchematicNodeEntity> nodes,
        IReadOnlyDictionary<string, List<SchematicNodeEntity>> childrenByParent)
    {
        var depthByNodeKey = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var nodeByKey = nodes.ToDictionary(node => node.NodeKey, StringComparer.OrdinalIgnoreCase);

        var rootNodes = nodes
            .Where(node => string.IsNullOrWhiteSpace(node.ParentNodeKey) || !nodeByKey.ContainsKey(node.ParentNodeKey))
            .OrderBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var queue = new Queue<(string NodeKey, int Depth)>();
        foreach (var root in rootNodes)
        {
            queue.Enqueue((root.NodeKey, 0));
        }

        while (queue.Count > 0)
        {
            var (nodeKey, depth) = queue.Dequeue();
            if (depthByNodeKey.TryGetValue(nodeKey, out var knownDepth) && knownDepth <= depth)
            {
                continue;
            }

            depthByNodeKey[nodeKey] = depth;

            if (!childrenByParent.TryGetValue(nodeKey, out var children))
            {
                continue;
            }

            foreach (var child in children)
            {
                queue.Enqueue((child.NodeKey, depth + 1));
            }
        }

        var maxDepth = depthByNodeKey.Values.DefaultIfEmpty(0).Max();
        foreach (var node in nodes.OrderBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase))
        {
            if (!depthByNodeKey.ContainsKey(node.NodeKey))
            {
                maxDepth++;
                depthByNodeKey[node.NodeKey] = maxDepth;
            }
        }

        return depthByNodeKey;
    }

    private static int GetFacilityDepth(IReadOnlyDictionary<string, int> depthByNodeKey, string nodeKey)
    {
        return depthByNodeKey.TryGetValue(nodeKey, out var depth) ? depth : 0;
    }

    private SubtreeBounds? BuildSelectedSubtreeBounds(
        IReadOnlyDictionary<string, SchematicNodeEntity> nodeByKey,
        IReadOnlyDictionary<string, int> depthByNodeKey,
        IReadOnlyDictionary<string, List<SchematicNodeEntity>> childrenByParent)
    {
        if (SelectedSubtreeNodeKeys.Count == 0)
        {
            return null;
        }

        var points = new List<(double X, double Y)>();
        var maxDepth = 0;

        foreach (var nodeKey in SelectedSubtreeNodeKeys)
        {
            if (!nodeByKey.TryGetValue(nodeKey, out var node) || !node.XHint.HasValue || !node.YHint.HasValue)
            {
                continue;
            }

            points.Add((node.XHint.Value * ViewBoxWidth, node.YHint.Value * ViewBoxHeight));
            maxDepth = Math.Max(maxDepth, GetFacilityDepth(depthByNodeKey, nodeKey));
        }

        if (points.Count == 0)
        {
            return null;
        }

        var minX = points.Min(point => point.X);
        var maxX = points.Max(point => point.X);
        var minY = points.Min(point => point.Y);
        var maxY = points.Max(point => point.Y);

        var verticalPadding = 42d;
        var rightPadding = maxDepth >= 2 ? 170d : 130d;
        var leftPadding = 36d;

        foreach (var nodeKey in SelectedSubtreeNodeKeys)
        {
            if (!childrenByParent.TryGetValue(nodeKey, out var children) || children.Count == 0)
            {
                continue;
            }

            rightPadding = Math.Max(rightPadding, 190d);
            break;
        }

        minX = Math.Max(0, minX - leftPadding);
        maxX = Math.Min(ViewBoxWidth, maxX + rightPadding);
        minY = Math.Max(0, minY - verticalPadding);
        maxY = Math.Min(ViewBoxHeight, maxY + verticalPadding);

        return new SubtreeBounds(minX, minY, Math.Max(0, maxX - minX), Math.Max(0, maxY - minY));
    }

    private static bool IsRectFacilityNode(SchematicNodeEntity node, int depth, bool hasChildren)
    {
        if (depth == 0)
        {
            return true;
        }

        if (!hasChildren)
        {
            return false;
        }

        return string.Equals(node.NodeType, "site", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(node.NodeType, "building", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(node.NodeType, "grid", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(node.NodeType, "transformer", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetFacilityNodeSymbol(string? nodeType)
    {
        if (string.IsNullOrWhiteSpace(nodeType))
        {
            return "?";
        }

        return nodeType.Trim()[0].ToString().ToUpperInvariant();
    }

    private static double EstimateLabelWidth(string label)
    {
        var normalizedLength = Math.Clamp(label.Length, 5, 30);
        return normalizedLength * 6.8;
    }

    private sealed record SubtreeBounds(double X, double Y, double Width, double Height);

    private static string GetDeviceSymbol(DeviceType type) => type switch
    {
        DeviceType.TemperatureSensor => "T",
        DeviceType.HumiditySensor    => "H",
        DeviceType.Light             => "L",
        DeviceType.HVAC              => "A",
        DeviceType.MotionSensor      => "M",
        DeviceType.DoorSensor        => "D",
        _                            => "?"
    };

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        try 
        { 
            await JSRuntime.InvokeVoidAsync("editorCanvas.dispose", _svgId); 
        }
        catch { /* ignorujeme chybu, komponenta už pravděpodobně neexistuje v DOMu */ }
        
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }
}
