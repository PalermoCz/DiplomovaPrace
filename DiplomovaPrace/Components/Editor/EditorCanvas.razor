@using DiplomovaPrace.Persistence.Schematic
@using DiplomovaPrace.Services
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@*
 * SVG canvas pro konfigurační editor.
 * JS (editor.js) obsluhuje pan/zoom/drawing/drag a volá JSInvokable metody.
 * Blazor renderuje statický obsah SVG z konfigurace.
 * Blazor nikdy nenastavuje 'transform' na #<id>-content — JS transform přežívá re-rendery.
 *
 * Validační chyby: místnosti s chybami mají červený obrys, zařízení s varováním žlutý.
 *@

<svg id="@_svgId" class="editor-svg"
     viewBox="0 0 @Fmt(ViewBoxWidth) @Fmt(ViewBoxHeight)"
     style="background-color: #e9ecef;">

    @* Content group — JS sem zapisuje pan/zoom transform *@
    <g id="@(_svgId + "-content")">

        @if (Facility is not null)
        {
            var positionedNodes = Facility.Nodes
                .Where(node => node.XHint.HasValue && node.YHint.HasValue)
                .ToList();
            var nodeByKey = positionedNodes.ToDictionary(node => node.NodeKey, StringComparer.OrdinalIgnoreCase);
            var childrenByParentKey = BuildFacilityChildrenLookup(positionedNodes);
            var depthByNodeKey = BuildFacilityDepthLookup(positionedNodes, childrenByParentKey);
            var hasAnySelection = SelectedElementIds.Count > 0 || !string.IsNullOrWhiteSpace(SelectedElementId);
            var facilityAreaBlocks = BuildFacilityAreaBlocks(positionedNodes);
            var subtreeBands = BuildSubtreeBands(positionedNodes, SelectedSubtreeNodeKeys);
            var backboneBand = BuildBackboneBand(positionedNodes);
            var renderLinks = BuildFacilityRenderLinks(positionedNodes, nodeByKey, Facility.Edges, childrenByParentKey);

            @* Bílé pozadí facility *@
            <rect x="0" y="0"
                  width="@Fmt(ViewBoxWidth)" height="@Fmt(ViewBoxHeight)"
                  fill="white" class="floor-background" pointer-events="none" />

            @if (backboneBand is not null)
            {
                <rect x="@Fmt(backboneBand.X)"
                      y="@Fmt(backboneBand.Y)"
                      width="@Fmt(backboneBand.Width)"
                      height="@Fmt(backboneBand.Height)"
                    rx="22"
                    fill="#dbeafe"
                    fill-opacity="0.28"
                    stroke="#7fb2ef"
                    stroke-width="1.6"
                      pointer-events="none" />

                <line x1="@Fmt(backboneBand.X + 18)"
                    y1="@Fmt(backboneBand.Y + 30)"
                    x2="@Fmt(backboneBand.X + backboneBand.Width - 18)"
                    y2="@Fmt(backboneBand.Y + 30)"
                    stroke="#76a6df"
                    stroke-opacity="0.45"
                    stroke-width="1.3"
                    pointer-events="none" />
            }

            @foreach (var areaBlock in facilityAreaBlocks)
            {
                <rect x="@Fmt(areaBlock.X)"
                      y="@Fmt(areaBlock.Y)"
                      width="@Fmt(areaBlock.Width)"
                      height="@Fmt(areaBlock.Height)"
                                            rx="14"
                      fill="@areaBlock.Fill"
                                            fill-opacity="0.19"
                      stroke="@areaBlock.Stroke"
                                            stroke-width="1.5"
                                            stroke-dasharray="5 4"
                      pointer-events="none" />

                <line x1="@Fmt(areaBlock.X + 10)"
                                            y1="@Fmt(areaBlock.Y + 26)"
                                            x2="@Fmt(areaBlock.X + areaBlock.Width - 10)"
                                            y2="@Fmt(areaBlock.Y + 26)"
                                            stroke="@areaBlock.Stroke"
                                            stroke-opacity="0.35"
                                            stroke-width="1.2"
                                            pointer-events="none" />

                                @((MarkupString)$"<text x=\"{Fmt(areaBlock.X + 12)}\" y=\"{Fmt(areaBlock.Y + 17)}\" text-anchor=\"start\" font-size=\"10.4\" font-weight=\"720\" fill=\"#1f2937\" pointer-events=\"none\">{EscapeXml(areaBlock.Label)}</text>")
            }

            @foreach (var band in subtreeBands)
            {
                <rect x="@Fmt(band.X)"
                      y="@Fmt(band.Y)"
                      width="@Fmt(band.Width)"
                      height="@Fmt(band.Height)"
                      rx="9"
                      fill="#dbeafe"
                      fill-opacity="0.18"
                      stroke="#60a5fa"
                      stroke-width="1.3"
                      stroke-opacity="0.75"
                      pointer-events="none" />
            }

            @* Vykreslení zvýraznění subtree větví *@
            @foreach (var link in renderLinks)
            {
                if (!nodeByKey.TryGetValue(link.SourceNodeKey, out var sourceNode) || !nodeByKey.TryGetValue(link.TargetNodeKey, out var targetNode))
                {
                    continue;
                }

                var edgeIsInSelectedSubtree = SelectedSubtreeNodeKeys.Contains(link.SourceNodeKey) && SelectedSubtreeNodeKeys.Contains(link.TargetNodeKey);
                if (!edgeIsInSelectedSubtree)
                {
                    continue;
                }

                var subtreeEdgeTouchesFocus = IsFocusElement(link.SourceNodeKey) || IsFocusElement(link.TargetNodeKey);

                <path d="@BuildOrthogonalLinkPath(sourceNode, targetNode)"
                      fill="none"
                      stroke="@(subtreeEdgeTouchesFocus ? "#0b3ea9" : "#1d4ed8")"
                      stroke-width="@(subtreeEdgeTouchesFocus ? "5.4" : "4.2")"
                      stroke-opacity="@(subtreeEdgeTouchesFocus ? "0.29" : "0.21")"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      pointer-events="none" />
            }

            @* Vykreslení hran *@
            @foreach (var link in renderLinks)
            {
                if (!nodeByKey.TryGetValue(link.SourceNodeKey, out var sourceNode) || !nodeByKey.TryGetValue(link.TargetNodeKey, out var targetNode))
                {
                    continue;
                }

                var edgeIsInSelectedSubtree = SelectedSubtreeNodeKeys.Contains(link.SourceNodeKey) && SelectedSubtreeNodeKeys.Contains(link.TargetNodeKey);
                var edgeTouchesSelection = SelectedElementIds.Contains(link.SourceNodeKey)
                    || SelectedElementIds.Contains(link.TargetNodeKey)
                    || IsFocusElement(link.SourceNodeKey)
                    || IsFocusElement(link.TargetNodeKey);

                var edgeStroke = edgeIsInSelectedSubtree
                    ? "#1d4ed8"
                    : edgeTouchesSelection
                        ? "#2563eb"
                        : link.IsExplicitEdge
                            ? "#8ea0b5"
                            : "#d7dee9";
                var edgeStrokeWidth = edgeIsInSelectedSubtree
                    ? "2.85"
                    : edgeTouchesSelection
                        ? "2.25"
                        : link.IsExplicitEdge
                            ? "1.75"
                            : "1.35";
                var edgeOpacity = hasAnySelection && !edgeTouchesSelection && !edgeIsInSelectedSubtree
                    ? "0.09"
                    : edgeIsInSelectedSubtree
                        ? "0.94"
                        : link.IsExplicitEdge
                            ? "0.78"
                            : "0.5";
                var edgeDashArray = link.IsExplicitEdge ? string.Empty : "4 4";

                <path d="@BuildOrthogonalLinkPath(sourceNode, targetNode)"
                      fill="none"
                      stroke="@edgeStroke"
                      stroke-width="@edgeStrokeWidth"
                      stroke-opacity="@edgeOpacity"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                        stroke-dasharray="@edgeDashArray"
                        pointer-events="none" />
            }

            @* Vykreslení uzlů *@
            @foreach (var node in positionedNodes
                .OrderBy(node => GetFacilityDepth(depthByNodeKey, node.NodeKey))
                .ThenBy(node => node.YHint))
            {
                var isFocusNode = IsFocusElement(node.NodeKey);
                var isSelectionNode = SelectedElementIds.Contains(node.NodeKey);
                var isSubtreeNode = SelectedSubtreeNodeKeys.Contains(node.NodeKey);
                var isPrimarySelectedNode = isSelectionNode;
                var isSubtreeDescendantNode = isSubtreeNode && !isSelectionNode;
                var isSecondaryFocusNode = isFocusNode && !isSelectionNode;
                var hasChildren = childrenByParentKey.TryGetValue(node.NodeKey, out var children) && children.Count > 0;
                var depth = GetFacilityDepth(depthByNodeKey, node.NodeKey);
                var cx = node.XHint!.Value * ViewBoxWidth;
                var cy = node.YHint!.Value * ViewBoxHeight;
                var isAreaAnchorNode = IsAreaAnchorNode(node);
                var isBackboneNode = IsBackboneNodeType(node);
                var isUtilityNode = IsUtilityBranchNodeType(node);
                var isDistributionNode = IsDistributionNode(node, hasChildren, isAreaAnchorNode, isBackboneNode, isUtilityNode);
                var isRectNode = IsRectFacilityNode(node, isAreaAnchorNode, isBackboneNode, isUtilityNode);
                var isDiamondNode = isDistributionNode && !isRectNode && !isUtilityNode;
                var nodeSize = isBackboneNode
                    ? 24.0d
                    : isAreaAnchorNode
                        ? 18.0d
                        : isUtilityNode
                            ? 21.0d
                            : isDistributionNode
                                ? 15.0d
                                : 13.0d;
                var symbol = GetFacilityNodeSymbol(node, isAreaAnchorNode, isDistributionNode, hasChildren);
                var symbolFontSize = symbol.Length > 2 ? "9.2" : "10.8";
                var nodeRole = FacilityNodeSemantics.ResolveRole(node.NodeKey, node.NodeType, node.Label);
                var nodeRoleLabel = FacilityNodeSemantics.GetRoleLabel(nodeRole);
                var nodeOpacity = 1d;
                var labelOpacity = 1d;

                NodeDeviationSeverity? alertSeverity = null;
                if (TryGetEnergyAlertSeverity(node.NodeKey, out var severity))
                {
                    alertSeverity = severity;
                }

                var (fillColor, strokeColor, textColor) = GetFacilityNodePalette(alertSeverity);
                if (alertSeverity is null)
                {
                    strokeColor = GetFacilityRoleAccent(nodeRole);
                }

                var labelColor = hasChildren ? "#0b1320" : "#1f3348";
                var labelWeight = hasChildren ? "660" : "580";
                var strokeW = "2.05";
                var haloStroke = "none";
                var haloStrokeWidth = "0";
                var haloDashArray = string.Empty;
                var haloFill = "none";

                if (hasAnySelection && !isSelectionNode && !isFocusNode && !isSubtreeNode)
                {
                    nodeOpacity = 0.46;
                    labelOpacity = 0.56;
                }

                if (isSubtreeDescendantNode)
                {
                    strokeColor = "#3b82f6";
                    strokeW = "3.0";
                    labelColor = "#1d4ed8";
                    labelWeight = "620";
                    haloStroke = "#dbeafe";
                    haloStrokeWidth = "3.3";
                    haloFill = "#eff6ff";
                }

                if (isSelectionNode)
                {
                    strokeColor = "#1d4ed8";
                    strokeW = "4.4";
                    haloStroke = "#93c5fd";
                    haloStrokeWidth = "6.5";
                    haloFill = "none";

                    if (alertSeverity is null)
                    {
                        fillColor = "#2563eb";
                        textColor = "white";
                    }
                    else if (alertSeverity == NodeDeviationSeverity.Elevated)
                    {
                        textColor = "#1f2937";
                    }
                    else
                    {
                        textColor = "white";
                    }

                    labelColor = "#1e3a8a";
                    labelWeight = "700";
                }

                if (isSecondaryFocusNode)
                {
                    strokeColor = "#1f2937";
                    strokeW = "3.05";
                    haloStroke = "#475569";
                    haloStrokeWidth = "2.0";
                    haloDashArray = "4 3";
                    haloFill = "none";
                    labelColor = "#0f172a";
                    labelWeight = "660";
                }

                if (isPrimarySelectedNode)
                {
                    strokeColor = "#0b3ea9";
                    strokeW = "5.0";
                    haloStroke = "#1d4ed8";
                    haloStrokeWidth = "8.0";
                    haloDashArray = string.Empty;
                    haloFill = "#dbeafe";
                    labelColor = "#0f2f7a";
                    labelWeight = "730";

                    if (alertSeverity is null)
                    {
                        fillColor = "#1d4ed8";
                        textColor = "white";
                    }
                }

                var labelText = node.Label ?? node.NodeKey;
                var labelWidth = EstimateLabelWidth(labelText);
                var labelPlacement = GetFacilityLabelPlacement(node, cx, cy, nodeSize, labelWidth, isBackboneNode, isUtilityNode, isAreaAnchorNode, isDistributionNode);

                     <g data-node-key="@node.NodeKey"
                         data-node-x="@Fmt(cx)"
                         data-node-y="@Fmt(cy)"
                         opacity="@Fmt(nodeOpacity)">
                    <title>@($"{labelText} - {nodeRoleLabel}")</title>
                    @if (haloStrokeWidth != "0")
                    {
                        @if (isRectNode)
                        {
                            <rect x="@Fmt(cx - nodeSize - 3)" y="@Fmt(cy - nodeSize - 3)"
                                  width="@Fmt((nodeSize + 3) * 2)" height="@Fmt((nodeSize + 3) * 2)" rx="9"
                                                                    fill="@haloFill" fill-opacity="0.35" stroke="@haloStroke" stroke-width="@haloStrokeWidth" stroke-dasharray="@haloDashArray" pointer-events="none" />
                        }
                        else
                        {
                            <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="@Fmt(nodeSize + 4)"
                                                                        fill="@haloFill" fill-opacity="0.35" stroke="@haloStroke" stroke-width="@haloStrokeWidth" stroke-dasharray="@haloDashArray" pointer-events="none" />
                        }
                    }

                    @if (isRectNode)
                    {
                        <rect x="@Fmt(cx - nodeSize)" y="@Fmt(cy - nodeSize)" width="@Fmt(nodeSize * 2)" height="@Fmt(nodeSize * 2)" rx="7"
                              fill="@fillColor" stroke="@strokeColor" stroke-width="@strokeW" />
                    }
                    else if (isAreaAnchorNode)
                    {
                        <rect x="@Fmt(cx - (nodeSize + 5))" y="@Fmt(cy - (nodeSize * 0.68))"
                              width="@Fmt((nodeSize + 5) * 2)" height="@Fmt((nodeSize * 0.68) * 2)" rx="10"
                              fill="@fillColor" stroke="@strokeColor" stroke-width="@strokeW" />
                    }
                    else if (isDiamondNode)
                    {
                        <polygon points="@($"{Fmt(cx)} {Fmt(cy - nodeSize)} {Fmt(cx + nodeSize)} {Fmt(cy)} {Fmt(cx)} {Fmt(cy + nodeSize)} {Fmt(cx - nodeSize)} {Fmt(cy)}")"
                                 fill="@fillColor"
                                 stroke="@strokeColor"
                                 stroke-width="@strokeW" />
                    }
                    else
                    {
                        <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="@Fmt(nodeSize)"
                                fill="@fillColor" stroke="@strokeColor" stroke-width="@strokeW" />
                    }

                                        @((MarkupString)$"<text x=\"{Fmt(cx)}\" y=\"{Fmt(cy + 4.6)}\" text-anchor=\"middle\" font-size=\"{symbolFontSize}\" font-weight=\"700\" fill=\"{textColor}\" pointer-events=\"none\">{EscapeXml(symbol)}</text>")

                                            <rect x="@Fmt(labelPlacement.BoxX)" y="@Fmt(labelPlacement.BoxY)" width="@Fmt(labelWidth + 8)" height="18" rx="7"
                          fill="white" fill-opacity="0.93" stroke="#cfd8e3" stroke-width="1" pointer-events="none" opacity="@Fmt(labelOpacity)" />

                                        @((MarkupString)$"<text x=\"{Fmt(labelPlacement.X)}\" y=\"{Fmt(labelPlacement.Y)}\" text-anchor=\"{labelPlacement.Anchor}\" font-size=\"12.8\" font-weight=\"{labelWeight}\" fill=\"{labelColor}\" pointer-events=\"none\" opacity=\"{Fmt(labelOpacity)}\">{EscapeXml(labelText)}</text>")
                </g>
            }
        }
        else if (Floor is not null)
        {
            @* Definice grid patternu UVNITŘ content group → škáluje se zoomem *@
            @if (ShowGrid)
            {
                <defs>
                    <pattern id="smallGrid-@_svgId" width="20" height="20" patternUnits="userSpaceOnUse">
                        <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#e2e8f0" stroke-width="0.5" />
                    </pattern>
                    <pattern id="grid-@_svgId" width="100" height="100" patternUnits="userSpaceOnUse">
                        <rect width="100" height="100" fill="url(#smallGrid-@_svgId)" />
                        <path d="M 100 0 L 0 0 0 100" fill="none" stroke="#cbd5e0" stroke-width="1" />
                    </pattern>
                </defs>
            }

            @* Bílé pozadí patra — v prostoru patra, zoumuje spolu s obsahem *@
            <rect x="0" y="0"
                  width="@Fmt(ViewBoxWidth)" height="@Fmt(ViewBoxHeight)"
                  fill="white" class="floor-background" pointer-events="none" />

            @* Grid overlay — podmíněně, uvnitř content group → zoumuje *@
            @if (ShowGrid)
            {
                <rect x="0" y="0"
                      width="@Fmt(ViewBoxWidth)" height="@Fmt(ViewBoxHeight)"
                      fill="url(#grid-@_svgId)" pointer-events="none" />
            }

            @foreach (var room in Floor.Rooms.Where(r => !r.IsDeleted))
            {
                var isRoomSelected = IsElementSelected(room.Id);
                var roomIssues = ValidationIssues.Where(i => i.RoomId == room.Id).ToList();
                var hasRoomError   = roomIssues.Any(i => i.Type == IssueType.Error);
                var hasRoomWarning = roomIssues.Any(i => i.Type == IssueType.Warning);

                var strokeColor = isRoomSelected ? "#2980b9"
                    : hasRoomError   ? "#dc2626"
                    : hasRoomWarning ? "#d97706"
                    : "#78909c";
                var strokeWidth = isRoomSelected || hasRoomError ? "2.5" : "1.5";
                var fillColor   = isRoomSelected   ? "#dbeafe"
                    : hasRoomError   ? "#fee2e2"
                    : hasRoomWarning ? "#fffbeb"
                    : "#f0f4f8";

                <g data-room-id="@room.Id">
                    <rect class="editor-room-rect"
                          x="@Fmt(room.Geometry.X)"
                          y="@Fmt(room.Geometry.Y)"
                          width="@Fmt(room.Geometry.Width)"
                          height="@Fmt(room.Geometry.Height)"
                          fill="@fillColor"
                          stroke="@strokeColor"
                          stroke-width="@strokeWidth"
                          rx="4" />

                    @((MarkupString)$"<text x=\"{Fmt(room.Geometry.X + room.Geometry.Width / 2)}\" " +
                        $"y=\"{Fmt(room.Geometry.Y + 16)}\" " +
                        $"text-anchor=\"middle\" class=\"room-label\" pointer-events=\"none\">{EscapeXml(room.Name)}</text>")

                    @* Zařízení v místnosti *@
                    @foreach (var device in room.Devices.Where(d => !d.IsDeleted))
                    {
                        var isDeviceSelected = IsElementSelected(device.Id);
                        var deviceIssues = ValidationIssues.Where(i => i.DeviceId == device.Id).ToList();
                        var hasDeviceWarning = deviceIssues.Any();

                        var color = StateColorMapper.GetDeviceColor(device.Type, null);
                        var symbol = GetDeviceSymbol(device.Type);
                        var label = device.DisplaySettings.LabelOverride ?? device.Name;

                        var devStroke = isDeviceSelected ? "#fff"
                            : hasDeviceWarning ? "#d97706"
                            : "#455a64";
                        var devStrokeW = isDeviceSelected || hasDeviceWarning ? "3" : "1.5";

                        <g data-device-id="@device.Id">
                            <circle cx="@Fmt(device.Position.X)"
                                    cy="@Fmt(device.Position.Y)"
                                    r="13"
                                    fill="@color"
                                    stroke="@devStroke"
                                    stroke-width="@devStrokeW" />

                            @((MarkupString)$"<text x=\"{Fmt(device.Position.X)}\" " +
                                $"y=\"{Fmt(device.Position.Y + 4)}\" " +
                                $"text-anchor=\"middle\" class=\"device-symbol\" fill=\"white\" " +
                                $"font-size=\"11\" font-weight=\"bold\" pointer-events=\"none\">{EscapeXml(symbol)}</text>")

                            @if (device.DisplaySettings.ShowValue && device.DisplaySettings.Unit is not null)
                            {
                                @((MarkupString)$"<text x=\"{Fmt(device.Position.X)}\" " +
                                    $"y=\"{Fmt(device.Position.Y + 27)}\" " +
                                    $"text-anchor=\"middle\" class=\"device-value\" font-size=\"9\" " +
                                    $"pointer-events=\"none\">{EscapeXml(device.DisplaySettings.Unit)}</text>")
                            }
                        </g>
                    }
                </g>
            }
        }
        else
        {
            @* Prázdný canvas — informační text *@
            @((MarkupString)$"<text x=\"{Fmt(ViewBoxWidth / 2)}\" y=\"{Fmt(ViewBoxHeight / 2 - 10)}\" " +
                $"text-anchor=\"middle\" font-size=\"16\" fill=\"#9ca3af\" pointer-events=\"none\">Žádná data</text>")
            @((MarkupString)$"<text x=\"{Fmt(ViewBoxWidth / 2)}\" y=\"{Fmt(ViewBoxHeight / 2 + 14)}\" " +
                $"text-anchor=\"middle\" font-size=\"11\" fill=\"#b0bec5\" pointer-events=\"none\">Načtěte patro nebo facility</text>")
        }

    </g>
</svg>

@code {
    [Parameter] public FacilityEntity? Facility { get; set; }
    [Parameter] public FloorConfig? Floor { get; set; }
    [Parameter] public EditorTool ActiveTool { get; set; }
    [Parameter] public string? SelectedElementId { get; set; }
    [Parameter] public IReadOnlySet<string> SelectedElementIds { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlySet<string> SelectedSubtreeNodeKeys { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public bool ShowGrid { get; set; }
    [Parameter] public bool EnableFacilityNodeDrag { get; set; }
    [Parameter] public IReadOnlyList<ValidationIssue> ValidationIssues { get; set; } = [];
    [Parameter] public IReadOnlyDictionary<string, NodeDeviationSeverity> FacilityNodeAlertSeverities { get; set; } = new Dictionary<string, NodeDeviationSeverity>();

    [Parameter] public EventCallback<RoomGeometry> OnRoomCreated { get; set; }
    [Parameter] public EventCallback<(string DeviceId, DevicePosition Pos)> OnDeviceMoved { get; set; }
    [Parameter] public EventCallback<(string NodeKey, double XHint, double YHint)> OnFacilityNodeMoved { get; set; }
    [Parameter] public EventCallback<(string Id, EditorSelectionType Type)> OnElementSelected { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnCanvasClicked { get; set; }
    [Parameter] public EventCallback<(string Id, EditorSelectionType Type)> OnDeleteRequested { get; set; }
    [Parameter] public EventCallback<string> OnKeyboardShortcut { get; set; }

    private readonly string _svgId = "editor-canvas-svg";
    private DotNetObjectReference<EditorCanvas>? _dotNetRef;
    private bool _jsInitialized;
    private bool _isDisposed;
    private EditorTool _prevTool;
    private string? _prevFloorId;
    private int? _prevFacilityId;
    private double _prevWidth;
    private double _prevHeight;
    private bool _prevShowGrid;
    private bool _prevFacilityNodeDragEnabled;

    private double ViewBoxWidth  { get {
        if (Facility != null) return 640;
        return Floor?.ViewBoxWidth ?? 800;
    } }
    private double ViewBoxHeight { get {
        if (Facility != null) return 520;
        return Floor?.ViewBoxHeight ?? 300;
    } }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed) return;

        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try 
            {
                await JSRuntime.InvokeVoidAsync("editorCanvas.init", _svgId, _dotNetRef);
                
                if (_isDisposed) 
                {
                    // Komponenta byla zničena v průběhu JS inicializace.
                    await JSRuntime.InvokeVoidAsync("editorCanvas.dispose", _svgId);
                    return;
                }

                await JSRuntime.InvokeVoidAsync("editorCanvas.setTool", ActiveTool.ToString());
                await JSRuntime.InvokeVoidAsync("editorCanvas.setFloorBounds", ViewBoxWidth, ViewBoxHeight);
                await JSRuntime.InvokeVoidAsync("editorCanvas.setGrid", ShowGrid, 20);
                await JSRuntime.InvokeVoidAsync("editorCanvas.setFacilityNodeDragEnabled", EnableFacilityNodeDrag);
                
                _prevTool     = ActiveTool;
                _prevFloorId  = Floor?.Id;
                _prevFacilityId = Facility?.Id;
                _prevWidth    = ViewBoxWidth;
                _prevHeight   = ViewBoxHeight;
                _prevShowGrid = ShowGrid;
                _prevFacilityNodeDragEnabled = EnableFacilityNodeDrag;
                _jsInitialized = true;
            }
            catch { /* ignorujeme případné chyby padající z odpojené stránky */ }
            return;
        }

        if (!_jsInitialized || _isDisposed) return;

        if (ActiveTool != _prevTool)
        {
            _prevTool = ActiveTool;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setTool", ActiveTool.ToString());
        }

        if (Floor?.Id != _prevFloorId || Facility?.Id != _prevFacilityId)
        {
            _prevFloorId = Floor?.Id;
            _prevFacilityId = Facility?.Id;
            await JSRuntime.InvokeVoidAsync("editorCanvas.resetView");
        }

        // Aktualizuj hranice patra při změně rozměrů
        if (ViewBoxWidth != _prevWidth || ViewBoxHeight != _prevHeight)
        {
            _prevWidth  = ViewBoxWidth;
            _prevHeight = ViewBoxHeight;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setFloorBounds", ViewBoxWidth, ViewBoxHeight);
        }

        // Synchronizuj stav mřížky do JS (snap-to-grid)
        if (ShowGrid != _prevShowGrid)
        {
            _prevShowGrid = ShowGrid;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setGrid", ShowGrid, 20);
        }

        if (EnableFacilityNodeDrag != _prevFacilityNodeDragEnabled)
        {
            _prevFacilityNodeDragEnabled = EnableFacilityNodeDrag;
            await JSRuntime.InvokeVoidAsync("editorCanvas.setFacilityNodeDragEnabled", EnableFacilityNodeDrag);
        }

        await JSRuntime.InvokeVoidAsync("editorCanvas.reapplyTransform");
    }

    // ── JSInvokable — volají je JS event handlery ─────────────────────────

    [JSInvokable]
    public async Task JsOnRoomDrawn(double x, double y, double width, double height) =>
        await OnRoomCreated.InvokeAsync(new RoomGeometry(x, y, width, height));

    [JSInvokable]
    public async Task JsOnDeviceDragEnd(string deviceId, double x, double y) =>
