@* Nástrojová lišta editoru — přepínač nástrojů, undo/redo, import/export, indikátor stavu. *@

<div class="editor-toolbar-row">

    @* ── Nástroje ───────────────────────────────────────────────────────── *@
    <button class="tool-btn @(ActiveTool == EditorTool.Select ? "active" : "")"
            title="Vybrat prvek (S)"
            @onclick="() => OnToolChanged.InvokeAsync(EditorTool.Select)">
        &#9654; Vybrat
    </button>
    <button class="tool-btn @(ActiveTool == EditorTool.AddRoom ? "active" : "")"
            title="Nakreslit místnost tažením (R)"
            @onclick="() => OnToolChanged.InvokeAsync(EditorTool.AddRoom)">
        &#9633; Místnost
    </button>
    <button class="tool-btn @(ActiveTool == EditorTool.AddDevice ? "active" : "")"
            title="Přidat zařízení kliknutím do místnosti (D)"
            @onclick="() => OnToolChanged.InvokeAsync(EditorTool.AddDevice)">
        &#11044; Zařízení
    </button>
    <button class="tool-btn danger @(ActiveTool == EditorTool.Delete ? "active" : "")"
            title="Smazat kliknutím (Del)"
            @onclick="() => OnToolChanged.InvokeAsync(EditorTool.Delete)">
        &#10005; Smazat
    </button>

    <div class="editor-toolbar-sep"></div>

    @* ── Undo / Redo ─────────────────────────────────────────────────────── *@
    <button class="tool-btn"
            disabled="@(!CanUndo)"
            title="@(CanUndo ? "Zpět: " + UndoDescription + " (Ctrl+Z)" : "Žádná akce k vrácení")"
            @onclick="() => OnUndo.InvokeAsync()">
        &#8630; Zpět
    </button>
    <button class="tool-btn"
            disabled="@(!CanRedo)"
            title="@(CanRedo ? "Znovu: " + RedoDescription + " (Ctrl+Y)" : "Žádná akce k opakování")"
            @onclick="() => OnRedo.InvokeAsync()">
        &#8631; Znovu
    </button>

    <div class="editor-toolbar-sep"></div>

    @* ── Pohled ─────────────────────────────────────────────────────────── *@
    <button class="tool-btn @(ShowGrid ? "active" : "")"
            title="Zobrazit/skrýt mřížku"
            @onclick="() => OnGridToggled.InvokeAsync()">
        &#9638; Mřížka
    </button>
    <button class="tool-btn"
            title="Obnovit pohled (reset zoom/pan)"
            @onclick="() => OnResetView.InvokeAsync()">
        &#8635; Reset
    </button>

    <div class="editor-toolbar-sep"></div>

    @* ── Budova / Patra ─────────────────────────────────────────────────── *@
    <button class="btn btn-sm btn-outline-secondary"
            title="Vytvořit novou budovu"
            @onclick="() => OnNewBuilding.InvokeAsync()">
        + Nová budova
    </button>
    <button class="btn btn-sm btn-outline-secondary"
            disabled="@(!CanAddFloor)"
            title="Přidat patro do aktuální budovy"
            @onclick="() => OnAddFloor.InvokeAsync()">
        + Patro
    </button>

    <div class="editor-toolbar-sep"></div>

    @* ── Import / Export ─────────────────────────────────────────────────── *@
    <button class="btn btn-sm btn-outline-secondary"
            disabled="@(!CanApply)"
            title="Exportovat konfiguraci budovy jako JSON soubor"
            @onclick="() => OnExport.InvokeAsync()">
        &#8595; Export
    </button>
    <button class="btn btn-sm btn-outline-secondary"
            title="Importovat konfiguraci budovy ze JSON souboru"
            @onclick="() => OnImportClicked.InvokeAsync()">
        &#8593; Import
    </button>

    <div class="editor-toolbar-sep"></div>

    @* ── Publikace ──────────────────────────────────────────────────────── *@
    <button class="btn btn-sm @(ValidationErrorCount > 0 ? "btn-outline-danger" : "btn-success")"
            disabled="@(!CanApply || ValidationErrorCount > 0)"
            title="@(ValidationErrorCount > 0
                    ? ValidationErrorCount + " chyb — opravte před publikací"
                    : "Aplikovat konfiguraci do runtime vizualizace na /building")"
            @onclick="() => OnApplyToVisualization.InvokeAsync()">
        &#9654; Použít ve vizualizaci
    </button>

    @* ── Stavový indikátor ───────────────────────────────────────────────── *@
    @{
        var (statusHtml, statusCls, statusTitle) = PublicationState switch
        {
            PublicationState.Published =>
                ("&#9679; Publikováno",     "bg-success",             "Konfigurace je publikována"),
            PublicationState.Modified =>
                ("&#9679; Změněno",         "bg-warning text-dark",   "Změněno od posledního publikování"),
            _ => HasUnsavedChanges
                    ? ("&#9679; Neuloženo",  "bg-warning text-dark",   "Neuložené změny")
                    : ("&#9675; Návrh",      "bg-secondary",           "Dosud nepublikováno")
        };
    }
    <span class="badge @statusCls ms-1" title="@statusTitle">@((MarkupString)statusHtml)</span>

    @if (ValidationErrorCount > 0)
    {
        <span class="badge bg-danger ms-1"
              title="Chyby blokují publikaci — vyberte prvek pro detail">
            &#9888; @ValidationErrorCount @(ValidationErrorCount == 1 ? "chyba" : "chyb")
        </span>
    }
</div>

@code {
    [Parameter] public EditorTool ActiveTool { get; set; }
    [Parameter] public bool HasUnsavedChanges { get; set; }
    [Parameter] public bool ShowGrid { get; set; }
    [Parameter] public bool CanAddFloor { get; set; }
    [Parameter] public bool CanApply { get; set; }
    [Parameter] public bool CanUndo { get; set; }
    [Parameter] public bool CanRedo { get; set; }
    [Parameter] public string? UndoDescription { get; set; }
    [Parameter] public string? RedoDescription { get; set; }
    [Parameter] public int ValidationErrorCount { get; set; }
    [Parameter] public PublicationState PublicationState { get; set; }

    [Parameter] public EventCallback<EditorTool> OnToolChanged { get; set; }
    [Parameter] public EventCallback OnNewBuilding { get; set; }
    [Parameter] public EventCallback OnAddFloor { get; set; }
    [Parameter] public EventCallback OnGridToggled { get; set; }
    [Parameter] public EventCallback OnResetView { get; set; }
    [Parameter] public EventCallback OnApplyToVisualization { get; set; }
    [Parameter] public EventCallback OnUndo { get; set; }
    [Parameter] public EventCallback OnRedo { get; set; }
    [Parameter] public EventCallback OnExport { get; set; }
    [Parameter] public EventCallback OnImportClicked { get; set; }
}
