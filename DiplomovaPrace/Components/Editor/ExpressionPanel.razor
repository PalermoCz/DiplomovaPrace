@* Výpočtový panel — zadání výrazu, evaluace, výsledek *@

@inject ExpressionEvaluator Evaluator

<div class="expression-panel">
    <div class="prop-section-title">Výpočtový panel</div>
    <div class="mb-1" style="font-size:0.72rem; color:#64748b;">
        Syntaxe: <code>FUNC(Target.Property)</code><br/>
        FUNC: <code>SUM AVG COUNT MIN MAX</code><br/>
        Target: <code>Building</code> · <code>Floor[n]</code> · <code>Room["název"]</code><br/>
        Property: <code>Consumption</code> · <code>Value</code>
    </div>

    @for (int i = 0; i < _entries.Count; i++)
    {
        var idx = i;
        var entry = _entries[idx];
        <div class="expression-entry mb-2">
            <div class="input-group input-group-sm">
                <input type="text" class="form-control font-monospace"
                       placeholder="SUM(Building.Consumption)"
                       value="@entry.Expression"
                       @oninput="e => UpdateExpression(idx, e.Value?.ToString() ?? string.Empty)" />
                <button class="btn btn-outline-secondary" @onclick="() => RemoveEntry(idx)">✕</button>
            </div>
            @if (entry.Result.HasValue)
            {
                <div class="expression-result text-success">= @entry.Result.Value.ToString("G6")</div>
            }
            else if (entry.Error is not null)
            {
                <div class="expression-result text-danger">⛔ @entry.Error</div>
            }
        </div>
    }

    <div class="d-flex gap-2 mt-1">
        <button class="btn btn-sm btn-outline-secondary flex-fill" @onclick="AddEntry">+ Přidat výraz</button>
        <button class="btn btn-sm btn-primary flex-fill" @onclick="EvaluateAll">Vypočítat</button>
    </div>
</div>

@code {
    [Parameter] public string BuildingId { get; set; } = "";

    private List<ExpressionEntry> _entries = [new ExpressionEntry("")];

    private sealed class ExpressionEntry(string expression)
    {
        public string Expression { get; set; } = expression;
        public double? Result { get; set; }
        public string? Error { get; set; }
    }

    private void AddEntry() => _entries.Add(new ExpressionEntry(""));

    private void RemoveEntry(int idx)
    {
        if (_entries.Count > 1)
            _entries.RemoveAt(idx);
        else
            _entries[0] = new ExpressionEntry("");
    }

    private void UpdateExpression(int idx, string value)
    {
        _entries[idx].Expression = value;
        _entries[idx].Result     = null;
        _entries[idx].Error      = null;
    }

    private async Task EvaluateAll()
    {
        foreach (var entry in _entries)
        {
            if (string.IsNullOrWhiteSpace(entry.Expression))
            {
                entry.Result = null;
                entry.Error  = null;
                continue;
            }
            var (result, error) = await Evaluator.EvaluateAsync(entry.Expression, BuildingId);
            entry.Result = result;
            entry.Error  = error;
        }
    }
}
