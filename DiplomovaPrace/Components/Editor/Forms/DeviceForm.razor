@* Formulář vlastností zařízení — typ, zobrazení, prahové hodnoty, spotřeba *@

<div class="prop-section-title">Zařízení</div>

<EditForm Model="_model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="mb-2">
        <label class="form-label">Název</label>
        <InputText class="form-control" @bind-Value="_model.Name" />
    </div>

    <div class="mb-2">
        <label class="form-label">Typ</label>
        <InputSelect class="form-select" @bind-Value="_model.Type">
            <option disabled>── Smart Metering ──</option>
            <option value="@DeviceType.EnergyMeter">Elektroměr</option>
            <option value="@DeviceType.PowerMeter">Analyzátor výkonu</option>
            <option value="@DeviceType.CurrentTransformer">Proudový transformátor</option>
            <option disabled>── Kontextové senzory ──</option>
            <option value="@DeviceType.TemperatureSensor">Teplotní senzor</option>
            <option value="@DeviceType.HumiditySensor">Senzor vlhkosti</option>
            <option value="@DeviceType.Light">Osvětlení</option>
            <option value="@DeviceType.HVAC">Klimatizace</option>
            <option value="@DeviceType.DoorSensor">Dveřní senzor</option>
            @* MotionSensor skrytý, protože není v novém směru aplikace relevantní *@
        </InputSelect>
    </div>


    <div class="mb-3">
        <label class="form-label">Spotřeba (W)</label>
        <InputNumber class="form-control" @bind-Value="_model.Consumption" min="0" />
        <div class="form-text">Příkon zařízení v Wattech pro agregační výpočty.</div>
    </div>

    <div class="prop-section-title mt-3">Zobrazení</div>

    <div class="mb-2">
        <label class="form-label">Jednotka</label>
        <InputText class="form-control" @bind-Value="_model.Unit" placeholder="e.g. deg C, %, lux" />
    </div>

    <div class="mb-2">
        <label class="form-label">Vlastní popisek</label>
        <InputText class="form-control" @bind-Value="_model.LabelOverride" placeholder="(empty = use name)" />
    </div>

    <div class="mb-2 form-check">
        <InputCheckbox class="form-check-input" id="chk-show-value" @bind-Value="_model.ShowValue" />
        <label class="form-check-label" for="chk-show-value">Show value under icon</label>
    </div>

    <div class="prop-section-title mt-3">Alarm Thresholds</div>

    <div class="mb-2">
        <label class="form-label">Max (alarm above)</label>
        <InputNumber class="form-control" @bind-Value="_model.AlarmHigh" placeholder="(empty = no limit)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Min (alarm below)</label>
        <InputNumber class="form-control" @bind-Value="_model.AlarmLow" placeholder="(empty = no limit)" />
    </div>

    <div class="prop-section-title mt-3">Conditional Formatting</div>

    <div class="mb-3">
        <label class="form-label">Display Rules</label>
        <div class="form-text mb-2">The color is applied if the condition is met. The first satisfied rule wins.</div>
        @foreach (var (rule, index) in _model.DisplayRules.Select((r, i) => (r, i)))
        {
            <div class="card mb-2 p-2">
                <div class="row g-2">
                    <div class="col-7">
                        <InputText class="form-control form-control-sm"
                                   @bind-Value="rule.Condition"
                                   placeholder='Room["Lab"].Value > 30' />
                    </div>
                    <div class="col-3">
                        <input type="color"
                               class="form-control form-control-sm form-control-color"
                               @bind="rule.Color"
                               @bind:event="oninput" />
                    </div>
                    <div class="col-2">
                        <button type="button" class="btn btn-sm btn-outline-danger w-100"
                                @onclick="() => RemoveRule(index)">×</button>
                    </div>
                </div>
            </div>
        }
        @if (_model.DisplayRules.Count == 0)
        {
            <div class="text-muted small">No rules. The default color will be used.</div>
        }
        <button type="button" class="btn btn-sm btn-outline-primary w-100 mt-2"
                @onclick="AddRule">+ Přidat pravidlo</button>
    </div>

    <button type="submit" class="btn btn-sm btn-primary btn-save w-100">Uložit</button>
</EditForm>

<div class="delete-section">
    <button class="btn btn-sm btn-outline-danger w-100"
            @onclick="() => OnDelete.InvokeAsync()">
        Smazat zařízení
    </button>
</div>

@code {
    [Parameter, EditorRequired] public DeviceConfig Device { get; set; } = default!;
    [Parameter] public EventCallback<DeviceConfig> OnSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private FormModel _model = new();
    private string? _prevId;

    private void AddRule()
    {
        _model.DisplayRules.Add(new DisplayRuleModel
        {
            Condition = "",
            Color = "#e74c3c"
        });
    }

    private void RemoveRule(int index)
    {
        if (index >= 0 && index < _model.DisplayRules.Count)
            _model.DisplayRules.RemoveAt(index);
    }

    protected override void OnParametersSet()
    {
        if (Device.Id == _prevId) return;
        _prevId = Device.Id;
        _model = new FormModel
        {
            Name          = Device.Name,
            Type          = Device.Type,
            Consumption   = Device.Consumption,
            Unit          = Device.DisplaySettings.Unit,
            LabelOverride = Device.DisplaySettings.LabelOverride,
            ShowValue     = Device.DisplaySettings.ShowValue,
            AlarmHigh     = Device.DisplaySettings.AlarmThresholdHigh,
            AlarmLow      = Device.DisplaySettings.AlarmThresholdLow,
            DisplayRules  = Device.DisplayRules
                .Select(r => new DisplayRuleModel
                {
                    Condition = r.Condition,
                    Color = r.Color
                })
                .ToList()
        };
    }

    private async Task HandleSubmit()
    {
        var settings = new DeviceDisplaySettings(
            Unit:                  _model.Unit,
            LabelOverride:         _model.LabelOverride,
            AlarmThresholdHigh:    _model.AlarmHigh,
            AlarmThresholdLow:     _model.AlarmLow,
            ShowValue:             _model.ShowValue
        );
        var displayRules = _model.DisplayRules
            .Select(r => new DisplayRule(r.Condition, r.Color))
            .ToList();
        var updated = Device with
        {
            Name             = _model.Name,
            Type             = _model.Type,
            Consumption      = _model.Consumption,
            DisplaySettings  = settings,
            DisplayRules     = displayRules,
            UpdatedAt        = DateTime.UtcNow
        };
        await OnSave.InvokeAsync(updated);
    }

    private sealed class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Název je povinný")]
        public string Name { get; set; } = "";
        public DeviceType Type { get; set; } = DeviceType.EnergyMeter;
        [System.ComponentModel.DataAnnotations.Range(0, double.MaxValue, ErrorMessage = "Spotřeba musí být >= 0")]
        public double Consumption { get; set; }
        public string? Unit { get; set; }
        public string? LabelOverride { get; set; }
        public bool ShowValue { get; set; }
        public double? AlarmHigh { get; set; }
        public double? AlarmLow { get; set; }
        public List<DisplayRuleModel> DisplayRules { get; set; } = new();
    }

    private sealed class DisplayRuleModel
    {
        public string Condition { get; set; } = "";
        public string Color { get; set; } = "#e74c3c";
    }
}
