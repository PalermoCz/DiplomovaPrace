@* Formulář vlastností místnosti *@

<div class="prop-section-title">Místnost</div>

<EditForm Model="_model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="mb-2">
        <label class="form-label">Název</label>
        <InputText class="form-control" @bind-Value="_model.Name" />
    </div>

    <div class="prop-section-title mt-3">Rozměry místnosti</div>

    <div class="row g-2 mb-2">
        <div class="col">
            <label class="form-label">Šířka (px)</label>
            <InputNumber class="form-control" @bind-Value="_model.Width" min="20" />
        </div>
        <div class="col">
            <label class="form-label">Výška (px)</label>
            <InputNumber class="form-control" @bind-Value="_model.Height" min="20" />
        </div>
    </div>
    <div class="mb-3 text-muted" style="font-size:0.77rem;">
        Pozice: @Room.Geometry.X.ToString("F0"), @Room.Geometry.Y.ToString("F0") px
    </div>

    <div class="prop-section-title mt-3">Podmíněné formátování</div>

    <div class="mb-3">
        <label class="form-label">Pravidla zobrazení</label>
        <div class="form-text mb-2">Barva se aplikuje pokud je podmínka splněna. První splněné pravidlo vyhrává.</div>
        @foreach (var (rule, index) in _model.DisplayRules.Select((r, i) => (r, i)))
        {
            <div class="card mb-2 p-2">
                <div class="row g-2">
                    <div class="col-7">
                        <InputText class="form-control form-control-sm"
                                   @bind-Value="rule.Condition"
                                   placeholder='Room["Lab"].Value > 30' />
                    </div>
                    <div class="col-3">
                        <input type="color"
                               class="form-control form-control-sm form-control-color"
                               @bind="rule.Color"
                               @bind:event="oninput" />
                    </div>
                    <div class="col-2">
                        <button type="button" class="btn btn-sm btn-outline-danger w-100"
                                @onclick="() => RemoveRule(index)">×</button>
                    </div>
                </div>
            </div>
        }
        @if (_model.DisplayRules.Count == 0)
        {
            <div class="text-muted small">Žádná pravidla. Použije se výchozí barva.</div>
        }
        <button type="button" class="btn btn-sm btn-outline-primary w-100 mt-2"
                @onclick="AddRule">+ Přidat pravidlo</button>
    </div>

    <button type="submit" class="btn btn-sm btn-primary btn-save w-100">Uložit</button>
</EditForm>

<div class="delete-section">
    <button class="btn btn-sm btn-outline-danger w-100"
            @onclick="() => OnDelete.InvokeAsync()">
        Smazat místnost
    </button>
</div>

@code {
    [Parameter, EditorRequired] public RoomConfig Room { get; set; } = default!;
    [Parameter] public EventCallback<RoomConfig> OnSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private FormModel _model = new();
    private string? _prevId;

    private void AddRule()
    {
        _model.DisplayRules.Add(new DisplayRuleModel
        {
            Condition = "",
            Color = "#3498db"
        });
    }

    private void RemoveRule(int index)
    {
        if (index >= 0 && index < _model.DisplayRules.Count)
            _model.DisplayRules.RemoveAt(index);
    }

    protected override void OnParametersSet()
    {
        if (Room.Id == _prevId) return;
        _prevId = Room.Id;
        _model = new FormModel
        {
            Name   = Room.Name,
            Width  = Room.Geometry.Width,
            Height = Room.Geometry.Height,
            DisplayRules = Room.DisplayRules
                .Select(r => new DisplayRuleModel
                {
                    Condition = r.Condition,
                    Color = r.Color
                })
                .ToList()
        };
    }

    private async Task HandleSubmit()
    {
        var newGeometry = new RoomGeometry(Room.Geometry.X, Room.Geometry.Y, _model.Width, _model.Height);
        var displayRules = _model.DisplayRules
            .Select(r => new DisplayRule(r.Condition, r.Color))
            .ToList();
        var updated = Room with
        {
            Name = _model.Name,
            Geometry = newGeometry,
            DisplayRules = displayRules,
            UpdatedAt = DateTime.UtcNow
        };
        await OnSave.InvokeAsync(updated);
    }

    private sealed class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Název je povinný")]
        public string Name { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Range(20, 5000, ErrorMessage = "Šířka musí být 20–5000 px")]
        public double Width { get; set; } = 100;
        [System.ComponentModel.DataAnnotations.Range(20, 5000, ErrorMessage = "Výška musí být 20–5000 px")]
        public double Height { get; set; } = 100;
        public List<DisplayRuleModel> DisplayRules { get; set; } = new();
    }

    private sealed class DisplayRuleModel
    {
        public string Condition { get; set; } = "";
        public string Color { get; set; } = "#3498db";
    }
}
