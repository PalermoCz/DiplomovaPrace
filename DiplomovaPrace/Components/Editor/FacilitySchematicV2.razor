@using DiplomovaPrace.Services
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@*
 * FacilitySchematicV2 — nový SVG renderer pro facility schematic.
 *
 * Rozdíly oproti V1 (EditorCanvas facility mode):
 *   - Čistý tree layout z SchematicComposerV2 (subtree-width centering)
 *   - Rovné čáry místo ortogonálního routingu
 *   - Kruhy místo boxy pro všechny uzly
 *   - Žádné area bounding boxy / backbone band
 *   - Čistý subtree highlight bez giant dekorací
 *
 * Pan/zoom: sdílí editorCanvas.js (JS modul pro SVG interakci).
 * Kliknutí: JS dispatchuje přes data-node-key atributy.
 *@

<svg id="@_svgId" class="editor-svg"
     style="background-color: #ffffff;"
     tabindex="0">

    <g id="@(_svgId + "-content")">
        @if (Layout is not null && Layout.Nodes.Count > 0)
        {
            var nodeByKey = Layout.Nodes.ToDictionary(n => n.NodeKey, StringComparer.OrdinalIgnoreCase);
            var hasAnySelection = SelectedElementIds.Count > 0 || !string.IsNullOrWhiteSpace(SelectedElementId);

            @* ── Background ─────────────────────────────────── *@
            <rect x="0" y="0"
                  width="@Fmt(Layout.CanvasWidth)" height="@Fmt(Layout.CanvasHeight)"
                  fill="white" pointer-events="none" />

            @* ── Editor grid (shown only in edit mode) ──────── *@
            @if (ShowGrid)
            {
                @((MarkupString)$@"<defs>
  <pattern id=""{_svgId}-grid"" width=""20"" height=""20"" patternUnits=""userSpaceOnUse"">
    <path d=""M 20 0 L 0 0 0 20"" fill=""none"" stroke=""#e2e8f0"" stroke-width=""0.5""/>
  </pattern>
</defs>
<rect x=""-100000"" y=""-100000"" width=""200000"" height=""200000"" fill=""url(#{_svgId}-grid)"" pointer-events=""none""/>")
            }

            @* ── Links ──────────────────────────────────────── *@
            @foreach (var link in Layout.Links)
            {
                if (!nodeByKey.TryGetValue(link.SourceNodeKey, out var src) ||
                    !nodeByKey.TryGetValue(link.TargetNodeKey, out var tgt))
                    continue;

                var linkInSubtree = SelectedSubtreeNodeKeys.Contains(link.SourceNodeKey)
                    && SelectedSubtreeNodeKeys.Contains(link.TargetNodeKey);
                var linkTouchesSelection = IsElementSelected(link.SourceNodeKey)
                    || IsElementSelected(link.TargetNodeKey);
                var linkTouchesFocus = IsFocusElement(link.SourceNodeKey)
                    || IsFocusElement(link.TargetNodeKey);

                var linkStroke = link.IsParentChild
                    ? (linkTouchesFocus ? "#1d4ed8"
                        : linkInSubtree ? "#3b82f6"
                        : linkTouchesSelection ? "#64748b"
                        : "#64748b")
                    : "#64748b";
                var linkWidth = link.IsParentChild
                    ? (linkTouchesFocus ? "2.4"
                        : linkInSubtree ? "2.0"
                        : linkTouchesSelection ? "1.6"
                        : "1.6")
                    : "1.6";
                var linkOpacity = link.IsParentChild
                    ? (hasAnySelection && !linkInSubtree && !linkTouchesSelection && !linkTouchesFocus
                        ? "0.15" : linkInSubtree ? "0.9" : "0.65")
                    : "0.8";
                var linkDash = string.Empty;

                @* Subtree highlight underlay for focused links *@
                @if (linkInSubtree && linkTouchesFocus)
                {
                    <line x1="@Fmt(src.X)" y1="@Fmt(src.Y)"
                          x2="@Fmt(tgt.X)" y2="@Fmt(tgt.Y)"
                          stroke="#93c5fd" stroke-width="6" stroke-opacity="0.25"
                          stroke-linecap="round" pointer-events="none" />
                }

                <line x1="@Fmt(src.X)" y1="@Fmt(src.Y)"
                      x2="@Fmt(tgt.X)" y2="@Fmt(tgt.Y)"
                      stroke="@linkStroke" stroke-width="@linkWidth"
                      stroke-opacity="@linkOpacity" stroke-linecap="round"
                      stroke-dasharray="@linkDash"
                      pointer-events="none" />
            }

            @* ── Nodes ──────────────────────────────────────── *@
            @foreach (var node in Layout.Nodes)
            {
                var isFocus = IsFocusElement(node.NodeKey);
                var isSelected = IsElementSelected(node.NodeKey);
                var isSubtree = SelectedSubtreeNodeKeys.Contains(node.NodeKey);
                var cx = node.X;
                var cy = node.Y;
                var baseStyle = FacilityNodeStyleSystem.ResolveStyle(ResolveNodeStylePresetKey(node.NodeKey), StylePresetsByKey);
                var radius = baseStyle.Size / 2.0;
                var symbol = baseStyle.Symbol;
                var symbolFontSize = Math.Clamp(radius - 2.5, 7.5, 13).ToString(System.Globalization.CultureInfo.InvariantCulture);

                var fillColor = baseStyle.FillColor;
                var strokeColor = baseStyle.StrokeColor;
                var textColor = baseStyle.SymbolColor;
                var labelColor = baseStyle.LabelColor;
                var labelWeight = baseStyle.LabelFontWeight.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var nodeOpacity = 1.0;
                var labelOpacity = 1.0;

                // Selection state styling
                if (hasAnySelection && !isSelected && !isFocus && !isSubtree)
                {
                    nodeOpacity = 0.35;
                    labelOpacity = 0.4;
                }

                if (isSubtree && !isSelected && !isFocus)
                {
                    labelWeight = node.HasChildren ? "700" : "640";
                }

                if (isSelected && !isFocus)
                {
                    labelWeight = "680";
                }

                if (isFocus)
                {
                    labelWeight = "720";
                }

                // Halo for selected/focused/subtree nodes
                var showHalo = isSelected || isFocus || isSubtree;
                var haloRadius = radius + (isFocus ? 6 : isSelected ? 5 : (isSubtree && node.HasChildren ? 4 : 3));
                var haloStroke = isFocus ? "#1d4ed8" : isSelected ? "#93c5fd" : (isSubtree && node.HasChildren ? "#2563eb" : "#dbeafe");
                var haloStrokeWidth = isFocus ? "3.5" : isSelected ? "2.8" : (isSubtree && node.HasChildren ? "2.2" : "1.5");
                var haloFill = isFocus ? "#dbeafe" : "none";
                var haloFillOpacity = isFocus ? "0.4" : "0";

                var labelText = TruncateLabel(node.Label ?? node.NodeKey, baseStyle.Size);
                var labelFontSize = baseStyle.LabelFontSize.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var labelY = cy + radius + 13;
                var nodeStrokeWidth = isFocus ? "3.5" : isSelected ? "2.8" : baseStyle.StrokeWidth.ToString(System.Globalization.CultureInfo.InvariantCulture);

                <g data-node-key="@node.NodeKey"
                   data-node-x="@Fmt(cx)"
                   data-node-y="@Fmt(cy)"
                   data-node-label="@(node.Label ?? node.NodeKey)"
                   data-node-type="@(node.NodeType ?? "")"
                   data-node-zone="@(node.Zone ?? "")"
                   data-node-meter="@(node.MeterUrn ?? "")"
                   data-node-preset="@(ResolveNodeStylePresetKey(node.NodeKey) ?? "")"
                         data-node-preset-label="@(ResolveNodeStylePresetLabel(node.NodeKey) ?? "")"
                         data-node-tags="@(ResolveNodeTags(node.NodeKey) ?? "")"
                         data-node-note="@(ResolveNodeNote(node.NodeKey) ?? "")"
                   opacity="@Fmt(nodeOpacity)"
                   style="cursor: pointer;">

                    @* Halo *@
                    @if (showHalo)
                    {
                        <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="@Fmt(haloRadius)"
                                fill="@haloFill" fill-opacity="@haloFillOpacity"
                                stroke="@haloStroke" stroke-width="@haloStrokeWidth"
                                pointer-events="none" />
                    }

                    @* Base node shape *@
                    @if (baseStyle.Shape == FacilityNodeShapeKind.Circle)
                    {
                        <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="@Fmt(radius)"
                                fill="@fillColor" stroke="@strokeColor"
                                stroke-width="@nodeStrokeWidth" />
                    }
                    else if (baseStyle.Shape == FacilityNodeShapeKind.Square)
                    {
                        <rect x="@Fmt(cx - radius)" y="@Fmt(cy - radius)"
                              width="@Fmt(baseStyle.Size)" height="@Fmt(baseStyle.Size)"
                              rx="4" ry="4"
                              fill="@fillColor" stroke="@strokeColor"
                              stroke-width="@nodeStrokeWidth" />
                    }
                    else
                    {
                        <polygon points="@BuildDiamondPoints(cx, cy, radius)"
                                 fill="@fillColor" stroke="@strokeColor"
                                 stroke-width="@nodeStrokeWidth" />
                    }

                    @* Symbol *@
                    @if (!string.IsNullOrWhiteSpace(symbol))
                    {
                        @((MarkupString)$"<text x=\"{Fmt(cx)}\" y=\"{Fmt(cy + 4)}\" text-anchor=\"middle\" font-size=\"{symbolFontSize}\" font-weight=\"700\" fill=\"{textColor}\" pointer-events=\"none\">{EscapeXml(symbol)}</text>")
                    }

                    @* Label *@
                    @((MarkupString)$"<text x=\"{Fmt(cx)}\" y=\"{Fmt(labelY)}\" text-anchor=\"middle\" font-size=\"{labelFontSize}\" font-weight=\"{labelWeight}\" fill=\"{labelColor}\" pointer-events=\"none\" opacity=\"{Fmt(labelOpacity)}\">{EscapeXml(labelText)}</text>")
                </g>
            }
        }
        else
        {
            @* Empty state *@
            @((MarkupString)"<text x=\"200\" y=\"145\" text-anchor=\"middle\" font-size=\"14\" fill=\"#64748b\" pointer-events=\"none\">Žádná facility data</text>")
            @((MarkupString)"<text x=\"200\" y=\"165\" text-anchor=\"middle\" font-size=\"11\" fill=\"#cbd5e1\" pointer-events=\"none\">Importujte nebo načtěte facility</text>")
        }
    </g>
</svg>

@code {
    [Parameter] public SchematicLayoutV2? Layout { get; set; }
    [Parameter] public string? SelectedElementId { get; set; }
    [Parameter] public IReadOnlySet<string> SelectedElementIds { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlySet<string> SelectedSubtreeNodeKeys { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlyDictionary<string, string> NodeStylePresetKeysByNodeKey { get; set; } = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlyDictionary<string, string> NodeStylePresetLabelsByNodeKey { get; set; } = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlyDictionary<string, string> NodeTagsByNodeKey { get; set; } = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlyDictionary<string, string> NodeNotesByNodeKey { get; set; } = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public IReadOnlyDictionary<string, FacilityNodeStylePreset> StylePresetsByKey { get; set; } = new Dictionary<string, FacilityNodeStylePreset>(StringComparer.OrdinalIgnoreCase);
    /// <summary>Controls the initial fit behavior: "home" (default, root-centric), "focus", "edit".</summary>
    [Parameter] public string InitialFitMode { get; set; } = "home";

    [Parameter] public EventCallback<(string Id, EditorSelectionType Type)> OnElementSelected { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnCanvasClicked { get; set; }
    [Parameter] public EventCallback<(string NodeKey, double X, double Y)> OnNodeDragEnd { get; set; }
    [Parameter] public EventCallback<(double X1, double Y1, double X2, double Y2, bool Additive)> OnRectSelectEnd { get; set; }
    [Parameter] public EventCallback<(double DeltaX, double DeltaY)> OnGroupDragEnd { get; set; }
    [Parameter] public EventCallback<string> OnNodeCtrlClicked { get; set; }
    [Parameter] public EventCallback<string> OnKeyboardShortcut { get; set; }
    [Parameter] public bool ShowGrid { get; set; } = false;

    private readonly string _svgId = "schematic-v2-svg";
    private DotNetObjectReference<FacilitySchematicV2>? _dotNetRef;
    private bool _jsInitialized;
    private bool _isDisposed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed) return;

        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                await JSRuntime.InvokeVoidAsync("editorCanvas.init", _svgId, _dotNetRef);
                if (_isDisposed)
                {
                    await JSRuntime.InvokeVoidAsync("editorCanvas.dispose", _svgId);
                    return;
                }
                await JSRuntime.InvokeVoidAsync("editorCanvas.setTool", "Select");
                await JSRuntime.InvokeVoidAsync("editorCanvas.setFloorBounds",
                    Layout?.CanvasWidth ?? 400, Layout?.CanvasHeight ?? 300);
                await JSRuntime.InvokeVoidAsync("editorCanvas.setupHoverTooltip", _svgId);
                if (InitialFitMode == "home")
                    await JSRuntime.InvokeVoidAsync("editorCanvas.goHome");
                else
                    await JSRuntime.InvokeVoidAsync("editorCanvas.fitToView", InitialFitMode);
                _jsInitialized = true;
            }
            catch { /* component may have been disposed during render */ }
            return;
        }

        if (!_jsInitialized || _isDisposed) return;

        await JSRuntime.InvokeVoidAsync("editorCanvas.setFloorBounds",
            Layout?.CanvasWidth ?? 400, Layout?.CanvasHeight ?? 300);
        await JSRuntime.InvokeVoidAsync("editorCanvas.reapplyTransform");
    }

    // ── JSInvokable — called by editorCanvas.js ──────────────────────────

    [JSInvokable]
    public Task JsOnRoomDrawn(double x, double y, double width, double height) => Task.CompletedTask;

    [JSInvokable]
    public Task JsOnDeviceDragEnd(string deviceId, double x, double y) => Task.CompletedTask;

    [JSInvokable]
    public async Task JsOnFacilityNodeDragEnd(string nodeKey, double x, double y)
    {
        if (OnNodeDragEnd.HasDelegate)
            await OnNodeDragEnd.InvokeAsync((nodeKey, x, y));
    }

    [JSInvokable]
    public async Task JsOnElementClicked(string id, string typeName)
    {
        if (!Enum.TryParse<EditorSelectionType>(typeName, out var type))
            type = EditorSelectionType.None;
        await OnElementSelected.InvokeAsync((id, type));
    }

    [JSInvokable]
    public async Task JsOnCanvasClicked(double x, double y) =>
        await OnCanvasClicked.InvokeAsync((x, y));

    [JSInvokable]
    public Task JsOnDeleteClicked(string id, string typeName) => Task.CompletedTask;

    [JSInvokable]
    public async Task JsOnKeyboardShortcut(string shortcut)
    {
        if (OnKeyboardShortcut.HasDelegate)
            await OnKeyboardShortcut.InvokeAsync(shortcut);
    }

    [JSInvokable]
    public async Task JsOnRectSelectEnd(double x1, double y1, double x2, double y2, bool additive)
    {
        if (OnRectSelectEnd.HasDelegate)
            await OnRectSelectEnd.InvokeAsync((x1, y1, x2, y2, additive));
    }

    [JSInvokable]
    public async Task JsOnFacilityGroupDragEnd(double deltaX, double deltaY)
    {
        if (OnGroupDragEnd.HasDelegate)
            await OnGroupDragEnd.InvokeAsync((deltaX, deltaY));
    }

    [JSInvokable]
    public async Task JsOnFacilityNodeCtrlClicked(string nodeKey)
    {
        if (OnNodeCtrlClicked.HasDelegate)
            await OnNodeCtrlClicked.InvokeAsync(nodeKey);
    }

    // ── Helpers ──────────────────────────────────────────────────────────

    public async Task ResetViewAsync()
    {
        if (_jsInitialized && !_isDisposed)
            await JSRuntime.InvokeVoidAsync("editorCanvas.resetView");
    }

    private bool IsFocusElement(string key) =>
        !string.IsNullOrEmpty(SelectedElementId)
        && string.Equals(SelectedElementId, key, StringComparison.OrdinalIgnoreCase);

    private bool IsElementSelected(string key) =>
        SelectedElementIds.Count > 1
            ? SelectedElementIds.Contains(key)
            : IsFocusElement(key) || SelectedElementIds.Contains(key);

    private string? ResolveNodeStylePresetKey(string nodeKey)
    {
        return NodeStylePresetKeysByNodeKey.TryGetValue(nodeKey, out var presetKey)
            ? presetKey
            : null;
    }

    private string? ResolveNodeStylePresetLabel(string nodeKey)
    {
        return NodeStylePresetLabelsByNodeKey.TryGetValue(nodeKey, out var presetLabel)
            ? presetLabel
            : null;
    }

    private string? ResolveNodeTags(string nodeKey)
    {
        return NodeTagsByNodeKey.TryGetValue(nodeKey, out var tags)
            ? tags
            : null;
    }

    private string? ResolveNodeNote(string nodeKey)
    {
        return NodeNotesByNodeKey.TryGetValue(nodeKey, out var note)
            ? note
            : null;
    }

    private static string BuildDiamondPoints(double cx, double cy, double radius)
    {
        return FormattableString.Invariant($"{cx},{cy - radius} {cx + radius},{cy} {cx},{cy + radius} {cx - radius},{cy}");
    }

    private static string Fmt(double v) =>
        v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string EscapeXml(string? s) =>
        string.IsNullOrEmpty(s) ? "" :
        s.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("\"", "&quot;");

    private static string TruncateLabel(string label, double size)
    {
        var maxLen = size switch
        {
            >= 34 => 20,
            >= 28 => 16,
            >= 22 => 13,
            _ => 11
        };
        return label.Length <= maxLen ? label : label[..(maxLen - 1)] + "…";
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        try
        {
            await JSRuntime.InvokeVoidAsync("editorCanvas.dispose", _svgId);
        }
        catch { }
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }
}
