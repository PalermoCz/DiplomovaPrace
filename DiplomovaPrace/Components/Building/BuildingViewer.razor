@* Root komponenta vizualizace budovy.
   Implementuje Observer pattern: subscribe v OnInitialized, dispose v Dispose.
   HandleStateChanged marshalluje na UI vlákno přes InvokeAsync.
   Multi-building: reaguje na IActiveBuildingService.OnActiveBuildingChanged. *@

@inject IBuildingStateService StateService
@inject IBuildingConfigurationService ConfigService
@inject IActiveBuildingService ActiveBuildingService
@implements IDisposable

<div class="building-viewer">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>@StateService.Building.Name</h4>
        <div class="btn-group" role="group">
            @foreach (var floor in StateService.Building.Floors)
            {
                <button class="btn @(floor.Id == _selectedFloorId ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SelectFloor(floor.Id)">
                    @floor.Name
                </button>
            }
        </div>
    </div>

    @if (_selectedFloor is not null)
    {
        <FloorPlan Floor="_selectedFloor"
                   SelectedDeviceId="@_selectedDeviceId"
                   OnDeviceSelected="HandleDeviceSelected" />
    }

    @if (_selectedDeviceId is not null)
    {
        <DeviceDetailPanel DeviceId="@_selectedDeviceId"
                           OnClose="() => _selectedDeviceId = null" />
    }
</div>

@code {
    private string _selectedFloorId = "";
    private Floor? _selectedFloor;
    private string? _selectedDeviceId;

    protected override async Task OnInitializedAsync()
    {
        // Pokud je aktivní budova nastavena, načteme ji do runtime domény
        if (ActiveBuildingService.ActiveBuildingId is not null)
            await ApplyActiveBuildingAsync(ActiveBuildingService.ActiveBuildingId);

        SelectFirstFloor();

        StateService.OnStateChanged               += HandleStateChanged;
        ActiveBuildingService.OnActiveBuildingChanged += HandleActiveBuildingChanged;
    }

    private void SelectFirstFloor()
    {
        var floors = StateService.Building.Floors;
        if (floors.Count > 0)
        {
            _selectedFloorId = floors[0].Id;
            _selectedFloor   = floors[0];
        }
        else
        {
            _selectedFloorId = "";
            _selectedFloor   = null;
        }
        _selectedDeviceId = null;
    }

    private void SelectFloor(string floorId)
    {
        _selectedFloorId = floorId;
        _selectedFloor   = StateService.Building.Floors.FirstOrDefault(f => f.Id == floorId);
    }

    private void HandleDeviceSelected(string deviceId)
    {
        _selectedDeviceId = deviceId;
    }

    private async void HandleStateChanged()
    {
        // Refresh selected floor reference (building may have been replaced)
        _selectedFloor = StateService.Building.Floors.FirstOrDefault(f => f.Id == _selectedFloorId);
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleActiveBuildingChanged()
    {
        if (ActiveBuildingService.ActiveBuildingId is not null)
        {
            await ApplyActiveBuildingAsync(ActiveBuildingService.ActiveBuildingId);
            SelectFirstFloor();
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyActiveBuildingAsync(string buildingId)
    {
        var config = await ConfigService.GetBuildingAsync(buildingId);
        if (config is null) return;
        var domain = ConfigService.ToBuildingDomainModel(config);
        StateService.ReplaceBuilding(domain);
    }

    public void Dispose()
    {
        StateService.OnStateChanged               -= HandleStateChanged;
        ActiveBuildingService.OnActiveBuildingChanged -= HandleActiveBuildingChanged;
    }
}
