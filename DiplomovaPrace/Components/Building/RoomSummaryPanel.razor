@* Souhrnný panel pro vybranou místnost — zařízení, příkon, živé hodnoty.
   Patří do Runtime vizualizace. Používá VÝHRADNĚ doménové modely (Room, Device)
   a IBuildingStateService. Žádné Config typy. *@

@inject IBuildingStateService StateService
@implements IDisposable

<div class="summary-panel mb-3">
    <div class="prop-section-title">Přehled místnosti</div>

    <div class="summary-stats d-flex gap-3 mb-2 flex-wrap">
        <div class="summary-stat">
            <span class="summary-stat-label">Zařízení</span>
            <span class="summary-stat-value">@_deviceCount</span>
        </div>
        <div class="summary-stat">
            <span class="summary-stat-label">Příkon</span>
            <span class="summary-stat-value">@_totalConsumption.ToString("F0") W</span>
        </div>
        @if (_avgTemp.HasValue)
        {
            <div class="summary-stat">
                <span class="summary-stat-label">Avg teplota</span>
                <span class="summary-stat-value">@_avgTemp.Value.ToString("F1") °C</span>
            </div>
        }
    </div>

    @if (Room.Devices.Count > 0)
    {
        <table class="table table-sm table-borderless summary-table mb-0">
            <thead>
                <tr>
                    <th>Zařízení</th>
                    <th>Typ</th>
                    <th class="text-end">Příkon</th>
                    <th class="text-end">Hodnota</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Room.Devices)
                {
                    <tr>
                        <td>@d.Name</td>
                        <td style="font-size:0.78rem; color:#64748b;">@DeviceTypeLabel(d.Type)</td>
                        <td class="text-end">@d.Consumption.ToString("F0") W</td>
                        <td class="text-end">@FormatValue(d)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter, EditorRequired] public Room Room { get; set; } = default!;

    private int    _deviceCount;
    private double _totalConsumption;
    private double? _avgTemp;

    protected override void OnInitialized()
    {
        StateService.OnStateChanged += HandleStateChanged;
        Refresh();
    }

    protected override void OnParametersSet() => Refresh();

    private void Refresh()
    {
        _deviceCount      = Room.Devices.Count;
        _totalConsumption = Room.Devices.Sum(d => d.Consumption);

        var temps = Room.Devices
            .Where(d => d.Type == DeviceType.TemperatureSensor)
            .Select(d => StateService.GetDeviceState(d.Id)?.NumericValue)
            .Where(v => v.HasValue)
            .Select(v => v!.Value)
            .ToList();

        _avgTemp = temps.Count > 0 ? temps.Average() : null;
    }

    private string FormatValue(Device d)
    {
        var state = StateService.GetDeviceState(d.Id);
        if (state is null) return "–";
        if (state.NumericValue.HasValue)
        {
            var unit = UnitForType(d.Type);
            return string.IsNullOrEmpty(unit)
                ? state.NumericValue.Value.ToString("F1")
                : $"{state.NumericValue.Value:F1} {unit}";
        }
        if (state.IsActive.HasValue)
            return state.IsActive.Value ? "Aktivní" : "Neaktivní";
        return "–";
    }

    private static string UnitForType(DeviceType t) => t switch
    {
        DeviceType.TemperatureSensor => "°C",
        DeviceType.HumiditySensor    => "%",
        _                            => ""
    };

    private static string DeviceTypeLabel(DeviceType t) => t switch
    {
        DeviceType.TemperatureSensor => "Teplota",
        DeviceType.HumiditySensor    => "Vlhkost",
        DeviceType.Light             => "Světlo",
        DeviceType.HVAC              => "Klimatizace",
        DeviceType.MotionSensor      => "Pohyb",
        DeviceType.DoorSensor        => "Dveře",
        _                            => t.ToString()
    };

    private async void HandleStateChanged()
    {
        Refresh();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => StateService.OnStateChanged -= HandleStateChanged;
}
