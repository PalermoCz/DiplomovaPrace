@using DiplomovaPrace.Services
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<style>
    .scatter-chart-host {
        height: 240px;
        width: 100%;
        min-width: 0;
    }
</style>

@if (_jsInteropUnavailable)
{
    <div class="alert alert-secondary py-2 mb-2 border-0">
        The temperature vs load scatter is unavailable because the chart runtime could not be initialized.
    </div>
}
else if (Data is not null && Data.Points.Count > 0)
{
    <div id="@_chartElementId" class="scatter-chart-host"></div>
    <div class="small text-muted mt-2">Status: X axis <strong>@Data.XAxisLabel</strong> · Y axis <strong>@Data.YAxisLabel</strong> · @Data.GranularityLabel.ToLowerInvariant() · points <strong>@Data.PointCount</strong></div>
}

@code {
    [Parameter] public SelectionTemperatureLoadScatterResult? Data { get; set; }

    private readonly string _chartElementId = $"facility-temperature-load-scatter-{Guid.NewGuid():N}";
    private string? _lastRenderedSignature;
    private bool _jsInteropUnavailable;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_jsInteropUnavailable)
        {
            return;
        }

        try
        {
            if (Data is not null && Data.Points.Count > 0)
            {
                var signature = BuildSignature(Data);

                if (!string.Equals(signature, _lastRenderedSignature, StringComparison.Ordinal))
                {
                    _lastRenderedSignature = signature;
                    await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.renderTemperatureLoadScatter", _chartElementId, BuildModel(Data));
                }
                else if (firstRender)
                {
                    await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.resize", _chartElementId);
                }
            }
            else
            {
                _lastRenderedSignature = null;
                await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.dispose", _chartElementId);
            }
        }
        catch (JSException)
        {
            _jsInteropUnavailable = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string BuildSignature(SelectionTemperatureLoadScatterResult data)
    {
        if (data.Points.Count == 0)
        {
            return "0";
        }

        var firstPoint = data.Points[0];
        var lastPoint = data.Points[^1];
        return $"{data.Points.Count}:{firstPoint.TimestampUtc.Ticks}:{firstPoint.OutdoorTemperatureC:F4}:{firstPoint.LoadValue:F4}:{lastPoint.TimestampUtc.Ticks}:{lastPoint.OutdoorTemperatureC:F4}:{lastPoint.LoadValue:F4}";
    }

    private static object BuildModel(SelectionTemperatureLoadScatterResult data)
    {
        return new
        {
            title = "Temperature vs load scatter",
            unit = data.Unit,
            xAxisLabel = data.XAxisLabel,
            yAxisLabel = data.YAxisLabel,
            points = data.Points.Select(point => new
            {
                timestampUtc = point.TimestampUtc,
                outdoorTemperatureC = point.OutdoorTemperatureC,
                loadValue = point.LoadValue
            }).ToArray()
        };
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.dispose", _chartElementId);
        }
        catch (JSDisconnectedException)
        {
            // No-op: circuit is already disconnected.
        }
        catch (JSException)
        {
            // No-op: chart runtime may not be available.
        }
    }
}