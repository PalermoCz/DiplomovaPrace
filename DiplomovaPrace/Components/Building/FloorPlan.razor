@inject IBuildingStateService StateService

<svg viewBox="0 0 @Fmt(Floor.Width) @Fmt(Floor.Height)" class="floor-plan" xmlns="http://www.w3.org/2000/svg">
    <rect x="0" y="0" width="@Fmt(Floor.Width)" height="@Fmt(Floor.Height)"
          fill="#f8f9fa" stroke="#2c3e50" stroke-width="2" rx="5" />

    @((MarkupString)$"<text x=\"{Fmt(Floor.Width / 2)}\" y=\"18\" text-anchor=\"middle\" class=\"floor-label\">{Floor.Name}</text>")

    @foreach (var room in Floor.Rooms)
    {
        <RoomShape Room="room"
                   IsSelected="@(_selectedRoomId == room.Id)"
                   OnRoomClicked="HandleRoomClicked"
                   SelectedDeviceId="@SelectedDeviceId"
                   OnDeviceSelected="OnDeviceSelected" />
    }
</svg>

@code {
    [Parameter, EditorRequired]
    public Floor Floor { get; set; } = default!;

    [Parameter]
    public string? SelectedDeviceId { get; set; }

    [Parameter]
    public EventCallback<string> OnDeviceSelected { get; set; }

    /// <summary>Volán po kliknutí na místnost — předá ID (výběr) nebo null (zrušení výběru).</summary>
    [Parameter]
    public EventCallback<string?> OnRoomSelected { get; set; }

    private string? _selectedRoomId;

    private void HandleRoomClicked(string roomId)
    {
        if (_selectedRoomId == roomId)
        {
            _selectedRoomId = null;
            OnRoomSelected.InvokeAsync(null);
        }
        else
        {
            _selectedRoomId = roomId;
            OnRoomSelected.InvokeAsync(roomId);
        }
    }

    private static string Fmt(double v) =>
        v.ToString(System.Globalization.CultureInfo.InvariantCulture);
}
