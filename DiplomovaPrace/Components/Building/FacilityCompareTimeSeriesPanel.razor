@using DiplomovaPrace.Services
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<style>
    .compare-chart-host {
        height: clamp(13rem, 22vh, 16rem);
        width: 100%;
        min-width: 0;
    }
</style>

<div class="card border-0 shadow-none mb-0 bg-transparent">
    <div class="card-body p-3">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
            <div class="text-muted text-uppercase fw-bold" style="font-size: 0.8rem;">@GetPanelTitle(Data)</div>
            @if (Data?.Series.Count > 0)
            {
                <span class="badge bg-light text-dark border">@Data.Series.Count.ToString("N0") series</span>
            }
        </div>

        @if (Data is not null)
        {
            <div class="small text-muted mb-2">
                Mode: <strong>@GetModeLabel(Data.RequestedMode)</strong> · Granularity: <strong>@Data.GranularityLabel</strong>
            </div>
        }

        @if (_jsInteropUnavailable)
        {
            <div class="alert alert-secondary py-2 mb-0 border-0">
                The compare chart is unavailable because the chart runtime could not be initialized.
            </div>
        }
        else if (Data is null)
        {
            <div class="alert alert-secondary py-2 mb-0 border-0">
                Compare preview is not ready yet.
            </div>
        }
        else if (Data.Series.Count == 0)
        {
            <div class="alert alert-info py-2 mb-0 border-0 d-flex align-items-start">
                <i class="bi bi-info-circle-fill text-info me-2"></i>
                <div>@(Data.NoDataMessage ?? "No time-series data is available for the selected nodes in the analysis window.")</div>
            </div>
        }
        else
        {
            <div id="@_chartElementId" class="compare-chart-host"></div>
            <div class="small text-muted mt-2">Status: Y axis <strong>@Data.YAxisLabel</strong> · visible series <strong>@Data.Series.Count</strong>@(Data.ExcludedNodeMessages.Count > 0 ? $" · excluded nodes: {Data.ExcludedNodeMessages.Count}" : string.Empty)</div>
        }
    </div>
</div>

@code {
    [Parameter] public CuratedNodeCompareTimeSeriesResult? Data { get; set; }

    private readonly string _chartElementId = $"facility-compare-timeseries-{Guid.NewGuid():N}";
    private string? _lastRenderedSignature;
    private bool _jsInteropUnavailable;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_jsInteropUnavailable)
        {
            return;
        }

        try
        {
            if (Data is not null && Data.Series.Count > 0)
            {
                var signature = BuildSignature(Data);

                if (!string.Equals(signature, _lastRenderedSignature, StringComparison.Ordinal))
                {
                    _lastRenderedSignature = signature;
                    await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.renderCompare", _chartElementId, BuildModel(Data));
                }
                else if (firstRender)
                {
                    await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.resize", _chartElementId);
                }
            }
            else
            {
                _lastRenderedSignature = null;
                await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.dispose", _chartElementId);
            }
        }
        catch (JSException)
        {
            _jsInteropUnavailable = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string BuildSignature(CuratedNodeCompareTimeSeriesResult data)
    {
        var seriesToken = string.Join(";", data.Series.Select(series =>
        {
            if (series.Points.Count == 0)
            {
                return $"{series.NodeKey}:0";
            }

            var firstPoint = series.Points[0];
            var lastPoint = series.Points[^1];
            return $"{series.NodeKey}:{series.Points.Count}:{firstPoint.TimestampUtc.Ticks}:{lastPoint.TimestampUtc.Ticks}";
        }));

        return $"{data.PrimaryNodeKey}:{data.Granularity}:{seriesToken}";
    }

    private static object BuildModel(CuratedNodeCompareTimeSeriesResult data)
    {
        return new
        {
            title = data.Title,
            unit = data.Unit,
            yAxisLabel = data.YAxisLabel,
            series = data.Series.Select(series => new
            {
                name = series.Label,
                nodeKey = series.NodeKey,
                isPrimary = series.IsPrimary,
                points = series.Points.Select(point => new
                {
                    timestampUtc = point.TimestampUtc,
                    value = point.Value
                }).ToArray()
            }).ToArray()
        };
    }

    private static string GetModeLabel(CuratedNodeTimeSeriesMode mode)
    {
        return mode switch
        {
            CuratedNodeTimeSeriesMode.Auto => "Auto (adaptive by interval length)",
            CuratedNodeTimeSeriesMode.Raw15Min => "15 min (manual override)",
            CuratedNodeTimeSeriesMode.HourlyAverage => "Hourly (manual override)",
            CuratedNodeTimeSeriesMode.DailyAverage => "Daily (manual override)",
            _ => "Auto (adaptive by interval length)"
        };
    }

    private static string GetPanelTitle(CuratedNodeCompareTimeSeriesResult? data)
    {
        if (!string.IsNullOrWhiteSpace(data?.Title))
        {
            return data.Title;
        }

        return "Compare chart preview (v1)";
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.dispose", _chartElementId);
        }
        catch (JSDisconnectedException)
        {
            // No-op: circuit is already disconnected.
        }
        catch (JSException)
        {
            // No-op: chart runtime may not be available.
        }
    }
}
