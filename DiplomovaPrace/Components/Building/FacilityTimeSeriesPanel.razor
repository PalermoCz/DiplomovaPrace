@using DiplomovaPrace.Services
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<style>
    .ts-panel-header {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .ts-panel-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .ts-panel-title {
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        white-space: nowrap;
    }

    .ts-panel-controls-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    .ts-controls-cluster {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        min-width: 0;
        flex: 1 1 auto;
    }

    .ts-mode-buttons {
        display: flex;
        flex-wrap: nowrap;
        gap: 0.35rem;
        min-width: 0;
        flex-shrink: 0;
    }

    .ts-mode-buttons .btn {
        min-width: 4.65rem;
        white-space: nowrap;
    }

    .ts-inline-pins {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        min-width: 0;
        flex: 1 1 auto;
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .ts-inline-pins::-webkit-scrollbar {
        display: none;
    }

    .ts-inline-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.26rem 0.56rem;
        border: 1px solid #fdba74;
        border-radius: 999px;
        background: #fff7ed;
        color: #9a3412;
        font-size: 0.72rem;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .ts-inline-chip-label {
        max-width: 10rem;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ts-inline-chip-dismiss {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 0.95rem;
        height: 0.95rem;
        border: 0;
        padding: 0;
        border-radius: 999px;
        background: transparent;
        color: #dc2626;
        font-size: 0.86rem;
        font-weight: 800;
        line-height: 1;
    }

    .ts-inline-chip-dismiss:hover {
        color: #b91c1c;
        background: rgba(220, 38, 38, 0.08);
    }

    .ts-baseline-toggle {
        white-space: nowrap;
    }

    .ts-chart-host {
        height: clamp(14.25rem, 24vh, 18rem);
        width: 100%;
        min-width: 0;
    }

    .ts-chart-host-compact {
        height: clamp(12.75rem, 21vh, 16rem);
    }

    @@media (max-width: 900px) {
        .ts-controls-cluster {
            width: 100%;
        }

        .ts-mode-buttons .btn {
            min-width: 4.25rem;
        }
    }
</style>

<div class="card border-0 shadow-none mb-0 bg-transparent">
    <div class="card-body @(ShowPanelTitle || ShowStatusSummary ? "p-3" : "p-2")">
        <div class="ts-panel-header mb-2">
            @if (ShowPanelTitle)
            {
                <div class="ts-panel-title-row">
                    <div class="text-muted text-uppercase fw-bold ts-panel-title">@PanelTitle</div>
                    @if (Data?.Points.Count > 0)
                    {
                        <span class="badge bg-light text-dark border">@Data.Points.Count.ToString("N0") points</span>
                    }
                </div>
            }

            <div class="ts-panel-controls-row">
                <div class="ts-controls-cluster">
                    <div class="ts-mode-buttons" role="group" aria-label="Time-series granularity mode">
                        @foreach (var mode in _availableModes)
                        {
                            <button type="button"
                                    class="btn btn-sm @(SelectedMode == mode ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SelectModeAsync(mode)">
                                @GetModeShortLabel(mode)
                            </button>
                        }
                    </div>

                    @if (HeaderPinnedChips?.Count > 0)
                    {
                        <div class="ts-inline-pins" aria-label="Pinned contributor overlays">
                            @foreach (var pinnedChip in HeaderPinnedChips)
                            {
                                <span class="ts-inline-chip">
                                    <span class="ts-inline-chip-label">@pinnedChip.Label</span>
                                    <button type="button"
                                            class="ts-inline-chip-dismiss"
                                            title="Remove pin"
                                            aria-label="Remove pin for @pinnedChip.Label"
                                            @onclick="() => DismissPinnedChipAsync(pinnedChip.NodeKey)">
                                        ×
                                    </button>
                                </span>
                            }
                        </div>
                    }
                </div>

                @if (ShowBaselineToggle)
                {
                    <div class="form-check form-switch m-0 ts-baseline-toggle">
                        <input class="form-check-input"
                               type="checkbox"
                               id="@_baselineToggleId"
                               checked="@ShowBaselineOverlay"
                               @onchange="OnBaselineOverlayChanged" />
                        <label class="form-check-label small text-muted" for="@_baselineToggleId">
                            Baseline overlay
                        </label>
                    </div>
                }
            </div>
        </div>

        @if (ShowStatusSummary)
        {
            <div class="d-flex flex-wrap align-items-center gap-3 small text-muted mb-2">
                <span>Display mode: <strong>@GetModeLabel(SelectedMode)</strong></span>
                @if (ShowBaselineToggle && ShowBaselineOverlay)
                {
                    <span>Baseline: <strong>@(Data?.BaselineOverlayAvailable == true ? "available" : "unavailable")</strong></span>
                }
                @if (IsLoading)
                {
                    <span class="d-inline-flex align-items-center">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>Updating chart...
                    </span>
                }
            </div>
        }

        @if (_jsInteropUnavailable)
        {
            <div class="alert alert-secondary py-2 mb-0 border-0">
                The time-series chart is unavailable because the chart runtime could not be initialized.
            </div>
        }
        else if (Data is null)
        {
            <div class="alert alert-secondary py-2 mb-0 border-0">
                A chart data source is not ready for this node yet.
            </div>
        }
        else if (Data.Points.Count == 0)
        {
            <div class="alert alert-info py-2 mb-0 border-0 d-flex align-items-start">
                <i class="bi bi-info-circle-fill text-info me-2"></i>
                <div>@(Data.NoDataMessage ?? "No time-series data is available for the selected interval.")</div>
            </div>
            <div class="small text-muted mt-2">Status: no data is available for the selected interval.</div>
        }
        else
        {
            <div id="@_chartElementId" class="ts-chart-host @(!ShowPanelTitle && !ShowStatusSummary ? "ts-chart-host-compact" : string.Empty)"></div>
            @if (ShowStatusSummary)
            {
                <div class="small text-muted mt-2">
                    Status: <strong>@Data.GranularityLabel</strong> · Y axis: <strong>@Data.YAxisLabel</strong>@(ShowBaselineOverlay ? $" · Baseline: {(Data.BaselineOverlayAvailable ? "active" : "unavailable")}" : string.Empty)
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public CuratedNodeTimeSeriesResult? Data { get; set; }
    [Parameter] public CuratedNodeTimeSeriesMode SelectedMode { get; set; } = CuratedNodeTimeSeriesMode.Auto;
    [Parameter] public EventCallback<CuratedNodeTimeSeriesMode> SelectedModeChanged { get; set; }
    [Parameter] public bool ShowBaselineOverlay { get; set; }
    [Parameter] public EventCallback<bool> ShowBaselineOverlayChanged { get; set; }
    [Parameter] public bool ShowBaselineToggle { get; set; } = true;
    [Parameter] public IReadOnlyList<(CuratedNodeTimeSeriesResult Data, string SeriesName, bool IsPinned)>? OverlaySeries { get; set; }
    [Parameter] public IReadOnlyList<(string NodeKey, string Label)>? HeaderPinnedChips { get; set; }
    [Parameter] public EventCallback<string> HeaderPinnedChipDismissed { get; set; }
    [Parameter] public bool ShowPanelTitle { get; set; } = true;
    [Parameter] public bool ShowStatusSummary { get; set; } = true;
    [Parameter] public bool IsLoading { get; set; }

    private static readonly CuratedNodeTimeSeriesMode[] _availableModes =
    [
        CuratedNodeTimeSeriesMode.Auto,
        CuratedNodeTimeSeriesMode.Raw15Min,
        CuratedNodeTimeSeriesMode.HourlyAverage,
        CuratedNodeTimeSeriesMode.DailyAverage
    ];

    private readonly string _chartElementId = $"facility-timeseries-{Guid.NewGuid():N}";
    private readonly string _baselineToggleId = $"facility-baseline-toggle-{Guid.NewGuid():N}";
    private string? _lastRenderedSignature;
    private bool _jsInteropUnavailable;

    private string PanelTitle => string.Equals(Data?.NodeKey, "selection_set", StringComparison.OrdinalIgnoreCase)
        ? "Aggregate time series"
        : "Single-node time series";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_jsInteropUnavailable)
        {
            return;
        }

        try
        {
            if (Data?.Points.Count > 0)
            {
                var signature = BuildRenderSignature(Data, OverlaySeries);

                if (!string.Equals(signature, _lastRenderedSignature, StringComparison.Ordinal))
                {
                    _lastRenderedSignature = signature;
                    await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.render", _chartElementId, BuildModel(Data, ShowBaselineOverlay, OverlaySeries, !ShowPanelTitle && !ShowStatusSummary));
                }
                else if (firstRender)
                {
                    await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.resize", _chartElementId);
                }
            }
            else
            {
                _lastRenderedSignature = null;
                await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.dispose", _chartElementId);
            }
        }
        catch (JSException)
        {
            _jsInteropUnavailable = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string BuildRenderSignature(
        CuratedNodeTimeSeriesResult data,
        IReadOnlyList<(CuratedNodeTimeSeriesResult Data, string SeriesName, bool IsPinned)>? overlaySeries)
    {
        var signatureParts = new List<string>
        {
            data.NodeKey,
            data.Title,
            data.Unit,
            data.YAxisLabel,
            data.SeriesSemantics.ToString(),
            data.UsesDerivedIntervalSeries.ToString(),
            data.Granularity.ToString(),
            data.RequestedMode.ToString(),
            data.BaselineOverlayAvailable.ToString(),
            ShowBaselineOverlay.ToString(),
            ComputeSeriesFingerprint(data).ToString(),
            ShowPanelTitle.ToString(),
            ShowStatusSummary.ToString()
        };

        foreach (var overlay in overlaySeries ?? [])
        {
            signatureParts.Add(overlay.Data.NodeKey);
            signatureParts.Add(overlay.SeriesName ?? string.Empty);
            signatureParts.Add(overlay.IsPinned.ToString());
            signatureParts.Add(ComputeSeriesFingerprint(overlay.Data).ToString());
        }

        return string.Join(':', signatureParts);
    }

    private static int ComputeSeriesFingerprint(CuratedNodeTimeSeriesResult? series)
    {
        if (series is null)
        {
            return 0;
        }

        var hash = new HashCode();
        hash.Add(series.NodeKey, StringComparer.Ordinal);
        hash.Add(series.Title, StringComparer.Ordinal);
        hash.Add(series.Unit, StringComparer.Ordinal);
        hash.Add(series.YAxisLabel, StringComparer.Ordinal);
        hash.Add(series.SeriesSemantics);
        hash.Add(series.UsesDerivedIntervalSeries);
        hash.Add(series.SeriesStatusMessage, StringComparer.Ordinal);
        hash.Add(series.Granularity);
        hash.Add(series.RequestedMode);
        hash.Add(series.BaselineOverlayRequested);
        hash.Add(series.BaselineOverlayAvailable);
        hash.Add(series.BaselineOverlayMessage, StringComparer.Ordinal);
        hash.Add(series.NoDataMessage, StringComparer.Ordinal);
        AppendPointsFingerprint(ref hash, series.Points);
        AppendPointsFingerprint(ref hash, series.BaselinePoints);
        return hash.ToHashCode();
    }

    private static void AppendPointsFingerprint(ref HashCode hash, IReadOnlyList<CuratedNodeTimeSeriesPoint> points)
    {
        hash.Add(points.Count);

        for (var index = 0; index < points.Count; index++)
        {
            var point = points[index];
            hash.Add(point.TimestampUtc.Ticks);
            hash.Add(BitConverter.DoubleToInt64Bits(point.Value));
        }
    }

    private async Task SelectModeAsync(CuratedNodeTimeSeriesMode mode)
    {
        if (SelectedMode == mode)
        {
            return;
        }

        if (SelectedModeChanged.HasDelegate)
        {
            await SelectedModeChanged.InvokeAsync(mode);
        }
    }

    private async Task OnBaselineOverlayChanged(ChangeEventArgs e)
    {
        var enabled = e.Value switch
        {
            bool value => value,
            string s => string.Equals(s, "true", StringComparison.OrdinalIgnoreCase) || string.Equals(s, "on", StringComparison.OrdinalIgnoreCase),
            _ => false
        };

        if (ShowBaselineOverlayChanged.HasDelegate)
        {
            await ShowBaselineOverlayChanged.InvokeAsync(enabled);
        }
    }

    private async Task DismissPinnedChipAsync(string nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey) || !HeaderPinnedChipDismissed.HasDelegate)
        {
            return;
        }

        await HeaderPinnedChipDismissed.InvokeAsync(nodeKey);
    }

    private static string GetModeShortLabel(CuratedNodeTimeSeriesMode mode)
    {
        return mode switch
        {
            CuratedNodeTimeSeriesMode.Auto => "Auto",
            CuratedNodeTimeSeriesMode.Raw15Min => "15min",
            CuratedNodeTimeSeriesMode.HourlyAverage => "Hourly",
            CuratedNodeTimeSeriesMode.DailyAverage => "Daily",
            _ => "Auto"
        };
    }

    private static string GetModeLabel(CuratedNodeTimeSeriesMode mode)
    {
        return mode switch
        {
            CuratedNodeTimeSeriesMode.Auto => "Auto (adaptive by interval length)",
            CuratedNodeTimeSeriesMode.Raw15Min => "15 min (manual override)",
            CuratedNodeTimeSeriesMode.HourlyAverage => "Hourly (manual override)",
            CuratedNodeTimeSeriesMode.DailyAverage => "Daily (manual override)",
            _ => "Auto (adaptive by interval length)"
        };
    }

    private static object BuildModel(
        CuratedNodeTimeSeriesResult data,
        bool showBaselineOverlay,
        IReadOnlyList<(CuratedNodeTimeSeriesResult Data, string SeriesName, bool IsPinned)>? overlaySeries,
        bool compactMode)
    {
        return new
        {
            title = data.Title,
            actualSeriesName = data.Title,
            baselineSeriesName = "Baseline reference",
            compact = compactMode,
            unit = data.Unit,
            yAxisLabel = data.YAxisLabel,
            points = data.Points.Select(p => new
            {
                timestampUtc = p.TimestampUtc,
                value = p.Value
            }).ToArray(),
            baselinePoints = (showBaselineOverlay ? data.BaselinePoints : []).Select(p => new
            {
                timestampUtc = p.TimestampUtc,
                value = p.Value
            }).ToArray(),
            overlaySeries = (overlaySeries ?? [])
                .Select(series => new
                {
                    seriesName = string.IsNullOrWhiteSpace(series.SeriesName) ? series.Data.Title : series.SeriesName,
                    pinned = series.IsPinned,
                    points = series.Data.Points.Select(p => new
                    {
                        timestampUtc = p.TimestampUtc,
                        value = p.Value
                    }).ToArray()
                })
                .ToArray()
        };
    }

    public async Task ResetZoomAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.resetZoom", _chartElementId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
    }

    public async Task ExportSnapshotAsync(string fileName)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.exportPng", _chartElementId, fileName);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("facilityTimeSeriesChart.dispose", _chartElementId);
        }
        catch (JSDisconnectedException)
        {
            // No-op: circuit is already disconnected.
        }
        catch (JSException)
        {
            // No-op: chart runtime may not be available.
        }
    }
}
