@inject IBuildingStateService StateService

@if (_device is not null)
{
    <div class="card mt-3 device-detail-panel">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>@_device.Name</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="OnClose">Zavřít</button>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">ID zařízení</dt>
                <dd class="col-sm-8"><code>@_device.Id</code></dd>

                <dt class="col-sm-4">Typ</dt>
                <dd class="col-sm-8">@GetTypeName(_device.Type)</dd>

                <dt class="col-sm-4">Místnost</dt>
                <dd class="col-sm-8">@_device.RoomId</dd>

                @if (_state is not null)
                {
                    @if (_state.NumericValue.HasValue)
                    {
                        <dt class="col-sm-4">Hodnota</dt>
                        <dd class="col-sm-8">@_state.NumericValue.Value.ToString("F2")</dd>
                    }

                    @if (_state.IsActive.HasValue)
                    {
                        <dt class="col-sm-4">Stav</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(_state.IsActive.Value ? "bg-success" : "bg-secondary")">
                                @(_state.IsActive.Value ? "Aktivní" : "Neaktivní")
                            </span>
                        </dd>
                    }

                    <dt class="col-sm-4">Alarm</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(_state.IsAlarm ? "bg-danger" : "bg-success")">
                            @(_state.IsAlarm ? "ALARM" : "Normální")
                        </span>
                    </dd>

                    <dt class="col-sm-4">Poslední aktualizace</dt>
                    <dd class="col-sm-8">@_state.Timestamp.ToString("HH:mm:ss")</dd>
                }
            </dl>
        </div>
    </div>

    @if (_device.Type == DeviceType.TemperatureSensor || _device.Type == DeviceType.HumiditySensor)
    {
        <div class="card mt-3">
            <div class="card-header">
                <strong>Historie hodnot</strong>
            </div>
            <div class="card-body">
                @if (_chartData != null && _chartData.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Čas</th>
                                <th>@GetUnitLabel()</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var point in _chartData)
                            {
                                <tr>
                                    <td>@point.FormattedTime</td>
                                    <td>@point.Value.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-muted">Nejsou dostupná historická data</div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter, EditorRequired]
    public string DeviceId { get; set; } = "";

    [Parameter]
    public EventCallback OnClose { get; set; }

    private Device? _device;
    private DeviceState? _state;
    private List<ChartDataPoint> _chartData = new();
    private string? _prevDeviceId;

    private sealed class ChartDataPoint
    {
        public string FormattedTime { get; set; } = "";
        public double Value { get; set; }
    }

    protected override void OnParametersSet()
    {
        _device = FindDevice(DeviceId);
        _state = StateService.GetDeviceState(DeviceId);

        // Aktualizuj chart data pokud Device změnil
        if (DeviceId != _prevDeviceId)
        {
            _prevDeviceId = DeviceId;
            UpdateChartData();
            StateHasChanged();
        }
    }

    private void UpdateChartData()
    {
        try
        {
            var newData = new List<ChartDataPoint>();

            if (_device?.Type == DeviceType.TemperatureSensor || _device?.Type == DeviceType.HumiditySensor)
            {
                var history = StateService.GetDeviceHistory(DeviceId).ToList();

                foreach (var record in history)
                {
                    newData.Add(new ChartDataPoint
                    {
                        FormattedTime = record.Timestamp.ToString("HH:mm"),
                        Value = record.Value
                    });
                }
            }

            _chartData = newData;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chart data error: {ex.Message}");
            _chartData = new List<ChartDataPoint>();
        }
    }

    private Device? FindDevice(string deviceId)
    {
        foreach (var floor in StateService.Building.Floors)
        foreach (var room in floor.Rooms)
        foreach (var device in room.Devices)
        {
            if (device.Id == deviceId) return device;
        }
        return null;
    }

    private string GetUnitLabel() => _device?.Type switch
    {
        DeviceType.TemperatureSensor => "Teplota (°C)",
        DeviceType.HumiditySensor    => "Vlhkost (%)",
        _                            => "Hodnota"
    };

    private static string GetTypeName(DeviceType type) => type switch
    {
        DeviceType.TemperatureSensor => "Teplotní senzor",
        DeviceType.HumiditySensor   => "Senzor vlhkosti",
        DeviceType.Light            => "Osvětlení",
        DeviceType.HVAC             => "Klimatizace",
        DeviceType.MotionSensor     => "Pohybový senzor",
        DeviceType.DoorSensor       => "Dveřní senzor",
        _                           => type.ToString()
    };
}
