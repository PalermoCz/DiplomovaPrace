@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Facility Workbench</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column nav-full pb-3">

        <hr class="text-white-50 mx-3 my-2" />
        <div class="px-3 text-info small text-uppercase fw-bold mb-1 mt-2">Hlavní produktový pohled</div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link border border-info rounded" href="facility" Match="NavLinkMatch.All" style="background-color: rgba(13, 202, 240, 0.1);">
                <span class="bi bi-diagram-2 text-info" aria-hidden="true"></span> Facility Schematic
            </NavLink>
        </div>

        <hr class="text-white-50 mx-3 my-2" />
        <div class="px-3 text-muted small text-uppercase fw-bold mb-1 mt-2">Data a správa</div>

        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link" href="import">
                <span class="bi bi-file-earmark-arrow-up" aria-hidden="true"></span> CSV Import
            </NavLink>
        </div>

        <div class="px-3 mt-2 mb-1 text-white-50 small">
            Legacy/reference stránky (dashboard, kpi, building, editor) jsou dostupné pouze přes přímou URL.
        </div>

    </nav>
</div>
