        }

        .facility-selector-label {
            display: none;
        }

        .facility-selector-value {
            font-size: 0.84rem;
        }

        .facility-alert-trigger {
            padding: 0.35rem 0.56rem;
            gap: 0.2rem;
        }

        .topbar-user-chip {
            max-width: 160px;
        }

        .topbar-signout-link,
        .topbar-signin-link {
            padding: 0.4rem 0.72rem;
        }
    }

    .facility-alert-trigger:hover {
        transform: translateY(-1px);
        border-color: rgba(245, 158, 11, 0.8);
        background: rgba(30, 41, 59, 0.92);
    }

    .facility-alert-trigger:focus-visible {
        outline: 2px solid #f59e0b;
        outline-offset: 2px;
    }

    .facility-badge-critical {
