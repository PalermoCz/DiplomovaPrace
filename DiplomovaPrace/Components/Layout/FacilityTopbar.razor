    .topbar-account-wrap {
        position: relative;
    }

    .topbar-account-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        max-width: 260px;
        min-width: 0;
        padding: 0.38rem 0.65rem;
        border-radius: 999px;
        font-size: 0.84rem;
        color: #e2e8f0;
