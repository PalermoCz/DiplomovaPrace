        outline-offset: 2px;
    }

    .topbar-account-icon {
        font-size: 1.05rem;
        color: #94a3b8;
        flex-shrink: 0;
    }

    .topbar-account-chevron {
        font-size: 0.72rem;
        color: #94a3b8;
        flex-shrink: 0;
    }

    .topbar-user-email {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
