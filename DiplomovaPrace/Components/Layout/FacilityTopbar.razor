@using DiplomovaPrace.Components.Editor
@using DiplomovaPrace.Persistence
@using DiplomovaPrace.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject FacilityMembersManagementService MembersManagementService
@inject IConfiguration Configuration
@inject IDbContextFactory<AppDbContext> DbFactory

@* Parameters for parent components to pass callbacks *@
@code { [Parameter] public EventCallback OnMembersClicked { get; set; } }

<header class="facility-topbar text-white d-flex align-items-center px-3 px-lg-4" style="height: 72px; box-shadow: 0 2px 8px rgba(2, 6, 23, 0.35); flex-shrink: 0; position: relative; z-index: 1050;">
    @* Left section: Branding & navigation *@
    <div class="d-flex align-items-center" style="flex: 1; min-width: 0;">
        <a class="facility-brand text-white text-decoration-none d-inline-flex align-items-center" href="/facility" title="Go to Facility Workbench">
            <span class="facility-brand-mark me-2">FW</span>
            <span class="d-flex flex-column">
                <span class="facility-brand-title">Facility Workbench</span>
                <span class="facility-brand-subtitle">Smart systems monitoring</span>
            </span>
        </a>
    </div>

    @* Center section: Facility selector *@
    <div class="d-flex justify-content-center align-items-center" style="flex: 1; min-width: 0;">
        <div class="position-relative">
            <button type="button"
                    class="facility-selector-trigger"
                    @onclick="ToggleFacilitySelector"
                    aria-expanded="@_isFacilitySelectorOpen"
                    title="Select active facility">
                <i class="bi bi-buildings facility-selector-icon"></i>
                <span class="d-flex flex-column text-center align-items-center flex-grow-1">
                    <span class="facility-selector-label">Active facility</span>
                    <span class="facility-selector-value">@CurrentFacilityName</span>
                </span>
                <i class="bi @( _isFacilitySelectorOpen ? "bi-chevron-up" : "bi-chevron-down") ms-2"></i>
            </button>

            @if (_isFacilitySelectorOpen)
            {
                <div class="card shadow border-0 position-absolute start-50 translate-middle-x mt-2" style="width: 320px; z-index: 1200;">
                    <div class="card-header bg-light py-2 d-flex align-items-center justify-content-between">
                        <span class="fw-semibold">Select facility</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CloseFacilitySelector">Close</button>
                    </div>
                    <div class="list-group list-group-flush">
                        <button type="button" class="list-group-item list-group-item-action active d-flex align-items-center justify-content-between" @onclick="OpenFacilityWorkspace">
                            <span>@CurrentFacilityName</span>
                            <i class="bi bi-check2-circle"></i>
                        </button>
                        <div class="list-group-item text-muted small d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Additional facilities will be available in a follow-up milestone.
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* Right section: Account & utility *@
    <div class="d-flex justify-content-end align-items-center gap-2" style="flex: 1; min-width: 0;">
        <AuthorizeView>
            <Authorized>
                <div class="account-actions">
                    @if (_showMembersButton)
                    {
                        <button type="button"
                                class="btn btn-sm topbar-members-btn"
                                @onclick="async () => await OnMembersClicked.InvokeAsync()"
                                title="Manage facility members"
                                aria-label="Manage facility members">
                            <i class="bi bi-people me-1"></i>
                            Members
                        </button>
                    }

                    @* Account menu chip *@
                    <div class="topbar-account-wrap">
                        <button type="button"
                                class="topbar-account-btn"
                                @onclick="ToggleAccountMenu"
                                title="Account"
                                aria-haspopup="true"
                                aria-expanded="@_isAccountMenuOpen">
                            <i class="bi bi-person-circle topbar-account-icon" aria-hidden="true"></i>
                            <span class="topbar-user-email">
                                @context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                            </span>
                            <i class="bi @(_isAccountMenuOpen ? "bi-chevron-up" : "bi-chevron-down") topbar-account-chevron" aria-hidden="true"></i>
                        </button>

                        @if (_isAccountMenuOpen)
                        {
                            <div class="topbar-account-dropdown" role="menu">
                                <div class="topbar-account-email-header">
                                    <i class="bi bi-person-circle me-2"></i>
                                    @context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                                </div>
                                <div class="topbar-account-divider"></div>
                                <a class="topbar-account-item" href="/change-password" role="menuitem">
                                    <i class="bi bi-key me-2"></i>
                                    Change password
                                </a>
                                <div class="topbar-account-divider"></div>
                                <a class="topbar-account-item topbar-account-item--danger" href="/logout" role="menuitem">
                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    Sign out
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="topbar-signin-link">
                    Sign in
                </a>
            </NotAuthorized>
        </AuthorizeView>
        @* Reserved for future utility buttons *@
        <div id="facility-toolbar-portal-right"></div>
    </div>
</header>

@code {
    private bool _isFacilitySelectorOpen;
    private bool _isAccountMenuOpen;
    private bool _showMembersButton;
    private string CurrentFacilityName => "Smart Company Facility";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState?.User?.Identity?.IsAuthenticated == true)
            {
                var userIdClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (int.TryParse(userIdClaim, out var userId))
                {
                    var activeFacilityName = Configuration["Facility:ActiveFacilityName"] ?? "Smart Company Facility";

                    await using var db = await DbFactory.CreateDbContextAsync();
                    var facilityId = await db.Facilities
                        .Where(f => f.Name == activeFacilityName)
                        .Select(f => (int?)f.Id)
                        .FirstOrDefaultAsync();

                    if (facilityId.HasValue)
                    {
                        _showMembersButton = await MembersManagementService.IsUserOwnerOrAdminAsync(facilityId.Value, userId);
                    }
                }
            }
        }
        catch
        {
            _showMembersButton = false;
        }
    }

    private void ToggleFacilitySelector()
    {
        _isFacilitySelectorOpen = !_isFacilitySelectorOpen;
        _isAccountMenuOpen = false;
    }

    private void CloseFacilitySelector()
    {
        _isFacilitySelectorOpen = false;
    }

    private void ToggleAccountMenu()
    {
        _isAccountMenuOpen = !_isAccountMenuOpen;
        _isFacilitySelectorOpen = false;
    }

    private void OpenFacilityWorkspace()
    {
        _isFacilitySelectorOpen = false;

        if (!Navigation.Uri.Contains("/facility", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/facility");
        }
    }

}

<style>
