        padding: 0.38rem 0.55rem;
    }

    .facility-badge-elevated {
        background: #facc15;
        color: #1f2937;
        font-size: 0.78rem;
        padding: 0.38rem 0.55rem;
    }

    .facility-badge-critical-pulse {
        animation: facilityCriticalPulse 1.1s ease-in-out 2;
    }

    @@keyframes facilityCriticalPulse {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.55); }
        40% { transform: scale(1.07); box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
