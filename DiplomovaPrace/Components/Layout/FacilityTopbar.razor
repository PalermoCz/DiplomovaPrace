        overflow: hidden;
        animation: accountMenuIn 0.14s ease;
    }

    @@keyframes accountMenuIn {
        from { opacity: 0; transform: translateY(-6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .topbar-account-email-header {
        padding: 0.7rem 1rem;
        font-size: 0.8rem;
        color: #94a3b8;
        font-weight: 500;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .topbar-account-divider {
        height: 1px;
        background: rgba(148, 163, 184, 0.18);
    }

    .topbar-account-item {
        display: flex;
        align-items: center;
        padding: 0.65rem 1rem;
        font-size: 0.875rem;
        color: #e2e8f0;
        text-decoration: none;
        transition: background 0.12s ease;
        cursor: pointer;
    }

    .topbar-account-item:hover {
        background: rgba(148, 163, 184, 0.12);
        color: #f1f5f9;
    }

    .topbar-account-item--danger {
        color: #fca5a5;
    }

    .topbar-account-item--danger:hover {
        background: rgba(220, 38, 38, 0.15);
