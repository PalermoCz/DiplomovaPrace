        min-width: 0;
        padding: 0.38rem 0.6rem;
        border-radius: 999px;
        font-size: 0.84rem;
        color: #e2e8f0;
        background: rgba(148, 163, 184, 0.14);
        border: 1px solid rgba(148, 163, 184, 0.33);
