        z-index: 2;
        pointer-events: auto;
        border: 1px solid rgba(251, 191, 36, 0.5);
        background: rgba(17, 24, 39, 0.75);
        color: #f8fafc;
        border-radius: 12px;
        padding: 0.45rem 0.75rem;
        min-height: 42px;
        cursor: pointer;
        transition: all 0.16s ease;
        box-shadow: 0 6px 16px rgba(2, 6, 23, 0.28);
