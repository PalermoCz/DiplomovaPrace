@page "/editor"
@rendermode InteractiveServer
@inject IBuildingConfigurationService ConfigService
@inject IEditorSessionService SessionService
@inject IBuildingStateService StateService
@inject IActiveBuildingService ActiveBuildingService
@inject NavigationManager Nav
@inject FacilityQueryService FacilityQueryService
@inject NodeAnalyticsPreviewService AnalyticsPreview
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Editor budov</PageTitle>

@* Skrytý input pro import souboru *@
<InputFile id="import-file-input"
           style="display:none"
           accept=".json"
           OnChange="HandleImportFileSelected" />

<div class="editor-page">

    @* ── Toolbar ─────────────────────────────────────────────────────────── *@
    <EditorToolbar ActiveTool="@SessionService.ActiveTool"
                   HasUnsavedChanges="@SessionService.HasUnsavedChanges"
                   ShowGrid="@_showGrid"
                   CanAddFloor="@(SessionService.CurrentConfig is not null)"
                   CanApply="@(SessionService.CurrentConfig is not null)"
                   CanUndo="@SessionService.CanUndo"
                   CanRedo="@SessionService.CanRedo"
                   UndoDescription="@SessionService.UndoDescription"
                   RedoDescription="@SessionService.RedoDescription"
                   ValidationErrorCount="@_validationErrorCount"
                   PublicationState="@SessionService.PublicationState"
                   OnToolChanged="HandleToolChanged"
                   OnNewBuilding="HandleNewBuilding"
                   OnAddFloor="HandleAddFloor"
                   OnGridToggled="() => _showGrid = !_showGrid"
                   OnResetView="HandleResetView"
                   OnApplyToVisualization="HandleApplyToVisualization"
                   OnUndo="HandleUndo"
                   OnRedo="HandleRedo"
                   OnExport="HandleExport"
                   OnImportClicked="HandleImportClicked" />

    <div class="editor-main">

        @* ── Stromová navigace ─────────────────────────────────────────── *@
        <EditorTreeNav Config="@SessionService.CurrentConfig"
                       ActiveFloorId="@SessionService.ActiveFloorId"
                       SelectedElementId="@SessionService.SelectedElementId"
                       SelectedElementType="@SessionService.SelectedElementType"
                       OnFloorSelected="HandleFloorSelected"
                       OnElementSelected="HandleElementSelected"
                       OnAddFloor="HandleAddFloor"
                       OnDeleteFloor="HandleDeleteFloor" />

        @* ── Canvas ───────────────────────────────────────────────────── *@
        <div class="editor-canvas-wrapper">
            @if (SessionService.CurrentConfig is null && _facility is null)
            {
                <div class="editor-empty-state">
                    <div style="font-size:3rem; opacity:0.25;">&#9633;</div>
                    <p class="mb-0">Žádná data nejsou načtena.</p>
                </div>
            }
            else
            {
                <EditorCanvas @ref="_canvas"
                              Facility="_facility"
                              Floor="@SessionService.GetActiveFloor()"
                              ActiveTool="@SessionService.ActiveTool"
                              SelectedElementId="@SessionService.SelectedElementId"
                              ShowGrid="@_showGrid"
                              ValidationIssues="@_validationIssues"
                              OnRoomCreated="HandleRoomCreated"
                              OnDeviceMoved="HandleDeviceMoved"
                              OnElementSelected="HandleElementSelected"
                              OnCanvasClicked="HandleCanvasClicked"
                              OnDeleteRequested="HandleDeleteRequested"
                              OnKeyboardShortcut="HandleKeyboardShortcut" />
            }
        </div>

        @* ── Properties panel ───────────────────────────────────────── *@
        @if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _selectedFacilityNode is not null)
        {
            <div class="editor-properties" style="padding: 1rem; overflow-y: auto; background-color: white; border-left: 1px solid #e2e8f0; width: 320px;">
                <h5 class="mb-3">Detail uzlu</h5>
                
                <div class="mb-3">
                    <label class="form-label text-muted mb-0" style="font-size: 0.8rem;">Název</label>
                    <div class="fw-bold">@_selectedFacilityNode.Label</div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted mb-0" style="font-size: 0.8rem;">NodeKey</label>
                    <div><code style="color: #64748b;">@_selectedFacilityNode.NodeKey</code></div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted mb-0" style="font-size: 0.8rem;">TypUzlu & Zóna</label>
                    <div>@(_selectedFacilityNode.NodeType ?? "Neznámý") @(string.IsNullOrEmpty(_selectedFacilityNode.Zone) ? "" : $" ({_selectedFacilityNode.Zone})")</div>
                </div>

                <hr />

                <h6 class="mb-2">Analytický stav</h6>
                @if (_isCuratedNode)
                {
                    <div class="mb-2"><span class="badge bg-info">Facility-level / Curated Node</span></div>
                    
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span> Načítám curated data...</div>
                    }
                    else if (_curatedPreviewData != null)
                    {
                        <div class="card bg-light border-0 shadow-sm mb-3">
                            <div class="card-body py-2 px-3">
                                <div style="font-size: 0.85rem;" class="text-muted text-uppercase mb-1">@_curatedPreviewData.Title</div>
                                <div class="fs-5 fw-bold text-dark">
                                    @if (IsWeatherContextNode(_selectedFacilityNode))
                                    {
                                        @(_curatedPreviewData.Average.ToString("N1")) <span style="font-size: 0.9rem; font-weight: normal; color: #64748b;">°C (průměr)</span>
                                    }
                                    else
                                    {
                                        @(_curatedPreviewData.TotalSum.ToString("N0")) <span style="font-size: 0.9rem; font-weight: normal; color: #64748b;">@_curatedPreviewData.Unit</span>
                                    }
                                </div>
                                <div style="font-size: 0.85rem;" class="mt-1 text-muted">
                                    Zpracováno @_curatedPreviewData.DataPoints.ToString("N0") záznamů
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2" style="font-size: 0.9rem;">
                            Pro tento high-level systém (<strong>@_selectedFacilityNode?.NodeKey</strong>) aktuálně není k dispozici reálný curated CSV dataset, takže data nebylo možné načíst.
                        </div>
                    }
                }
                else if (string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn))
                {
                    <div class="alert alert-secondary py-2" style="font-size: 0.9rem;">
                        Tento uzel je čistě strukturální (nemá přiřazený Meter URN). Analytická data zde nejsou očekávána.
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label text-muted mb-0" style="font-size: 0.8rem;">Meter URN</label>
                        <div style="word-break: break-all; font-size: 0.85rem;"><code style="color: #0369a1;">@_selectedFacilityNode.MeterUrn</code></div>
                    </div>

                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span> Načítám analytiku...</div>
                    }
                    else if (_nodePreviewData is not null)
                    {
                        <div class="card bg-light border-0 shadow-sm mb-3">
                            <div class="card-body py-2 px-3">
                                <div style="font-size: 0.85rem;" class="text-muted text-uppercase mb-1">Spotřeba (2020)</div>
                                <div class="fs-5 fw-bold text-dark">
                                    @(_nodePreviewData.TotalConsumptionKWh?.ToString("N0") ?? "0") <span style="font-size: 0.9rem; font-weight: normal; color: #64748b;">kWh</span>
                                </div>
                                <div style="font-size: 0.85rem;" class="mt-1 text-muted">
                                    Průměrný výkon: @(_nodePreviewData.AveragePowerKW?.ToString("N2") ?? "0") kW
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2" style="font-size: 0.9rem;">
                            Pro tento uzel (<strong style="word-break: break-all;">@_selectedFacilityNode.MeterUrn</strong>) zatím nejsou v aplikaci napojená historická data pro rok 2020.
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <EditorPropertiesPanel Config="@SessionService.CurrentConfig"
                                   SelectedElementId="@SessionService.SelectedElementId"
                                   SelectedElementType="@SessionService.SelectedElementType"
                                   ActiveFloor="@SessionService.GetActiveFloor()"
                                   ValidationIssues="@_validationIssues"
                                   OnUpdateBuilding="HandleUpdateBuilding"
                                   OnUpdateFloor="HandleUpdateFloor"
                                   OnUpdateRoomName="HandleUpdateRoomName"
                                   OnUpdateDevice="HandleUpdateDevice"
                                   OnDeleteRoom="HandleDeleteRoom"
                                   OnDeleteDevice="HandleDeleteDevice" />
        }

    </div>
</div>

@* Modální dialog pro název nové budovy *@
@if (_showNewBuildingDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title mb-0">Nová budova</h6>
                </div>
                <div class="modal-body py-2">
                    <input class="form-control form-control-sm"
                           placeholder="Název budovy"
                           @bind="_newBuildingName"
                           @onkeydown="HandleNewBuildingKeyDown" />
                </div>
                <div class="modal-footer py-1">
                    <button class="btn btn-sm btn-secondary" @onclick="() => _showNewBuildingDialog = false">Zrušit</button>
                    <button class="btn btn-sm btn-primary" @onclick="ConfirmNewBuilding">Vytvořit</button>
                </div>
            </div>
        </div>
    </div>
}

@* Modální dialog pro název nového patra *@
@if (_showNewFloorDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title mb-0">Nové patro</h6>
                </div>
                <div class="modal-body py-2">
                    <input class="form-control form-control-sm mb-2"
                           placeholder="Název patra (např. Přízemí)"
                           @bind="_newFloorName"
                           @onkeydown="HandleNewFloorKeyDown" />
                    <input type="number" class="form-control form-control-sm"
                           placeholder="Číslo patra (0 = přízemí)"
                           @bind="_newFloorLevel" />
                </div>
                <div class="modal-footer py-1">
                    <button class="btn btn-sm btn-secondary" @onclick="() => _showNewFloorDialog = false">Zrušit</button>
                    <button class="btn btn-sm btn-primary" @onclick="ConfirmNewFloor">Přidat</button>
                </div>
            </div>
        </div>
    </div>
}

@* Toast notifikace *@
@if (_toastMessage is not null)
{
    <div class="toast show position-fixed bottom-0 end-0 m-3"
         style="z-index:9999; min-width:220px;"
         role="alert">
        <div class="toast-body py-2 px-3 @(_toastIsSuccess ? "bg-success text-white" : "bg-danger text-white")"
             style="border-radius:6px;">
            @_toastMessage
        </div>
    </div>
}

@code {
    private EditorCanvas? _canvas;
    private bool _showGrid = true;
    private DiplomovaPrace.Persistence.Schematic.FacilityEntity? _facility;
    
    // Facility Node State
    private DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity? _selectedFacilityNode;
    private DiplomovaPrace.Models.Kpi.MeterKpiResult? _nodePreviewData;
    private CuratedNodeSummary? _curatedPreviewData;
    private bool _isPreviewLoading;
    private bool _isCuratedNode;

    // Validace
    private IReadOnlyList<ValidationIssue> _validationIssues = [];
    private int _validationErrorCount;

    // Dialogy
    private bool _showNewBuildingDialog;
    private string _newBuildingName = "Nová budova";
    private bool _showNewFloorDialog;
    private string _newFloorName = "Přízemí";
    private int _newFloorLevel;

    // Toast
    private string? _toastMessage;
    private bool _toastIsSuccess;
    private System.Threading.CancellationTokenSource? _toastCts;

    // Navigation guard
    private IDisposable? _navGuard;

    // ── Inicializace ──────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _facility = await FacilityQueryService.GetMainFacilityAsync();

        SessionService.OnSessionChanged += HandleSessionChanged;
        ActiveBuildingService.OnActiveBuildingChanged += HandleActiveBuildingChanged;

        // Navigation guard — varuj při neuložených změnách
        _navGuard = Nav.RegisterLocationChangingHandler(async ctx =>
        {
            if (SessionService.HasUnsavedChanges)
            {
                var confirmed = await JSRuntime.InvokeAsync<bool>(
                    "confirm",
                    "Máte neuložené změny. Opravdu chcete opustit editor?");
                if (!confirmed)
                    ctx.PreventNavigation();
            }
        });

        // Načti aktivní budovu (nebo první z kolekce)
        var activeId = ActiveBuildingService.ActiveBuildingId;
        if (activeId is not null)
        {
            var config = await ConfigService.GetBuildingAsync(activeId);
            if (config is not null)
                SessionService.LoadConfig(config);
        }
        else
        {
            var buildings = await ConfigService.GetAllBuildingsAsync();
            if (buildings.Count > 0)
            {
                SessionService.LoadConfig(buildings[0]);
                ActiveBuildingService.SetActiveBuilding(buildings[0].Id);
            }
        }

        RevalidateCurrentFloor();
    }

    private async void HandleSessionChanged()
    {
        RevalidateCurrentFloor();
        
        // Handling FacilityNode selection
        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _facility != null)
        {
            var selectedNodeId = SessionService.SelectedElementId;
            if (_selectedFacilityNode?.NodeKey != selectedNodeId)
            {
                _selectedFacilityNode = _facility.Nodes.FirstOrDefault(n => n.NodeKey == selectedNodeId);
                _nodePreviewData = null;
                _curatedPreviewData = null;
                _isCuratedNode = false;
                
                if (_selectedFacilityNode != null)
                {
                    _isCuratedNode = IsCuratedAnalyticsNode(_selectedFacilityNode);

                    if (_isCuratedNode || !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn))
                    {
                        _isPreviewLoading = true;
                        await InvokeAsync(StateHasChanged);
                        
                        try
                        {
                            var from = new DateTime(2020, 1, 1, 0, 0, 0, DateTimeKind.Utc);
                            var to = new DateTime(2021, 1, 1, 0, 0, 0, DateTimeKind.Utc);
                            if (_isCuratedNode)
                            {
                                _curatedPreviewData = await AnalyticsPreview.GetCuratedSummaryAsync(_selectedFacilityNode.NodeKey, from, to);
                            }
                            else
                            {
                                var meterUrn = _selectedFacilityNode.MeterUrn;
                                if (!string.IsNullOrEmpty(meterUrn))
                                {
                                    _nodePreviewData = await AnalyticsPreview.GetPreviewDataAsync(meterUrn, from, to);
                                }
                            }
                        }
                        finally
                        {
                            _isPreviewLoading = false;
                        }
                    }
                }
            }
        }
        else
        {
            _selectedFacilityNode = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private static bool IsWeatherContextNode(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity? node)
        => node is not null && FacilityNodeSemantics.IsWeatherContextNode(node.NodeKey, node.NodeType);

    private static bool IsCuratedAnalyticsNode(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity node)
    {
        return node.NodeKey is "pv_main" or "chp_main" or "cooling_main" or "heating_main"
            || FacilityNodeSemantics.IsWeatherContextNode(node.NodeKey, node.NodeType);
    }

    private async void HandleActiveBuildingChanged()
    {
        var activeId = ActiveBuildingService.ActiveBuildingId;
        if (activeId is null) return;
        var config = await ConfigService.GetBuildingAsync(activeId);
        if (config is null) return;
        SessionService.LoadConfig(config);
        await InvokeAsync(StateHasChanged);
    }

    private void RevalidateCurrentFloor()
    {
        var floor = SessionService.GetActiveFloor();
        if (floor is not null)
        {
            _validationIssues = BuildingValidator.ValidateFloor(floor);
            _validationErrorCount = _validationIssues.Count(i => i.Type == IssueType.Error);
        }
        else
        {
            _validationIssues = [];
            _validationErrorCount = 0;
        }
    }

    // ── Toolbar akce ──────────────────────────────────────────────────────

    private void HandleToolChanged(EditorTool tool) =>
        SessionService.SetActiveTool(tool);

    private async Task HandleResetView()
    {
        if (_canvas is not null) await _canvas.ResetViewAsync();
    }

    private async Task HandleUndo() =>
        await SessionService.UndoAsync(ConfigService);

    private async Task HandleRedo() =>
        await SessionService.RedoAsync(ConfigService);

    // ── Klávesové zkratky z JS ───────────────────────────────────────────

    private async Task HandleKeyboardShortcut(string shortcut)
    {
        if (shortcut == "undo") await SessionService.UndoAsync(ConfigService);
        else if (shortcut == "redo") await SessionService.RedoAsync(ConfigService);
    }

    // ── Nová budova ───────────────────────────────────────────────────────

    private void HandleNewBuilding()
    {
        _newBuildingName = "Nová budova";
        _showNewBuildingDialog = true;
    }

    private async Task ConfirmNewBuilding()
    {
        _showNewBuildingDialog = false;
        if (string.IsNullOrWhiteSpace(_newBuildingName)) return;
        var config = await ConfigService.CreateBuildingAsync(_newBuildingName.Trim(), null, null);
        SessionService.LoadConfig(config);
        ShowToast("Budova vytvořena", success: true);
    }

    private async Task HandleNewBuildingKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConfirmNewBuilding();
        if (e.Key == "Escape") _showNewBuildingDialog = false;
    }

    // ── Patra ─────────────────────────────────────────────────────────────

    private void HandleAddFloor()
    {
        if (SessionService.CurrentConfig is null) return;
        var existingLevels = SessionService.CurrentConfig.Floors
            .Where(f => !f.IsDeleted).Select(f => f.Level);
        _newFloorLevel = existingLevels.Any() ? existingLevels.Max() + 1 : 0;
        _newFloorName  = _newFloorLevel == 0 ? "Přízemí" : _newFloorLevel + ". patro";
        _showNewFloorDialog = true;
    }

    private async Task ConfirmNewFloor()
    {
        _showNewFloorDialog = false;
        if (SessionService.CurrentConfig is null) return;
        if (string.IsNullOrWhiteSpace(_newFloorName)) return;
        var buildingId = SessionService.CurrentConfig.Id;
        var name = _newFloorName.Trim();
        var level = _newFloorLevel;
        FloorConfig? floor = null;
        await SessionService.ExecuteCommandAsync(
            new AddFloorCommand(name),
            async () => { floor = await ConfigService.AddFloorAsync(buildingId, name, level); },
            ConfigService);
        if (floor is not null)
        {
            SessionService.SelectFloor(floor.Id);
            SessionService.SelectElement(floor.Id, EditorSelectionType.Floor);
        }
        ShowToast("Patro přidáno", success: true);
    }

    private async Task HandleNewFloorKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConfirmNewFloor();
        if (e.Key == "Escape") _showNewFloorDialog = false;
    }

    private Task HandleFloorSelected(string floorId)
    {
        SessionService.SelectFloor(floorId);
        return Task.CompletedTask;
    }

    private async Task HandleDeleteFloor(string floorId)
    {
        if (SessionService.CurrentConfig is null) return;
        var floor = SessionService.CurrentConfig.Floors.FirstOrDefault(f => f.Id == floorId);
        var floorName = floor?.Name ?? floorId;
        var buildingId = SessionService.CurrentConfig.Id;
        await SessionService.ExecuteCommandAsync(
            new DeleteFloorCommand(floorName),
            () => ConfigService.DeleteFloorAsync(buildingId, floorId),
            ConfigService);
        ShowToast("Patro smazáno", success: true);
    }

    // ── Element selection ─────────────────────────────────────────────────

    private void HandleElementSelected((string Id, EditorSelectionType Type) args)
    {
        if (string.IsNullOrEmpty(args.Id))
            SessionService.ClearSelection();
        else
            SessionService.SelectElement(args.Id, args.Type);
    }

    // ── Canvas: přidání místnosti (rubber-band) ───────────────────────────

    private async Task HandleRoomCreated(RoomGeometry geometry)
    {
        if (SessionService.ActiveFloorId is null) return;
        var floorId = SessionService.ActiveFloorId;
        RoomConfig? room = null;
        await SessionService.ExecuteCommandAsync(
            new AddRoomCommand("Nová místnost"),
            async () => { room = await ConfigService.AddRoomAsync(floorId, "Nová místnost", geometry); },
            ConfigService);
        if (room is not null)
        {
            SessionService.SelectElement(room.Id, EditorSelectionType.Room);
            SessionService.SetActiveTool(EditorTool.Select);
        }
        ShowToast("Místnost přidána — upravte název v panelu vpravo", success: true);
    }

    // ── Canvas: klik v AddDevice módu ────────────────────────────────────

    private async Task HandleCanvasClicked((double X, double Y) pos)
    {
        var floor = SessionService.GetActiveFloor();
        if (floor is null) return;

        var room = floor.Rooms.FirstOrDefault(r =>
            !r.IsDeleted &&
            pos.X >= r.Geometry.X && pos.X <= r.Geometry.X + r.Geometry.Width &&
            pos.Y >= r.Geometry.Y && pos.Y <= r.Geometry.Y + r.Geometry.Height);

        if (room is null)
        {
            ShowToast("Klikněte uvnitř místnosti pro přidání zařízení", success: false);
            return;
        }

        var roomId = room.Id;
        DeviceConfig? device = null;
        await SessionService.ExecuteCommandAsync(
            new AddDeviceCommand("Nové zařízení"),
            async () =>
            {
                device = await ConfigService.AddDeviceAsync(
                    roomId, "Nové zařízení", DeviceType.EnergyMeter,
                    new DevicePosition(pos.X, pos.Y));
            },
            ConfigService);
        if (device is not null)
        {
            SessionService.SelectElement(device.Id, EditorSelectionType.Device);
            SessionService.SetActiveTool(EditorTool.Select);
        }
        ShowToast("Zařízení přidáno — nastavte vlastnosti v panelu vpravo", success: true);
    }

    // ── Drag & Drop zařízení ──────────────────────────────────────────────

    private async Task HandleDeviceMoved((string DeviceId, DevicePosition Pos) args)
    {
        var device = SessionService.FindDevice(args.DeviceId);
        var name = device?.Name ?? args.DeviceId;
        await SessionService.ExecuteCommandAsync(
            new MoveDeviceCommand(name),
            () => ConfigService.UpdateDevicePositionAsync(args.DeviceId, args.Pos),
            ConfigService);
    }

    // ── Delete (z canvasu nebo properties) ───────────────────────────────

    private async Task HandleDeleteRequested((string Id, EditorSelectionType Type) args)
    {
        switch (args.Type)
        {
            case EditorSelectionType.Room:   await HandleDeleteRoom(args.Id); break;
            case EditorSelectionType.Device: await HandleDeleteDevice(args.Id); break;
        }
    }

    private async Task HandleDeleteRoom(string roomId)
    {
        var room = SessionService.FindRoom(roomId);
        var name = room?.Name ?? roomId;
        await SessionService.ExecuteCommandAsync(
            new DeleteRoomCommand(name),
            () => ConfigService.DeleteRoomAsync(roomId),
            ConfigService);
        SessionService.ClearSelection();
        ShowToast("Místnost smazána", success: true);
    }

    private async Task HandleDeleteDevice(string deviceId)
    {
        var device = SessionService.FindDevice(deviceId);
        var name = device?.Name ?? deviceId;
        await SessionService.ExecuteCommandAsync(
            new DeleteDeviceCommand(name),
            () => ConfigService.DeleteDeviceAsync(deviceId),
            ConfigService);
        SessionService.ClearSelection();
        ShowToast("Zařízení smazáno", success: true);
    }

    // ── Properties panel — uložení změn ──────────────────────────────────

    private async Task HandleUpdateBuilding((string Name, string? Description, string? Address, FacilityMetadata? Metadata) args)
    {
        if (SessionService.CurrentConfig is null) return;
        var id = SessionService.CurrentConfig.Id;
        await SessionService.ExecuteCommandAsync(
            new UpdateBuildingCommand(args.Name),
            () => ConfigService.UpdateBuildingMetadataAsync(id, args.Name, args.Description, args.Address, args.Metadata),
            ConfigService);
        ShowToast("Budova uložena", success: true);
    }

    private async Task HandleUpdateFloor((string Name, int Level, double Width, double Height) args)
    {
        if (SessionService.CurrentConfig is null || SessionService.ActiveFloorId is null) return;
        var buildingId = SessionService.CurrentConfig.Id;
        var floorId = SessionService.ActiveFloorId;
        await SessionService.ExecuteCommandAsync(
            new UpdateFloorCommand(args.Name),
            async () =>
            {
                await ConfigService.UpdateFloorAsync(buildingId, floorId, args.Name, args.Level);
                await ConfigService.UpdateFloorDimensionsAsync(buildingId, floorId, args.Width, args.Height);
            },
            ConfigService);
        ShowToast("Patro uloženo", success: true);
    }

    private async Task HandleUpdateRoomName(RoomConfig updated)
    {
        if (SessionService.SelectedElementId is null) return;
        var roomId = SessionService.SelectedElementId;
        await SessionService.ExecuteCommandAsync(
            new UpdateRoomCommand(updated.Name),
            async () =>
            {
                await ConfigService.UpdateRoomNameAsync(roomId, updated.Name);
                await ConfigService.UpdateRoomGeometryAsync(roomId, updated.Geometry);
                await ConfigService.UpdateRoomDisplayRulesAsync(roomId, updated.DisplayRules);
            },
            ConfigService);
        ShowToast("Místnost uložena", success: true);
    }

    private async Task HandleUpdateDevice(DeviceConfig updated)
    {
        await SessionService.ExecuteCommandAsync(
            new UpdateDeviceCommand(updated.Name),
            () => ConfigService.UpdateDevicePropertiesAsync(
                updated.Id, updated.Name, updated.Type, updated.DisplaySettings, updated.Consumption, updated.DisplayRules),
            ConfigService);
        ShowToast("Zařízení uloženo", success: true);
    }

    // ── Publikace do runtime ──────────────────────────────────────────────

    private async Task HandleApplyToVisualization()
    {
        if (SessionService.CurrentConfig is null) return;

        // Blokovat při validačních chybách
        if (_validationErrorCount > 0)
        {
            ShowToast($"Publikace blokována — {_validationErrorCount} validačních chyb", success: false);
            return;
        }

        var domainBuilding = ConfigService.ToBuildingDomainModel(SessionService.CurrentConfig);
        StateService.ReplaceBuilding(domainBuilding);
        SessionService.MarkPublished();
        ShowToast("Konfigurace publikována do vizualizace (/building)", success: true);
    }

    // ── Export / Import ───────────────────────────────────────────────────

    private async Task HandleExport()
    {
        if (SessionService.CurrentConfig is null) return;
        var json = BuildingConfigSerializer.Serialize(SessionService.CurrentConfig);
        var filename = $"{SessionService.CurrentConfig.Name.Replace(' ', '_')}_config.json";
        await JSRuntime.InvokeVoidAsync("downloadTextFile", filename, json);
        ShowToast($"Export uložen: {filename}", success: true);
    }

    private async Task HandleImportClicked()
    {
        await JSRuntime.InvokeVoidAsync("triggerClick", "import-file-input");
    }

    private async Task HandleImportFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        if (file.Size > 2 * 1024 * 1024) // max 2 MB
        {
            ShowToast("Soubor je příliš velký (max 2 MB)", success: false);
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var config = BuildingConfigSerializer.Deserialize(json);
            if (config is null)
            {
                ShowToast("Neplatný formát souboru", success: false);
                return;
            }

            await SessionService.ExecuteCommandAsync(
                new ImportConfigCommand(),
                () => ConfigService.ReplaceConfigAsync(config),
                ConfigService);
            SessionService.LoadConfig(config);
            ShowToast($"Import úspěšný: {config.Name}", success: true);
        }
        catch
        {
            ShowToast("Chyba při čtení souboru", success: false);
        }
    }

    // ── Toast helper ──────────────────────────────────────────────────────

    private void ShowToast(string message, bool success)
    {
        _toastCts?.Cancel();
        _toastMessage   = message;
        _toastIsSuccess = success;
        _toastCts = new System.Threading.CancellationTokenSource();
        var token = _toastCts.Token;
        _ = Task.Delay(3500, token).ContinueWith(_ =>
        {
            if (token.IsCancellationRequested) return;
            _toastMessage = null;
            InvokeAsync(StateHasChanged);
        }, TaskScheduler.Default);
    }

    public void Dispose()
    {
        SessionService.OnSessionChanged -= HandleSessionChanged;
        ActiveBuildingService.OnActiveBuildingChanged -= HandleActiveBuildingChanged;
        _navGuard?.Dispose();
        _toastCts?.Cancel();
    }
}
