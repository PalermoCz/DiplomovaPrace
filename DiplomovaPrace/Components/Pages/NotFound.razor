@page "/not-found"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@layout DiplomovaPrace.Components.Layout.FacilityLayout

<PageTitle>Page not found</PageTitle>

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 70vh;">
    <h1 class="display-4 fw-bold text-secondary mb-3">Page not found</h1>
    <p class="text-muted mb-4 fs-5">The page you are looking for does not exist.</p>
    <a href="/facility" class="btn btn-primary px-4 py-2">
        <i class="bi bi-arrow-left me-2"></i>Back to facility
    </a>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", true);
        }
    }
}