        _styleSymbolInput = preset.Symbol;
        _styleSymbolColorInput = preset.SymbolColor;
        _styleLabelColorInput = preset.LabelColor;
        _styleLabelFontSizeInput = preset.LabelFontSize;
        _styleLabelFontWeightInput = preset.LabelFontWeight;
