@page "/"
@page "/facility"
@using DiplomovaPrace.Services
@using DiplomovaPrace.Components.Editor
@rendermode InteractiveServer
@inject FacilityQueryService FacilityQueryService
@inject NodeAnalyticsPreviewService AnalyticsPreview
@inject FacilityAlertSummaryService GlobalAlertSummaryService
@inject IEditorSessionService SessionService
@inject IJSRuntime JSRuntime
@layout DiplomovaPrace.Components.Layout.FacilityLayout
@implements IDisposable

<PageTitle>Facility Schematic</PageTitle>

@* Aplikujeme lokální styly pro flexibilitu okna *@
<style>
    .facility-workbench {
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: #f8fafc;
    }
    
    .facility-main {
        display: flex;
        flex: 1;
        overflow: hidden;
    }
    
    .facility-canvas-wrapper {
        flex: 1;
        position: relative;
        overflow: hidden;
    }
    
    .facility-properties {
        flex: 1;
        min-width: 0;
        background-color: #ffffff;
        padding: 1.5rem;
        overflow-y: auto;
        box-shadow: -2px 0 10px rgba(0,0,0,0.02);
    }
</style>

<div class="facility-workbench">
    @* ── Hlavní část ──────────────────────────────────────────────────── *@
    <div class="facility-main position-relative">
        
        @* Levá část: Canvas *@
        <div class="facility-canvas-wrapper @(_isSchematicHidden ? "d-none" : "d-flex flex-column")" style="border-right: 1px solid #e2e8f0;">
            <div class="bg-white border-bottom px-3 py-2 d-flex justify-content-between align-items-center" style="z-index: 10;">
                <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schéma</span>
                <button class="btn btn-sm btn-light border d-flex align-items-center text-secondary shadow-sm" @onclick="ReloadData">
                    <i class="bi bi-arrow-clockwise me-1"></i> Znovu načíst schéma
                </button>
            </div>
            
            <div class="flex-grow-1 position-relative">
                @if (_facility is null)
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                        <div class="spinner-border mb-3" role="status"></div>
                        <p class="mb-0">Načítám strukturní data...</p>
                    </div>
                }
                else
                {
                    <EditorCanvas @ref="_canvas"
                                  Facility="_facility"
                                  ActiveTool="@SessionService.ActiveTool"
                                  SelectedElementId="@SessionService.SelectedElementId"
                                  FacilityNodeAlertSeverities="@AlertSeverityByNodeKey"
                                  ShowGrid="false"
                                  OnElementSelected="HandleElementSelected"
                                  OnCanvasClicked="HandleCanvasClicked" />
                }
            </div>
        </div>
        
        @* Pravá část: Detail & Analytika *@
        @if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _selectedFacilityNode is not null)
        {
            <div class="facility-properties">
                <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
                    <h5 class="mb-0 fw-bold">Detail uzlu</h5>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center bg-light px-3 text-nowrap fw-medium" @onclick="ToggleSchematic">
                            <i class="bi @(_isSchematicHidden ? "bi-layout-split" : "bi-arrows-fullscreen") me-1"></i>
                            @(_isSchematicHidden ? "Zobrazit schéma" : "Maximalizovat detail")
                        </button>
                        <button class="btn btn-sm btn-light border shadow-sm text-secondary px-3 text-nowrap fw-medium" @onclick="ClosePanel" title="Zavřít detail uzlu">
                            <i class="bi bi-x-lg me-1"></i> Zavřít
                        </button>
                    </div>
                </div>
                
                <div class="card border-0 bg-light mb-4">
                    <div class="card-body p-3">
                        <div class="mb-3">
                            <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">Název sub-systému</label>
                            <div class="fw-bold fs-5 text-dark" style="line-height: 1.2;">@_selectedFacilityNode.Label</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">NodeKey</label>
                            <div><code style="color: #475569; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 0.85rem;">@_selectedFacilityNode.NodeKey</code></div>
                        </div>

                        <div>
                            <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">Typ Uzlu & Zóna</label>
                            <div>
                                <span class="badge border border-secondary text-secondary me-1">@(_selectedFacilityNode.NodeType ?? "Neznámý")</span>
                                @if (!string.IsNullOrEmpty(_selectedFacilityNode.Zone))
                                {
                                    <span class="badge bg-secondary">@_selectedFacilityNode.Zone</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <h6 class="mb-3 fw-bold border-bottom pb-2">Časový rozsah</h6>
                <div class="mb-4">
                    <select class="form-select bg-light fw-medium" @onchange="OnIntervalChanged" value="@_selectedInterval">
                        <option value="last24h">Posledních 24 hodin</option>
                        <option value="last7d">Posledních 7 dní</option>
                        <option value="last30d">Posledních 30 dní</option>
                        <option value="thisMonth">Tento měsíc</option>
                        <option value="custom">Vlastní rozsah</option>
                    </select>

                    @if (_selectedInterval == "custom")
                    {
                        <div class="row g-2 mt-2">
                            <div class="col-6">
                                <label class="form-label text-muted small mb-1">Od</label>
                                <input type="date" class="form-control bg-light" value="@CustomFromDateValue" @onchange="OnCustomFromChanged" />
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small mb-1">Do</label>
                                <input type="date" class="form-control bg-light" value="@CustomToDateValue" @onchange="OnCustomToChanged" />
                            </div>
                        </div>
                    }

                    <div class="mt-3 small text-muted">
                        <div>
                            <span class="fw-semibold text-dark">Vybraný interval:</span>
                            @DisplayIntervalFromTo
                        </div>
                        @if (ShowPresetAnchorNote)
                        {
                            <div class="mt-1">
                                Preset je ukotven k poslednímu dostupnému timestampu dat pro tento uzel.
                            </div>
                        }
                    </div>
                </div>

                <h6 class="mb-3 fw-bold border-bottom pb-2">Analytický souhrn</h6>
                
                @if (_isCuratedNode)
                {
                    <div class="mb-3">
                        <span class="badge bg-primary px-2 py-1"><i class="bi bi-star-fill me-1"></i> Facility-level / High-Level Systém</span>
                    </div>
                    
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Načítám data pro vybraný interval...
                        </div>
                    }
                    else if (_curatedPreviewData != null)
                    {
                        <div class="card border border-primary shadow-sm mb-3">
                            <div class="card-body p-3">
                                <div style="font-size: 0.85rem;" class="text-primary text-uppercase fw-bold mb-1">@_curatedPreviewData.Title</div>
                                <div class="fs-3 fw-bold text-dark mb-1" style="letter-spacing: -1px;">
                                    @if (_selectedFacilityNode?.NodeKey == "weather_main")
                                    {
                                        @(_curatedPreviewData.Average.ToString("N1")) <span style="font-size: 1.1rem; font-weight: normal; color: #64748b;">°C (průměr)</span>
                                    }
                                    else
                                    {
                                        @(_curatedPreviewData.TotalSum.ToString("N1")) <span style="font-size: 1.1rem; font-weight: normal; color: #64748b;">@_curatedPreviewData.Unit</span>
                                    }
                                </div>
                                @if (_selectedFacilityNode?.NodeKey != "weather_main")
                                {
                                    <div style="font-size: 0.85rem;" class="text-muted">@_curatedPreviewData.SummaryLabel</div>
                                }
                                <hr class="my-2 border-primary border-opacity-25" />
                                <div class="row text-center g-2 mt-1">
                                    <div class="col-4">
                                        <div class="text-muted small text-uppercase">Min</div>
                                        <div class="fw-bold" style="color: #0284c7;">@(_curatedPreviewData.Min.ToString("N1")) @_curatedPreviewData.StatsUnit</div>
                                    </div>
                                    <div class="col-4 border-start border-end">
                                        <div class="text-muted small text-uppercase">Průměr</div>
                                        <div class="fw-bold">@(_curatedPreviewData.Average.ToString("N1")) @_curatedPreviewData.StatsUnit</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="text-muted small text-uppercase">Max</div>
                                        <div class="fw-bold" style="color: #dc2626;">@(_curatedPreviewData.Max.ToString("N1")) @_curatedPreviewData.StatsUnit</div>
                                    </div>
                                </div>
                                <div style="font-size: 0.8rem;" class="text-muted d-flex align-items-center mt-3 justify-content-center">
                                    <i class="bi bi-info-circle me-1"></i> Vypočítáno ze @_curatedPreviewData.DataPoints.ToString("N0") vzorků
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-3 shadow-sm border-0 d-flex align-items-start" style="font-size: 0.9rem;">
                            <i class="bi bi-exclamation-triangle-fill text-warning fs-5 me-2"></i>
                            <div>
                                Pro tento high-level systém (<strong>@_selectedFacilityNode?.NodeKey</strong>) nejsou ve zvoleném období k dispozici žádná data.
                            </div>
                        </div>
                    }

                    <h6 class="mb-3 mt-4 fw-bold border-bottom pb-2">Deviation / Baseline</h6>

                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center mb-3">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Vyhodnocuji baseline a odchylku...
                        </div>
                    }
                    else if (_curatedDeviationData?.IsAvailable == true)
                    {
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <div class="text-muted text-uppercase fw-bold" style="font-size: 0.8rem;">Odchylka vůči baseline</div>
                                    <span class="badge @GetDeviationBadgeClass(_curatedDeviationData.Severity)">@GetDeviationBadgeText(_curatedDeviationData.Severity)</span>
                                </div>

                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="small text-muted text-uppercase">Aktuální hodnota</div>
                                        <div class="fw-bold">@(_curatedDeviationData.CurrentValue?.ToString("N1") ?? "N/A") @_curatedDeviationData.Unit</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="small text-muted text-uppercase">Baseline</div>
                                        <div class="fw-bold">@(_curatedDeviationData.BaselineValue?.ToString("N1") ?? "N/A") @_curatedDeviationData.Unit</div>
                                    </div>
                                    <div class="col-6 mt-2">
                                        <div class="small text-muted text-uppercase">Absolutní odchylka</div>
                                        <div class="fw-bold">@FormatSigned(_curatedDeviationData.DeltaAbsolute, "N1") @_curatedDeviationData.Unit</div>
                                    </div>
                                    <div class="col-6 mt-2">
                                        <div class="small text-muted text-uppercase">Relativní odchylka</div>
                                        <div class="fw-bold">@FormatSigned(_curatedDeviationData.DeltaPercent, "N1") %</div>
                                    </div>
                                </div>

                                <div class="small text-muted mt-3">
                                    <i class="bi bi-info-circle me-1"></i>
                                    @_curatedDeviationData.Methodology
                                </div>
                                <div class="small text-muted mt-1">
                                    Referenčních intervalů použito: @_curatedDeviationData.ReferenceIntervalsUsed
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary py-3 border-0 shadow-sm d-flex align-items-start" style="font-size: 0.9rem;">
                            <i class="bi bi-info-circle text-secondary fs-5 me-2"></i>
                            <div>
                                <div>@(_curatedDeviationData?.Message ?? "Baseline není pro tento uzel / interval zatím k dispozici.")</div>
                                @if (!string.IsNullOrWhiteSpace(_curatedDeviationData?.Methodology))
                                {
                                    <div class="small text-muted mt-1">@_curatedDeviationData.Methodology</div>
                                }
                            </div>
                        </div>
                    }

                    <h6 class="mb-3 mt-4 fw-bold border-bottom pb-2">Alert Foundation (v1)</h6>

                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center mb-3">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Vyhodnocuji alert stav uzlu...
                        </div>
                    }
                    else
                    {
                        var nodeKey = _selectedFacilityNode?.NodeKey;
                        var colorHint = GetSchematicAlertColorHint(nodeKey, _curatedDeviationData);

                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <div class="text-muted text-uppercase fw-bold" style="font-size: 0.8rem;">Aktuální alert stav uzlu</div>
                                    <span class="badge @GetAlertBadgeClass(nodeKey, _curatedDeviationData)">@GetAlertStatusText(nodeKey, _curatedDeviationData)</span>
                                </div>

                                <div class="small text-muted text-uppercase">Proč tento stav</div>
                                <div class="fw-semibold mt-1">@GetAlertReasonText(nodeKey, _curatedDeviationData)</div>

                                <div class="small text-muted text-uppercase mt-3">Zdroj logiky</div>
                                <div class="small mt-1">@GetAlertSourceText(nodeKey, _curatedDeviationData)</div>

                                <div class="small text-muted text-uppercase mt-3">Budoucí barva uzlu ve schématu (interní hint)</div>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <span class="badge border text-dark" style="background-color: @colorHint.Hex;">@colorHint.Token</span>
                                    <span class="small text-muted">@colorHint.Hex</span>
                                </div>

                                <div class="small text-muted mt-3">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Jde o první alert foundation navázaný na deviation/baseline. Nejde ještě o finální business alert engine.
                                </div>
                            </div>
                        </div>
                    }
                }
                else if (string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn))
                {
                    <div class="alert alert-secondary py-3 border-0 d-flex align-items-start" style="font-size: 0.9rem;">
                        <i class="bi bi-diagram-2 text-secondary fs-5 me-2"></i>
                        <div>
                            Tento uzel je čistě <strong>strukturální</strong> (např. budova, site, patro). Má pouze vizualizační / architektonickou roli a neměří žádná analytická data samotný.
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-3 mt-1">
                        <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">Měřitelný fyzický uzel</label>
                        <div style="word-break: break-all; font-size: 0.85rem;"><code style="color: #0369a1; background: #e0f2fe; padding: 2px 6px; border-radius: 4px;">@_selectedFacilityNode.MeterUrn</code></div>
                    </div>

                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Načítám data pro zvolený interval...
                        </div>
                    }
                    else if (_nodePreviewData is not null)
                    {
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body p-3">
                                <div style="font-size: 0.85rem;" class="text-muted text-uppercase mb-1 fw-bold">Spotřeba za interval</div>
                                <div class="fs-3 fw-bold text-dark mb-1" style="letter-spacing: -1px;">
                                    @(_nodePreviewData.TotalConsumptionKWh?.ToString("N0") ?? "0") <span style="font-size: 1.1rem; font-weight: normal; color: #64748b;">kWh</span>
                                </div>
                                <div style="font-size: 0.85rem;" class="text-muted">
                                    Průměrný výkon: <strong class="text-dark">@(_nodePreviewData.AveragePowerKW?.ToString("N2") ?? "0") kW</strong>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info py-3 border-0 shadow-sm d-flex align-items-start" style="font-size: 0.9rem;">
                            <i class="bi bi-info-circle-fill text-info fs-5 me-2"></i>
                            <div>
                                Tento uzel (<strong>@_selectedFacilityNode.MeterUrn</strong>) je měřitelný, ale momentálně pro něj není nahrána / namapována časová řada v reálné databázi pro zvolený interval.
                            </div>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <div class="facility-properties bg-light d-flex flex-column position-relative">
                <div class="d-flex align-items-center justify-content-end mb-4 pb-3 border-bottom">
                    <button class="btn btn-sm btn-outline-secondary d-flex align-items-center bg-white" @onclick="ToggleSchematic">
                        <i class="bi @(_isSchematicHidden ? "bi-layout-split" : "bi-arrows-fullscreen") me-1"></i>
                        @(_isSchematicHidden ? "Zobrazit schéma" : "Maximalizovat detail")
                    </button>
                </div>
                
                <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-center">
                    <i class="bi bi-cursor text-muted" style="font-size: 3rem; opacity: 0.5;"></i>
                    <h6 class="mt-3 text-muted">Aplikace je v režimu @(_isSchematicHidden ? "100% Detail" : "50% Schematic / 50% Detail")</h6>
                    <p class="text-muted small mb-0 px-3 mt-2">
                        Vyberte uzel ve schématu vlevo k zobrazení analytických dat.<br/>
                        @if (_isSchematicHidden)
                        {
                            <span class="text-primary mt-1 d-block"><i class="bi bi-info-circle me-1"></i>Schéma je aktuálně skryto. Použijte tlačítko 'Zobrazit schéma'.</span>
                        }
                    </p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private static readonly string[] EnergyAlertNodeKeys = ["pv_main", "chp_main", "cooling_main", "heating_main"];

    private EditorCanvas? _canvas;
    private DiplomovaPrace.Persistence.Schematic.FacilityEntity? _facility;
    
    // Facility Node State
    private DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity? _selectedFacilityNode;
    private DiplomovaPrace.Models.Kpi.MeterKpiResult? _nodePreviewData;
    private CuratedNodeSummary? _curatedPreviewData;
    private CuratedNodeDeviationSummary? _curatedDeviationData;
    private bool _isPreviewLoading;
    private bool _isCuratedNode;
    
    // UI State
    private bool _isSchematicHidden = false;
    private string _selectedInterval = "last7d";
    private DateTime _customFromUtc = DateTime.UtcNow.Date.AddDays(-7);
    private DateTime _customToUtcExclusive = DateTime.UtcNow.Date.AddDays(1);
    private DateTime _presetAnchorUtc = DateTime.UtcNow;

    private (DateTime From, DateTime To) GetInterval()
    {
        var anchor = _presetAnchorUtc;

        return _selectedInterval switch
        {
            "last24h" => (anchor.AddHours(-24), anchor),
            "last7d" => (anchor.AddDays(-7), anchor),
            "last30d" => (anchor.AddDays(-30), anchor),
            "thisMonth" => (new DateTime(anchor.Year, anchor.Month, 1, 0, 0, 0, DateTimeKind.Utc), anchor),
            "custom" => GetSafeCustomInterval(),
            _ => (anchor.AddDays(-7), anchor)
        };
    }

    private async Task RefreshPresetAnchorAsync()
    {
        if (_selectedFacilityNode is null)
        {
            _presetAnchorUtc = DateTime.UtcNow;
            return;
        }

        if (!_isCuratedNode)
        {
            _presetAnchorUtc = DateTime.UtcNow;
            return;
        }

        var maxTimestamp = await AnalyticsPreview.GetCuratedNodeMaxTimestampUtcAsync(_selectedFacilityNode.NodeKey);
        _presetAnchorUtc = maxTimestamp ?? DateTime.UtcNow;
    }

    private (DateTime From, DateTime To) GetSafeCustomInterval()
    {
        var from = _customFromUtc;
        var to = _customToUtcExclusive;

        if (to <= from)
        {
            to = from.AddDays(1);
        }

        return (from, to);
    }

    private string CustomFromDateValue => _customFromUtc.ToString("yyyy-MM-dd");

    private string CustomToDateValue => _customToUtcExclusive.AddDays(-1).ToString("yyyy-MM-dd");

    private string DisplayIntervalFromTo
    {
        get
        {
            var interval = GetInterval();
            return $"{interval.From.ToLocalTime():dd.MM.yyyy HH:mm} - {interval.To.ToLocalTime():dd.MM.yyyy HH:mm}";
        }
    }

    private bool ShowPresetAnchorNote => _isCuratedNode && _selectedInterval != "custom";

    private IReadOnlyDictionary<string, NodeDeviationSeverity> AlertSeverityByNodeKey =>
        GlobalAlertSummaryService.Current.AlertedNodes
            .ToDictionary(x => x.NodeKey, x => x.Severity, StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await ReloadData();
        SessionService.OnSessionChanged += HandleSessionChanged;
        // Výchozí nástroj pro prohlížení schématu
        SessionService.SetActiveTool(EditorTool.Select);
    }

    private async Task ReloadData()
    {
        _facility = await FacilityQueryService.GetMainFacilityAsync();
        SessionService.ClearSelection();
        await RefreshGlobalAlertSummaryAsync();
    }

    private async void HandleSessionChanged()
    {
        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _facility != null)
        {
            var selectedNodeId = SessionService.SelectedElementId;
            if (_selectedFacilityNode?.NodeKey != selectedNodeId)
            {
                _selectedFacilityNode = _facility.Nodes.FirstOrDefault(n => n.NodeKey == selectedNodeId);
                _nodePreviewData = null;
                _curatedPreviewData = null;
                _curatedDeviationData = null;
                _isCuratedNode = false;
                
                if (_selectedFacilityNode != null)
                {
                    _isCuratedNode = _selectedFacilityNode.NodeKey is "pv_main" or "chp_main" or "cooling_main" or "heating_main" or "weather_main";
                    await ReloadPreviewDataAsync();
                }
                else
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        else
        {
            _selectedFacilityNode = null;
            _nodePreviewData = null;
            _curatedPreviewData = null;
            _curatedDeviationData = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnIntervalChanged(ChangeEventArgs e)
    {
        if (e.Value is string s)
        {
            _selectedInterval = s;
            await ReloadPreviewDataAsync();
        }
    }

    private async Task OnCustomFromChanged(ChangeEventArgs e)
    {
        if (e.Value is not string raw || !DateTime.TryParse(raw, out var parsed))
        {
            return;
        }

        _customFromUtc = DateTime.SpecifyKind(parsed.Date, DateTimeKind.Utc);
        if (_customToUtcExclusive <= _customFromUtc)
        {
            _customToUtcExclusive = _customFromUtc.AddDays(1);
        }

        await ReloadPreviewDataAsync();
    }

    private async Task OnCustomToChanged(ChangeEventArgs e)
    {
        if (e.Value is not string raw || !DateTime.TryParse(raw, out var parsed))
        {
            return;
        }

        _customToUtcExclusive = DateTime.SpecifyKind(parsed.Date.AddDays(1), DateTimeKind.Utc);
        if (_customToUtcExclusive <= _customFromUtc)
        {
            _customToUtcExclusive = _customFromUtc.AddDays(1);
        }

        await ReloadPreviewDataAsync();
    }

    private async Task ReloadPreviewDataAsync()
    {
        if (_selectedFacilityNode != null && (_isCuratedNode || !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn)))
        {
            _isPreviewLoading = true;
            await InvokeAsync(StateHasChanged);
            
            try
            {
                await RefreshPresetAnchorAsync();
                var interval = GetInterval();
                if (_isCuratedNode)
                {
                    var summaryTask = AnalyticsPreview.GetCuratedSummaryAsync(_selectedFacilityNode.NodeKey, interval.From, interval.To);
                    var deviationTask = AnalyticsPreview.GetCuratedDeviationSummaryAsync(_selectedFacilityNode.NodeKey, interval.From, interval.To);

                    await Task.WhenAll(summaryTask, deviationTask);
                    _curatedPreviewData = summaryTask.Result;
                    _curatedDeviationData = deviationTask.Result;
                }
                else
                {
                    _curatedDeviationData = null;
                    _nodePreviewData = await AnalyticsPreview.GetPreviewDataAsync(_selectedFacilityNode.MeterUrn!, interval.From, interval.To);
                }
            }
            finally
            {
                _isPreviewLoading = false;
            }
        }

        await RefreshGlobalAlertSummaryAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshGlobalAlertSummaryAsync(CancellationToken ct = default)
    {
        try
        {
            // Global summary musí používat stejný aktuální analysis window jako detail/schéma.
            var interval = GetInterval();

            var deviationTasks = EnergyAlertNodeKeys.Select(async nodeKey =>
            {
                var deviation = await AnalyticsPreview.GetCuratedDeviationSummaryAsync(nodeKey, interval.From, interval.To, ct);
                return (NodeKey: nodeKey, Deviation: deviation);
            }).ToArray();

            await Task.WhenAll(deviationTasks);

            var labelByNodeKey = _facility?.Nodes
                .ToDictionary(n => n.NodeKey, n => n.Label, StringComparer.OrdinalIgnoreCase)
                ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            var facilityName = !string.IsNullOrWhiteSpace(_facility?.Name)
                ? _facility!.Name
                : "Smart Company Facility";

            var alertedNodes = new List<FacilityAlertNodeSummaryItem>();
            foreach (var task in deviationTasks)
            {
                var result = task.Result;
                if (result.Deviation.IsAvailable != true)
                {
                    continue;
                }

                if (result.Deviation.Severity is not (NodeDeviationSeverity.High or NodeDeviationSeverity.Elevated))
                {
                    continue;
                }

                alertedNodes.Add(new FacilityAlertNodeSummaryItem
                {
                    NodeKey = result.NodeKey,
                    Label = labelByNodeKey.TryGetValue(result.NodeKey, out var label) && !string.IsNullOrWhiteSpace(label)
                        ? label
                        : result.NodeKey,
                    FacilityName = facilityName,
                    Severity = result.Deviation.Severity!.Value
                });
            }

            var orderedNodes = alertedNodes
                .OrderByDescending(n => n.Severity)
                .ThenBy(n => n.Label, StringComparer.CurrentCulture)
                .ToList();

            GlobalAlertSummaryService.Update(new FacilityGlobalAlertSummary
            {
                HighCount = orderedNodes.Count(n => n.Severity == NodeDeviationSeverity.High),
                ElevatedCount = orderedNodes.Count(n => n.Severity == NodeDeviationSeverity.Elevated),
                ActiveFacilityName = facilityName,
                AlertedNodes = orderedNodes,
                UpdatedUtc = DateTime.UtcNow
            });
        }
        catch
        {
            GlobalAlertSummaryService.Update(new FacilityGlobalAlertSummary
            {
                HighCount = 0,
                ElevatedCount = 0,
                ActiveFacilityName = _facility?.Name ?? "Smart Company Facility",
                AlertedNodes = []
            });
        }
    }

    private void HandleElementSelected((string Id, EditorSelectionType Type) args)
    {
        if (string.IsNullOrEmpty(args.Id))
            SessionService.ClearSelection();
        else
            SessionService.SelectElement(args.Id, args.Type);
    }

    private void HandleCanvasClicked((double X, double Y) pos)
    {
        // Volitelně můžeme zrušit výběr při kliknutí mimo uzel
        SessionService.ClearSelection();
    }
    
    private void ToggleSchematic()
    {
        _isSchematicHidden = !_isSchematicHidden;
        StateHasChanged();
        
        // Timeout zajišťuje, že se DOM aktualizuje (display: none/block) 
        // předtím než se zavolá přeškálování a posun JS plátna.
        Task.Delay(100).ContinueWith(_ => InvokeAsync(async () =>
        {
            if (!_isSchematicHidden)
            {
               await JSRuntime.InvokeVoidAsync("editorCanvas.reapplyTransform");
            }
        }));
    }

    private void ClosePanel()
    {
        SessionService.ClearSelection();
    }

    private static string FormatSigned(double? value, string format)
    {
        if (!value.HasValue)
        {
            return "N/A";
        }

        var number = value.Value.ToString(format);
        return value.Value > 0 ? $"+{number}" : number;
    }

    private static string GetDeviationBadgeText(NodeDeviationSeverity? severity)
    {
        return severity switch
        {
            NodeDeviationSeverity.High => "silná odchylka",
            NodeDeviationSeverity.Elevated => "výraznější odchylka",
            _ => "v normě"
        };
    }

    private static string GetDeviationBadgeClass(NodeDeviationSeverity? severity)
    {
        return severity switch
        {
            NodeDeviationSeverity.High => "bg-danger",
            NodeDeviationSeverity.Elevated => "bg-warning text-dark",
            _ => "bg-success"
        };
    }

    private static string GetAlertStatusText(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "explanatory uzel";
        }

        if (deviation?.IsAvailable != true)
        {
            return "bez vyhodnocení";
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => "kritická odchylka",
            NodeDeviationSeverity.Elevated => "pozornost",
            _ => "v normě"
        };
    }

    private static string GetAlertBadgeClass(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "bg-info text-dark";
        }

        if (deviation?.IsAvailable != true)
        {
            return "bg-secondary";
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => "bg-danger",
            NodeDeviationSeverity.Elevated => "bg-warning text-dark",
            _ => "bg-success"
        };
    }

    private static string GetAlertReasonText(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "Uzel weather_main je v tomto sprintu jen vysvětlující faktor, energetický alert se zde záměrně nevyhodnocuje.";
        }

        if (deviation?.IsAvailable != true)
        {
            return deviation?.Message ?? "Odchylka vůči baseline není pro vybraný interval dostupná, alert stav proto nelze zatím vyhodnotit.";
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => "Absolutní relativní odchylka vůči baseline je nad 25 %.",
            NodeDeviationSeverity.Elevated => "Absolutní relativní odchylka vůči baseline je v pásmu 10-25 %.",
            _ => "Absolutní relativní odchylka vůči baseline je pod 10 %."
        };
    }

    private static string GetAlertSourceText(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "Weather uzel je explicitně mimo energetické alert hodnocení. Zůstává explanatory kontext pro ostatní systémy.";
        }

        if (deviation?.IsAvailable == true)
        {
            return "Alert stav je přímo mapovaný z deviation severity: Normal -> v normě, Elevated -> pozornost, High -> kritická odchylka. Severity je odvozena z |delta %| vůči baseline (<10, 10-25, >25).";
        }

        return "Alert foundation je navázaný na deviation/baseline vrstvu. Pokud deviation není dostupná, uzel zůstává ve stavu bez vyhodnocení (bez improvizovaného fallback alertu).";
    }

    private static (string Token, string Hex) GetSchematicAlertColorHint(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return ("informational / blue", "#0ea5e9");
        }

        if (deviation?.IsAvailable != true)
        {
            return ("neutral / slate", "#94a3b8");
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => ("danger / red", "#dc2626"),
            NodeDeviationSeverity.Elevated => ("warning / amber", "#f59e0b"),
            _ => ("neutral / green-ish", "#22c55e")
        };
    }

    private static bool IsWeatherNode(string? nodeKey)
    {
        return string.Equals(nodeKey, "weather_main", StringComparison.Ordinal);
    }

