            _workingSetStatusMessage = "Working set could not be removed because it was not found.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        await ReloadWorkingSetsAsync();
        _workingSetStatusMessage = $"Working set {workingSetName} deleted.";
        await InvokeAsync(StateHasChanged);
    }

