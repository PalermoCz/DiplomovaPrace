    private static bool TryParseCustomDateInput(string raw, out DateTime parsedDateUtc)
    {
        parsedDateUtc = default;

        if (string.IsNullOrWhiteSpace(raw))
        {
            return false;
        }

        // Accept both legacy dd.MM.yyyy and new yyyy-MM-dd formats
        if (DateTime.TryParseExact(raw.Trim(), new[] { "yyyy-MM-dd", "dd.MM.yyyy" }, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var parsed))
        {
            parsedDateUtc = DateTime.SpecifyKind(parsed.Date, DateTimeKind.Utc);
            return true;
        }

        return false;
    }

    private async Task<string?> ValidateCustomIntervalForAnalyticsAsync()
    {
        if (_customFromUtc == default || _customToUtcExclusive == default)
        {
            return "The custom interval is incomplete.";
        }

        if (_customToUtcExclusive <= _customFromUtc)
        {
            return "The end date must be later than the start date.";
        }

        if (_customFromUtc.Year <= BaselineHistoricalYearsForValidation)
        {
            return "The start date is too early for baseline comparison against previous years.";
        }

        var domain = await GetCurrentAnalyticsTimeDomainUtcAsync();
        if (!domain.MinUtc.HasValue || !domain.MaxUtc.HasValue)
        {
            return null;
        }

        var domainMin = domain.MinUtc.Value;
        var domainMaxExclusive = domain.MaxUtc.Value.AddMinutes(15);
        var hasOverlap = _customFromUtc < domainMaxExclusive && _customToUtcExclusive > domainMin;

        if (!hasOverlap)
        {
            var scopeLabel = ShouldUseAggregateAnalyticsIntervalScope
                ? "the current analytics scope"
                : $"node {_selectedFacilityNode?.NodeKey}";

            return $"The selected custom interval is outside the available data range for {scopeLabel} ({domainMin:dd.MM.yyyy} - {domain.MaxUtc.Value:dd.MM.yyyy}).";
        }

        return null;
    }

    public void Dispose()
    {
        CancelPendingOverviewHoverPreview();
        _selectionSignalAnalysisCts?.Cancel();
        _selectionSignalAnalysisCts?.Dispose();
        _selectionSignalAnalysisCts = null;
        StopAnalyticsLoadingUiTimer();
        SessionService.OnSessionChanged -= HandleSessionChanged;
    }
}


