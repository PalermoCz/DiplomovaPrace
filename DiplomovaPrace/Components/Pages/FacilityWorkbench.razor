{
    if (rects.Count == 0)
    {
        return new OverviewTreemapRect(0d, 0d, 100d, 100d);
    }

    return rects[^1];
}



    

    private (string Fill, string Accent, string Text) ResolveOverviewTreemapVisualStyle(string nodeKey, bool isSyntheticGroup)
    {
        if (isSyntheticGroup)
        {
            return ("#cbd5e1", "#64748b", "#0f172a");
        }

        var effectivePresetKeys = EffectiveNodeStylePresetKeysForCanvas;
        var effectivePresets = EffectiveStylePresetsForCanvas;
        var assignedKey = effectivePresetKeys.TryGetValue(nodeKey, out var presetKey)
            ? presetKey
            : null;
        var style = FacilityNodeStyleSystem.ResolveStyle(assignedKey, effectivePresets);
        var fill = string.IsNullOrWhiteSpace(style.FillColor) ? "#dbeafe" : style.FillColor;
        var accent = string.IsNullOrWhiteSpace(style.StrokeColor) ? "#475569" : style.StrokeColor;
        var text = ResolveReadableTextColor(fill, string.IsNullOrWhiteSpace(style.LabelColor) ? "#0f172a" : style.LabelColor);
        return (fill, accent, text);
    }

    private static OverviewTreemapTextMode ResolveOverviewTreemapTextMode(OverviewTreemapRect rect)
    {
    var area = rect.WidthPercent * rect.HeightPercent;
    var shorterSide = Math.Min(rect.WidthPercent, rect.HeightPercent);
    var longerSide = Math.Max(rect.WidthPercent, rect.HeightPercent);
    var aspectRatio = shorterSide <= 0.0001d ? longerSide : longerSide / shorterSide;

    if (area < 34d || shorterSide < 4.2d)
    {
        return OverviewTreemapTextMode.Hidden;
    }

    if (area < 120d || shorterSide < 6.4d || aspectRatio > 6.8d)
    {
        return OverviewTreemapTextMode.LabelOnly;
    }

    if (area < 280d || shorterSide < 9.2d || aspectRatio > 4.2d)
    {
        return OverviewTreemapTextMode.Compact;
    }

    return OverviewTreemapTextMode.Full;
    }

    private static string GetOverviewTreemapTextModeCssValue(OverviewTreemapTextMode mode)
        => mode switch
        {
            OverviewTreemapTextMode.LabelOnly => "label-only",
            OverviewTreemapTextMode.Full => "full",
            OverviewTreemapTextMode.Compact => "compact",
            OverviewTreemapTextMode.Hidden => "hidden",
            _ => "hidden"
        };


    private static string ResolveReadableTextColor(string backgroundColor, string fallback)
    {
        if (!TryParseHexColor(backgroundColor, out var red, out var green, out var blue))
        {
            return fallback;
        }

        var luminance = ((0.2126d * red) + (0.7152d * green) + (0.0722d * blue)) / 255d;
        return luminance < 0.52d
            ? "#f8fafc"
            : fallback;
    }

