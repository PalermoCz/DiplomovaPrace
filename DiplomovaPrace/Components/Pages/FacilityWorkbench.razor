    private async Task ReconnectFocusedNodeAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _structureStatusMessage = "Enable editor mode first.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _structureStatusMessage = "Select an editable focus node before reconnecting.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var parentMap = BuildCurrentParentMap();
        var nodeKey = _selectedFacilityNode.NodeKey;
        var nodeLabel = _selectedFacilityNode.Label ?? nodeKey;

        // Snapshot p�ed operac� pro undo
        var snapshot = await SnapshotEditStateAsync();

        var reconnectResult = await FacilityEditorStateService.TryReconnectNodeAsync(
            nodeKey,
            NormalizeOptionalText(_reconnectParentNodeKeyInput),
            parentMap);

        _structureStatusMessage = reconnectResult.Message;
        if (!reconnectResult.Success)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        PushEditUndoSnapshot(snapshot, $"Reconnect \"{nodeLabel}\"");

        await ReloadData(preserveSelection: true, preferredFocusNodeKey: nodeKey);
        _isReconnectMode = false;
        _reconnectChildrenWarningConfirmed = false;
