    private async Task ApplySemanticSelectionAsync(FacilityNodeSemanticQuery query, string sourceLabel)
    {
        if (_facility is null || _facility.Nodes.Count == 0)
        {
            _semanticSelectionStatusMessage = "Facility data is not loaded. Semantic selection did not run.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var candidateNodes = _facility.Nodes
            .Where(IsLeafOrAnalyticNode)
            .ToList();
        var candidateNodeKeys = FacilityNodeSemantics
            .ResolveMatchingNodeKeys(candidateNodes, query, node => GetEditorTags(node.NodeKey))
            .Where(_nodesByKey.ContainsKey)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        string? supportedFilterNotice = null;
        if (_semanticSelectionSupportedOnly && candidateNodeKeys.Count > 0)
        {
            try
            {
                var supportedNodeKeys = await ResolveAnalyticsSupportedNodeKeysAsync(candidateNodeKeys);
                candidateNodeKeys = candidateNodeKeys
                    .Where(supportedNodeKeys.Contains)
                    .ToList();
            }
            catch
            {
                supportedFilterNotice = "The supported-only filter was unavailable, so the full query result was used.";
            }
        }

        var mutationResult = MutateSelectionSet(candidateNodeKeys, _semanticSelectionMutationMode);
        _semanticSelectionStatusMessage = BuildSemanticSelectionStatusMessage(sourceLabel, candidateNodeKeys.Count, mutationResult, supportedFilterNotice);

        var nextFocusNodeKey = ResolveFocusNodeAfterSemanticMutation(_semanticSelectionMutationMode, mutationResult);
        var focusChanged = ApplyFocusNode(nextFocusNodeKey);
        if (!focusChanged)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<HashSet<string>> ResolveAnalyticsSupportedNodeKeysAsync(IReadOnlyList<string> candidateNodeKeys)
    {
        if (candidateNodeKeys.Count == 0)
        {
            return new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }

        var interval = GetInterval();
        var aggregate = await AnalyticsPreview.GetCuratedSelectionAggregateOverviewAsync(
            candidateNodeKeys,
            interval.From,
            interval.To,
            _timeSeriesMode,
            _showBaselineOverlay,
            CurrentAggregateRequestOptions);

        return aggregate.SupportedNodeKeys.ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private SemanticSelectionMutationResult MutateSelectionSet(
        IReadOnlyList<string> nodeKeys,
        SemanticSelectionMutationMode mutationMode)
    {
        ResetSelectionTraversalMode();

        var uniqueNodeKeys = nodeKeys
            .Where(key => !string.IsNullOrWhiteSpace(key))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var addedCount = 0;
        var removedCount = 0;

        if (mutationMode == SemanticSelectionMutationMode.Replace)
        {
            var previousSelection = _selectionSet.ToHashSet(StringComparer.OrdinalIgnoreCase);
            ClearSelectionSetState();

            foreach (var nodeKey in uniqueNodeKeys)
            {
                AddNodeToSelectionSet(nodeKey);
            }

            var nextSelection = _selectionSet;
            addedCount = nextSelection.Count(nodeKey => !previousSelection.Contains(nodeKey));
            removedCount = previousSelection.Count(nodeKey => !nextSelection.Contains(nodeKey));
            return new SemanticSelectionMutationResult(addedCount, removedCount);
        }

        if (mutationMode == SemanticSelectionMutationMode.Add)
        {
            foreach (var nodeKey in uniqueNodeKeys)
            {
                if (_selectionSet.Contains(nodeKey))
                {
                    continue;
                }

                AddNodeToSelectionSet(nodeKey);
                addedCount++;
            }
            return new SemanticSelectionMutationResult(addedCount, 0);
        }

        foreach (var nodeKey in uniqueNodeKeys)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            RemoveNodeFromSelectionSet(nodeKey);
            removedCount++;
        }
        return new SemanticSelectionMutationResult(0, removedCount);
    }

    private string? ResolveFocusNodeAfterSemanticMutation(
        SemanticSelectionMutationMode mutationMode,
        SemanticSelectionMutationResult mutationResult)
    {
        if (_selectionSet.Count == 0)
        {
            return null;
        }

        if (mutationMode is SemanticSelectionMutationMode.Replace)
        {
            return GetFallbackFocusNodeKey();
        }

        if (mutationMode is SemanticSelectionMutationMode.Add && mutationResult.AddedCount > 0)
        {
            return GetFallbackFocusNodeKey();
        }

        if (!string.IsNullOrWhiteSpace(SessionService.SelectedElementId)
            && _selectionSet.Contains(SessionService.SelectedElementId))
        {
            return SessionService.SelectedElementId;
        }

        return GetFallbackFocusNodeKey();
    }

    private string BuildSemanticSelectionStatusMessage(
        string sourceLabel,
        int matchedCount,
        SemanticSelectionMutationResult mutationResult,
        string? note)
    {
        var scopeLabel = _semanticSelectionSupportedOnly ? "supported-only" : "full-scope";
        var mutationLabel = GetSemanticMutationModeLabel(_semanticSelectionMutationMode).ToLowerInvariant();

        string baseMessage;
        if (matchedCount == 0)
        {
            baseMessage = $"{sourceLabel}: no nodes matched ({scopeLabel}).";
        }
        else if (!mutationResult.HasChanges)
        {
            baseMessage = $"{sourceLabel}: found {matchedCount} nodes ({scopeLabel}), selection unchanged ({mutationLabel}).";
        }
        else
        {
            baseMessage = $"{sourceLabel}: found {matchedCount} nodes ({scopeLabel}), selection change {mutationLabel}: +{mutationResult.AddedCount} / -{mutationResult.RemovedCount}.";
        }

        if (string.IsNullOrWhiteSpace(note))
        {
            return baseMessage;
        }

        return $"{baseMessage} {note}";
    }

    private static string GetSemanticMutationModeLabel(SemanticSelectionMutationMode mode)
    {
        return mode switch
        {
            SemanticSelectionMutationMode.Replace => "Replace",
            SemanticSelectionMutationMode.Add => "Add",
            SemanticSelectionMutationMode.Remove => "Remove",
            _ => "Replace"
        };
    }

