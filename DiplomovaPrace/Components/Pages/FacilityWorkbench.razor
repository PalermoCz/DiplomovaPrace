@page "/"
@page "/facility"
@using DiplomovaPrace.Services
@using DiplomovaPrace.Components.Editor
@rendermode InteractiveServer
@inject FacilityQueryService FacilityQueryService
@inject NodeAnalyticsPreviewService AnalyticsPreview
@inject IEditorSessionService SessionService
@inject IJSRuntime JSRuntime
@layout DiplomovaPrace.Components.Layout.FacilityLayout
@implements IDisposable

<PageTitle>Facility Schematic</PageTitle>

@* Aplikujeme lokální styly pro flexibilitu okna *@
<style>
    .facility-workbench {
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: #f8fafc;
    }
    
    .facility-main {
        display: flex;
        flex: 1;
        overflow: hidden;
    }
    
    .facility-canvas-wrapper {
        flex: 1;
        position: relative;
        overflow: hidden;
    }
    
    .facility-properties {
        flex: 1;
        min-width: 0;
        background-color: #ffffff;
        padding: 1.5rem;
        overflow-y: auto;
        box-shadow: -2px 0 10px rgba(0,0,0,0.02);
    }
</style>

<div class="facility-workbench">
    @* ── Hlavní část ──────────────────────────────────────────────────── *@
    <div class="facility-main position-relative">
        
        @* Levá část: Canvas *@
        <div class="facility-canvas-wrapper @(_isSchematicHidden ? "d-none" : "d-flex flex-column")" style="border-right: 1px solid #e2e8f0;">
            <div class="bg-white border-bottom px-3 py-2 d-flex justify-content-between align-items-center" style="z-index: 10;">
                <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schéma</span>
                <button class="btn btn-sm btn-light border d-flex align-items-center text-secondary shadow-sm" @onclick="ReloadData">
                    <i class="bi bi-arrow-clockwise me-1"></i> Znovu načíst schéma
                </button>
            </div>
            
            <div class="flex-grow-1 position-relative">
                @if (_facility is null)
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                        <div class="spinner-border mb-3" role="status"></div>
                        <p class="mb-0">Načítám strukturní data...</p>
                    </div>
                }
                else
                {
                    <EditorCanvas @ref="_canvas"
                                  Facility="_facility"
                                  ActiveTool="@SessionService.ActiveTool"
                                  SelectedElementId="@SessionService.SelectedElementId"
                                  ShowGrid="false"
                                  OnElementSelected="HandleElementSelected"
                                  OnCanvasClicked="HandleCanvasClicked" />
                }
            </div>
        </div>
        
        @* Pravá část: Detail & Analytika *@
        @if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _selectedFacilityNode is not null)
        {
            <div class="facility-properties">
                <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
                    <h5 class="mb-0 fw-bold">Detail uzlu</h5>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center bg-light px-3 text-nowrap fw-medium" @onclick="ToggleSchematic">
                            <i class="bi @(_isSchematicHidden ? "bi-layout-split" : "bi-arrows-fullscreen") me-1"></i>
                            @(_isSchematicHidden ? "Zobrazit schéma" : "Maximalizovat detail")
                        </button>
                        <button class="btn btn-sm btn-light border shadow-sm text-secondary px-3 text-nowrap fw-medium" @onclick="ClosePanel" title="Zavřít detail uzlu">
                            <i class="bi bi-x-lg me-1"></i> Zavřít
                        </button>
                    </div>
                </div>
                
                <div class="card border-0 bg-light mb-4">
                    <div class="card-body p-3">
                        <div class="mb-3">
                            <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">Název sub-systému</label>
                            <div class="fw-bold fs-5 text-dark" style="line-height: 1.2;">@_selectedFacilityNode.Label</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">NodeKey</label>
                            <div><code style="color: #475569; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 0.85rem;">@_selectedFacilityNode.NodeKey</code></div>
                        </div>

                        <div>
                            <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">Typ Uzlu & Zóna</label>
                            <div>
                                <span class="badge border border-secondary text-secondary me-1">@(_selectedFacilityNode.NodeType ?? "Neznámý")</span>
                                @if (!string.IsNullOrEmpty(_selectedFacilityNode.Zone))
                                {
                                    <span class="badge bg-secondary">@_selectedFacilityNode.Zone</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <h6 class="mb-3 fw-bold border-bottom pb-2">Časový rozsah</h6>
                <div class="mb-4">
                    <select class="form-select bg-light fw-medium" @onchange="OnIntervalChanged" value="@_selectedInterval">
                        <option value="2020">Celý rok 2020 (Default)</option>
                        <option value="2020-Q1">1. čtvrtletí 2020</option>
                        <option value="2020-01">Leden 2020</option>
                        <option value="2020-W1">1. týden 2020 (1.-7. ledna)</option>
                    </select>
                </div>

                <h6 class="mb-3 fw-bold border-bottom pb-2">Analytický souhrn</h6>
                
                @if (_isCuratedNode)
                {
                    <div class="mb-3">
                        <span class="badge bg-primary px-2 py-1"><i class="bi bi-star-fill me-1"></i> Facility-level / High-Level Systém</span>
                    </div>
                    
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Načítám data pro vybraný interval...
                        </div>
                    }
                    else if (_curatedPreviewData != null)
                    {
                        <div class="card border border-primary shadow-sm mb-3">
                            <div class="card-body p-3">
                                <div style="font-size: 0.85rem;" class="text-primary text-uppercase fw-bold mb-1">@_curatedPreviewData.Title</div>
                                <div class="fs-3 fw-bold text-dark mb-1" style="letter-spacing: -1px;">
                                    @if (_selectedFacilityNode?.NodeKey == "weather_main")
                                    {
                                        @(_curatedPreviewData.Average.ToString("N1")) <span style="font-size: 1.1rem; font-weight: normal; color: #64748b;">°C (průměr)</span>
                                    }
                                    else
                                    {
                                        @(_curatedPreviewData.TotalSum.ToString("N0")) <span style="font-size: 1.1rem; font-weight: normal; color: #64748b;">@_curatedPreviewData.Unit</span>
                                    }
                                </div>
                                <hr class="my-2 border-primary border-opacity-25" />
                                <div class="row text-center g-2 mt-1">
                                    <div class="col-4">
                                        <div class="text-muted small text-uppercase">Min</div>
                                        <div class="fw-bold" style="color: #0284c7;">@(_curatedPreviewData.Min.ToString("N1"))</div>
                                    </div>
                                    <div class="col-4 border-start border-end">
                                        <div class="text-muted small text-uppercase">Průměr</div>
                                        <div class="fw-bold">@(_curatedPreviewData.Average.ToString("N1"))</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="text-muted small text-uppercase">Max</div>
                                        <div class="fw-bold" style="color: #dc2626;">@(_curatedPreviewData.Max.ToString("N1"))</div>
                                    </div>
                                </div>
                                <div style="font-size: 0.8rem;" class="text-muted d-flex align-items-center mt-3 justify-content-center">
                                    <i class="bi bi-info-circle me-1"></i> Vypočítáno ze @_curatedPreviewData.DataPoints.ToString("N0") vzorků
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-3 shadow-sm border-0 d-flex align-items-start" style="font-size: 0.9rem;">
                            <i class="bi bi-exclamation-triangle-fill text-warning fs-5 me-2"></i>
                            <div>
                                Pro tento high-level systém (<strong>@_selectedFacilityNode?.NodeKey</strong>) nejsou ve zvoleném období k dispozici žádná data.
                            </div>
                        </div>
                    }
                }
                else if (string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn))
                {
                    <div class="alert alert-secondary py-3 border-0 d-flex align-items-start" style="font-size: 0.9rem;">
                        <i class="bi bi-diagram-2 text-secondary fs-5 me-2"></i>
                        <div>
                            Tento uzel je čistě <strong>strukturální</strong> (např. budova, site, patro). Má pouze vizualizační / architektonickou roli a neměří žádná analytická data samotný.
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-3 mt-1">
                        <label class="form-label text-muted mb-0" style="font-size: 0.8rem; text-transform: uppercase;">Měřitelný fyzický uzel</label>
                        <div style="word-break: break-all; font-size: 0.85rem;"><code style="color: #0369a1; background: #e0f2fe; padding: 2px 6px; border-radius: 4px;">@_selectedFacilityNode.MeterUrn</code></div>
                    </div>

                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Načítám data pro zvolený interval...
                        </div>
                    }
                    else if (_nodePreviewData is not null)
                    {
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body p-3">
                                <div style="font-size: 0.85rem;" class="text-muted text-uppercase mb-1 fw-bold">Spotřeba za interval</div>
                                <div class="fs-3 fw-bold text-dark mb-1" style="letter-spacing: -1px;">
                                    @(_nodePreviewData.TotalConsumptionKWh?.ToString("N0") ?? "0") <span style="font-size: 1.1rem; font-weight: normal; color: #64748b;">kWh</span>
                                </div>
                                <div style="font-size: 0.85rem;" class="text-muted">
                                    Průměrný výkon: <strong class="text-dark">@(_nodePreviewData.AveragePowerKW?.ToString("N2") ?? "0") kW</strong>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info py-3 border-0 shadow-sm d-flex align-items-start" style="font-size: 0.9rem;">
                            <i class="bi bi-info-circle-fill text-info fs-5 me-2"></i>
                            <div>
                                Tento uzel (<strong>@_selectedFacilityNode.MeterUrn</strong>) je měřitelný, ale momentálně pro něj není nahrána / namapována časová řada v reálné databázi pro zvolený interval.
                            </div>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <div class="facility-properties bg-light d-flex flex-column position-relative">
                <div class="d-flex align-items-center justify-content-end mb-4 pb-3 border-bottom">
                    <button class="btn btn-sm btn-outline-secondary d-flex align-items-center bg-white" @onclick="ToggleSchematic">
                        <i class="bi @(_isSchematicHidden ? "bi-layout-split" : "bi-arrows-fullscreen") me-1"></i>
                        @(_isSchematicHidden ? "Zobrazit schéma" : "Maximalizovat detail")
                    </button>
                </div>
                
                <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-center">
                    <i class="bi bi-cursor text-muted" style="font-size: 3rem; opacity: 0.5;"></i>
                    <h6 class="mt-3 text-muted">Aplikace je v režimu @(_isSchematicHidden ? "100% Detail" : "50% Schematic / 50% Detail")</h6>
                    <p class="text-muted small mb-0 px-3 mt-2">
                        Vyberte uzel ve schématu vlevo k zobrazení analytických dat.<br/>
                        @if (_isSchematicHidden)
                        {
                            <span class="text-primary mt-1 d-block"><i class="bi bi-info-circle me-1"></i>Schéma je aktuálně skryto. Použijte tlačítko 'Zobrazit schéma'.</span>
                        }
                    </p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private EditorCanvas? _canvas;
    private DiplomovaPrace.Persistence.Schematic.FacilityEntity? _facility;
    
    // Facility Node State
    private DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity? _selectedFacilityNode;
    private DiplomovaPrace.Models.Kpi.MeterKpiResult? _nodePreviewData;
    private CuratedNodeSummary? _curatedPreviewData;
    private bool _isPreviewLoading;
    private bool _isCuratedNode;
    
    // UI State
    private bool _isSchematicHidden = false;
    private string _selectedInterval = "2020";

    private (DateTime From, DateTime To) GetInterval()
    {
        return _selectedInterval switch
        {
            "2020-01" => (new DateTime(2020, 1, 1, 0, 0, 0, DateTimeKind.Utc), new DateTime(2020, 2, 1, 0, 0, 0, DateTimeKind.Utc)),
            "2020-Q1" => (new DateTime(2020, 1, 1, 0, 0, 0, DateTimeKind.Utc), new DateTime(2020, 4, 1, 0, 0, 0, DateTimeKind.Utc)),
            "2020-W1" => (new DateTime(2020, 1, 1, 0, 0, 0, DateTimeKind.Utc), new DateTime(2020, 1, 8, 0, 0, 0, DateTimeKind.Utc)),
            _ => (new DateTime(2020, 1, 1, 0, 0, 0, DateTimeKind.Utc), new DateTime(2021, 1, 1, 0, 0, 0, DateTimeKind.Utc))
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadData();
        SessionService.OnSessionChanged += HandleSessionChanged;
        // Výchozí nástroj pro prohlížení schématu
        SessionService.SetActiveTool(EditorTool.Select);
    }

    private async Task ReloadData()
    {
        _facility = await FacilityQueryService.GetMainFacilityAsync();
        SessionService.ClearSelection();
    }

    private async void HandleSessionChanged()
    {
        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _facility != null)
        {
            var selectedNodeId = SessionService.SelectedElementId;
            if (_selectedFacilityNode?.NodeKey != selectedNodeId)
            {
                _selectedFacilityNode = _facility.Nodes.FirstOrDefault(n => n.NodeKey == selectedNodeId);
                _nodePreviewData = null;
                _curatedPreviewData = null;
                _isCuratedNode = false;
                
                if (_selectedFacilityNode != null)
                {
                    _isCuratedNode = _selectedFacilityNode.NodeKey is "pv_main" or "chp_main" or "cooling_main" or "heating_main" or "weather_main";
                    await ReloadPreviewDataAsync();
                }
                else
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        else
        {
            _selectedFacilityNode = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnIntervalChanged(ChangeEventArgs e)
    {
        if (e.Value is string s)
        {
            _selectedInterval = s;
            await ReloadPreviewDataAsync();
        }
    }

    private async Task ReloadPreviewDataAsync()
    {
        if (_selectedFacilityNode != null && (_isCuratedNode || !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn)))
        {
            _isPreviewLoading = true;
            await InvokeAsync(StateHasChanged);
            
            try
            {
                var interval = GetInterval();
                if (_isCuratedNode)
                {
                    _curatedPreviewData = await AnalyticsPreview.GetCuratedSummaryAsync(_selectedFacilityNode.NodeKey, interval.From, interval.To);
                }
                else
                {
                    _nodePreviewData = await AnalyticsPreview.GetPreviewDataAsync(_selectedFacilityNode.MeterUrn!, interval.From, interval.To);
                }
            }
            finally
            {
                _isPreviewLoading = false;
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    private void HandleElementSelected((string Id, EditorSelectionType Type) args)
    {
        if (string.IsNullOrEmpty(args.Id))
            SessionService.ClearSelection();
        else
            SessionService.SelectElement(args.Id, args.Type);
    }

    private void HandleCanvasClicked((double X, double Y) pos)
    {
        // Volitelně můžeme zrušit výběr při kliknutí mimo uzel
        SessionService.ClearSelection();
    }
    
    private void ToggleSchematic()
    {
        _isSchematicHidden = !_isSchematicHidden;
        StateHasChanged();
        
        // Timeout zajišťuje, že se DOM aktualizuje (display: none/block) 
        // předtím než se zavolá přeškálování a posun JS plátna.
        Task.Delay(100).ContinueWith(_ => InvokeAsync(async () =>
        {
            if (!_isSchematicHidden)
            {
               await JSRuntime.InvokeVoidAsync("editorCanvas.reapplyTransform");
            }
        }));
    }

    private void ClosePanel()
    {
        SessionService.ClearSelection();
    }

    public void Dispose()
    {
        SessionService.OnSessionChanged -= HandleSessionChanged;
    }
}
