    private int BeginAnalyticsLoadingOperation(string operationType, string headline, string phaseLabel, string detail, int percent)
    {
    CancelPendingAnalyticsLoadingDismiss();
    var operationVersion = ++_analyticsLoadingOperationVersion;

    _analyticsLoadingOperationType = operationType;
    _showAnalyticsLoadingRail = true;
    _analyticsLoadingHeadline = headline;
    _analyticsLoadingPhaseLabel = phaseLabel;
    _analyticsLoadingDetail = detail;
    _analyticsLoadingPercent = Math.Clamp(percent, 0, 100);
    _analyticsLoadingLastProgressUtc = DateTime.UtcNow;
    _analyticsLoadingStartedUtc = DateTime.UtcNow;

    EnsureAnalyticsLoadingUiTimer();
    return operationVersion;
    }

    private void UpdateAnalyticsLoadingOperation(int operationVersion, string phaseLabel, string detail, int percent)
    {
        if (operationVersion != _analyticsLoadingOperationVersion)
        {
            return;
        }

        _analyticsLoadingPhaseLabel = phaseLabel;
        _analyticsLoadingDetail = detail;
        _analyticsLoadingPercent = Math.Clamp(percent, 0, 100);
        _analyticsLoadingLastProgressUtc = DateTime.UtcNow;
    }

    private void CompleteAnalyticsLoadingOperation(int operationVersion)
    {
        if (operationVersion != _analyticsLoadingOperationVersion)
        {
            return;
        }

        _analyticsLoadingPercent = 100;
        _analyticsLoadingLastProgressUtc = DateTime.UtcNow;
        ScheduleAnalyticsLoadingDismiss(operationVersion);
    }

    private void ClearAnalyticsLoadingState()
    {
        CancelPendingAnalyticsLoadingDismiss();
        StopAnalyticsLoadingUiTimer();
        _showAnalyticsLoadingRail = false;
        _analyticsLoadingHeadline = string.Empty;
        _analyticsLoadingPhaseLabel = string.Empty;
        _analyticsLoadingDetail = string.Empty;
        _analyticsLoadingPercent = 0;
        _analyticsLoadingLastProgressUtc = null;
        _analyticsLoadingStartedUtc = null;
    }

    private int AnalyticsLoadingDisplayPercent => Math.Clamp(_analyticsLoadingPercent, 0, 100);


    private void EnsureAnalyticsLoadingUiTimer()
    {
        if (_analyticsLoadingUiTimer is not null)
        {
            return;
        }

        _analyticsLoadingUiTimer = new System.Threading.Timer(_ =>
        {
            try
            {
                _ = InvokeAsync(() =>
                {
                    if (_showAnalyticsLoadingRail)
                    {
                        StateHasChanged();
                    }
                });
            }
            catch (ObjectDisposedException)
            {
            }
            catch (InvalidOperationException)
            {
            }
        }, null, TimeSpan.Zero, TimeSpan.FromMilliseconds(250));
    }

    private void StopAnalyticsLoadingUiTimer()
    {
        _analyticsLoadingUiTimer?.Dispose();
        _analyticsLoadingUiTimer = null;
    }

    private void CancelPendingAnalyticsLoadingDismiss()
    {
        if (_analyticsLoadingDismissCts is null)
        {
            return;
        }

        _analyticsLoadingDismissCts.Cancel();
        _analyticsLoadingDismissCts.Dispose();
        _analyticsLoadingDismissCts = null;
    }

    private void ScheduleAnalyticsLoadingDismiss(int operationVersion)
    {
        CancelPendingAnalyticsLoadingDismiss();

        var dismissCts = new System.Threading.CancellationTokenSource();
        _analyticsLoadingDismissCts = dismissCts;

        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(320, dismissCts.Token);
            }
            catch (TaskCanceledException)
            {
                return;
            }

            if (dismissCts.IsCancellationRequested || operationVersion != _analyticsLoadingOperationVersion)
            {
                return;
            }

            ClearAnalyticsLoadingState();
            StateHasChanged();
        });
    }

