        => string.Equals(nodeType, FacilityBuiltInNodeTypes.AreaNodeType, StringComparison.OrdinalIgnoreCase);

    private static string FormatFloorAreaInput(double? floorAreaM2)
        => floorAreaM2.HasValue
            ? floorAreaM2.Value.ToString("0.###", CultureInfo.InvariantCulture)
            : string.Empty;

    private double? TryParseEditorFloorArea(out string? validationMessage)
    {
        validationMessage = null;
        var rawValue = _editorFloorAreaInput.Trim();
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return null;
        }

        var normalized = rawValue.Replace(',', '.');
        if (!double.TryParse(normalized, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out var floorAreaM2)
            || !double.IsFinite(floorAreaM2))
        {
            validationMessage = "Floor area must be a valid number greater than 0, or left empty.";
            return null;
        }

        if (floorAreaM2 <= 0d)
        {
            validationMessage = "Floor area must be greater than 0, or left empty.";
            return null;
        }

        return floorAreaM2;
    }

    private static string BuildBindingPreviewText(FacilityDataBindingRegistry.BindingRecord binding)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(binding.MeterUrn))
        {
            parts.Add($"Meter URN: {binding.MeterUrn}");
        }

        if (!string.IsNullOrWhiteSpace(binding.SourceLabel))
        {
            parts.Add($"Label: {binding.SourceLabel}");
        }

        var fileName = !string.IsNullOrWhiteSpace(binding.OriginalFileName)
            ? binding.OriginalFileName
            : binding.FileName;
        if (!string.IsNullOrWhiteSpace(fileName))
        {
            parts.Add($"File: {fileName}");
        }

        if (binding.ImportedUtc.HasValue)
        {
            parts.Add($"Added: {binding.ImportedUtc.Value.ToLocalTime():dd/MM/yyyy HH:mm}");
        }

        return parts.Count == 0 ? "No additional metadata." : string.Join(Environment.NewLine, parts);
    }

    private bool IsCuratedNode(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity? node)
    {
        return node is not null
            && (BindingRegistry.IsSupported(node.NodeKey)
                || !string.IsNullOrEmpty(node.MeterUrn)
                || node.NodeKey is "pv_main" or "chp_main" or "cooling_main" or "heating_main");
    }

    private async Task AddAdditionalRelationshipAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _editorStatusMessage = "Schematic editor is disabled. Turn it on before editing relationships.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _editorStatusMessage = "Select an editable focus node.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var counterpartyNodeKey = NormalizeOptionalText(_additionalRelationshipCounterpartyNodeKeyInput);
        if (string.IsNullOrWhiteSpace(counterpartyNodeKey))
        {
            _editorStatusMessage = "Select a counterparty node for the new explicit relationship.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var sourceNodeKey = _selectedFacilityNode.NodeKey;
        var targetNodeKey = counterpartyNodeKey;

        var snapshot = await SnapshotEditStateAsync();
        var result = await FacilityEditorStateService.TryAddAdditionalRelationshipAsync(
            new FacilityAdditionalRelationship
            {
                SourceNodeKey = sourceNodeKey,
                TargetNodeKey = targetNodeKey,
                RelationshipKind = SchematicRelationshipKinds.AdditionalLink,
                Note = null,
                UpdatedUtc = DateTime.UtcNow
            },
            BuildCurrentNodeKeySet(),
            BuildCurrentAdditionalRelationships());

        _editorStatusMessage = result.Message;
        if (!result.Success)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        PushEditUndoSnapshot(snapshot, $"Add link \"{sourceNodeKey} -> {targetNodeKey}\"");
        await ReloadData(preserveSelection: true, preferredFocusNodeKey: _selectedFacilityNode.NodeKey);
        _editorStatusMessage = result.Message;
        await InvokeAsync(StateHasChanged);
    }

