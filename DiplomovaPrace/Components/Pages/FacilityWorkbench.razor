                            <div class="performance-detail-note">Schedule heuristic v1</div>
                        </div>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Splitting demand by schedule window...
                            </div>
                        }
                        else if (afterHoursLoad.IsAvailable)
                        {
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="badge @GetPerformanceKpiStateBadgeClass(afterHoursLoad.State)">@GetPerformanceKpiStateText(afterHoursLoad.State)</span>
                                @if (afterHoursLoad.HasMixedSigns)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis border">Demand-positive projection</span>
                                }
                                @if (afterHoursLoad.UsesReferenceFloor)
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border">Low active reference</span>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(afterHoursLoad.StateReason))
                            {
                                <div class="small text-muted mb-2">@afterHoursLoad.StateReason</div>
                            }
                            <div class="small text-muted mb-2">@afterHoursLoad.Summary</div>

                            <div class="micro-grid mb-2">
                                <div class="micro-kpi"><div class="metric-caption">After-hours / Active</div><div class="fw-semibold">@FormatRatioPercent(afterHoursLoad.AfterHoursRatio)</div></div>
                                <div class="micro-kpi"><div class="metric-caption">Night / Active</div><div class="fw-semibold">@(afterHoursLoad.NightRatio.HasValue ? FormatRatioPercent(afterHoursLoad.NightRatio) : "Hidden")</div></div>
                                <div class="micro-kpi"><div class="metric-caption">Weekend / Active</div><div class="fw-semibold">@(afterHoursLoad.WeekendRatio.HasValue ? FormatRatioPercent(afterHoursLoad.WeekendRatio) : "Hidden")</div></div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="badge bg-light text-secondary border">Active weekday: @afterHoursLoad.ActiveWeekdaySampleCount</span>
                                <span class="badge bg-light text-secondary border">After-hours: @afterHoursLoad.AfterHoursSampleCount</span>
                                <span class="badge bg-light text-secondary border">Night: @afterHoursLoad.NightSampleCount</span>
                                <span class="badge bg-light text-secondary border">Weekend: @afterHoursLoad.WeekendSampleCount</span>
                            </div>

                            @if (afterHoursLoad.Notes.Count > 0)
                            {
                                foreach (var note in afterHoursLoad.Notes)
                                {
                                    <div class="small text-muted">@note</div>
                                }
                            }
                            <div class="small text-muted">@afterHoursLoad.Methodology</div>
                        }
                        else
                        {
                            @if (!string.IsNullOrWhiteSpace(afterHoursLoad.StateReason))
                            {
                                <div class="small text-muted">@afterHoursLoad.StateReason</div>
                            }
                            <div class="small text-muted">@afterHoursLoad.Summary</div>
                        }
                    </div>
                </div>

                <div class="overview-widget overview-widget-soft performance-secondary-widget mt-3">
                    <div class="performance-detail-header">
                        <h6>Load Duration Curve</h6>
                        <div class="performance-detail-note">Distribution of demand over the interval</div>
                    </div>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Evaluating load distribution...
                        </div>
                    }
                    else if (SelectionLoadDurationCurve.IsAvailable && SelectionLoadDurationCurve.Points.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge @GetPerformanceKpiStateBadgeClass(SelectionLoadDurationCurve.State)">@GetPerformanceKpiStateText(SelectionLoadDurationCurve.State)</span>
                            <span class="badge bg-light text-secondary border">Points: @SelectionLoadDurationCurve.PointCount</span>
                            @if (SelectionLoadDurationCurve.HasMixedSigns)
                            {
                                <span class="badge bg-info-subtle text-info-emphasis border">Demand-positive projection</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(SelectionLoadDurationCurve.StateReason))
                        {
                            <div class="small text-muted mb-2">@SelectionLoadDurationCurve.StateReason</div>
                        }
                        <div class="small text-muted mb-2">@SelectionLoadDurationCurve.Summary</div>

                        <FacilityLoadDurationCurvePanel Data="@SelectionLoadDurationCurve" />

                        @if (SelectionLoadDurationCurve.Notes.Count > 0)
                        {
                            foreach (var note in SelectionLoadDurationCurve.Notes)
                            {
                                <div class="small text-muted">@note</div>
                            }
                        }

                        <div class="small text-muted">Peak Demand, Load Factor, and After-hours Load define the main Performance story. Load duration curve shows load distribution.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge @GetPerformanceKpiStateBadgeClass(SelectionLoadDurationCurve.State)">@GetPerformanceKpiStateText(SelectionLoadDurationCurve.State)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(SelectionLoadDurationCurve.StateReason))
                        {
                            <div class="small text-muted">@SelectionLoadDurationCurve.StateReason</div>
                        }
                        <div class="small text-muted">@SelectionLoadDurationCurve.Summary</div>
                    }
                </div>
                }

                @if (IsCompareTabActive)
                {
                <div class="overview-grid compare-analytics-grid">
                    <div class="overview-widget overview-widget-soft compare-sidebar-widget">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div>
                                <h6 class="mb-1">Compare setup</h6>
                                <div class="compare-status-line">Build a compare set from any dataset-backed nodes in the current selection. Duplicates are ignored automatically.</div>
                            </div>
                            <div class="compare-summary-chips">
                                <span class="badge bg-light text-secondary border">@_compareSet.Count @(_compareSet.Count == 1 ? "node in set" : "nodes in set")</span>
                                <span class="badge bg-light text-secondary border">@SelectionCompareSupportedCount eligible in selection</span>
                            </div>
                        </div>
                        <div class="compare-action-row">
                            <button class="btn btn-sm btn-outline-primary" @onclick="AddSelectionSetToCompareSet" disabled="@(!CanAddSelectionSetToCompareSet)">
                                <i class="bi bi-plus-circle me-1"></i> Add current selection
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearCompareSet" disabled="@(_compareSet.Count == 0)">
                                Clear compare set
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_compareSetStatusMessage))
                        {
                            <div class="compare-status-line mb-2">@_compareSetStatusMessage</div>
                        }
                        @if (_compareSet.Count == 0)
                        {
                            <div class="analytics-sparse-card">
                                @if (SelectionCompareSupportedCount > 0)
                                {
                                    <div class="analytics-sparse-title">Start with a compare-ready selection</div>
                                    <div class="analytics-sparse-copy">Add dataset-backed nodes from the current selection to prepare an aligned comparison view.</div>
                                    <div class="analytics-sparse-meta">Eligible nodes in the current selection: @SelectionCompareSupportedCount</div>
                                }
                                else
                                {
                                    <div class="analytics-sparse-title">No compare-capable nodes in the current selection</div>
                                    <div class="analytics-sparse-copy">Compare now follows dataset-backed analytics capability. Select nodes with supported time-series bindings to enable this tab.</div>
                                    <div class="analytics-sparse-meta">If no eligible nodes exist, the compare set remains intentionally empty.</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="compare-set-list">
                                @foreach (var item in _compareSet)
                                {
                                    <div class="compare-set-item">
                                        <div class="compare-set-item-copy">
                                            <div class="compare-set-item-label">@item.Label</div>
                                            <div class="compare-set-item-meta">@item.NodeKey@(string.IsNullOrWhiteSpace(item.NodeType) ? string.Empty : $" - {item.NodeType}")</div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger compare-set-remove" @onclick="() => RemoveNodeFromCompareSet(item.NodeKey)">
                                            Remove
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="overview-widget chart-widget compare-preview-widget">
                        <h6>Compare chart</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Preparing the comparison view...
                            </div>
                        }
                        else if (ShouldShowComparePreview)
                        {
                            <FacilityCompareTimeSeriesPanel Data="@_curatedCompareTimeSeriesData" />
                        }
                        else
                        {
                            <div class="analytics-sparse-card analytics-sparse-card-emphasis">
                                <div class="analytics-sparse-title">Comparison chart will appear here</div>
                                <div class="analytics-sparse-copy">Select a dataset-backed focus node and keep at least one other node in the compare set to render aligned time series.</div>
                                <div class="analytics-sparse-meta">The chart appears once the focused node and compare set share usable dataset-backed time series.</div>
                            </div>
                        }
                    </div>
                </div>
                }

            }

        </div> @* closes wb-analytics *@
    } @* closes else (dashboard mode) *@
</div> @* closes facility-workbench *@

