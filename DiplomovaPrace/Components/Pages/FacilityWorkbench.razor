    private async Task UndoEditAsync()
    {
        if (_editUndoStack.Count == 0) return;
        var currentJson = await FacilityEditorStateService.GetRawStateAsync();
        var entry = _editUndoStack[^1];
        _editUndoStack.RemoveAt(_editUndoStack.Count - 1);
        _editRedoStack.Add((currentJson, entry.Description));
        await FacilityEditorStateService.RestoreFromRawStateAsync(entry.Json);
        await ReloadData(preserveSelection: true);
        await InvokeAsync(StateHasChanged);
