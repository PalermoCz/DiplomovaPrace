                                    <div class="micro-grid mb-2">
                                        <div class="micro-kpi"><div class="metric-caption">Focus</div><div class="fw-semibold">@SelectionScopeFocusLabel</div></div>
                                        <div class="micro-kpi"><div class="metric-caption">Scope</div><div class="fw-semibold">@SelectionScopeModeLabel</div></div>
                                        <div class="micro-kpi"><div class="metric-caption">Supported</div><div class="fw-semibold">@SelectionAggregateSupportedCount</div></div>
                                        <div class="micro-kpi"><div class="metric-caption">Contributing</div><div class="fw-semibold">@SelectionAggregateIncludedCount</div></div>
                                    </div>

                                    <div class="small text-muted mb-2">@SelectionScopeCoverageText</div>

                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        @if (SelectionAggregateNoDataCount > 0)
                                        {
                                            <span class="badge bg-light text-secondary border">No-data: @SelectionAggregateNoDataCount</span>
                                        }
                                        @if (SelectionAggregateUnsupportedCount > 0)
                                        {
                                            <span class="badge bg-light text-secondary border">Unsupported: @SelectionAggregateUnsupportedCount</span>
                                        }
                                        @if (SelectionAggregateContextOnlyCount > 0)
                                        {
                                            <span class="badge bg-light text-secondary border">Context-only: @SelectionAggregateContextOnlyCount</span>
                                        }
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview?.Message))
                                    {
                                        <div class="aggregate-status-line">@_selectionAggregateOverview.Message</div>
                                    }
                                }
                                else
                                {
                                    <h6>Selection Scope</h6>
                                    <div class="small text-muted">@SelectionScopeEmptyStateText</div>
                                }
                            }
                            else if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _selectedFacilityNode is not null)
                            {
                                @if (_isCuratedNode)
                                {
                                    <h6>Deviation / Baseline Detail</h6>
                                    <div class="small text-muted">Weather-aware baseline detail now lives in Overview &gt; Signal Analytics and follows the active exact signal plus current selection scope instead of the old focus-only comparable-window heuristic.</div>
                                }
                                else
                                {
                                    <h6>Focus Detail</h6>
                                    @if (_isPreviewLoading)
                                    {
                                        <div class="text-muted d-flex align-items-center">
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Loading focus detail...
                                        </div>
                                    }
                                    else if (_nodePreviewData is not null)
                                    {
                                        <div class="small text-muted">Meter URN</div>
                                        <div class="fw-semibold text-break mb-2">@_selectedFacilityNode.MeterUrn</div>
                                        <div class="micro-grid">
                                            <div class="micro-kpi"><div class="metric-caption">Consumption</div><div class="fw-semibold">@(_nodePreviewData.TotalConsumptionKWh?.ToString("N0") ?? "0") kWh</div></div>
                                            <div class="micro-kpi"><div class="metric-caption">Average power</div><div class="fw-semibold">@(_nodePreviewData.AveragePowerKW?.ToString("N2") ?? "0") kW</div></div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="small text-muted">No additional focus detail is available for the current selection.</div>
                                    }
                                }
                            }
                            else
                            {
                                <h6>Focus Detail</h6>
                                <div class="small text-muted">No focus node is selected. The main overview analytics run over the current selection set.</div>
                            }
                        </div>
                    </div>

                    <div class="overview-widget chart-widget main-chart-widget">
                        <h6>Main Time Series</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Preparing the aggregate time series...
                            </div>
                        }
                        else if (_overviewChartTimeSeriesData is not null)
                        {
                            <FacilityTimeSeriesPanel Data="@_overviewChartTimeSeriesData"
                                                    SelectedMode="@_timeSeriesMode"
                                                    ShowBaselineOverlay="@_showBaselineOverlay"
                                                    ShowBaselineOverlayChanged="OnShowBaselineOverlayChanged"
                                                    IsLoading="@_isOverviewChartLoading"
                                                    SelectedModeChanged="OnTimeSeriesModeChanged" />
                        }
                        else if (_isOverviewChartLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Updating the aggregate time series...
                            </div>
                        }
                        else
                        {
                            <div class="small text-muted">The selection set does not contain compatible nodes with an available time series.</div>
                            @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview?.Message))
                            {
                                <div class="aggregate-status-line mt-2">@_selectionAggregateOverview.Message</div>
                            }
                        }
                    </div>
                </div>
                }

                @if (IsDiagnosticsTabActive)
                {
                <div class="overview-grid forecast-analytics-grid">
                    <div class="overview-widget chart-widget forecast-compare-widget">
                        <h6>Forecast vs Actual</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Preparing the forecast comparison...
                            </div>
                        }
                        else if (SelectionForecastCompareTimeSeries is not null)
                        {
                            <FacilityCompareTimeSeriesPanel Data="@SelectionForecastCompareTimeSeries" />
                        }
                        else
                        {
                            <div class="small text-muted">@SelectionForecastDiagnostics.Summary</div>
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft forecast-diagnostics-widget">
                        <h6>Forecast Diagnostics</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Calculating forecast error metrics...
                            </div>
                        }
                        else
                        {
                            var forecastDiagnostics = SelectionForecastDiagnostics;

                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge @GetForecastStatusBadgeClass(forecastDiagnostics.Status)">@GetForecastStatusText(forecastDiagnostics.Status)</span>
                                <span class="badge bg-light text-secondary border">Aligned: @forecastDiagnostics.AlignedPointCount/@forecastDiagnostics.ActualPointCount</span>
                            </div>

                            <div class="small text-muted mb-2">@forecastDiagnostics.Summary</div>

                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="badge bg-light text-secondary border">MAE: @FormatForecastMetric(forecastDiagnostics.MaeKw) kW</span>
                                <span class="badge bg-light text-secondary border">RMSE: @FormatForecastMetric(forecastDiagnostics.RmseKw) kW</span>
                                <span class="badge bg-light text-secondary border">Bias: @FormatSigned(forecastDiagnostics.BiasKw, "N2") kW</span>
                                <span class="badge bg-light text-secondary border">WAPE: @(forecastDiagnostics.WapePercent?.ToString("N1") ?? "N/A") %</span>
                            </div>

                            <div class="forecast-diagnostics-list">
                                @foreach (var point in BuildForecastDiagnosticsPoints(forecastDiagnostics).Take(4))
                                {
                                    <div class="forecast-diagnostics-point">@point</div>
                                }
                            </div>
                        }
                    </div>
                </div>
                }

                @if (IsPerformanceTabActive)
                {
                    var peakAnalysis = SelectionPeakAnalysis;
                    var loadFactor = SelectionLoadFactor;
                    var afterHoursLoad = SelectionAfterHoursLoad;
                    var loadProfile = SelectionLoadProfile;

                <div class="performance-kpi-grid mb-3">
                    <div class="overview-widget overview-widget-soft performance-kpi-widget">
                        <div class="performance-kpi-label">Peak Demand</div>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Evaluating peak demand...
                            </div>
                        }
                        else if (peakAnalysis.IsAvailable && peakAnalysis.DemandPeak.IsAvailable)
                        {
                            <div class="performance-kpi-value">@FormatMetricValue(peakAnalysis.DemandPeak.ValueKw, "N2") <span class="performance-kpi-unit">kW</span></div>
                            <div class="performance-kpi-meta">Observed at @FormatPeakTimestamp(peakAnalysis.DemandPeak.TimestampUtc)</div>
                            <div class="performance-kpi-context">
                                <span class="badge @GetPerformanceKpiStateBadgeClass(peakAnalysis.State)">@GetPerformanceKpiStateText(peakAnalysis.State)</span>
                                <span class="badge @GetPeakSignificanceBadgeClass(peakAnalysis.SignificanceLevel)">@GetPeakSignificanceText(peakAnalysis.SignificanceLevel)</span>
                                @if (peakAnalysis.SignificanceRatio.HasValue)
                                {
                                    <span class="badge bg-light text-secondary border">@(peakAnalysis.SignificanceRatio.Value.ToString("N2"))x typical</span>
                                }
                                @if (peakAnalysis.HasMixedSigns)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis border">Mixed-sign context</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(peakAnalysis.StateReason))
                            {
                                <div class="small text-muted">@peakAnalysis.StateReason</div>
                            }
                            <div class="small text-muted">@peakAnalysis.Summary</div>
                        }
                        else
                        {
                            <div class="performance-kpi-value">N/A</div>
                            <div class="small text-muted">@GetPeakDemandUnavailableSummary(peakAnalysis)</div>
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft performance-kpi-widget">
                        <div class="performance-kpi-label">Load Factor</div>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Calculating load factor...
                            </div>
                        }
                        else if (loadFactor.IsAvailable)
                        {
                            <div class="performance-kpi-value">@FormatRatioPercent(loadFactor.LoadFactorRatio, "N1")</div>
                            <div class="performance-kpi-meta">Avg demand @FormatMetricValue(loadFactor.AverageDemandKw, "N2") kW vs peak @FormatMetricValue(loadFactor.PeakDemandKw, "N2") kW</div>
                            <div class="performance-kpi-context">
                                <span class="badge @GetPerformanceKpiStateBadgeClass(loadFactor.State)">@GetPerformanceKpiStateText(loadFactor.State)</span>
                                <span class="badge bg-light text-secondary border">Points: @loadFactor.PointCount</span>
                                @if (loadFactor.HasMixedSigns)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis border">Demand-positive projection</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(loadFactor.StateReason))
                            {
                                <div class="small text-muted">@loadFactor.StateReason</div>
                            }
                            <div class="small text-muted">@loadFactor.Summary</div>
                        }
                        else
                        {
                            <div class="performance-kpi-value">N/A</div>
                            @if (!string.IsNullOrWhiteSpace(loadFactor.StateReason))
                            {
                                <div class="small text-muted">@loadFactor.StateReason</div>
                            }
                            <div class="small text-muted">@loadFactor.Summary</div>
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft performance-kpi-widget">
                        <div class="performance-kpi-label">After-hours Load</div>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Calculating after-hours demand...
                            </div>
                        }
                        else if (afterHoursLoad.IsAvailable)
                        {
                            <div class="performance-kpi-value">@FormatRatioPercent(afterHoursLoad.AfterHoursRatio)</div>
                            <div class="performance-kpi-meta">After-hours avg @FormatMetricValue(afterHoursLoad.AverageAfterHoursDemandKw, "N2") kW vs active weekday @FormatMetricValue(afterHoursLoad.AverageActiveWeekdayDemandKw, "N2") kW</div>
                            <div class="performance-kpi-context">
                                <span class="badge @GetPerformanceKpiStateBadgeClass(afterHoursLoad.State)">@GetPerformanceKpiStateText(afterHoursLoad.State)</span>
                                @if (afterHoursLoad.NightRatio.HasValue)
                                {
                                    <span class="badge bg-light text-secondary border">Night: @FormatRatioPercent(afterHoursLoad.NightRatio)</span>
                                }
                                @if (afterHoursLoad.WeekendRatio.HasValue)
                                {
                                    <span class="badge bg-light text-secondary border">Weekend: @FormatRatioPercent(afterHoursLoad.WeekendRatio)</span>
                                }
                                @if (afterHoursLoad.HasMixedSigns)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis border">Demand-positive projection</span>
                                }
                                @if (afterHoursLoad.UsesReferenceFloor)
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border">Low active reference</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(afterHoursLoad.StateReason))
                            {
                                <div class="small text-muted">@afterHoursLoad.StateReason</div>
                            }
                            <div class="small text-muted">@afterHoursLoad.Summary</div>
                        }
                        else
                        {
                            <div class="performance-kpi-value">N/A</div>
                            @if (!string.IsNullOrWhiteSpace(afterHoursLoad.StateReason))
                            {
                                <div class="small text-muted">@afterHoursLoad.StateReason</div>
                            }
                            <div class="small text-muted">@afterHoursLoad.Summary</div>
                        }
                    </div>
                </div>

                <div class="overview-grid performance-detail-grid">
