    private const string SelectionPieChartSvgId = "cp-selection-pie-chart";

    private sealed record SelectionDonutSegment(string Label, int Count, string Color, string Tooltip, string? DetailText = null);

    private int SupportedSelectionSummaryCount => GetSupportedSelectionSummaryItems().Count;

    private IReadOnlyList<SelectionDonutSegment> GetSelectionDonutSegments()
    {
        var supportedItems = GetSupportedSelectionSummaryItems();
        if (supportedItems.Count == 0)
        {
            return [];
        }

        var groups = supportedItems
            .GroupBy(item => string.IsNullOrWhiteSpace(item.NodeType) ? "Unknown" : item.NodeType.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(group => new
            {
                Label = group.Key,
                Count = group.Count(),
                Nodes = group.ToList()
            })
            .OrderByDescending(group => group.Count)
            .ThenBy(group => group.Label, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var segments = new List<SelectionDonutSegment>();
        var totalCount = supportedItems.Count;

        foreach (var group in groups)
        {
            var percentage = (double)group.Count / totalCount;
            segments.Add(new SelectionDonutSegment(
                group.Label,
                group.Count,
                ResolveNodeTypeFillColor(group.Nodes),
                $"{group.Label}: {group.Count} nodes ({percentage:P0})"));
        }

        return segments;
    }

    private static string DescribePieSlicePath(double centerX, double centerY, double radius, double startAngleDeg, double sweepAngleDeg)
    {
        if (sweepAngleDeg <= 0d)
        {
            return string.Empty;
        }

        if (sweepAngleDeg >= 359.999d)
        {
            var diameter = radius * 2d;
            return FormattableString.Invariant(
                $"M {centerX:F3} {centerY:F3} m {-radius:F3} 0 a {radius:F3} {radius:F3} 0 1 0 {diameter:F3} 0 a {radius:F3} {radius:F3} 0 1 0 {-diameter:F3} 0 Z");
        }

        var startRad = DegreesToRadians(startAngleDeg);
        var endRad = DegreesToRadians(startAngleDeg + sweepAngleDeg);

        var startX = centerX + (radius * Math.Cos(startRad));
        var startY = centerY + (radius * Math.Sin(startRad));
        var endX = centerX + (radius * Math.Cos(endRad));
        var endY = centerY + (radius * Math.Sin(endRad));
        var largeArcFlag = sweepAngleDeg > 180d ? 1 : 0;

        return FormattableString.Invariant(
            $"M {centerX:F3} {centerY:F3} L {startX:F3} {startY:F3} A {radius:F3} {radius:F3} 0 {largeArcFlag} 1 {endX:F3} {endY:F3} Z");
    }

    private static double DegreesToRadians(double degrees)
    {
        return degrees * Math.PI / 180d;
    }

    private string ResolveNodeTypeFillColor(IEnumerable<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> nodes)
    {
        var fillCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var effectivePresetKeys = EffectiveNodeStylePresetKeysForCanvas;
        var effectivePresets = EffectiveStylePresetsForCanvas;

        foreach (var node in nodes)
        {
            var assignedKey = effectivePresetKeys.TryGetValue(node.NodeKey, out var nodePresetKey)
                ? nodePresetKey
                : null;
            var style = FacilityNodeStyleSystem.ResolveStyle(assignedKey, effectivePresets);
            var fill = string.IsNullOrWhiteSpace(style.FillColor) ? "#cbd5e1" : style.FillColor;
            fillCounts.TryGetValue(fill, out var current);
            fillCounts[fill] = current + 1;
        }

        return fillCounts
            .OrderByDescending(pair => pair.Value)
            .ThenBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase)
            .Select(pair => pair.Key)
            .FirstOrDefault() ?? "#cbd5e1";
    }

