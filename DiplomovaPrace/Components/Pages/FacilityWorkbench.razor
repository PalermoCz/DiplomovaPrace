    private async Task DuplicateSelectedStylePresetAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _styleStatusMessage = "Schematic editor is disabled. Enable edit mode before duplicating the preset.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _styleStatusMessage = "Select an editable node.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var snapshot = await SnapshotEditStateAsync();
        var sourcePreset = BuildCurrentStylePresetDraft();
        var duplicateKey = CreateDuplicateStylePresetKey(sourcePreset.Key);
        var duplicateName = CreateDuplicateStylePresetName(sourcePreset.Name);
        var duplicatePreset = FacilityNodeStyleSystem.NormalizePreset(new FacilityNodeStylePreset
        {
            Key = duplicateKey,
            Name = duplicateName,
            Shape = sourcePreset.Shape,
            Size = sourcePreset.Size,
            FillColor = sourcePreset.FillColor,
            StrokeColor = sourcePreset.StrokeColor,
            StrokeWidth = sourcePreset.StrokeWidth,
            Symbol = sourcePreset.Symbol,
            SymbolColor = sourcePreset.SymbolColor,
            LabelColor = sourcePreset.LabelColor,
            LabelFontSize = sourcePreset.LabelFontSize,
            LabelFontWeight = sourcePreset.LabelFontWeight
        });

        _stylePresetsByKey[duplicatePreset.Key] = duplicatePreset;
        await FacilityEditorStateService.SaveStylePresetsAsync(_stylePresetsByKey.Values);
        PushEditUndoSnapshot(snapshot, $"Duplicate style preset \"{GetStylePresetLabel(sourcePreset)}\"");
        _styleAssignmentPresetKeyInput = duplicatePreset.Key;
        LoadStylePresetEditorDraft(duplicatePreset.Key);
        _styleStatusMessage = $"Preset {duplicatePreset.Name} was duplicated and is ready to edit.";
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteSelectedStylePresetAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _styleStatusMessage = "Schematic editor is disabled. Enable edit mode before deleting the preset.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _styleStatusMessage = "Select an editable node.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var blockReason = GetDeleteSelectedStylePresetBlockReason();
        if (!string.IsNullOrWhiteSpace(blockReason))
        {
            _styleStatusMessage = blockReason;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var snapshot = await SnapshotEditStateAsync();
        var deletedPreset = GetStylePresetByKey(_styleAssignmentPresetKeyInput);
        _stylePresetsByKey.Remove(deletedPreset.Key);
        await FacilityEditorStateService.SaveStylePresetsAsync(_stylePresetsByKey.Values);
        PushEditUndoSnapshot(snapshot, $"Delete style preset \"{GetStylePresetLabel(deletedPreset)}\"");

        var nextPresetKey = ResolveSelectedNodeStylePresetKey();
        LoadStylePresetEditorDraft(nextPresetKey);
        _styleStatusMessage = $"Preset {GetStylePresetLabel(deletedPreset)} was deleted.";
        await ReloadData(preserveSelection: true, preferredFocusNodeKey: _selectedFacilityNode.NodeKey);
        await InvokeAsync(StateHasChanged);
    }

    private string CreateDuplicateStylePresetKey(string sourceKey)
    {
        var baseKey = string.IsNullOrWhiteSpace(sourceKey)
            ? "style-preset"
            : FacilityNodeStyleSystem.NormalizePresetKey(sourceKey);

        var candidate = $"{baseKey}-copy";
        var suffix = 2;
        while (_stylePresetsByKey.ContainsKey(candidate))
        {
            candidate = $"{baseKey}-copy-{suffix}";
            suffix++;
        }

        return candidate;
    }

    private string CreateDuplicateStylePresetName(string sourceName)
    {
        var baseName = string.IsNullOrWhiteSpace(sourceName)
            ? "Copied preset"
            : sourceName.Trim();

        var candidate = $"{baseName} copy";
        var suffix = 2;
        while (_stylePresetsByKey.Values.Any(preset => preset.Name.Equals(candidate, StringComparison.CurrentCultureIgnoreCase)))
        {
            candidate = $"{baseName} copy {suffix}";
            suffix++;
        }

        return candidate;
    }

    private async Task ApplySemanticQueryAsync()
    {
        if (_facility is null || _facility.Nodes.Count == 0)
        {
            _semanticSelectionStatusMessage = "Facility data is not loaded.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var hasNodeTypeFilter = !string.IsNullOrWhiteSpace(_filterNodeType);
        var hasZoneFilter = !string.IsNullOrWhiteSpace(_filterZone);

        var candidateNodeKeys = _facility.Nodes
            .Where(n => !hasNodeTypeFilter || string.Equals(n.NodeType, _filterNodeType, StringComparison.OrdinalIgnoreCase))
            .Where(n => !hasZoneFilter || string.Equals(n.Zone, _filterZone, StringComparison.OrdinalIgnoreCase))
            .Select(n => n.NodeKey)
            .Where(_nodesByKey.ContainsKey)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        string? supportedFilterNotice = null;
        if (_semanticSelectionSupportedOnly && candidateNodeKeys.Count > 0)
        {
            try
            {
                var supportedNodeKeys = await ResolveAnalyticsSupportedNodeKeysAsync(candidateNodeKeys);
                candidateNodeKeys = candidateNodeKeys.Where(supportedNodeKeys.Contains).ToList();
            }
            catch
            {
                supportedFilterNotice = "The supported-only filter was unavailable.";
            }
        }

        var mutationResult = MutateSelectionSet(candidateNodeKeys, _semanticSelectionMutationMode);
        _semanticSelectionStatusMessage = BuildSemanticSelectionStatusMessage("Filter", candidateNodeKeys.Count, mutationResult, supportedFilterNotice);

        var nextFocusNodeKey = ResolveFocusNodeAfterSemanticMutation(_semanticSelectionMutationMode, mutationResult);
        var focusChanged = ApplyFocusNode(nextFocusNodeKey);
        if (!focusChanged)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

