        {
            Key = FacilityNodeStyleSystem.ResolvePresetKey(_styleAssignmentPresetKeyInput, _stylePresetsByKey),
            Name = _stylePresetNameInput,
            Shape = _styleShapeInput,
            Size = _styleSizeInput,
            FillColor = _styleFillColorInput,
            StrokeColor = _styleStrokeColorInput,
            StrokeWidth = _styleStrokeWidthInput,
            Symbol = _styleSymbolInput,
            SymbolColor = _styleSymbolColorInput,
            LabelColor = _styleLabelColorInput,
            LabelFontSize = _styleLabelFontSizeInput,
            LabelFontWeight = _styleLabelFontWeightInput
        });
    }

    private FacilityNodeStylePreset GetStylePresetByKey(string? presetKey)
    {
        var resolvedKey = FacilityNodeStyleSystem.ResolvePresetKey(presetKey, _stylePresetsByKey);
        if (_stylePresetsByKey.TryGetValue(resolvedKey, out var preset))
        {
            return preset;
        }

        return FacilityNodeStyleSystem.CreateDefaultPresetLibrary()[FacilityNodeStyleSystem.DefaultPresetKey];
    }

    private string ResolveSelectedNodeStylePresetKey()
    {
        if (_selectedFacilityNode is null)
        {
            return FacilityNodeStyleSystem.DefaultPresetKey;
        }

        if (_editorNodeStatesByKey.TryGetValue(_selectedFacilityNode.NodeKey, out var nodeState)
            && !string.IsNullOrWhiteSpace(nodeState.StylePresetKey))
        {
            return FacilityNodeStyleSystem.ResolvePresetKey(nodeState.StylePresetKey, _stylePresetsByKey);
        }

        return FacilityNodeStyleSystem.DefaultPresetKey;
    }

