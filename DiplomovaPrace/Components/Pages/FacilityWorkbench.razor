@page "/"
@page "/facility"
@using DiplomovaPrace.Services
@using DiplomovaPrace.Components.Editor
@rendermode InteractiveServer
@inject FacilityQueryService FacilityQueryService
@inject FacilityEditorStateService FacilityEditorStateService
@inject NodeAnalyticsPreviewService AnalyticsPreview
@inject FacilityAlertSummaryService GlobalAlertSummaryService
@inject IEditorSessionService SessionService
@inject IJSRuntime JSRuntime
@layout DiplomovaPrace.Components.Layout.FacilityLayout
@implements IDisposable

<PageTitle>Facility Schematic</PageTitle>

@* Layout CSS is in FacilityWorkbench.razor.css (scoped) *@

<div class="facility-workbench">

    @* ══ FOCUS MODE OVERLAY ══════════════════════════════════════ *@
    @if (_isSchematicFullscreen)
    {
        <div class="wb-focus-overlay">
            <div class="wb-schematic">
                <div class="wb-schematic-toolbar">
                    <div class="toolbar-left">
                        <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schéma</span>
                        <span class="badge bg-secondary-subtle text-secondary border"><i class="bi bi-arrows-fullscreen me-1"></i>Focus</span>
                    </div>
                    <div class="toolbar-right">
                        <button class="wb-toolbar-icon-btn" @onclick="GoHomeAsync"
                                title="Domů – výchozí pohled" disabled="@(_canvasV2 is null)">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn" @onclick="() => ReloadData()" title="Znovu načíst schéma">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn"
                                @onclick="ToggleSchematicFullscreen" title="Zavřít focus – zpět do workbench">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M5.5 0a.5.5 0 0 1 .5.5v4A1.5 1.5 0 0 1 4.5 6h-4a.5.5 0 0 1 0-1h4a.5.5 0 0 0 .5-.5v-4a.5.5 0 0 1 .5-.5m5 0a.5.5 0 0 1 .5.5v4a.5.5 0 0 0 .5.5h4a.5.5 0 0 1 0 1h-4A1.5 1.5 0 0 1 10 4.5v-4a.5.5 0 0 1 .5-.5M0 10.5a.5.5 0 0 1 .5-.5h4A1.5 1.5 0 0 1 6 11.5v4a.5.5 0 0 1-1 0v-4a.5.5 0 0 0-.5-.5h-4a.5.5 0 0 1-.5-.5m10 1a1.5 1.5 0 0 1 1.5-1.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 0-.5.5v4a.5.5 0 0 1-1 0z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn wb-toolbar-icon-btn-primary"
                                @onclick="ToggleEditMode" title="Upravit schéma" disabled="@(_facility is null)">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/></svg>
                        </button>
                    </div>
                </div>
                <div class="wb-schematic-body">
                    @if (_facility is null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <div class="spinner-border mb-3" role="status"></div>
                            <p class="mb-0">Načítám strukturní data...</p>
                        </div>
                    }
                    else
                    {
                        <FacilitySchematicV2 @ref="_canvasV2"
                                      Layout="_schematicLayout"
                                      InitialFitMode="focus"
                                      SelectedElementId="@SessionService.SelectedElementId"
                                      SelectedElementIds="@_selectionSet"
                                      SelectedSubtreeNodeKeys="@SelectedSubtreeNodeKeysForCanvas"
                                      FacilityNodeAlertSeverities="@AlertSeverityByNodeKey"
                                      OnElementSelected="HandleElementSelected"
                                      OnCanvasClicked="HandleCanvasClicked"
                                      OnNodeDragEnd="HandleNodeDragEndAsync" />
                    }
                </div>
            </div>
        </div>
    }
    @* ══ EDIT MODE OVERLAY ═══════════════════════════════════════ *@
    else if (_isEditModeOpen)
    {
        <div class="wb-editor-overlay">
            @* Canvas area *@
            <div class="wb-schematic">
                <div class="wb-schematic-toolbar wb-editor-toolbar">
                    <div class="toolbar-left">
                        <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schéma</span>
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><i class="bi bi-pencil-fill me-1"></i>Edit Mode</span>
                    </div>
                    <div class="toolbar-right wb-editor-toolbar-right">
                        @* ── View tools ── *@
                        <button class="wb-toolbar-icon-btn" @onclick="GoHomeAsync"
                                title="Výchozí pohled" disabled="@(_canvasV2 is null)">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn" @onclick="() => ReloadData()" title="Znovu načíst schéma">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <div class="wb-editor-toolbar-divider"></div>
                        @* ── Structure tools ── *@
                        <button class="wb-toolbar-icon-btn @(_editorActiveTab == "add" ? "wb-toolbar-icon-btn-active" : "")"
                                title="@(_selectedFacilityNode is not null && CanEditFocusedNode ? $"Přidat child uzel pod '{_selectedFacilityNode.Label}'" : "Přidat uzel")"
                            disabled="@IsEditorMultiSelectActive"
                                @onclick="@(() => SwitchEditorTab("add"))">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn @(_editorActiveTab == "delete" ? "wb-toolbar-icon-btn-active" : "") @(CanRemoveFocusedLeafNode ? "wb-toolbar-icon-btn-danger" : "")"
                                title="Smazat vybraný uzel"
                            disabled="@IsEditorMultiSelectActive"
                                @onclick="@(() => SwitchEditorTab("delete"))">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                        </button>
                        <div class="wb-editor-toolbar-divider"></div>
                        @* ── Undo / Redo ── *@
                        <button class="wb-toolbar-icon-btn"
                                title="@(_editModeCanUndo ? ("Vrátit zpět: " + (_editUndoStack.Count > 0 ? _editUndoStack[^1].Description : "")) : "Zpět — žádná změna")"
                                disabled="@(!_editModeCanUndo)"
                                @onclick="UndoEditAsync">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 1-4.546 2.914.5.5 0 0 0-.908-.417A6 6 0 1 0 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 0-.41-.192L5.23 2.308a.25.25 0 0 0 0 .384l2.36 1.966A.25.25 0 0 0 8 4.466"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn"
                                title="@(_editModeCanRedo ? ("Znovu: " + (_editRedoStack.Count > 0 ? _editRedoStack[^1].Description : "")) : "Znovu — žádná vrácená změna")"
                                disabled="@(!_editModeCanRedo)"
                                @onclick="RedoEditAsync">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <div class="wb-editor-toolbar-divider"></div>
                        @* ── Import Data ── *@
                        <button class="wb-toolbar-icon-btn @(_editorActiveTab == "import" ? "wb-toolbar-icon-btn-active" : "")"
                                title="Import dat"
                            disabled="@IsEditorMultiSelectActive"
                                @onclick="@(() => SwitchEditorTab("import"))">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                        </button>
                        @* ── Spacer ── *@
                        <div class="wb-editor-toolbar-spacer"></div>
                        @* ── Save ── *@
                        <button class="wb-toolbar-icon-btn @(EditModeDirty ? "wb-toolbar-icon-btn-save-dirty" : "")"
                                title="@(EditModeDirty ? "Uložit změny (neuložené změny)" : "Uložit změny")"
                                @onclick="SaveEditModeChangesAsync">
                            @* Floppy disk / kazeta — proper SVG *@
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M11 2H9v3h2z"/>
                                <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v3.5A1.5 1.5 0 0 1 11.5 6h-7A1.5 1.5 0 0 1 3 4.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z"/>
                            </svg>
                        </button>
                        @* ── Close editor ── *@
                        <button class="wb-toolbar-icon-btn wb-toolbar-icon-btn-close"
                                title="Ukončit editor"
                                @onclick="ExitSchematicOverlayAsync">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/></svg>
                        </button>
                    </div>
                </div>
                <div class="wb-schematic-body">
                    @if (_facility is null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <div class="spinner-border mb-3" role="status"></div>
                            <p class="mb-0">Načítám strukturní data...</p>
                        </div>
                    }
                    else
                    {
                        <FacilitySchematicV2 @ref="_canvasV2"
                                      Layout="_schematicLayout"
                                      InitialFitMode="home"
                                      SelectedElementId="@SessionService.SelectedElementId"
                                      SelectedElementIds="@_selectionSet"
                                      SelectedSubtreeNodeKeys="@SelectedSubtreeNodeKeysForCanvas"
                                      FacilityNodeAlertSeverities="@AlertSeverityByNodeKey"
                                      ShowGrid="true"
                                      OnElementSelected="HandleElementSelected"
                                      OnCanvasClicked="HandleCanvasClicked"
                                      OnNodeDragEnd="HandleNodeDragEndAsync"
                                      OnRectSelectEnd="HandleRectSelectEndAsync"
                                      OnGroupDragEnd="HandleGroupDragEndAsync"
                                      OnNodeCtrlClicked="HandleNodeCtrlClickedAsync"
                                      OnKeyboardShortcut="HandleKeyboardShortcutAsync" />
                    }
                </div>
            </div>

            @* ── Properties Panel with tabs ── *@
            <div class="wb-editor-props" id="editor-props-panel">

                @* Tab header *@
                <div class="wb-editor-tabs-header">
                    @if (IsEditorMultiSelectActive)
                    {
                        <button class="wb-editor-tab @(_editorActiveTab == "layout" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("layout"))"
                                title="Rozvržení — @_selectionSet.Count uzlů vybráno">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm8 0A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5z"/></svg>
                            Layout
                            <span class="wb-editor-tab-count ms-1">@_selectionSet.Count</span>
                        </button>
                    }
                    else
                    {
                        <button class="wb-editor-tab @(_editorActiveTab == "edit" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("edit"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/></svg>
                            Edit
                        </button>
                        <button class="wb-editor-tab @(_editorActiveTab == "add" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("add"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                            Add node
                        </button>
                        <button class="wb-editor-tab @(_editorActiveTab == "delete" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("delete"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                            Delete
                        </button>
                        <button class="wb-editor-tab @(_editorActiveTab == "import" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("import"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                            Import
                        </button>
                    }
                </div>

                @* Tab content *@
                <div class="wb-editor-props-content">
                @{
                    var editorHasFocusNode = !IsEditorMultiSelectActive
                        && SessionService.SelectedElementType == EditorSelectionType.FacilityNode
                        && _selectedFacilityNode is not null;
                }

                @* ══ TAB: EDIT ══════════════════════════════════════════ *@
                @if (_editorActiveTab == "edit")
                {
                    @if (editorHasFocusNode)
                    {
                        <div class="ep-node-header">
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>
                    }
                    else
                    {
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/></svg>
                            <div>Vyberte uzel ve schématu pro editaci</div>
                        </div>
                    }
                    @if (editorHasFocusNode && CanEditFocusedNode)
                    {
                        <div class="ep-section">
                            <div class="ep-section-label">Základní info</div>
                            <div class="ep-field">
                                <label>Label / Název</label>
                                <input class="form-control form-control-sm" @bind="_editorLabelInput" maxlength="200" />
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>NodeType</label>
                                    <input class="form-control form-control-sm" @bind="_editorNodeTypeInput" maxlength="100" placeholder="subzone, meter…" />
                                </div>
                                <div class="ep-field">
                                    <label>Zone</label>
                                    <input class="form-control form-control-sm" @bind="_editorZoneInput" maxlength="100" placeholder="volitelně" />
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_selectedFacilityNode!.MeterUrn))
                            {
                                <div class="ep-field">
                                    <label>Meter URN</label>
                                    <input class="form-control form-control-sm ep-input-readonly" value="@_selectedFacilityNode.MeterUrn" readonly />
                                </div>
                            }
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">
                                <svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true"><path fill-rule="evenodd" d="M6 3.5A1.5 1.5 0 0 1 7.5 2h1A1.5 1.5 0 0 1 10 3.5v1A1.5 1.5 0 0 1 8.5 6v1H14a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0v-1A.5.5 0 0 1 2 7h5.5V6A1.5 1.5 0 0 1 6 4.5zM8.5 5a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5z"/></svg>
                                Změna parenta
                            </div>
                            <div class="ep-field">
                                <label>Aktuální parent</label>
                                <div class="ep-value-chip">@(_selectedFacilityNode!.ParentNodeKey ?? "root")</div>
                            </div>
                            <div class="ep-field">
                                <label>Nový parent</label>
                                <select class="form-select form-select-sm" @bind="_reconnectParentNodeKeyInput">
                                    <option value="">root (bez parenta)</option>
                                    @foreach (var parentCandidate in GetReconnectParentCandidates(_selectedFacilityNode.NodeKey))
                                    {
                                        <option value="@parentCandidate.NodeKey">@parentCandidate.Label (@parentCandidate.NodeKey)</option>
                                    }
                                </select>
                            </div>
                            @if (HasChildren(_selectedFacilityNode.NodeKey) && !string.Equals(_reconnectParentNodeKeyInput, _selectedFacilityNode.ParentNodeKey ?? string.Empty, StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="wb-editor-warning-box">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" class="me-1 flex-shrink-0" aria-hidden="true"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                    <div>
                                        Uzel má child uzly. Přepojením se přesunou <strong>všechny children</strong> spolu s ním.<br />
                                        <label class="d-flex align-items-center gap-2 mt-2">
                                            <input type="checkbox" @bind="_reconnectChildrenWarningConfirmed" />
                                            <span>Beru na vědomí, potvrzuji přepojení</span>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">Tagy</div>
                            @if (!string.IsNullOrWhiteSpace(_editorTagsInput))
                            {
                                <div class="wb-tag-list mb-2">
                                    @foreach (var tag in _editorTagsInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                    {
                                        <span class="wb-tag"><i class="bi bi-tag-fill me-1" style="font-size: 0.65rem;"></i>@tag</span>
                                    }
                                </div>
                            }
                            <input class="form-control form-control-sm" @bind="_editorTagsInput"
                                   placeholder="např. hvac, maintenance, zone:workshop" />
                            <div class="ep-hint">Oddělujte čárkou</div>
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">Poznámka</div>
                            <textarea class="form-control form-control-sm" rows="2" maxlength="500" @bind="_editorNoteInput" placeholder="Volitelná poznámka k uzlu..."></textarea>
                        </div>

                        <div class="ep-footer">
                            <button class="btn btn-sm btn-primary ep-btn-save"
                                    disabled="@(HasChildren(_selectedFacilityNode.NodeKey) && !string.Equals(_reconnectParentNodeKeyInput, _selectedFacilityNode.ParentNodeKey ?? string.Empty, StringComparison.OrdinalIgnoreCase) && !_reconnectChildrenWarningConfirmed)"
                                    @onclick="SaveFocusedNodeMetadataAsync">
                                @* Floppy disk / kazeta SVG *@
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true">
                                    <path d="M11 2H9v3h2z"/>
                                    <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v3.5A1.5 1.5 0 0 1 11.5 6h-7A1.5 1.5 0 0 1 3 4.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z"/>
                                </svg>
                                Uložit uzel
                            </button>
                            <button class="btn btn-sm btn-link text-decoration-none p-0 ep-btn-restore" @onclick="RestoreFocusedNodeEditorDraft">
                                Obnovit draft
                            </button>
                        </div>
                    }
                    else if (editorHasFocusNode)
                    {
                        <div class="ep-info-note">Uzel @_selectedFacilityNode!.NodeKey je kontextový a nelze ho editovat.</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_editorStatusMessage))
                    {
                        <div class="ep-status-msg">@_editorStatusMessage</div>
                    }
                }

                @* ══ TAB: ADD NODE ══════════════════════════════════════ *@
                else if (_editorActiveTab == "add")
                {
                    @if (!editorHasFocusNode || !CanEditFocusedNode)
                    {
                        <div class="ep-node-header ep-node-header-placeholder">
                            <div class="ep-node-header-label">Add node</div>
                            <div class="ep-node-header-key">Nový child uzel</div>
                        </div>
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                            <div>Vyberte uzel ve schématu — nový uzel se přidá jako jeho child.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ep-node-header">
                            <div class="ep-node-header-sublabel">Parent uzel</div>
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>
                        <div class="ep-section" id="editor-add-node-section">
                            <div class="ep-section-label">Nový child uzel</div>
                            <div class="ep-field">
                                <label>NodeKey <span class="text-danger">*</span></label>
                                <input class="form-control form-control-sm" @bind="_newNodeKeyInput" maxlength="100" placeholder="např. workshop_aux_1" />
                                <div class="ep-hint">Unikátní ID — malá písmena, podtržítko</div>
                            </div>
                            <div class="ep-field">
                                <label>Label <span class="text-danger">*</span></label>
                                <input class="form-control form-control-sm" @bind="_newNodeLabelInput" maxlength="200" placeholder="Zobrazovaný název" />
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>NodeType</label>
                                    <input class="form-control form-control-sm" @bind="_newNodeTypeInput" maxlength="100" placeholder="subzone" />
                                </div>
                                <div class="ep-field">
                                    <label>Zone</label>
                                    <input class="form-control form-control-sm" @bind="_newNodeZoneInput" maxlength="100" placeholder="volitelně" />
                                </div>
                            </div>
                            <div class="ep-field">
                                <label>Meter URN</label>
                                <input class="form-control form-control-sm" @bind="_newNodeMeterUrnInput" maxlength="200" placeholder="volitelně — vazba na měřidlo" />
                            </div>
                        </div>
                        <div class="ep-footer">
                            <button class="btn btn-sm btn-primary ep-btn-save" @onclick="AddNodeAsync">
                                <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                                Přidat child uzel
                            </button>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_structureStatusMessage))
                    {
                        <div class="ep-status-msg">@_structureStatusMessage</div>
                    }
                }

                @* ══ TAB: DELETE ════════════════════════════════════════ *@
                else if (_editorActiveTab == "delete")
                {
                    @if (!editorHasFocusNode)
                    {
                        <div class="ep-node-header ep-node-header-placeholder">
                            <div class="ep-node-header-label">Delete</div>
                            <div class="ep-node-header-key">Smazat uzel</div>
                        </div>
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                            <div>Vyberte uzel ve schématu pro smazání.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ep-node-header">
                            <div class="ep-node-header-sublabel">Vybraný uzel</div>
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>
                        @if (!CanEditFocusedNode)
                        {
                            <div class="wb-editor-warning-box">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="me-1 flex-shrink-0" aria-hidden="true"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                Tento uzel je kontextový a nelze ho smazat.
                            </div>
                        }
                        else if (HasChildren(_selectedFacilityNode!.NodeKey))
                        {
                            <div class="wb-editor-warning-box ep-warning-block">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="me-1 flex-shrink-0" aria-hidden="true"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                <div>
                                    <strong>Uzel nelze smazat.</strong><br />
                                    Uzel má child uzly. Nejdříve přepoj nebo smaž všechny children.
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="ep-section">
                                <div class="ep-section-label ep-section-label-danger">Nevratná akce</div>
                                <div class="ep-hint ep-hint-dark">Uzel bude trvale odstraněn ze struktury. Tuto akci nelze vrátit zpět.</div>
                            </div>
                            <div class="ep-footer">
                                <button class="btn btn-sm btn-danger ep-btn-save" @onclick="RemoveFocusedLeafNodeAsync">
                                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                                    Smazat uzel
                                </button>
                            </div>
                        }
                    }
                    @if (!string.IsNullOrWhiteSpace(_structureStatusMessage))
                    {
                        <div class="ep-status-msg">@_structureStatusMessage</div>
                    }
                }

                @* ══ TAB: IMPORT DATA ═══════════════════════════════════ *@
                else if (_editorActiveTab == "import")
                {
                    <div class="ep-node-header ep-node-header-placeholder">
                        <div class="ep-node-header-label">Import data</div>
                        <div class="ep-node-header-key">Napojení na zdroj dat</div>
                    </div>
                    <div class="ep-section">
                        <div class="ep-section-label">Data binding</div>
                        <div class="ep-placeholder">
                            <svg width="28" height="28" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="ep-placeholder-icon"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                            <div class="ep-placeholder-text">
                                Napojení na datový zdroj bude implementováno v pozdějším kroku.
                            </div>
                            <div class="ep-placeholder-sub">External source binding · CSV import · Meter mapping</div>
                        </div>
                    </div>
                    @if (editorHasFocusNode && !string.IsNullOrWhiteSpace(_selectedFacilityNode!.MeterUrn))
                    {
                        <div class="ep-section">
                            <div class="ep-section-label">Aktuální Meter URN</div>
                            <div class="ep-value-chip">@_selectedFacilityNode.MeterUrn</div>
                        </div>
                    }
                    <div class="ep-footer">
                        <button class="btn btn-sm btn-outline-secondary ep-btn-save" disabled title="Funkce bude dostupná v pozdějším kroku">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                            Import data
                        </button>
                    </div>
                }

                @* ══ TAB: LAYOUT ════════════════════════════════════════ *@
                else if (_editorActiveTab == "layout")
                {
                    <div class="ep-node-header ep-node-header-placeholder">
                        <div class="ep-node-header-label">Rozvržení</div>
                        <div class="ep-node-header-key">Zarovnat a rozložit uzly</div>
                    </div>
                    @if (_selectionSet.Count < 2)
                    {
                        <div class="ep-placeholder ep-layout-empty">
                            <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="ep-placeholder-icon"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm8 0A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5z"/></svg>
                            <div class="ep-placeholder-text">Vyberte 2 nebo více uzlů</div>
                            <div class="ep-placeholder-sub">Ctrl+klik pro přidání do výběru, nebo přetáhněte výběrový rámeček na prázdném místě schématu.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ep-section">
                            <div class="ep-section-label">@_selectionSet.Count uzlů vybráno</div>
                            <div class="ep-hint ep-hint-dark">Zarovnání se aplikuje na všechny vybrané uzly. Pohyb je zaznamenán do undo historii.</div>
                        </div>
                        <div class="ep-section">
                            <div class="ep-section-label">Zarovnat na osu X</div>
                            <div class="ep-align-grid">
                                <button class="ep-align-btn" @onclick="@(() => AlignSelectedNodesAsync("center-h"))" title="Zarovnat na střed (průměr X)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5V3H13a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H8.5v1H11a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H8.5v1.5a.5.5 0 0 1-1 0V13H5a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1h2.5V8H3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h4.5V1.5A.5.5 0 0 1 8 1"/></svg>
                                    Na střed X
                                </button>
                            </div>
                        </div>
                        <div class="ep-section">
                            <div class="ep-section-label">Zarovnat na osu Y</div>
                            <div class="ep-align-grid">
                                <button class="ep-align-btn" @onclick="@(() => AlignSelectedNodesAsync("center-v"))" title="Zarovnat na střed (průměr Y)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M2 8a.5.5 0 0 1 .5-.5H4V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2.5h2V6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2.5h1.5a.5.5 0 0 1 0 1H14V12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V9.5H8V12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9.5H2.5A.5.5 0 0 1 2 9z"/></svg>
                                    Na střed Y
                                </button>
                            </div>
                        </div>
                        <div class="ep-section">
                            <div class="ep-section-label">Rozložit rovnoměrně</div>
                            <div class="ep-hint ep-hint-dark">Potřeba alespoň 3 uzly. Pořadí se odvozuje od aktuální polohy.</div>
                            <div class="ep-align-grid mt-1">
                                <button class="ep-align-btn" disabled="@(_selectionSet.Count < 3)"
                                        @onclick="@(() => DistributeSelectedNodesAsync("horizontal"))"
                                        title="Rovnoměrně horizontálně (seřazeno dle X)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M2 1a1 1 0 0 1 1-1h.5a.5.5 0 0 1 0 1H3v12h.5a.5.5 0 0 1 0 1H3a1 1 0 0 1-1-1zm12 0a1 1 0 0 0-1-1h-.5a.5.5 0 0 0 0 1H13v12h-.5a.5.5 0 0 0 0 1H13a1 1 0 0 0 1-1zM6 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1z"/></svg>
                                    Horizontálně
                                </button>
                                <button class="ep-align-btn" disabled="@(_selectionSet.Count < 3)"
                                        @onclick="@(() => DistributeSelectedNodesAsync("vertical"))"
                                        title="Rovnoměrně vertikálně (seřazeno dle Y)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M1 2a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V1.5a.5.5 0 0 0-1 0V2H2V1.5a.5.5 0 0 0-1 0zm0 12a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v.5a.5.5 0 0 1-1 0V14H2v.5a.5.5 0 0 1-1 0zM4 6a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z"/></svg>
                                    Vertikálně
                                </button>
                            </div>
                        </div>
                    }
                }

                </div>@* end wb-editor-props-content *@
            </div>@* end wb-editor-props *@

            @* Discard Guard Dialog *@
            @if (_showDiscardGuard)
            {
                <div class="wb-discard-guard-overlay" @onclick="() => _showDiscardGuard = false">
                    <div class="wb-discard-guard-modal" @onclick:stopPropagation>
                        <div class="wb-discard-guard-title">&#9888; Neuložené změny</div>
                        <div class="wb-discard-guard-body">
                            Máš neuložené změny v edit mode. Chceš je zahodit a ukončit editor?
                        </div>
                        <div class="wb-discard-guard-actions">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showDiscardGuard = false">
                                Pokračovat v editaci
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="DiscardAndExitAsync">
                                Zahodit změny
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    @* ══ DASHBOARD MODE ══════════════════════════════════════════ *@
    else
    {
        @* ── Workspace Row: Schematic + Overview ── *@
        <div class="wb-workspace-row">
            <div class="wb-schematic">
                <div class="wb-schematic-toolbar">
                    <div class="toolbar-left">
                        <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schéma</span>
                        @if (_selectedFacilityNode is not null)
                        {
                            <button class="wb-focus-chip" @onclick="ClosePanel" title="Zrušit focus a výběr">
                                <i class="bi bi-crosshair2 me-1"></i>@_selectedFacilityNode.Label<i class="bi bi-x ms-1"></i>
                            </button>
                        }
                    </div>
                    <div class="toolbar-right">
                        <button class="wb-toolbar-icon-btn" @onclick="GoHomeAsync"
                                title="Domů – výchozí pohled na kořenový uzel" disabled="@(_canvasV2 is null)">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn" @onclick="() => ReloadData()" title="Znovu načíst schéma">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn"
                                @onclick="ToggleSchematicFullscreen" title="Otevřít focus – rozšířený pohled"
                                disabled="@(_facility is null)">
                            <svg class="wb-toolbar-icon-svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M1 6V1h5v1.5H2.5V6H1zm9-5h5v5h-1.5V2.5H10V1zm3.5 8.5H15V15h-5v-1.5h3.5V9.5zM6 15H1v-5h1.5v3.5H6V15z"/>
                            </svg>
                        </button>
                        <button class="wb-toolbar-icon-btn wb-toolbar-icon-btn-primary"
                                @onclick="ToggleEditMode"
                                title="Upravit schéma"
                                disabled="@(_facility is null)">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/></svg>
                        </button>
                    </div>
                </div>
                <div class="wb-schematic-body">
                    @if (_facility is null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <div class="spinner-border mb-3" role="status"></div>
                            <p class="mb-0">Načítám strukturní data...</p>
                        </div>
                    }
                    else
                    {
                        <FacilitySchematicV2 @ref="_canvasV2"
                                      Layout="_schematicLayout"
                                      InitialFitMode="home"
                                      SelectedElementId="@SessionService.SelectedElementId"
                                      SelectedElementIds="@_selectionSet"
                                      SelectedSubtreeNodeKeys="@SelectedSubtreeNodeKeysForCanvas"
                                      FacilityNodeAlertSeverities="@AlertSeverityByNodeKey"
                                      OnElementSelected="HandleElementSelected"
                                      OnCanvasClicked="HandleCanvasClicked"
                                      OnNodeDragEnd="HandleNodeDragEndAsync" />
                    }
                </div>
            </div>

            @* ── Overview Pane (Control Panel) ── *@
            <div class="wb-overview">
                @{
                    var weatherSummary = _curatedDeviationData?.WeatherExplanation;
                }

                @* ── INTERVAL — dominant top section ── *@
                <div class="cp-section cp-interval-section">
                    <div class="cp-section-label">
                        <i class="bi bi-calendar3 me-1"></i> Interval
                    </div>
                    <div class="cp-interval-range-display">@DisplayIntervalFromTo</div>
                    <div class="cp-preset-row">
                        <button class="cp-preset-btn @(_selectedInterval == "last24h" ? "cp-preset-btn-active" : "")"
                                @onclick='() => SetIntervalPreset("last24h")'>24h</button>
                        <button class="cp-preset-btn @(_selectedInterval == "last7d" ? "cp-preset-btn-active" : "")"
                                @onclick='() => SetIntervalPreset("last7d")'>7 dní</button>
                        <button class="cp-preset-btn @(_selectedInterval == "last30d" ? "cp-preset-btn-active" : "")"
                                @onclick='() => SetIntervalPreset("last30d")'>30 dní</button>
                        <button class="cp-preset-btn @(_selectedInterval == "thisMonth" ? "cp-preset-btn-active" : "")"
                                @onclick='() => SetIntervalPreset("thisMonth")'>Tento měsíc</button>
                        <button class="cp-preset-btn @(_selectedInterval == "custom" ? "cp-preset-btn-active" : "")"
                                @onclick='() => SetIntervalPreset("custom")'>Vlastní</button>
                    </div>
                    @if (_selectedInterval == "custom")
                    {
                        <div class="cp-custom-date-row">
                            <div>
                                <div class="cp-date-label">Od</div>
                                <input type="date" class="form-control form-control-sm" value="@CustomFromDateValue" @onchange="OnCustomFromChanged" />
                            </div>
                            <div>
                                <div class="cp-date-label">Do</div>
                                <input type="date" class="form-control form-control-sm" value="@CustomToDateValue" @onchange="OnCustomToChanged" />
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_customIntervalValidationMessage))
                    {
                        <div class="small text-danger mt-1">@_customIntervalValidationMessage</div>
                    }
                    @if (ShowPresetAnchorNote)
                    {
                        <div class="small text-muted mt-1">Anchor: poslední data focus uzlu</div>
                    }
                    @* Weather context — integrated into interval section *@
                    <div class="cp-weather-context">
                        <i class="bi bi-thermometer-half me-1"></i>
                        @if (SupportsWeatherExplanation(_selectedFacilityNode?.NodeKey) && weatherSummary?.IsAvailable == true)
                        {
                            <span>@GetWeatherExplanationStatusText(weatherSummary.Status) · @FormatSigned(weatherSummary.DeltaOutdoorTempC, "N1") °C delta</span>
                        }
                        else
                        {
                            <span>Weather: N/A pro aktuální focus</span>
                        }
                    </div>
                </div>

                @* ── SELECTION — compact summary ── *@
                <div class="cp-section cp-selection-section">
                    <div class="cp-section-label">Selection</div>
                    <div class="cp-selection-row">
                        <div class="cp-selection-count">
                            <span class="cp-count-big">@SelectionCount</span>
                            <span class="cp-count-label">vybraných uzlů</span>
                        </div>
                        @if (HasSelectedNodes)
                        {
                            <button class="btn btn-sm btn-outline-secondary cp-clear-btn" @onclick="ClearWorkspaceSelection" title="Zrušit celý výběr">
                                <i class="bi bi-x-lg me-1"></i>Zrušit výběr
                            </button>
                        }
                    </div>
                    @if (HasSelectedNodes)
                    {
                        var roleGroups = SelectionSummaryItems
                            .Select(n => ResolveNodeRole(n))
                            .GroupBy(r => r)
                            .OrderByDescending(g => g.Count())
                            .Take(3)
                            .ToList();
                        var totalRoleTypes = SelectionSummaryItems.Select(n => ResolveNodeRole(n)).Distinct().Count();
                        <div class="d-flex flex-wrap gap-1 mt-1">
                            @foreach (var grp in roleGroups)
                            {
                                <span class="badge rounded-pill border @GetFacilityRoleBadgeClass(grp.Key)">@grp.Count() × @GetFacilityRoleCompactLabel(grp.Key)</span>
                            }
                            @if (totalRoleTypes > 3)
                            {
                                <span class="badge rounded-pill border text-secondary-emphasis bg-light-subtle">+@(totalRoleTypes - 3) rolí</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="small text-muted mt-1">Výběr je prázdný — klikněte na uzel ve schématu.</div>
                    }
                </div>

                @* ── WORKFLOW TOOLS — Semantic Selection + Working Sets ── *@
                <div class="cp-section cp-tools-section">
                    <div class="cp-tools-tab-bar">
                        <button class="cp-tools-tab @(_workflowTab == "semantic" ? "cp-tools-tab-active" : "")"
                                @onclick='() => _workflowTab = "semantic"'>
                            <i class="bi bi-magic me-1"></i>Semantic Selection
                        </button>
                        <button class="cp-tools-tab @(_workflowTab == "workingsets" ? "cp-tools-tab-active" : "")"
                                @onclick='() => _workflowTab = "workingsets"'>
                            <i class="bi bi-bookmark-fill me-1"></i>Working Sets@(_savedWorkingSets.Count > 0 ? $" ({_savedWorkingSets.Count})" : "")
                        </button>
                    </div>

                    @if (_workflowTab == "semantic")
                    {
                        <div class="cp-tools-content">
                            @* Row 1: Preset + Mutation mode *@
                            <div class="cp-sem-row1">
                                <select class="form-select form-select-sm bg-light" @bind="_semanticPreset">
                                    @foreach (var preset in SemanticPresetOptions)
                                    {
                                        <option value="@preset">@FacilityNodeSemantics.GetPresetLabel(preset)</option>
                                    }
                                </select>
                                <select class="form-select form-select-sm bg-light" @bind="_semanticSelectionMutationMode">
                                    @foreach (var mode in SemanticSelectionMutationModeOptions)
                                    {
                                        <option value="@mode">@GetSemanticMutationModeLabel(mode)</option>
                                    }
                                </select>
                            </div>
                            @* Row 2: Role + Type *@
                            <div class="cp-sem-filters">
                                <select class="form-select form-select-sm bg-light" @bind="_semanticQueryRoleFilterValue">
                                    <option value="">Any role</option>
                                    @foreach (var role in SemanticRoleOptions)
                                    {
                                        <option value="@role">@FacilityNodeSemantics.GetRoleLabel(role)</option>
                                    }
                                </select>
                                <select class="form-select form-select-sm bg-light" @bind="_semanticQueryTypeFilterValue">
                                    <option value="">Any type</option>
                                    @foreach (var semanticType in SemanticTypeOptions)
                                    {
                                        <option value="@semanticType">@FacilityNodeSemantics.GetSemanticTypeLabel(semanticType)</option>
                                    }
                                </select>
                            </div>
                            @* Row 3: Tags *@
                            <input class="form-control form-control-sm bg-light mb-1" @bind="_semanticQueryTagInput" placeholder="Tagy (hvac, production…)" />
                            @* Row 4: Checkbox + Apply + Preset apply + Reset *@
                            <div class="cp-sem-actions">
                                <div class="cp-sem-checkbox">
                                    <input id="semantic-supported-only-cp" class="form-check-input mt-0" type="checkbox" @bind="_semanticSelectionSupportedOnly" />
                                    <label class="mb-0" for="semantic-supported-only-cp">Jen podporované</label>
                                </div>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="ApplySemanticPresetAsync" disabled="@(_facility is null)" title="Použít preset">
                                        <i class="bi bi-magic"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="ApplySemanticQueryAsync" disabled="@(_facility is null)" title="Použít filtr">
                                        <i class="bi bi-funnel"></i>
                                    </button>
                                    <button class="btn btn-sm btn-link text-decoration-none p-0 text-muted" @onclick="ClearSemanticQueryFilters" title="Reset">
                                        ×
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_semanticSelectionStatusMessage))
                            {
                                <div class="small text-muted mt-1">@_semanticSelectionStatusMessage</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="cp-tools-content">
                            @* Create row: name + optional description + save *@
                            <div class="cp-wset-create-row">
                                <input class="form-control form-control-sm bg-light" @bind="_workingSetNameInput" maxlength="80" placeholder="Název setu…" />
                                <button class="btn btn-sm btn-outline-secondary" title="Uložit aktuální selection" @onclick="SaveCurrentWorkingSetAsync" disabled="@(_facility is null)">
                                    <i class="bi bi-bookmark-plus"></i>
                                </button>
                            </div>
                            @if (_showWorkingSetDescription)
                            {
                                <input class="form-control form-control-sm bg-light mb-1" @bind="_workingSetDescriptionInput" maxlength="180" placeholder="Popis (volitelné)" />
                            }
                            <button class="btn btn-link btn-sm p-0 mb-1 cp-wset-desc-toggle" @onclick="() => _showWorkingSetDescription = !_showWorkingSetDescription">
                                @(_showWorkingSetDescription ? "− skrýt popis" : "+ popis")
                            </button>
                            @* Saved sets list *@
                            @if (_savedWorkingSets.Count == 0)
                            {
                                <div class="small text-muted mt-1">Žádné uložené sety.</div>
                            }
                            else
                            {
                                <div class="cp-wset-list">
                                    @foreach (var workingSet in _savedWorkingSets)
                                    {
                                        <div class="border rounded px-2 py-1 bg-light-subtle">
                                            <div class="d-flex justify-content-between align-items-center gap-1">
                                                <div class="small min-w-0">
                                                    <div class="fw-semibold text-dark text-truncate" style="font-size:0.78rem">@workingSet.Name</div>
                                                    <div class="text-muted" style="font-size:0.68rem">@workingSet.NodeKeys.Count n · @workingSet.UpdatedUtc.ToLocalTime().ToString("dd.MM.")</div>
                                                </div>
                                                <div class="d-flex align-items-center gap-1 flex-shrink-0">
                                                    <button class="btn btn-sm btn-outline-primary py-0 px-1" title="Aplikovat" @onclick="() => ApplyWorkingSetAsync(workingSet.Name)">
                                                        <i class="bi bi-check2-circle"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger py-0 px-1" title="Smazat" @onclick="() => DeleteWorkingSetAsync(workingSet.Name)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_workingSetStatusMessage))
                            {
                                <div class="small text-muted mt-1">@_workingSetStatusMessage</div>
                            }
                        </div>
                    }
                </div>

            </div> @* closes wb-overview *@
        </div> @* closes wb-workspace-row *@

        @* ── Analytics Section (full-width, below workspace) ── *@
        <div class="wb-analytics">

            @if (!HasSelectedNodes)
            {
                <div class="wb-analytics-empty-state">
                    <div class="analytics-empty-card">
                        <div class="analytics-empty-icon"><i class="bi bi-bar-chart-line"></i></div>
                        <div class="analytics-empty-title">Analytics připraveny</div>
                        <div class="analytics-empty-sub">
                            Vyberte uzly ve schématu pro spuštění aggregate analytics, disaggregace, KPI a časových řad.
                        </div>
                        <div class="analytics-empty-hints">
                            <div class="analytics-hint-item"><i class="bi bi-cursor-fill me-1 text-primary"></i>Klikněte na uzel — single select</div>
                            <div class="analytics-hint-item"><i class="bi bi-diagram-3-fill me-1 text-primary"></i>Klikněte na strukturální uzel — výběr celého subtree</div>
                            <div class="analytics-hint-item"><i class="bi bi-magic me-1 text-primary"></i>Použijte Semantic Selection v panelu vpravo</div>
                            <div class="analytics-hint-item"><i class="bi bi-bookmark-fill me-1 text-primary"></i>Aplikujte uložený Working Set</div>
                        </div>
                    </div>
                </div>
            }

            @if (HasSelectedNodes)
            {
            <div class="overview-grid secondary-widgets-grid">
                <div class="overview-widget overview-widget-soft secondary-breakdown-widget">
                    <h6>Disaggregation / Top Contributors</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Připravuji disaggregation a contribution intelligence...
                        </div>
                    }
                    else if (SelectionContributionIntelligence.TopContributors.Count > 0 || SelectionDisaggregation.MeasuredContributorCount > 0)
                    {
                        var disaggregation = SelectionDisaggregation;
                        var contributionIntelligence = SelectionContributionIntelligence;
                        var displayedContributors = contributionIntelligence.TopContributors.Take(3).ToList();
                        var extraContributors = contributionIntelligence.TopContributors.Skip(3).Take(8).ToList();

                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Measured included: @disaggregation.MeasuredContributorCount</span>
                            <span class="badge bg-light text-secondary border">Load: @disaggregation.ConsumptionContributorCount</span>
                            <span class="badge bg-light text-secondary border">Generation: @disaggregation.GenerationContributorCount</span>
                            @if (disaggregation.HasMixedSigns)
                            {
                                <span class="badge bg-light text-secondary border">Mixed-sign selection</span>
                            }
                            @if (SelectionAggregateNoDataCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">No-data: @SelectionAggregateNoDataCount</span>
                            }
                            @if (SelectionAggregateUnsupportedCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">Unsupported ignored: @SelectionAggregateUnsupportedCount</span>
                            }
                            @if (SelectionAggregateContextOnlyCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">Context-only excluded: @SelectionAggregateContextOnlyCount</span>
                            }
                        </div>

                        <div class="small text-muted mb-2">@disaggregation.CompositionSummary</div>
                        <div class="aggregate-status-line mb-2">@contributionIntelligence.DominantSourceSummary</div>

                        <div class="breakdown-list">
                            @foreach (var contributor in displayedContributors)
                            {
                                var sharePercent = contributor.AbsoluteSharePercent > 0
                                    ? Math.Clamp(contributor.AbsoluteSharePercent, 0.0, 100.0)
                                    : 0.0;
                                var contributionRoleLabel = GetContributionRoleText(contributor.ContributionRole);
                                var directionLabel = GetContributionDirectionText(contributor.Direction);

                                <div class="breakdown-item contributor-item">
                                    <div class="contributor-top-row">
                                        <div class="contributor-main-col">
                                            <div class="breakdown-node-label">@contributor.Label</div>
                                            <div class="contributor-badges">
                                                @contributor.NodeRoleLabel · @contributionRoleLabel · @directionLabel
                                            </div>
                                        </div>
                                        <div class="contributor-values">
                                            <div class="contributor-signed-value">@FormatSigned(contributor.IntervalEnergyKwh, "N1") kWh</div>
                                            <div class="contributor-share">share: @contributor.AbsoluteSharePercent.ToString("N1") %</div>
                                        </div>
                                    </div>
                                    <div class="breakdown-bar-track">
                                        <div class="breakdown-bar-fill" style="width: @(sharePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (contributionIntelligence.TopContributors.Count == 0)
                        {
                            <div class="small text-muted mt-2">Top contributors nejsou dostupní, protože selection nemá measured contribution s daty.</div>
                        }

                        @if (contributionIntelligence.TopContributors.Count > displayedContributors.Count)
                        {
                            <div class="small text-muted mt-2">Zobrazeni jsou top 3 contributors z @contributionIntelligence.TopContributors.Count.</div>
                        }

                        @if (extraContributors.Count > 0)
                        {
                            <details class="mt-2">
                                <summary class="small text-secondary">Další contributors (@(contributionIntelligence.TopContributors.Count - displayedContributors.Count))</summary>
                                <div class="contributor-more-list">
                                    @foreach (var extraContributor in extraContributors)
                                    {
                                        var extraSharePercent = extraContributor.AbsoluteSharePercent > 0
                                            ? Math.Clamp(extraContributor.AbsoluteSharePercent, 0.0, 100.0)
                                            : 0.0;
                                        var extraContributionRoleLabel = GetContributionRoleText(extraContributor.ContributionRole);
                                        var extraDirectionLabel = GetContributionDirectionText(extraContributor.Direction);

                                        <div class="breakdown-item contributor-item mt-1">
                                            <div class="contributor-top-row">
                                                <div class="contributor-main-col">
                                                    <div class="breakdown-node-label">@extraContributor.Label</div>
                                                    <div class="contributor-badges">
                                                        @extraContributor.NodeRoleLabel · @extraContributionRoleLabel · @extraDirectionLabel
                                                    </div>
                                                </div>
                                                <div class="contributor-values">
                                                    <div class="contributor-signed-value">@FormatSigned(extraContributor.IntervalEnergyKwh, "N1") kWh</div>
                                                    <div class="contributor-share">share: @extraContributor.AbsoluteSharePercent.ToString("N1") %</div>
                                                </div>
                                            </div>
                                            <div class="breakdown-bar-track">
                                                <div class="breakdown-bar-fill" style="width: @(extraSharePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </details>
                        }
                    }
                    else
                    {
                        <div class="small text-muted">Disaggregation se zobrazí po výběru podporovaných energetických uzlů v selection setu.</div>
                    }
                </div>

                <div class="overview-widget overview-widget-soft secondary-role-widget">
                    <h6>Role Breakdown</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Agreguji contribution podle rolí...
                        </div>
                    }
                    else if (SelectionRoleBreakdownItems.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Roles: @SelectionRoleBreakdownItems.Count</span>
                            <span class="badge bg-light text-secondary border">Included nodes: @SelectionAggregateIncludedCount</span>
                        </div>

                        <div class="breakdown-list">
                            @foreach (var roleContribution in SelectionRoleBreakdownItems.Take(6))
                            {
                                var sharePercent = roleContribution.SharePercent.HasValue
                                    ? Math.Clamp(roleContribution.SharePercent.Value, 0.0, 100.0)
                                    : 0.0;
                                var contributionRoleLabel = GetContributionRoleText(roleContribution.ContributionRole);

                                <div class="breakdown-item role-breakdown-item @(roleContribution.HasData ? string.Empty : "breakdown-item-nodata")">
                                    <div class="breakdown-header-row">
                                        <div class="role-breakdown-main">
                                            <div class="breakdown-node-label">@roleContribution.RoleLabel</div>
                                            <div class="breakdown-meta">
                                                @if (roleContribution.HasData)
                                                {
                                                    <span>@contributionRoleLabel · @roleContribution.ContributingNodeCount/@roleContribution.NodeCount uzlů</span>
                                                }
                                                else
                                                {
                                                    <span>@roleContribution.NodeCount uzlů bez použitelných dat.</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="breakdown-value-label">@FormatSigned(roleContribution.IntervalEnergyKwh, "N1") kWh</div>
                                    </div>
                                    @if (roleContribution.HasData)
                                    {
                                        <div class="breakdown-meta">
                                            share: @(roleContribution.SharePercent?.ToString("N1") ?? "0.0") %@(roleContribution.HasMixedSigns ? " · mixed-sign role" : string.Empty)
                                        </div>
                                    }
                                    @if (roleContribution.HasData)
                                    {
                                        <div class="breakdown-bar-track">
                                            <div class="breakdown-bar-fill" style="width: @(sharePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        @if (SelectionRoleBreakdownItems.Count > 6)
                        {
                            <div class="small text-muted mt-2">Zobrazeno top 6 rolí z @SelectionRoleBreakdownItems.Count.</div>
                        }
                    }
                    else
                    {
                        <div class="small text-muted">Role breakdown se zobrazí po výběru podporovaných uzlů s daty.</div>
                    }
                </div>

                <div class="overview-widget overview-widget-soft secondary-health-widget">
                    <h6>Operational Health</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Vyhodnocuji issue a anomaly signaly...
                        </div>
                    }
                    else
                    {
                        var operationalHealth = SelectionOperationalHealth;
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge @GetOperationalStatusBadgeClass(operationalHealth.Status)">@GetOperationalStatusText(operationalHealth.Status)</span>
                            <span class="badge bg-light text-secondary border">Signals: @operationalHealth.Signals.Count</span>
                        </div>
                        <div class="small text-muted mb-2">@operationalHealth.Summary</div>
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Supported: @operationalHealth.SupportedNodeCount/@operationalHealth.SelectedNodeCount</span>
                            <span class="badge bg-light text-secondary border">Included: @operationalHealth.IncludedNodeCount/@operationalHealth.SupportedNodeCount</span>
                            <span class="badge bg-light text-secondary border">Deviation H/E: @operationalHealth.HighDeviationNodeCount/@operationalHealth.ElevatedDeviationNodeCount</span>
                            <span class="badge bg-light text-secondary border">Issue U/C/ND: @operationalHealth.UnsupportedNodeCount/@operationalHealth.ContextOnlyNodeCount/@operationalHealth.NoDataNodeCount</span>
                        </div>
                        <div class="operational-point-list">
                            @foreach (var point in BuildOperationalSignalPoints(operationalHealth).Take(4))
                            {
                                <div class="operational-point">@point</div>
                            }
                        </div>
                    }
                </div>

                <div class="overview-widget overview-widget-soft secondary-coverage-widget">
                    <h6>Source Map</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Sestavuji mapu zahrnutých a vyloučených zdrojů...
                        </div>
                    }
                    else
                    {
                        var sourceMap = SelectionSourceMap;

                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Included: @sourceMap.IncludedMeasuredCount</span>
                            <span class="badge bg-light text-secondary border">Unsupported: @sourceMap.UnsupportedCount</span>
                            <span class="badge bg-light text-secondary border">No-data: @sourceMap.NoDataCount</span>
                            @if (sourceMap.ContextOnlyCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">Context-only: @sourceMap.ContextOnlyCount</span>
                            }
                        </div>

                        <div class="small text-muted mb-2">@sourceMap.Summary</div>

                        @if (sourceMap.Items.Count > 0)
                        {
                            <div class="breakdown-list">
                                @foreach (var item in sourceMap.Items.Take(6))
                                {
                                    var categoryBadgeClass = GetSourceMapCategoryBadgeClass(item.Category);
                                    <div class="breakdown-item">
                                        <div class="breakdown-header-row">
                                            <div class="d-flex align-items-center gap-2 min-w-0">
                                                <div class="breakdown-node-label">@item.Label</div>
                                                <span class="badge @categoryBadgeClass">@item.CategoryLabel</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (sourceMap.Items.Count > 6)
                            {
                                <div class="small text-muted mt-2">Zobrazeno 6 položek ze source map (@sourceMap.Items.Count celkem).</div>
                            }
                        }

                        <div class="aggregate-status-line mt-2">
                            Coverage ratio: @((SelectionOperationalHealth.IncludedCoverageRatio * 100.0).ToString("N0")) % podporovaných uzlů je analyticky zahrnuto.
                        </div>
                    }
                </div>

                <div class="overview-widget overview-widget-soft secondary-compare-widget">
                    <h6>Compare Set</h6>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <span class="badge bg-light text-secondary border">@_compareSet.Count/@MaxCompareSetSize v compare</span>
                        <span class="badge bg-light text-secondary border">@SelectionCompareSupportedCount kandidátů</span>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <button class="btn btn-sm btn-outline-primary" @onclick="AddSelectionSetToCompareSet" disabled="@(!CanAddSelectionSetToCompareSet)">
                            <i class="bi bi-plus-circle me-1"></i> Přidat selection set do porovnání
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ClearCompareSet" disabled="@(_compareSet.Count == 0)">
                            Vyčistit
                        </button>
                    </div>
                    <div class="small text-muted mb-2">Volná kapacita: @CompareSetRemainingCapacity</div>
                    @if (!string.IsNullOrWhiteSpace(_compareSetStatusMessage))
                    {
                        <div class="small text-muted mb-2">@_compareSetStatusMessage</div>
                    }
                    @if (_compareSet.Count == 0)
                    {
                        <div class="small text-muted">Compare set je prázdný.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var item in _compareSet)
                            {
                                <span class="badge rounded-pill border text-secondary-emphasis bg-white">@item.Label</span>
                            }
                        </div>
                    }
                </div>
            </div>
            }

            @if (HasSelectedNodes)
            {
                <div class="overview-grid main-analytics-grid">
                    <div class="overview-widget main-kpi-widget">
                        <h6>Headline KPI</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Načítám aggregate KPI...
                            </div>
                        }
                        else if (_selectionAggregateOverview?.Summary is not null)
                        {
                            <div class="metric-value">
                                @if (_selectionAggregateOverview.IsNetHeadline)
                                {
                                    @FormatSigned(_selectionAggregateOverview.HeadlineValueKwh, "N1") <span class="fs-6 text-muted">kWh</span>
                                }
                                else
                                {
                                    @_selectionAggregateOverview.HeadlineValueKwh.ToString("N1") <span class="fs-6 text-muted">kWh</span>
                                }
                            </div>
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div class="metric-caption">@_selectionAggregateOverview.HeadlineLabel</div>
                                <span class="badge bg-light text-secondary border">@_selectionAggregateOverview.Summary.StatsUnit</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview.HeadlineDescription))
                            {
                                <div class="small text-muted mb-2">@_selectionAggregateOverview.HeadlineDescription</div>
                            }
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="badge bg-light text-secondary border">Supported: @SelectionAggregateSupportedCount</span>
                                <span class="badge bg-light text-secondary border">Included: @SelectionAggregateIncludedCount</span>
                                @if (SelectionAggregateUnsupportedCount > 0)
                                {
                                    <span class="badge bg-light text-secondary border">Unsupported: @SelectionAggregateUnsupportedCount</span>
                                }
                                @if (SelectionAggregateNoDataCount > 0)
                                {
                                    <span class="badge bg-light text-secondary border">No-data: @SelectionAggregateNoDataCount</span>
                                }
                            </div>
                            <div class="headline-kpi-grid">
                                <div class="headline-kpi-cell"><div class="metric-caption">Spotřeba</div><div class="fw-semibold">@_selectionAggregateOverview.TotalConsumptionKwh.ToString("N1") kWh</div></div>
                                <div class="headline-kpi-cell"><div class="metric-caption">Výroba</div><div class="fw-semibold">@_selectionAggregateOverview.TotalGenerationKwh.ToString("N1") kWh</div></div>
                                <div class="headline-kpi-cell"><div class="metric-caption">Netto</div><div class="fw-semibold">@FormatSigned(_selectionAggregateOverview.NetEnergyKwh, "N1") kWh</div></div>
                                <div class="headline-kpi-cell"><div class="metric-caption">Samples</div><div class="fw-semibold">@_selectionAggregateOverview.Summary.DataPoints.ToString("N0")</div></div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview.Message))
                            {
                                <div class="aggregate-status-line mt-2">@_selectionAggregateOverview.Message</div>
                            }
                        }
                        else
                        {
                            <div class="small text-muted">Pro aktuální selection set není aggregate KPI dostupné.</div>
                            @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview?.Message))
                            {
                                <div class="aggregate-status-line mt-2">@_selectionAggregateOverview.Message</div>
                            }
                        }
                    </div>

                    <div class="overview-widget chart-widget main-chart-widget">
                        <h6>Hlavní vizualizace</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Připravuji aggregate časovou řadu...
                            </div>
                        }
                        else if (_selectionAggregateOverview?.TimeSeries is not null)
                        {
                            <FacilityTimeSeriesPanel Data="@_selectionAggregateOverview.TimeSeries"
                                                    SelectedMode="@_timeSeriesMode"
                                                    ShowBaselineOverlay="@_showBaselineOverlay"
                                                    ShowBaselineOverlayChanged="OnShowBaselineOverlayChanged"
                                                    SelectedModeChanged="OnTimeSeriesModeChanged" />
                        }
                        else
                        {
                            <div class="small text-muted">Selection set neobsahuje kompatibilní uzly s dostupnou časovou řadou.</div>
                            @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview?.Message))
                            {
                                <div class="aggregate-status-line mt-2">@_selectionAggregateOverview.Message</div>
                            }
                        }
                    </div>
                </div>

                <div class="overview-grid forecast-analytics-grid">
                    <div class="overview-widget chart-widget forecast-compare-widget">
                        <h6>Forecast vs Actual</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Připravuji forecast porovnání...
                            </div>
                        }
                        else if (SelectionForecastCompareTimeSeries is not null)
                        {
                            <FacilityCompareTimeSeriesPanel Data="@SelectionForecastCompareTimeSeries" />
                        }
                        else
                        {
                            <div class="small text-muted">@SelectionForecastDiagnostics.Summary</div>
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft forecast-diagnostics-widget">
                        <h6>Forecast Diagnostics</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Počítám error metriky forecastu...
                            </div>
                        }
                        else
                        {
                            var forecastDiagnostics = SelectionForecastDiagnostics;

                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge @GetForecastStatusBadgeClass(forecastDiagnostics.Status)">@GetForecastStatusText(forecastDiagnostics.Status)</span>
                                <span class="badge bg-light text-secondary border">Aligned: @forecastDiagnostics.AlignedPointCount/@forecastDiagnostics.ActualPointCount</span>
                            </div>

                            <div class="small text-muted mb-2">@forecastDiagnostics.Summary</div>

                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="badge bg-light text-secondary border">MAE: @FormatForecastMetric(forecastDiagnostics.MaeKw) kW</span>
                                <span class="badge bg-light text-secondary border">RMSE: @FormatForecastMetric(forecastDiagnostics.RmseKw) kW</span>
                                <span class="badge bg-light text-secondary border">Bias: @FormatSigned(forecastDiagnostics.BiasKw, "N2") kW</span>
                                <span class="badge bg-light text-secondary border">WAPE: @(forecastDiagnostics.WapePercent?.ToString("N1") ?? "N/A") %</span>
                            </div>

                            <div class="forecast-diagnostics-list">
                                @foreach (var point in BuildForecastDiagnosticsPoints(forecastDiagnostics).Take(4))
                                {
                                    <div class="forecast-diagnostics-point">@point</div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="overview-grid operational-intelligence-grid">
                    <div class="overview-widget overview-widget-soft">
                        <h6>Load Profile</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Sestavuji load profile...
                            </div>
                        }
                        else
                        {
                            var loadProfile = SelectionLoadProfile;
                            if (loadProfile.IsAvailable && loadProfile.Buckets.Count > 0)
                            {
                                var maxAbsBucket = loadProfile.Buckets.Max(bucket => Math.Abs(bucket.AverageKw));
                                var displayedBuckets = loadProfile.Buckets
                                    .OrderByDescending(bucket => Math.Abs(bucket.AverageKw))
                                    .ThenBy(bucket => bucket.BucketIndex)
                                    .Take(8)
                                    .ToList();

                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    <span class="badge @GetLoadProfileModeBadgeClass(loadProfile.Mode)">@loadProfile.ModeLabel</span>
                                    <span class="badge bg-light text-secondary border">Body: @loadProfile.PointCount</span>
                                    <span class="badge bg-light text-secondary border">Dny: @loadProfile.DistinctDayCount</span>
                                    @if (loadProfile.HasMixedSigns)
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis border">Mixed-sign</span>
                                    }
                                </div>

                                <div class="small text-muted mb-2">@loadProfile.Summary</div>

                                <div class="profile-bucket-list mb-2">
                                    @foreach (var bucket in displayedBuckets)
                                    {
                                        var fillPercent = maxAbsBucket > 0
                                            ? (Math.Abs(bucket.AverageKw) / maxAbsBucket) * 100.0
                                            : 0.0;

                                        <div class="profile-bucket-row">
                                            <div class="profile-bucket-label">@bucket.Label</div>
                                            <div class="profile-bucket-track">
                                                <div class="profile-bucket-fill" style="width: @(fillPercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                            </div>
                                            <div class="profile-bucket-value">@FormatSigned(bucket.AverageKw, "N2") kW</div>
                                        </div>
                                    }
                                </div>

                                <div class="small text-muted">@loadProfile.DifferenceFromMainChart</div>
                            }
                            else
                            {
                                <div class="small text-muted">@loadProfile.Summary</div>
                            }
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft">
                        <h6>Peak Analysis</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Vyhodnocuji peak eventy...
                            </div>
                        }
                        else
                        {
                            var peakAnalysis = SelectionPeakAnalysis;
                            if (peakAnalysis.IsAvailable)
                            {
                                var peakEvents = new[]
                                {
                                    peakAnalysis.DemandPeak,
                                    peakAnalysis.GenerationPeak,
                                    peakAnalysis.NetAbsolutePeak
                                };

                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    <span class="badge @GetPeakSignificanceBadgeClass(peakAnalysis.SignificanceLevel)">@GetPeakSignificanceText(peakAnalysis.SignificanceLevel)</span>
                                    <span class="badge bg-light text-secondary border">Ratio: @(peakAnalysis.SignificanceRatio?.ToString("N2") ?? "N/A")x</span>
                                    @if (peakAnalysis.HasMixedSigns)
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis border">Mixed-sign</span>
                                    }
                                </div>

                                <div class="small text-muted mb-2">@peakAnalysis.Summary</div>

                                <div class="breakdown-list mb-2">
                                    @foreach (var peakEvent in peakEvents.Where(item => item.IsAvailable))
                                    {
                                        <div class="breakdown-item">
                                            <div class="breakdown-header-row">
                                                <div class="breakdown-node-label">@peakEvent.Label</div>
                                                <div class="breakdown-value-label">@FormatSigned(peakEvent.ValueKw, "N2") kW</div>
                                            </div>
                                            <div class="breakdown-meta">@FormatPeakTimestamp(peakEvent.TimestampUtc)</div>
                                        </div>
                                    }
                                </div>

                                <div class="small text-muted">@peakAnalysis.Methodology</div>
                            }
                            else
                            {
                                <div class="small text-muted">@peakAnalysis.Summary</div>
                            }
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft">
                        <h6>Operating Regime</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Vyhodnocuji operating regime...
                            </div>
                        }
                        else
                        {
                            var operatingRegime = SelectionOperatingRegime;
                            if (operatingRegime.IsAvailable)
                            {
                                <div class="small text-muted mb-2">@operatingRegime.Summary</div>

                                <div class="micro-grid mb-2">
                                    <div class="micro-kpi"><div class="metric-caption">Baseload proxy</div><div class="fw-semibold">@FormatSigned(operatingRegime.BaseloadKw, "N2") kW</div></div>
                                    <div class="micro-kpi"><div class="metric-caption">Peak / Avg</div><div class="fw-semibold">@(operatingRegime.PeakToAverageRatio?.ToString("N2") ?? "N/A")x</div></div>
                                    <div class="micro-kpi"><div class="metric-caption">Variability (CV)</div><div class="fw-semibold">@(operatingRegime.VariabilityCoefficient?.ToString("N2") ?? "N/A")</div></div>
                                    <div class="micro-kpi"><div class="metric-caption">Weekday vs Weekend</div><div class="fw-semibold">@FormatSigned(operatingRegime.WeekdayWeekendDeltaPercent, "N1") %</div></div>
                                </div>

                                <div class="operational-point-list mb-2">
                                    @foreach (var point in BuildOperatingRegimeSignalPoints(operatingRegime).Take(4))
                                    {
                                        <div class="operational-point">@point</div>
                                    }
                                </div>

                                <div class="small text-muted">@operatingRegime.Methodology</div>
                            }
                            else
                            {
                                <div class="small text-muted">@operatingRegime.Summary</div>
                            }
                        }
                    </div>
                </div>

                <div class="overview-grid ems-evaluation-grid">
                    <div class="overview-widget overview-widget-soft">
                        <h6>EMS Operational Scorecards</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Vyhodnocuji EMS scorecards...
                            </div>
                        }
                        else
                        {
                            var ems = SelectionEmsEvaluation;
                            if (ems.IsAvailable && ems.Scorecards.Count > 0)
                            {
                                <div class="small text-muted mb-2">@ems.Summary</div>

                                <div class="ems-scorecard-list mb-2">
                                    @foreach (var card in ems.Scorecards)
                                    {
                                        <div class="ems-scorecard-item">
                                            <div class="ems-item-header">
                                                <div class="ems-item-title">@card.Label</div>
                                                <span class="badge @GetScorecardStatusBadgeClass(card.Status)">@GetScorecardStatusText(card.Status)</span>
                                            </div>
                                            <div class="ems-item-summary">@card.Summary</div>
                                            @if (!string.IsNullOrWhiteSpace(card.MetricLabel))
                                            {
                                                <div class="ems-item-meta">@card.MetricLabel: @card.MetricDisplay</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(card.Thresholds))
                                            {
                                                <div class="ems-item-meta">Thresholds: @card.Thresholds</div>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="small text-muted">@ems.Methodology</div>
                            }
                            else
                            {
                                <div class="small text-muted">@ems.Summary</div>
                            }
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft">
                        <h6>Schedule Inefficiency</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Kontroluji schedule inefficiency signály...
                            </div>
                        }
                        else
                        {
                            var ems = SelectionEmsEvaluation;
                            if (ems.IsAvailable)
                            {
                                if (ems.Inefficiencies.Count > 0)
                                {
                                    <div class="ems-inefficiency-list mb-2">
                                        @foreach (var inefficiency in ems.Inefficiencies.Take(4))
                                        {
                                            <div class="ems-inefficiency-item">
                                                <div class="ems-item-header">
                                                    <div class="ems-item-title">@inefficiency.Label</div>
                                                    <span class="badge @GetInefficiencySeverityBadgeClass(inefficiency.Severity)">@GetInefficiencySeverityText(inefficiency.Severity)</span>
                                                </div>
                                                <div class="ems-item-summary">@inefficiency.Summary</div>
                                                @if (!string.IsNullOrWhiteSpace(inefficiency.Evidence))
                                                {
                                                    <div class="ems-item-meta">Evidence: @inefficiency.Evidence</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="small text-muted mb-2">V aktuálním intervalu není detekována výrazná schedule inefficiency.</div>
                                }

                                <div class="small text-muted">@ems.DistinctionNote</div>
                            }
                            else
                            {
                                <div class="small text-muted">@ems.Summary</div>
                            }
                        }
                    </div>

                    <div class="overview-widget overview-widget-soft">
                        <h6>Opportunity Summary</h6>
                        @if (_isPreviewLoading)
                        {
                            <div class="text-muted d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span> Skládám opportunity kandidáty...
                            </div>
                        }
                        else
                        {
                            var ems = SelectionEmsEvaluation;
                            if (ems.IsAvailable && ems.Opportunities.Count > 0)
                            {
                                <div class="ems-opportunity-list mb-2">
                                    @foreach (var opportunity in ems.Opportunities.Take(3))
                                    {
                                        <div class="ems-opportunity-item">
                                            <div class="ems-item-summary">@opportunity</div>
                                        </div>
                                    }
                                </div>

                                <div class="d-flex flex-wrap gap-2">
                                    @if (ems.HasMixedSigns)
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis border">Mixed-sign selection</span>
                                    }
                                    @if (ems.HasGeneration)
                                    {
                                        <span class="badge bg-success-subtle text-success-emphasis border">Generation-aware</span>
                                    }
                                    @if (ems.HasConsumption)
                                    {
                                        <span class="badge bg-warning-subtle text-warning-emphasis border">Load-aware</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="small text-muted">@ems.Summary</div>
                            }
                        }
                    </div>
                </div>

                @if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _selectedFacilityNode is not null)
                {
                    @if (_isCuratedNode)
                    {
                        <div class="overview-grid">
                            <div class="overview-widget widget-col-6">
                                <h6>Deviation / Baseline Detail</h6>
                                @if (_isPreviewLoading)
                                {
                                    <div class="text-muted d-flex align-items-center">
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span> Vyhodnocuji baseline...
                                    </div>
                                }
                                else if (_curatedDeviationData?.IsAvailable == true)
                                {
