    private static string NormalizeNodeSearchText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value
            .Where(character => character != '.' && character != '_' && !char.IsWhiteSpace(character))
            .ToArray())
            .ToLowerInvariant();
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> FilterNodeSearchResults(
        IEnumerable<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> candidates,
        string? searchText)
    {
        var normalizedSearch = NormalizeNodeSearchText(searchText);

        var filteredCandidates = candidates
            .Where(node => string.IsNullOrWhiteSpace(normalizedSearch)
                || NormalizeNodeSearchText(node.NodeKey).Contains(normalizedSearch, StringComparison.Ordinal)
                || NormalizeNodeSearchText(node.Label).Contains(normalizedSearch, StringComparison.Ordinal));

        if (!string.IsNullOrWhiteSpace(normalizedSearch))
        {
            filteredCandidates = filteredCandidates.Take(NodeSearchResultLimit);
        }

        return filteredCandidates.ToList();
    }

