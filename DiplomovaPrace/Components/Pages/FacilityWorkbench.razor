    private void ToggleEditorTag(string tag)
    {
        if (_editorTagsSelected.Contains(tag))
        {
            _editorTagsSelected.Remove(tag);
            SyncEditorTagsInputFromSelected();
            return;
        }

        if (_editorTagsSelected.Count >= MaxTagsPerNode)
