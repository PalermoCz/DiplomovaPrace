        _styleStatusMessage = $"Node {_selectedFacilityNode.NodeKey} now uses preset {GetCurrentStylePresetLabel()}.";
        await ReloadData(preserveSelection: true, preferredFocusNodeKey: _selectedFacilityNode.NodeKey);
        await InvokeAsync(StateHasChanged);
