@page "/"
@page "/facility"
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@using DiplomovaPrace.Services
@using DiplomovaPrace.Persistence.Schematic
@using DiplomovaPrace.Components.Editor
@rendermode InteractiveServer
@inject FacilityQueryService FacilityQueryService
@inject FacilityEditorStateService FacilityEditorStateService
@inject FacilityDataBindingRegistry BindingRegistry
@inject FacilityNodeSeriesImportService NodeSeriesImportService
@inject NodeAnalyticsPreviewService AnalyticsPreview
@inject IEditorSessionService SessionService
@inject IJSRuntime JSRuntime
@layout DiplomovaPrace.Components.Layout.FacilityLayout
@implements IDisposable

<PageTitle>Facility Schematic</PageTitle>

@* Layout CSS is in FacilityWorkbench.razor.css (scoped) *@

<div class="facility-workbench">

    @* ══ FOCUS MODE OVERLAY ══════════════════════════════════════ *@
    @if (_isSchematicFullscreen)
    {
        <div class="wb-focus-overlay">
            <div class="wb-schematic">
                <div class="wb-schematic-toolbar">
                    <div class="toolbar-left">
                        <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schematic</span>
                        <span class="badge bg-secondary-subtle text-secondary border"><i class="bi bi-arrows-fullscreen me-1"></i>Focus</span>
                    </div>
                    <div class="toolbar-right">
                        <div class="wb-node-search">
                            <input class="form-control form-control-sm wb-node-search-input"
                                   @bind="_globalNodeSearchInput"
                                   @bind:event="oninput"
                                   @onfocus="OpenGlobalNodeSearch"
                                @onblur="CloseGlobalNodeSearch"
                                   placeholder="Search node"
                                   aria-label="Search node" />
                            @if (ShouldShowGlobalNodeSearchResults)
                            {
                                <div class="wb-node-search-results">
                                    @if (GetGlobalNodeSearchMatches().Count == 0)
                                    {
                                        <div class="wb-node-search-empty">No matches</div>
                                    }
                                    else
                                    {
                                        @foreach (var nodeMatch in GetGlobalNodeSearchMatches())
                                        {
                                            <button type="button"
                                                    class="wb-node-search-result"
                                                    @onmousedown:preventDefault="true"
                                                    @onclick="@(() => FocusNodeFromSearchAsync(nodeMatch.NodeKey))">
                                                <span class="wb-node-search-result-label">@GetNodeDisplayLabel(nodeMatch)</span>
                                                <span class="wb-node-search-result-key">@nodeMatch.NodeKey</span>
                                            </button>
                                        }
                                    }
                                </div>
                            }
                        </div>
                        <button class="wb-toolbar-icon-btn" @onclick="GoHomeAsync"
                                title="Default view" disabled="@(_canvasV2 is null)">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn" @onclick="() => ReloadData()" title="Reload schematic">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn"
                                @onclick="ToggleSchematicFullscreen" title="Close focus view">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M5.5 0a.5.5 0 0 1 .5.5v4A1.5 1.5 0 0 1 4.5 6h-4a.5.5 0 0 1 0-1h4a.5.5 0 0 0 .5-.5v-4a.5.5 0 0 1 .5-.5m5 0a.5.5 0 0 1 .5.5v4a.5.5 0 0 0 .5.5h4a.5.5 0 0 1 0 1h-4A1.5 1.5 0 0 1 10 4.5v-4a.5.5 0 0 1 .5-.5M0 10.5a.5.5 0 0 1 .5-.5h4A1.5 1.5 0 0 1 6 11.5v4a.5.5 0 0 1-1 0v-4a.5.5 0 0 0-.5-.5h-4a.5.5 0 0 1-.5-.5m10 1a1.5 1.5 0 0 1 1.5-1.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 0-.5.5v4a.5.5 0 0 1-1 0z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn wb-toolbar-icon-btn-primary"
                                @onclick="ToggleEditMode" title="Edit schematic" disabled="@(_facility is null)">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/></svg>
                        </button>
                    </div>
                </div>
                <div class="wb-schematic-body">
                    @if (_facility is null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <div class="spinner-border mb-3" role="status"></div>
                            <p class="mb-0">Loading structural data...</p>
                        </div>
                    }
                    else
                    {
                        <FacilitySchematicV2 @ref="_canvasV2"
                                      Layout="_schematicLayout"
                                      InitialFitMode="focus"
                                      SelectedElementId="@SessionService.SelectedElementId"
                                      SelectedElementIds="@ResolvedSelectionNodeKeysForCanvas"
                                      SelectedSubtreeNodeKeys="@VisualHighlightNodeKeysForCanvas"
                                      NodeStylePresetKeysByNodeKey="@EffectiveNodeStylePresetKeysForCanvas"
                                      NodeStylePresetLabelsByNodeKey="@EffectiveNodeStylePresetLabelsForCanvas"
                                      NodeTagsByNodeKey="@EffectiveNodeTagPreviewForCanvas"
                                      NodeNotesByNodeKey="@EffectiveNodeNotePreviewForCanvas"
                                      StylePresetsByKey="@EffectiveStylePresetsForCanvas"
                                      OnElementSelected="HandleElementSelected"
                                      OnCanvasClicked="HandleCanvasClicked"
                                      OnNodeDragEnd="HandleNodeDragEndAsync" />
                    }
                </div>
            </div>
        </div>
    }
    @* ══ EDIT MODE OVERLAY ═══════════════════════════════════════ *@
    else if (_isEditModeOpen)
    {
        <div class="wb-editor-overlay">
            @* Canvas area *@
            <div class="wb-schematic">
                <div class="wb-schematic-toolbar wb-editor-toolbar">
                    <div class="toolbar-left">
                        <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schematic</span>
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><i class="bi bi-pencil-fill me-1"></i>Edit Mode</span>
                    </div>
                    <div class="toolbar-right wb-editor-toolbar-right">
                        <div class="wb-node-search">
                            <input class="form-control form-control-sm wb-node-search-input"
                                   @bind="_globalNodeSearchInput"
                                   @bind:event="oninput"
                                   @onfocus="OpenGlobalNodeSearch"
                                @onblur="CloseGlobalNodeSearch"
                                   placeholder="Search node"
                                   aria-label="Search node" />
                            @if (ShouldShowGlobalNodeSearchResults)
                            {
                                <div class="wb-node-search-results">
                                    @if (GetGlobalNodeSearchMatches().Count == 0)
                                    {
                                        <div class="wb-node-search-empty">No matches</div>
                                    }
                                    else
                                    {
                                        @foreach (var nodeMatch in GetGlobalNodeSearchMatches())
                                        {
                                            <button type="button"
                                                    class="wb-node-search-result"
                                                    @onmousedown:preventDefault="true"
                                                    @onclick="@(() => FocusNodeFromSearchAsync(nodeMatch.NodeKey))">
                                                <span class="wb-node-search-result-label">@GetNodeDisplayLabel(nodeMatch)</span>
                                                <span class="wb-node-search-result-key">@nodeMatch.NodeKey</span>
                                            </button>
                                        }
                                    }
                                </div>
                            }
                        </div>
                        @* ── View tools ── *@
                        <button class="wb-toolbar-icon-btn" @onclick="GoHomeAsync"
                            title="Default view" disabled="@(_canvasV2 is null)">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn" @onclick="() => ReloadData()" title="Reload schematic">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <div class="wb-editor-toolbar-divider"></div>
                        @* ── Structure tools ── *@
                        <button class="wb-toolbar-icon-btn @(_editorActiveTab == "add" ? "wb-toolbar-icon-btn-active" : "")"
                                title="@(_selectedFacilityNode is not null && CanEditFocusedNode ? $"Add child node under '{_selectedFacilityNode.Label}'" : "Add node")"
                            disabled="@IsEditorMultiSelectActive"
                                @onclick="@(() => SwitchEditorTab("add"))">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn @(_editorActiveTab == "delete" ? "wb-toolbar-icon-btn-active" : "") @(CanRemoveFocusedLeafNode ? "wb-toolbar-icon-btn-danger" : "")"
                                title="Delete selected node"
                            disabled="@IsEditorMultiSelectActive"
                                @onclick="@(() => SwitchEditorTab("delete"))">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                        </button>
                        <div class="wb-editor-toolbar-divider"></div>
                        @* ── Undo / Redo ── *@
                        <button class="wb-toolbar-icon-btn"
                            title="@(_editModeCanUndo ? ("Undo: " + (_editUndoStack.Count > 0 ? _editUndoStack[^1].Description : "")) : "Undo - no change")"
                                disabled="@(!_editModeCanUndo)"
                                @onclick="UndoEditAsync">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 1-4.546 2.914.5.5 0 0 0-.908-.417A6 6 0 1 0 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 0-.41-.192L5.23 2.308a.25.25 0 0 0 0 .384l2.36 1.966A.25.25 0 0 0 8 4.466"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn"
                            title="@(_editModeCanRedo ? ("Redo: " + (_editRedoStack.Count > 0 ? _editRedoStack[^1].Description : "")) : "Redo - nothing to restore")"
                                disabled="@(!_editModeCanRedo)"
                                @onclick="RedoEditAsync">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <div class="wb-editor-toolbar-divider"></div>
                        @* ── Import Data ── *@
                        <button class="wb-toolbar-icon-btn @(_editorActiveTab == "import" ? "wb-toolbar-icon-btn-active" : "")"
                                title="Import data"
                            disabled="@IsEditorMultiSelectActive"
                                @onclick="@(() => SwitchEditorTab("import"))">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                        </button>
                        @* ── Spacer ── *@
                        <div class="wb-editor-toolbar-spacer"></div>
                        @* ── Save ── *@
                        <button class="wb-toolbar-icon-btn @(EditModeDirty ? "wb-toolbar-icon-btn-save-dirty" : "")"
                            title="@(EditModeDirty ? "Save changes (unsaved edits)" : "Save changes")"
                                @onclick="SaveEditModeChangesAsync">
                            @* Floppy disk / kazeta — proper SVG *@
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M11 2H9v3h2z"/>
                                <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v3.5A1.5 1.5 0 0 1 11.5 6h-7A1.5 1.5 0 0 1 3 4.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z"/>
                            </svg>
                        </button>
                        @* ── Close editor ── *@
                        <button class="wb-toolbar-icon-btn wb-toolbar-icon-btn-close"
                            title="Close editor"
                                @onclick="ExitSchematicOverlayAsync">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/></svg>
                        </button>
                    </div>
                </div>
                <div class="wb-schematic-body">
                    @if (_facility is null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <div class="spinner-border mb-3" role="status"></div>
                            <p class="mb-0">Loading structural data...</p>
                        </div>
                    }
                    else
                    {
                        <FacilitySchematicV2 @ref="_canvasV2"
                                      Layout="_schematicLayout"
                                      InitialFitMode="home"
                                      SelectedElementId="@SessionService.SelectedElementId"
                                      SelectedElementIds="@ResolvedSelectionNodeKeysForCanvas"
                                      SelectedSubtreeNodeKeys="@VisualHighlightNodeKeysForCanvas"
                                      NodeStylePresetKeysByNodeKey="@EffectiveNodeStylePresetKeysForCanvas"
                                      NodeStylePresetLabelsByNodeKey="@EffectiveNodeStylePresetLabelsForCanvas"
                                      NodeTagsByNodeKey="@EffectiveNodeTagPreviewForCanvas"
                                      NodeNotesByNodeKey="@EffectiveNodeNotePreviewForCanvas"
                                      StylePresetsByKey="@EffectiveStylePresetsForCanvas"
                                      ShowGrid="true"
                                      OnElementSelected="HandleElementSelected"
                                      OnCanvasClicked="HandleCanvasClicked"
                                      OnNodeDragEnd="HandleNodeDragEndAsync"
                                      OnRectSelectEnd="HandleRectSelectEndAsync"
                                      OnGroupDragEnd="HandleGroupDragEndAsync"
                                      OnNodeCtrlClicked="HandleNodeCtrlClickedAsync"
                                      OnKeyboardShortcut="HandleKeyboardShortcutAsync" />
                    }
                </div>
            </div>

            @* ── Properties Panel with tabs ── *@
            <div class="wb-editor-props" id="editor-props-panel">

                @* Tab header *@
                <div class="wb-editor-tabs-header">
                    @if (IsEditorMultiSelectActive)
                    {
                        <button class="wb-editor-tab @(_editorActiveTab == "layout" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("layout"))"
                                title="Layout - @_selectionSet.Count nodes selected">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm8 0A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5z"/></svg>
                            Layout
                            <span class="wb-editor-tab-count ms-1">@_selectionSet.Count</span>
                        </button>
                    }
                    else
                    {
                        <button class="wb-editor-tab @(_editorActiveTab == "edit" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("edit"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/></svg>
                            Edit
                        </button>
                        <button class="wb-editor-tab @(_editorActiveTab == "add" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("add"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                            Add node
                        </button>
                        <button class="wb-editor-tab @(_editorActiveTab == "delete" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("delete"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                            Delete
                        </button>
                        <button class="wb-editor-tab @(_editorActiveTab == "import" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("import"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                            Import
                        </button>
                        <button class="wb-editor-tab @(_editorActiveTab == "style" ? "wb-editor-tab-active" : "")"
                                @onclick="@(() => SwitchEditorTab("style"))">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12 .25a.75.75 0 0 1 .75.75v2.112a2.75 2.75 0 0 1 1.47 3.78l-4.1 7.38A1.75 1.75 0 0 1 8.59 15H4.75A1.75 1.75 0 0 1 3 13.25v-1.586a1.75 1.75 0 0 1 .256-.91l4.19-6.984A2.75 2.75 0 0 1 10.25 1.1V1A.75.75 0 0 1 11 .25zm-.25 4.5a1.25 1.25 0 0 0-1.072.608l-4.19 6.985a.25.25 0 0 0-.038.128v.779h2.14l4.063-7.314A1.25 1.25 0 0 0 11.75 4.75"/></svg>
                            Style
                        </button>
                    }
                </div>

                @* Tab content *@
                <div class="wb-editor-props-content">
                @{
                    var editorHasFocusNode = !IsEditorMultiSelectActive
                        && SessionService.SelectedElementType == EditorSelectionType.FacilityNode
                        && _selectedFacilityNode is not null;
                }

                @* ══ TAB: EDIT ══════════════════════════════════════════ *@
                @if (_editorActiveTab == "edit")
                {
                    @if (editorHasFocusNode)
                    {
                        <div class="ep-node-header">
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>
                    }
                    else
                    {
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/></svg>
                            <div>Select a node in the schematic to edit it</div>
                        </div>
                    }
                    @if (editorHasFocusNode && CanEditFocusedNode)
                    {
                        <div class="ep-section">
                            <div class="ep-section-label">Basic Info</div>
                            <div class="ep-field">
                                <label>Label</label>
                                <input class="form-control form-control-sm" @bind="_editorLabelInput" maxlength="200" />
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>NodeType</label>
                                        <input class="form-control form-control-sm" list="facility-node-type-suggestions-edit" autocomplete="off" @bind="_editorNodeTypeInput" maxlength="100" placeholder="area, bus, weather, or custom" />
                                    <datalist id="facility-node-type-suggestions-edit">
                                        @foreach (var suggestion in BuiltInNodeTypeSuggestions)
                                        {
                                            <option value="@suggestion"></option>
                                        }
                                    </datalist>
                                </div>
                                <div class="ep-field">
                                    <label>Zone</label>
                                    <input class="form-control form-control-sm" @bind="_editorZoneInput" maxlength="100" placeholder="optional" />
                                </div>
                            </div>
                            @if (ShouldShowEditorFloorAreaField)
                            {
                                <div class="ep-field">
                                    <label>Floor area [m²]</label>
                                    <input class="form-control form-control-sm"
                                           @bind="_editorFloorAreaInput"
                                           @bind:event="oninput"
                                           inputmode="decimal"
                                           maxlength="32"
                                           placeholder="optional, > 0" />
                                    <div class="ep-hint">Explicit area metadata for EUI. Leave empty or enter a value greater than 0. Decimal values are allowed.</div>
                                    @if (!string.IsNullOrWhiteSpace(_editorFloorAreaValidationMessage))
                                    {
                                        <div class="text-danger small mt-1">@_editorFloorAreaValidationMessage</div>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_selectedFacilityNode!.MeterUrn))
                            {
                                <div class="ep-field">
                                    <label>Meter URN</label>
                                    <input class="form-control form-control-sm ep-input-readonly" value="@_selectedFacilityNode.MeterUrn" readonly />
                                </div>
                            }
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">Connections</div>
                            <div class="ep-field">
                                <label>Primary Parent</label>
                                <div class="wb-link-item wb-link-item-compact">
                                    <div>
                                        <div class="wb-link-item-title">@GetSelectedParentDisplayText()</div>
                                        <div class="wb-link-item-key">@GetSelectedParentNodeKeyText()</div>
                                    </div>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary wb-inline-action-btn"
                                            @onclick="ToggleReconnectParentPicker">
                                        @(_isReconnectParentPickerOpen ? "Close" : "Change")
                                    </button>
                                </div>
                                @if (_isReconnectParentPickerOpen)
                                {
                                    <div class="wb-picker-combobox mt-2">
                                        <input class="form-control form-control-sm"
                                               @bind="_reconnectParentSearchInput"
                                               @bind:event="oninput"
                                               placeholder="Search by label or key" />
                                        <div class="wb-picker-list">
                                            <button type="button"
                                                    class="wb-picker-item @GetPickerSelectionClass(string.Empty, _reconnectParentNodeKeyInput)"
                                                    @onclick="@(() => SelectReconnectParent(string.Empty))">
                                                <span class="wb-picker-item-label">Root</span>
                                                <span class="wb-picker-item-key">No parent</span>
                                            </button>
                                            @foreach (var parentCandidate in GetReconnectParentSearchMatches())
                                            {
                                                <button type="button"
                                                        class="wb-picker-item @GetPickerSelectionClass(parentCandidate.NodeKey, _reconnectParentNodeKeyInput)"
                                                        @onclick="@(() => SelectReconnectParent(parentCandidate.NodeKey))">
                                                    <span class="wb-picker-item-label">@GetNodeDisplayLabel(parentCandidate)</span>
                                                    <span class="wb-picker-item-key">@parentCandidate.NodeKey</span>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (HasChildren(_selectedFacilityNode.NodeKey) && !string.Equals(_reconnectParentNodeKeyInput, _selectedFacilityNode.ParentNodeKey ?? string.Empty, StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="wb-editor-warning-box">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" class="me-1 flex-shrink-0" aria-hidden="true"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                    <div>
                                        This node has children. Reparenting will move <strong>all children</strong> with it.<br />
                                        <label class="d-flex align-items-center gap-2 mt-2">
                                            <input type="checkbox" @bind="_reconnectChildrenWarningConfirmed" />
                                            <span>I understand and confirm the reparenting</span>
                                        </label>
                                    </div>
                                </div>
                            }

                            <div class="ep-field mt-3">
                                <label>Additional Links</label>
                                @if (GetFocusedNodeAdditionalLinks().Count == 0)
                                {
                                    <div class="ep-hint">No additional links.</div>
                                }
                                else
                                {
                                    <div class="wb-link-list">
                                        @foreach (var relationship in GetFocusedNodeAdditionalLinks())
                                        {
                                            <div class="wb-link-item">
                                                <div>
                                                    <div class="wb-link-item-title">@relationship.CounterpartyLabel</div>
                                                    <div class="wb-link-item-key">@relationship.CounterpartyNodeKey</div>
                                                    @if (!string.IsNullOrWhiteSpace(relationship.Note))
                                                    {
                                                        <div class="wb-link-item-note">@relationship.Note</div>
                                                    }
                                                </div>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        disabled="@(!_isSchematicEditorEnabled)"
                                                        @onclick="@(() => RemoveAdditionalRelationshipAsync(relationship.SourceNodeKey, relationship.TargetNodeKey, relationship.StoredRelationshipKind))">
                                                    Remove
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                                @if (!_isAdditionalRelationshipPickerOpen)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary wb-picker-toggle"
                                            disabled="@(!_isSchematicEditorEnabled)"
                                            @onclick="OpenAdditionalRelationshipPicker">
                                        Add additional link
                                    </button>
                                }
                                else
                                {
                                    <div class="wb-picker-combobox">
                                        <input class="form-control form-control-sm"
                                               @bind="_additionalRelationshipSearchInput"
                                               @bind:event="oninput"
                                               placeholder="Search by label or key"
                                               disabled="@(!_isSchematicEditorEnabled)" />
                                        <div class="wb-picker-list mt-2">
                                            @foreach (var nodeCandidate in GetAdditionalRelationshipSearchMatches())
                                            {
                                                <button type="button"
                                                        class="wb-picker-item @GetPickerSelectionClass(nodeCandidate.NodeKey, _additionalRelationshipCounterpartyNodeKeyInput)"
                                                        disabled="@(!_isSchematicEditorEnabled)"
                                                        @onclick="@(() => SelectAdditionalRelationshipCounterparty(nodeCandidate.NodeKey))">
                                                    <span class="wb-picker-item-label">@GetNodeDisplayLabel(nodeCandidate)</span>
                                                    <span class="wb-picker-item-key">@nodeCandidate.NodeKey</span>
                                                </button>
                                            }
                                        </div>
                                        <div class="d-flex justify-content-end">
                                            <button type="button"
                                                    class="btn btn-sm btn-link text-decoration-none wb-inline-action"
                                                    disabled="@(!_isSchematicEditorEnabled)"
                                                    @onclick="CloseAdditionalRelationshipPicker">
                                                Close
                                            </button>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_additionalRelationshipCounterpartyNodeKeyInput))
                                {
                                    <div class="wb-link-item wb-link-item-compact wb-selected-target-preview">
                                        <div>
                                            <div class="wb-link-item-title">Selected target</div>
                                            <div class="wb-link-item-key">@GetNodeDisplayLabel(_additionalRelationshipCounterpartyNodeKeyInput) (@_additionalRelationshipCounterpartyNodeKeyInput)</div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="d-flex justify-content-between align-items-center gap-2 mt-2">
                                <button class="btn btn-sm btn-primary"
                                        disabled="@(!_isSchematicEditorEnabled || string.IsNullOrWhiteSpace(_additionalRelationshipCounterpartyNodeKeyInput))"
                                        @onclick="AddAdditionalRelationshipAsync">
                                    Add Link
                                </button>
                            </div>
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">Note</div>
                            <textarea class="form-control form-control-sm" rows="2" maxlength="500" @bind="_editorNoteInput" placeholder="Optional node note"></textarea>
                        </div>

                        <div class="ep-footer">
                            <button class="btn btn-sm btn-primary ep-btn-save"
                                    disabled="@(HasChildren(_selectedFacilityNode.NodeKey) && !string.Equals(_reconnectParentNodeKeyInput, _selectedFacilityNode.ParentNodeKey ?? string.Empty, StringComparison.OrdinalIgnoreCase) && !_reconnectChildrenWarningConfirmed)"
                                    @onclick="SaveFocusedNodeMetadataAsync">
                                @* Floppy disk / kazeta SVG *@
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true">
                                    <path d="M11 2H9v3h2z"/>
                                    <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v3.5A1.5 1.5 0 0 1 11.5 6h-7A1.5 1.5 0 0 1 3 4.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z"/>
                                </svg>
                                Save node
                            </button>
                            <button class="btn btn-sm btn-link text-decoration-none p-0 ep-btn-restore" @onclick="RestoreFocusedNodeEditorDraft">
                                Restore draft
                            </button>
                        </div>
                    }
                    else if (editorHasFocusNode)
                    {
                        <div class="ep-info-note">Node @_selectedFacilityNode!.NodeKey is contextual and cannot be edited.</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_editorStatusMessage))
                    {
                        <div class="ep-status-msg">@_editorStatusMessage</div>
                    }
                }

                @* ══ TAB: ADD NODE ══════════════════════════════════════ *@
                else if (_editorActiveTab == "add")
                {
                    @if (!editorHasFocusNode || !CanEditFocusedNode)
                    {
                        <div class="ep-node-header ep-node-header-placeholder">
                            <div class="ep-node-header-label">Add node</div>
                            <div class="ep-node-header-key">New child node</div>
                        </div>
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                            <div>Select a node in the schematic. The new node will be added as its child.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ep-node-header">
                            <div class="ep-node-header-sublabel">Parent node</div>
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>
                        <div class="ep-section" id="editor-add-node-section">
                            <div class="ep-section-label">New child node</div>
                            <div class="ep-field">
                                <label>NodeKey <span class="text-danger">*</span></label>
                                <input class="form-control form-control-sm" @bind="_newNodeKeyInput" maxlength="100" placeholder="e.g. workshop_aux_1" />
                                <div class="ep-hint">Unique ID - lowercase letters and underscores</div>
                            </div>
                            <div class="ep-field">
                                <label>Label <span class="text-danger">*</span></label>
                                <input class="form-control form-control-sm" @bind="_newNodeLabelInput" maxlength="200" placeholder="Display name" />
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>NodeType</label>
                                    <input class="form-control form-control-sm" list="facility-node-type-suggestions-add" autocomplete="off" @bind="_newNodeTypeInput" maxlength="100" placeholder="area, bus, weather, or custom" />
                                    <datalist id="facility-node-type-suggestions-add">
                                        @foreach (var suggestion in BuiltInNodeTypeSuggestions)
                                        {
                                            <option value="@suggestion"></option>
                                        }
                                    </datalist>
                                </div>
                                <div class="ep-field">
                                    <label>Zone</label>
                                    <input class="form-control form-control-sm" @bind="_newNodeZoneInput" maxlength="100" placeholder="optional" />
                                </div>
                            </div>
                            <div class="ep-field">
                                <label>Meter URN</label>
                                <input class="form-control form-control-sm" @bind="_newNodeMeterUrnInput" maxlength="200" placeholder="optional - meter binding" />
                            </div>
                        </div>
                        <div class="ep-footer">
                            <button class="btn btn-sm btn-primary ep-btn-save" @onclick="AddNodeAsync">
                                <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 1"/></svg>
                                Add child node
                            </button>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_structureStatusMessage))
                    {
                        <div class="ep-status-msg">@_structureStatusMessage</div>
                    }
                }

                @* ══ TAB: DELETE ════════════════════════════════════════ *@
                else if (_editorActiveTab == "delete")
                {
                    @if (!editorHasFocusNode)
                    {
                        <div class="ep-node-header ep-node-header-placeholder">
                            <div class="ep-node-header-label">Delete</div>
                            <div class="ep-node-header-key">Delete node</div>
                        </div>
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                            <div>Select a node in the schematic to delete it.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ep-node-header">
                            <div class="ep-node-header-sublabel">Selected node</div>
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>
                        @if (!CanEditFocusedNode)
                        {
                            <div class="wb-editor-warning-box">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="me-1 flex-shrink-0" aria-hidden="true"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                This node is contextual and cannot be deleted.
                            </div>
                        }
                        else if (HasChildren(_selectedFacilityNode!.NodeKey))
                        {
                            <div class="wb-editor-warning-box ep-warning-block">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="me-1 flex-shrink-0" aria-hidden="true"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                <div>
                                    <strong>This node cannot be deleted.</strong><br />
                                    The node has child nodes. Reconnect or delete all children first.
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="ep-section">
                                <div class="ep-section-label ep-section-label-danger">Irreversible action</div>
                                <div class="ep-hint ep-hint-dark">The node will be permanently removed from the structure. This action cannot be undone.</div>
                            </div>
                            <div class="ep-footer">
                                <button class="btn btn-sm btn-danger ep-btn-save" @onclick="RemoveFocusedLeafNodeAsync">
                                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" class="me-1" aria-hidden="true"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                                    Delete node
                                </button>
                            </div>
                        }
                    }
                    @if (!string.IsNullOrWhiteSpace(_structureStatusMessage))
                    {
                        <div class="ep-status-msg">@_structureStatusMessage</div>
                    }
                }

                @* ══ TAB: IMPORT DATA ═══════════════════════════════════ *@
                else if (_editorActiveTab == "import")
                {
                    @if (!editorHasFocusNode || !CanEditFocusedNode)
                    {
                        <div class="ep-node-header ep-node-header-placeholder">
                            <div class="ep-node-header-label">Import data</div>
                            <div class="ep-node-header-key">One series per selected node</div>
                        </div>
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                            <div>Select one editable node to import a fixed CSV time series.</div>
                        </div>
                    }
                    else
                    {
                        var selectedBindings = GetSelectedNodeBindingsForPreview();

                        <div class="ep-node-header">
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">Import one series</div>
                            <div class="ep-field">
                                <label>CSV file</label>
                                <InputFile class="form-control form-control-sm" OnChange="HandleImportSeriesFileSelected" accept=".csv" />
                            </div>
                            @if (_importSeriesFile is not null)
                            {
                                <div class="ep-hint">Selected file: @_importSeriesFile.Name</div>
                            }
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>Exact signal code</label>
                                    <select class="form-select form-select-sm" @bind="_importExactSignalCodeInput">
                                        @foreach (var exactCode in ImportExactSignalCodeOptions)
                                        {
                                            <option value="@exactCode.Value">@exactCode.Value</option>
                                        }
                                    </select>
                                </div>
                                <div class="ep-field">
                                    <label>Unit</label>
                                    <input class="form-control form-control-sm" @bind="_importUnitInput" @bind:event="oninput" maxlength="40" placeholder="kW, kWh, °C" />
                                </div>
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>Meter URN</label>
                                    <input class="form-control form-control-sm" @bind="_importMeterUrnInput" @bind:event="oninput" maxlength="200" placeholder="optional source reference" />
                                </div>
                                <div class="ep-field">
                                    <label>Source label</label>
                                    <input class="form-control form-control-sm" @bind="_importSourceLabelInput" @bind:event="oninput" maxlength="200" placeholder="optional file/source label" />
                                </div>
                            </div>
                            <div class="ep-hint">Expected CSV format: first column = timestamp, second column = value, comma delimiter.</div>
                            <div class="ep-footer">
                                <button class="btn btn-sm btn-primary ep-btn-save"
                                        @onclick="ImportSeriesForSelectedNodeAsync"
                                        disabled="@(_isImportingSeries || _importSeriesFile is null || string.IsNullOrWhiteSpace(_importUnitInput))">
                                    @if (_isImportingSeries)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        <span>Importing...</span>
                                    }
                                    else
                                    {
                                        <span>Import data</span>
                                    }
                                </button>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_importStatusMessage))
                        {
                            <div class="ep-status-msg">@_importStatusMessage</div>
                        }

                        @if (_importErrors.Count > 0)
                        {
                            <div class="ep-section">
                                <div class="ep-section-label">Import validation</div>
                                @foreach (var error in _importErrors.Take(8))
                                {
                                    <div class="wb-link-item wb-link-item-compact">
                                        <div class="wb-link-item-title">Line @error.LineNumber</div>
                                        <div class="wb-link-item-note">@error.Reason</div>
                                    </div>
                                }
                                @if (_importErrors.Count > 8)
                                {
                                    <div class="ep-hint">@(_importErrors.Count - 8) additional invalid rows were omitted from this preview.</div>
                                }
                            </div>
                        }

                        <div class="ep-section">
                            <div class="ep-section-label">Node bindings</div>
                            @if (selectedBindings.Count == 0)
                            {
                                <div class="ep-placeholder">
                                    <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="ep-placeholder-icon"><path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h.5A1.5 1.5 0 0 1 15 2.5v11A1.5 1.5 0 0 1 13.5 15h-11A1.5 1.5 0 0 1 1 13.5v-11A1.5 1.5 0 0 1 2.5 1H3V.5a.5.5 0 0 1 .5-.5M2 4v9.5a.5.5 0 0 0 .5.5h11a.5.5 0 0 0 .5-.5V4z"/></svg>
                                    <div class="ep-placeholder-text">No bindings are attached to this node yet.</div>
                                    <div class="ep-placeholder-sub">Bindings will appear here with exact signal code, unit, and source metadata.</div>
                                </div>
                            }
                            else
                            {
                                @foreach (var binding in selectedBindings)
                                {
                                    <div class="wb-link-item wb-link-item-compact wb-link-item-binding">
                                        <div class="wb-link-item-content">
                                            <div class="wb-link-item-title">
                                                @binding.ExactSignalCode.Value
                                                @if (!string.IsNullOrWhiteSpace(binding.Unit))
                                                {
                                                    <span> · @binding.Unit</span>
                                                }
                                            </div>
                                            <div class="wb-link-item-note">@BuildBindingPreviewText(binding)</div>
                                        </div>

                                        <div class="wb-link-item-action">
                                            <button type="button"
                                                    class="btn btn-sm btn-danger d-inline-flex align-items-center gap-1 py-1 px-2 wb-binding-delete-btn"
                                                    title="Delete binding"
                                                    aria-label="Delete binding"
                                                    @onclick="() => DeleteSelectedNodeBindingAsync(binding.BindingId)">
                                                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                                    <path d="M1 1L9 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                                                    <path d="M9 1L1 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                                                </svg>
                                                <span>Delete binding</span>
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                }

                @* ══ TAB: STYLE ════════════════════════════════════════ *@
                else if (_editorActiveTab == "style")
                {
                    @if (!editorHasFocusNode)
                    {
                        <div class="ep-node-header ep-node-header-placeholder">
                            <div class="ep-node-header-label">Style</div>
                            <div class="ep-node-header-key">Base appearance presets</div>
                        </div>
                        <div class="wb-editor-empty-state">
                            <svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="wb-editor-empty-icon"><path d="M12 .25a.75.75 0 0 1 .75.75v2.112a2.75 2.75 0 0 1 1.47 3.78l-4.1 7.38A1.75 1.75 0 0 1 8.59 15H4.75A1.75 1.75 0 0 1 3 13.25v-1.586a1.75 1.75 0 0 1 .256-.91l4.19-6.984A2.75 2.75 0 0 1 10.25 1.1V1A.75.75 0 0 1 11 .25zm-.25 4.5a1.25 1.25 0 0 0-1.072.608l-4.19 6.985a.25.25 0 0 0-.038.128v.779h2.14l4.063-7.314A1.25 1.25 0 0 0 11.75 4.75"/></svg>
                            <div>Select a node in the schematic to assign and edit style.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ep-node-header">
                            <div class="ep-node-header-label">@_selectedFacilityNode!.Label</div>
                            <div class="ep-node-header-key">@_selectedFacilityNode.NodeKey</div>
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">Preset assignment</div>
                            <div class="ep-field">
                                <label>Assigned preset</label>
                                <select class="form-select form-select-sm"
                                        @bind="_styleAssignmentPresetKeyInput"
                                        @bind:after="HandleStyleAssignmentPresetChanged">
                                    @foreach (var preset in GetOrderedStylePresets())
                                    {
                                        <option value="@preset.Key">@GetStylePresetLabel(preset)</option>
                                    }
                                </select>
                            </div>
                            <div class="ep-hint">Changes preview immediately for the selected node. Use Apply to persist the preset reference.</div>
                            <div class="wb-style-usage-note">Preset usage: @GetStylePresetUsageCount(_styleAssignmentPresetKeyInput) nodes</div>
                            <div class="ep-footer ep-style-footer">
                                <button class="btn btn-sm btn-primary ep-btn-save" @onclick="ApplySelectedNodeStylePresetAsync">
                                    Apply preset to node
                                </button>
                            </div>
                        </div>

                        <div class="ep-section">
                            <div class="ep-section-label">Preset editor</div>
                            <div class="wb-style-preset-chip">Editing preset: @GetCurrentStylePresetLabel()</div>
                            <div class="ep-field">
                                <label>Name</label>
                                <input class="form-control form-control-sm" @bind="_stylePresetNameInput" @bind:event="oninput" maxlength="80" />
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>Shape</label>
                                    <select class="form-select form-select-sm" @bind="_styleShapeInput">
                                        @foreach (var shape in Enum.GetValues<FacilityNodeShapeKind>())
                                        {
                                            <option value="@shape">@shape</option>
                                        }
                                    </select>
                                </div>
                                <div class="ep-field">
                                    <label>Symbol</label>
                                    <input class="form-control form-control-sm" @bind="_styleSymbolInput" @bind:event="oninput" maxlength="3" placeholder="optional" />
                                </div>
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>Size</label>
                                    <input type="range" class="form-range wb-style-range" min="16" max="60" step="1" @bind="_styleSizeInput" @bind:event="oninput" />
                                    <div class="wb-style-range-value">@_styleSizeInput.ToString("0") px</div>
                                </div>
                                <div class="ep-field">
                                    <label>Stroke width</label>
                                    <input type="range" class="form-range wb-style-range" min="1" max="6" step="0.1" @bind="_styleStrokeWidthInput" @bind:event="oninput" />
                                    <div class="wb-style-range-value">@_styleStrokeWidthInput.ToString("0.0") px</div>
                                </div>
                            </div>
                            <div class="ep-field-row wb-style-color-row">
                                <div class="ep-field">
                                    <label>Fill</label>
                                    <input type="color" class="form-control form-control-color wb-style-color" @bind="_styleFillColorInput" @bind:event="oninput" />
                                </div>
                                <div class="ep-field">
                                    <label>Stroke</label>
                                    <input type="color" class="form-control form-control-color wb-style-color" @bind="_styleStrokeColorInput" @bind:event="oninput" />
                                </div>
                                <div class="ep-field">
                                    <label>Symbol</label>
                                    <input type="color" class="form-control form-control-color wb-style-color" @bind="_styleSymbolColorInput" @bind:event="oninput" />
                                </div>
                                <div class="ep-field">
                                    <label>Label</label>
                                    <input type="color" class="form-control form-control-color wb-style-color" @bind="_styleLabelColorInput" @bind:event="oninput" />
                                </div>
                            </div>
                            <div class="ep-field-row">
                                <div class="ep-field">
                                    <label>Label size</label>
                                    <input type="range" class="form-range wb-style-range" min="6" max="18" step="0.5" @bind="_styleLabelFontSizeInput" @bind:event="oninput" />
                                    <div class="wb-style-range-value">@_styleLabelFontSizeInput.ToString("0.0") px</div>
                                </div>
                                <div class="ep-field">
                                    <label>Label weight</label>
                                    <input type="range" class="form-range wb-style-range" min="400" max="800" step="10" @bind="_styleLabelFontWeightInput" @bind:event="oninput" />
                                    <div class="wb-style-range-value">@_styleLabelFontWeightInput</div>
                                </div>
                            </div>
                            <div class="ep-hint">Editing the preset updates every node using that preset in the live preview. Save persists the preset library.</div>
                            @if (!CanDeleteSelectedStylePreset())
                            {
                                <div class="wb-style-usage-note">@GetDeleteSelectedStylePresetBlockReason()</div>
                            }
                            <div class="ep-footer ep-style-footer">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="DuplicateSelectedStylePresetAsync">
                                    Duplicate preset
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="DeleteSelectedStylePresetAsync"
                                        disabled="@(!CanDeleteSelectedStylePreset())"
                                        title="@GetDeleteSelectedStylePresetBlockReason()">
                                    Delete preset
                                </button>
                                <button class="btn btn-sm btn-primary ep-btn-save" @onclick="SaveSelectedStylePresetAsync">
                                    Save preset
                                </button>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_styleStatusMessage))
                        {
                            <div class="ep-status-msg">@_styleStatusMessage</div>
                        }
                    }
                }

                @* ══ TAB: LAYOUT ════════════════════════════════════════ *@
                else if (_editorActiveTab == "layout")
                {
                    <div class="ep-node-header ep-node-header-placeholder">
                        <div class="ep-node-header-label">Layout</div>
                        <div class="ep-node-header-key">Align and distribute nodes</div>
                    </div>
                    @if (_selectionSet.Count < 2)
                    {
                        <div class="ep-placeholder ep-layout-empty">
                            <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="ep-placeholder-icon"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm8 0A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5z"/></svg>
                            <div class="ep-placeholder-text">Select 2 or more nodes</div>
                            <div class="ep-placeholder-sub">Ctrl+click to add to the selection, or drag a selection box over empty schematic space.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ep-section">
                            <div class="ep-section-label">@_selectionSet.Count nodes selected</div>
                            <div class="ep-hint ep-hint-dark">Alignment applies to every selected node. Movement is recorded in the undo history.</div>
                        </div>
                        <div class="ep-section">
                            <div class="ep-section-label">Align on the X axis</div>
                            <div class="ep-align-grid">
                                <button class="ep-align-btn" @onclick="@(() => AlignSelectedNodesAsync("center-h"))" title="Align to the center (average X)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5V3H13a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H8.5v1H11a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H8.5v1.5a.5.5 0 0 1-1 0V13H5a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1h2.5V8H3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h4.5V1.5A.5.5 0 0 1 8 1"/></svg>
                                    Center X
                                </button>
                            </div>
                        </div>
                        <div class="ep-section">
                            <div class="ep-section-label">Align on the Y axis</div>
                            <div class="ep-align-grid">
                                <button class="ep-align-btn" @onclick="@(() => AlignSelectedNodesAsync("center-v"))" title="Align to the center (average Y)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M2 8a.5.5 0 0 1 .5-.5H4V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2.5h2V6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2.5h1.5a.5.5 0 0 1 0 1H14V12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V9.5H8V12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9.5H2.5A.5.5 0 0 1 2 9z"/></svg>
                                    Center Y
                                </button>
                            </div>
                        </div>
                        <div class="ep-section">
                            <div class="ep-section-label">Distribute evenly</div>
                            <div class="ep-hint ep-hint-dark">At least 3 nodes are required. Ordering is derived from the current positions.</div>
                            <div class="ep-align-grid mt-1">
                                <button class="ep-align-btn" disabled="@(_selectionSet.Count < 3)"
                                        @onclick="@(() => DistributeSelectedNodesAsync("horizontal"))"
                                        title="Distribute evenly horizontally (sorted by X)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M2 1a1 1 0 0 1 1-1h.5a.5.5 0 0 1 0 1H3v12h.5a.5.5 0 0 1 0 1H3a1 1 0 0 1-1-1zm12 0a1 1 0 0 0-1-1h-.5a.5.5 0 0 0 0 1H13v12h-.5a.5.5 0 0 0 0 1H13a1 1 0 0 0 1-1zM6 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1z"/></svg>
                                    Horizontal
                                </button>
                                <button class="ep-align-btn" disabled="@(_selectionSet.Count < 3)"
                                        @onclick="@(() => DistributeSelectedNodesAsync("vertical"))"
                                        title="Distribute evenly vertically (sorted by Y)">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M1 2a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V1.5a.5.5 0 0 0-1 0V2H2V1.5a.5.5 0 0 0-1 0zm0 12a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v.5a.5.5 0 0 1-1 0V14H2v.5a.5.5 0 0 1-1 0zM4 6a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z"/></svg>
                                    Vertical
                                </button>
                            </div>
                        </div>
                    }
                }

                </div>@* end wb-editor-props-content *@
            </div>@* end wb-editor-props *@

            @* Discard Guard Dialog *@
            @if (_showDiscardGuard)
            {
                <div class="wb-discard-guard-overlay" @onclick="() => _showDiscardGuard = false">
                    <div class="wb-discard-guard-modal" @onclick:stopPropagation>
                        <div class="wb-discard-guard-title">&#9888; Unsaved changes</div>
                        <div class="wb-discard-guard-body">
                            You have unsaved changes in edit mode. Do you want to discard them and close the editor?
                        </div>
                        <div class="wb-discard-guard-actions">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showDiscardGuard = false">
                                Continue editing
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="DiscardAndExitAsync">
                                Discard changes
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    @* ══ DASHBOARD MODE ══════════════════════════════════════════ *@
    else
    {
        @* ── Workspace Row: Schematic + Overview ── *@
        <div class="wb-workspace-row">
            <div class="wb-schematic">
                <div class="wb-schematic-toolbar">
                    <div class="toolbar-left">
                        <span class="text-muted fw-bold small text-uppercase"><i class="bi bi-bezier2 me-1"></i> Facility Schematic</span>
                        @if (_selectedFacilityNode is not null)
                        {
                            <button class="wb-focus-chip" @onclick="ClosePanel" title="Clear focus and selection">
                                <i class="bi bi-crosshair2 me-1"></i>@_selectedFacilityNode.Label<i class="bi bi-x ms-1"></i>
                            </button>
                        }
                    </div>
                    <div class="toolbar-right">
                        <div class="wb-node-search">
                            <input class="form-control form-control-sm wb-node-search-input"
                                   @bind="_globalNodeSearchInput"
                                   @bind:event="oninput"
                                @onfocus="OpenGlobalNodeSearch"
                                @onblur="CloseGlobalNodeSearch"
                                   placeholder="Search node"
                                   aria-label="Search node" />
                            @if (ShouldShowGlobalNodeSearchResults)
                            {
                                <div class="wb-node-search-results">
                                    @if (GetGlobalNodeSearchMatches().Count == 0)
                                    {
                                        <div class="wb-node-search-empty">No matches</div>
                                    }
                                    else
                                    {
                                        @foreach (var nodeMatch in GetGlobalNodeSearchMatches())
                                        {
                                            <button type="button"
                                                    class="wb-node-search-result"
                                                    @onmousedown:preventDefault="true"
                                                    @onclick="@(() => FocusNodeFromSearchAsync(nodeMatch.NodeKey))">
                                                <span class="wb-node-search-result-label">@GetNodeDisplayLabel(nodeMatch)</span>
                                                <span class="wb-node-search-result-key">@nodeMatch.NodeKey</span>
                                            </button>
                                        }
                                    }
                                </div>
                            }
                        </div>
                        <button class="wb-toolbar-icon-btn" @onclick="GoHomeAsync"
                            title="Default view" disabled="@(_canvasV2 is null)">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354z"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn" @onclick="() => ReloadData()" title="Reload schematic">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                        </button>
                        <button class="wb-toolbar-icon-btn"
                            @onclick="ToggleSchematicFullscreen" title="Open focus view"
                                disabled="@(_facility is null)">
                            <svg class="wb-toolbar-icon-svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M1 6V1h5v1.5H2.5V6H1zm9-5h5v5h-1.5V2.5H10V1zm3.5 8.5H15V15h-5v-1.5h3.5V9.5zM6 15H1v-5h1.5v3.5H6V15z"/>
                            </svg>
                        </button>
                        <button class="wb-toolbar-icon-btn wb-toolbar-icon-btn-primary"
                                @onclick="ToggleEditMode"
                            title="Edit schematic"
                                disabled="@(_facility is null)">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/></svg>
                        </button>
                    </div>
                </div>
                <div class="wb-schematic-body">
                    @if (_facility is null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <div class="spinner-border mb-3" role="status"></div>
                            <p class="mb-0">Loading structural data...</p>
                        </div>
                    }
                    else
                    {
                        <FacilitySchematicV2 @ref="_canvasV2"
                                      Layout="_schematicLayout"
                                      InitialFitMode="home"
                                      SelectedElementId="@SessionService.SelectedElementId"
                                      SelectedElementIds="@ResolvedSelectionNodeKeysForCanvas"
                                      SelectedSubtreeNodeKeys="@VisualHighlightNodeKeysForCanvas"
                                      NodeStylePresetKeysByNodeKey="@EffectiveNodeStylePresetKeysForCanvas"
                                      NodeStylePresetLabelsByNodeKey="@EffectiveNodeStylePresetLabelsForCanvas"
                                      NodeTagsByNodeKey="@EffectiveNodeTagPreviewForCanvas"
                                      NodeNotesByNodeKey="@EffectiveNodeNotePreviewForCanvas"
                                      StylePresetsByKey="@EffectiveStylePresetsForCanvas"
                                      OnElementSelected="HandleElementSelected"
                                      OnCanvasClicked="HandleCanvasClicked"
                                      OnNodeDragEnd="HandleNodeDragEndAsync" />
                    }
                </div>
            </div>

            @* ── Overview Pane (Control Panel) ── *@
            <div class="wb-overview">
                <div class="cp-card cp-interval-card">
                    <div class="cp-card-head">
                        <span class="cp-card-label">INTERVAL</span>
                    </div>
                    <div class="cp-interval-range-shell">
                        <div class="cp-interval-range-display">@DisplayIntervalFromTo</div>
                    </div>
                    <div class="cp-preset-row">
                        <button class="cp-preset-btn @(_selectedInterval == "last24h" ? "cp-preset-btn-active" : "")" @onclick='() => SetIntervalPreset("last24h")'>24h</button>
                        <button class="cp-preset-btn @(_selectedInterval == "last7d" ? "cp-preset-btn-active" : "")" @onclick='() => SetIntervalPreset("last7d")'>7d</button>
                        <button class="cp-preset-btn @(_selectedInterval == "last30d" ? "cp-preset-btn-active" : "")" @onclick='() => SetIntervalPreset("last30d")'>30d</button>
                        <button class="cp-preset-btn @(_selectedInterval == "thisMonth" ? "cp-preset-btn-active" : "")" @onclick='() => SetIntervalPreset("thisMonth")'>Month</button>
                        <button class="cp-preset-btn @(_selectedInterval == "custom" ? "cp-preset-btn-active" : "")" @onclick='() => SetIntervalPreset("custom")'>Custom</button>
                    </div>
                    @if (_selectedInterval == "custom")
                    {
                        <div class="cp-custom-picker-block">
                            <div class="cp-custom-date-row">
                                <div>
                                    <div class="cp-date-label">FROM</div>
                                    <RadzenDatePicker TValue="DateTime" Value="_customFromUtc" Change="OnCustomFromPickerChanged" ShowTime="true" ShowSeconds="false" HoursStep="1" MinutesStep="1" DateFormat="dd/MM/yyyy HH:mm" Culture="@_pickerCulture" class="cp-radzen-picker" />
                                </div>
                                <div>
                                    <div class="cp-date-label">TO</div>
                                    <RadzenDatePicker TValue="DateTime" Value="_customToUtcExclusive.AddMinutes(-1)" Change="OnCustomToPickerChanged" ShowTime="true" ShowSeconds="false" HoursStep="1" MinutesStep="1" DateFormat="dd/MM/yyyy HH:mm" Culture="@_pickerCulture" class="cp-radzen-picker" />
                                </div>
                            </div>
                        </div>    
                    }
                    @if (!string.IsNullOrWhiteSpace(_customIntervalValidationMessage))
                    {
                        <div class="cp-custom-validation-msg">@_customIntervalValidationMessage</div>
                    }
                </div>

                <div class="cp-card cp-selection-card">
                    <div class="cp-card-head cp-selection-card-head">
                        <span class="cp-card-label">SELECTION</span>
                        <button class="btn btn-sm btn-outline-secondary cp-clear-sel-btn" @onclick="ClearWorkspaceSelection" disabled="@(!HasSelectedNodes)">Clear selection</button>
                    </div>
                    <div class="cp-selection-layout">
                        <div class="cp-selection-kpi">
                            <div class="cp-sel-count-big">@SelectionCount</div>
                            <div class="cp-sel-count-label">SELECTED NODES</div>
                        </div>
                        <div class="cp-selection-visual">
                            <div class="cp-sel-donut-shell">
                                <div class="cp-sel-donut">
                                    @{
                                        var donutSegments = GetSelectionDonutSegments();
                                        const double pieCenterX = 54;
                                        const double pieCenterY = 54;
                                        const double pieRadius = 44;
                                        var pieStartAngle = -90d;
                                    }
                                    <svg id="@SelectionPieChartSvgId" width="108" height="108" viewBox="0 0 108 108" class="cp-donut-svg" aria-hidden="true">
                                        @if (donutSegments.Count == 0)
                                        {
                                            <circle cx="54" cy="54" r="44" fill="#e2e8f0"></circle>
                                        }
                                        else
                                        {
                                            @foreach (var segment in donutSegments)
                                            {
                                                var segmentSweepAngle = (segment.Count / (double)SupportedSelectionSummaryCount) * 360d;
                                                if (segmentSweepAngle <= 0d)
                                                {
                                                    continue;
                                                }

                                                var segmentPath = DescribePieSlicePath(pieCenterX, pieCenterY, pieRadius, pieStartAngle, segmentSweepAngle);
                                                var segmentPercent = (segment.Count / (double)SupportedSelectionSummaryCount).ToString("P0");

                                                <path class="cp-donut-segment"
                                                      d="@segmentPath"
                                                      fill="@segment.Color"
                                                      data-selection-pie-segment="true"
                                                      data-segment-label="@segment.Label"
                                                      data-segment-count="@segment.Count"
                                                      data-segment-percent="@segmentPercent"
                                                      data-segment-detail="@segment.DetailText"></path>

                                                pieStartAngle += segmentSweepAngle;
                                            }
                                        }
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="cp-card cp-tools-card">
                    <div class="cp-card-head cp-tools-card-head">
                        <span class="cp-card-label">TOOLS</span>
                    </div>
                    <div class="cp-tools-tab-bar">
                        <button class="cp-tools-tab @(_workflowTab == "semantic" ? "cp-tools-tab-active" : "")" @onclick='() => _workflowTab = "semantic"'>
                            <i class="bi bi-funnel me-1"></i>Selection Filters
                        </button>
                        <button class="cp-tools-tab @(_workflowTab == "workingsets" ? "cp-tools-tab-active" : "")" @onclick='() => _workflowTab = "workingsets"'>
                            <i class="bi bi-bookmark-fill me-1"></i>Working Sets
                        </button>
                    </div>

                    @if (_workflowTab == "semantic")
                    {
                        <div class="cp-tools-content">
                            <div class="cp-sem-row1">
                                <select class="form-select form-select-sm bg-light" @bind="_filterNodeType">
                                    <option value="">Any type</option>
                                    @foreach (var nodeType in _availableNodeTypes)
                                    {
                                        <option value="@nodeType">@nodeType</option>
                                    }
                                </select>
                                <select class="form-select form-select-sm bg-light" @bind="_filterZone">
                                    <option value="">Any zone</option>
                                    @foreach (var zone in _availableZones)
                                    {
                                        <option value="@zone">@zone</option>
                                    }
                                </select>
                            </div>
                            <div class="cp-sem-mutation-row">
                                <button type="button"
                                        class="cp-sem-mode-btn @(_semanticSelectionMutationMode == SemanticSelectionMutationMode.Replace ? "cp-sem-mode-btn-active" : "")"
                                        aria-pressed="@(_semanticSelectionMutationMode == SemanticSelectionMutationMode.Replace)"
                                        @onclick='() => _semanticSelectionMutationMode = SemanticSelectionMutationMode.Replace'>
                                    Replace
                                </button>

                                <button type="button"
                                        class="cp-sem-mode-btn @(_semanticSelectionMutationMode == SemanticSelectionMutationMode.Add ? "cp-sem-mode-btn-active" : "")"
                                        aria-pressed="@(_semanticSelectionMutationMode == SemanticSelectionMutationMode.Add)"
                                        @onclick='() => _semanticSelectionMutationMode = SemanticSelectionMutationMode.Add'>
                                    Add
                                </button>

                                <button type="button"
                                        class="cp-sem-mode-btn @(_semanticSelectionMutationMode == SemanticSelectionMutationMode.Remove ? "cp-sem-mode-btn-active" : "")"
                                        aria-pressed="@(_semanticSelectionMutationMode == SemanticSelectionMutationMode.Remove)"
                                        @onclick='() => _semanticSelectionMutationMode = SemanticSelectionMutationMode.Remove'>
                                    Remove
                                </button>
                            </div>
                            <div class="cp-sem-actions">
                                <div class="cp-sem-checkbox">
                                    <input id="semantic-supported-only-cp" class="form-check-input mt-0" type="checkbox" @bind="_semanticSelectionSupportedOnly" />
                                    <label class="mb-0" for="semantic-supported-only-cp">Supported only</label>
                                </div>
                                <div class="cp-sem-action-buttons">
                                    <button class="btn btn-sm btn-primary cp-sem-apply-btn" @onclick="ApplySemanticQueryAsync" disabled="@(_facility is null)">Apply</button>
                                    <button class="btn btn-sm btn-outline-secondary cp-sem-reset-btn" @onclick="ClearSemanticQueryFilters">Reset</button>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="cp-tools-content">
                            <div class="cp-wset-create-row">
                                <input class="form-control form-control-sm bg-light" @bind="_workingSetNameInput" maxlength="80" placeholder="Set name..." />
                                <button class="btn btn-sm btn-outline-secondary" title="Save current selection" @onclick="SaveCurrentWorkingSetAsync" disabled="@(_facility is null)">
                                    <i class="bi bi-bookmark-plus"></i>
                                </button>
                            </div>
                            @if (_showWorkingSetDescription)
                            {
                                <input class="form-control form-control-sm bg-light mb-1" @bind="_workingSetDescriptionInput" maxlength="180" placeholder="Description (optional)" />
                            }
                            <button class="btn btn-link btn-sm p-0 mb-1 cp-wset-desc-toggle" @onclick="() => _showWorkingSetDescription = !_showWorkingSetDescription">@(_showWorkingSetDescription ? "- hide description" : "+ description")</button>
                            @if (_savedWorkingSets.Count == 0)
                            {
                                <div class="small text-muted mt-1">No saved sets yet.</div>
                            }
                            else
                            {
                                <div class="cp-wset-list">
                                    @foreach (var workingSet in _savedWorkingSets)
                                    {
                                        <div class="border rounded px-2 py-1 bg-light-subtle">
                                            <div class="d-flex justify-content-between align-items-center gap-1">
                                                <div class="small min-w-0">
                                                    <div class="fw-semibold text-dark text-truncate" style="font-size:0.78rem">@workingSet.Name</div>
                                                    <div class="text-muted" style="font-size:0.68rem">@workingSet.NodeKeys.Count nodes · @workingSet.UpdatedUtc.ToLocalTime().ToString("dd.MM.")</div>
                                                </div>
                                                <div class="d-flex align-items-center gap-1 flex-shrink-0">
                                                    <button class="btn btn-sm btn-outline-primary py-0 px-1" title="Apply" @onclick="() => ApplyWorkingSetAsync(workingSet.Name)"><i class="bi bi-check2-circle"></i></button>
                                                    <button class="btn btn-sm btn-outline-danger py-0 px-1" title="Delete" @onclick="() => DeleteWorkingSetAsync(workingSet.Name)"><i class="bi bi-trash"></i></button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_workingSetStatusMessage))
                            {
                                <div class="small text-muted mt-1">@_workingSetStatusMessage</div>
                            }
                        </div>
                    }
                </div>

            </div> @* closes wb-overview *@
        </div> @* closes wb-workspace-row *@

        @* ── Analytics Section (full-width, below workspace) ── *@
        <div class="wb-analytics">

            @if (!HasSelectedNodes)
            {
                <div class="wb-analytics-empty-state">
                    <div class="analytics-empty-card">
                        <div class="analytics-empty-icon"><i class="bi bi-bar-chart-line"></i></div>
                        <div class="analytics-empty-title">Analytics ready</div>
                        <div class="analytics-empty-sub">
                            Select nodes in the schematic to open aggregate analytics, breakdowns, KPI summaries, and time-series views.
                        </div>
                        <div class="analytics-empty-hints">
                            <div class="analytics-hint-item"><i class="bi bi-cursor-fill me-1 text-primary"></i>Click a node for a single-node selection</div>
                            <div class="analytics-hint-item"><i class="bi bi-diagram-3-fill me-1 text-primary"></i>Click a structural node to expand the subtree selection</div>
                            <div class="analytics-hint-item"><i class="bi bi-magic me-1 text-primary"></i>Use Semantic Selection in the right panel</div>
                            <div class="analytics-hint-item"><i class="bi bi-bookmark-fill me-1 text-primary"></i>Apply a saved working set</div>
                        </div>
                    </div>
                </div>
            }

            @if (HasSelectedNodes)
            {
                <div class="analytics-nav-shell mb-3">
                    <div class="analytics-tab-bar" role="tablist" aria-label="Analytics navigation">
                        <button type="button" class="analytics-tab-button @(IsOverviewTabActive ? "analytics-tab-button-active" : "")" title="Core KPI and time-series overview" @onclick='() => ActivateAnalyticsTabAsync(AnalyticsTabOverview)'>
                            <i class="bi bi-house-door analytics-tab-icon"></i>
                            <span class="analytics-tab-label">Overview</span>
                        </button>
                        <button type="button" class="analytics-tab-button @(IsBreakdownTabActive ? "analytics-tab-button-active" : "")" title="Sources, roles, and analytic coverage" @onclick='() => ActivateAnalyticsTabAsync(AnalyticsTabBreakdown)'>
                            <i class="bi bi-pie-chart analytics-tab-icon"></i>
                            <span class="analytics-tab-label">Breakdown</span>
                        </button>
                        <button type="button" class="analytics-tab-button @(IsPerformanceTabActive ? "analytics-tab-button-active" : "")" title="Peak demand, load factor, and after-hours demand" @onclick='() => ActivateAnalyticsTabAsync(AnalyticsTabPerformance)'>
                            <i class="bi bi-speedometer2 analytics-tab-icon"></i>
                            <span class="analytics-tab-label">Performance</span>
                        </button>
                        <button type="button" class="analytics-tab-button @(IsCompareTabActive ? "analytics-tab-button-active" : "")" title="Compare aligned time series for dataset-backed nodes" @onclick='() => ActivateAnalyticsTabAsync(AnalyticsTabCompare)'>
                            <i class="bi bi-intersect analytics-tab-icon"></i>
                            <span class="analytics-tab-label">Compare</span>
                        </button>
                        <button type="button" class="analytics-tab-button @(IsDiagnosticsTabActive ? "analytics-tab-button-active" : "")" title="Forecast quality, fit, and diagnostic confidence" @onclick='() => ActivateAnalyticsTabAsync(AnalyticsTabDiagnostics)'>
                            <i class="bi bi-activity analytics-tab-icon"></i>
                            <span class="analytics-tab-label">Diagnostics</span>
                        </button>
                    </div>
                </div>
            }

            @if (HasSelectedNodes && IsBreakdownTabActive)
            {
            <div class="overview-grid secondary-widgets-grid">
                <div class="overview-widget overview-widget-soft secondary-breakdown-widget">
                    <h6>Disaggregation / Top Contributors</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Preparing disaggregation and contribution intelligence...
                        </div>
                    }
                    else if (SelectionContributionIntelligence.TopContributors.Count > 0 || SelectionDisaggregation.MeasuredContributorCount > 0)
                    {
                        var disaggregation = SelectionDisaggregation;
                        var contributionIntelligence = SelectionContributionIntelligence;
                        var displayedContributors = contributionIntelligence.TopContributors.Take(3).ToList();
                        var extraContributors = contributionIntelligence.TopContributors.Skip(3).Take(8).ToList();

                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Measured included: @disaggregation.MeasuredContributorCount</span>
                            <span class="badge bg-light text-secondary border">Load: @disaggregation.ConsumptionContributorCount</span>
                            <span class="badge bg-light text-secondary border">Generation: @disaggregation.GenerationContributorCount</span>
                            @if (disaggregation.HasMixedSigns)
                            {
                                <span class="badge bg-light text-secondary border">Mixed-sign selection</span>
                            }
                            @if (SelectionAggregateNoDataCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">No-data: @SelectionAggregateNoDataCount</span>
                            }
                            @if (SelectionAggregateUnsupportedCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">Unsupported ignored: @SelectionAggregateUnsupportedCount</span>
                            }
                            @if (SelectionAggregateContextOnlyCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">Context-only excluded: @SelectionAggregateContextOnlyCount</span>
                            }
                        </div>

                        <div class="small text-muted mb-2">@disaggregation.CompositionSummary</div>
                        <div class="aggregate-status-line mb-2">@contributionIntelligence.DominantSourceSummary</div>

                        <div class="breakdown-list">
                            @foreach (var contributor in displayedContributors)
                            {
                                var sharePercent = contributor.AbsoluteSharePercent > 0
                                    ? Math.Clamp(contributor.AbsoluteSharePercent, 0.0, 100.0)
                                    : 0.0;
                                var contributionRoleLabel = GetContributionRoleText(contributor.ContributionRole);
                                var directionLabel = GetContributionDirectionText(contributor.Direction);

                                <div class="breakdown-item contributor-item">
                                    <div class="contributor-top-row">
                                        <div class="contributor-main-col">
                                            <div class="breakdown-node-label">@contributor.Label</div>
                                            <div class="contributor-badges">
                                                @contributor.NodeRoleLabel · @contributionRoleLabel · @directionLabel
                                            </div>
                                        </div>
                                        <div class="contributor-values">
                                            <div class="contributor-signed-value">@FormatSigned(contributor.IntervalEnergyKwh, "N1") kWh</div>
                                            <div class="contributor-share">share: @contributor.AbsoluteSharePercent.ToString("N1") %</div>
                                        </div>
                                    </div>
                                    <div class="breakdown-bar-track">
                                        <div class="breakdown-bar-fill" style="width: @(sharePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (contributionIntelligence.TopContributors.Count == 0)
                        {
                            <div class="small text-muted mt-2">Top contributors are unavailable because the current selection has no measured contribution data.</div>
                        }

                        @if (contributionIntelligence.TopContributors.Count > displayedContributors.Count)
                        {
                            <div class="small text-muted mt-2">Showing the top 3 contributors out of @contributionIntelligence.TopContributors.Count.</div>
                        }

                        @if (extraContributors.Count > 0)
                        {
                            <details class="mt-2">
                                <summary class="small text-secondary">More contributors (@(contributionIntelligence.TopContributors.Count - displayedContributors.Count))</summary>
                                <div class="contributor-more-list">
                                    @foreach (var extraContributor in extraContributors)
                                    {
                                        var extraSharePercent = extraContributor.AbsoluteSharePercent > 0
                                            ? Math.Clamp(extraContributor.AbsoluteSharePercent, 0.0, 100.0)
                                            : 0.0;
                                        var extraContributionRoleLabel = GetContributionRoleText(extraContributor.ContributionRole);
                                        var extraDirectionLabel = GetContributionDirectionText(extraContributor.Direction);

                                        <div class="breakdown-item contributor-item mt-1">
                                            <div class="contributor-top-row">
                                                <div class="contributor-main-col">
                                                    <div class="breakdown-node-label">@extraContributor.Label</div>
                                                    <div class="contributor-badges">
                                                        @extraContributor.NodeRoleLabel · @extraContributionRoleLabel · @extraDirectionLabel
                                                    </div>
                                                </div>
                                                <div class="contributor-values">
                                                    <div class="contributor-signed-value">@FormatSigned(extraContributor.IntervalEnergyKwh, "N1") kWh</div>
                                                    <div class="contributor-share">share: @extraContributor.AbsoluteSharePercent.ToString("N1") %</div>
                                                </div>
                                            </div>
                                            <div class="breakdown-bar-track">
                                                <div class="breakdown-bar-fill" style="width: @(extraSharePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </details>
                        }
                    }
                    else
                    {
                        <div class="small text-muted">Disaggregation appears once the selection contains supported energy nodes.</div>
                    }
                </div>

                <div class="overview-widget overview-widget-soft secondary-role-widget">
                    <h6>Role Breakdown</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Aggregating contributions by role...
                        </div>
                    }
                    else if (SelectionRoleBreakdownItems.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Roles: @SelectionRoleBreakdownItems.Count</span>
                            <span class="badge bg-light text-secondary border">Included nodes: @SelectionAggregateIncludedCount</span>
                        </div>

                        <div class="breakdown-list">
                            @foreach (var roleContribution in SelectionRoleBreakdownItems.Take(6))
                            {
                                var sharePercent = roleContribution.SharePercent.HasValue
                                    ? Math.Clamp(roleContribution.SharePercent.Value, 0.0, 100.0)
                                    : 0.0;
                                var contributionRoleLabel = GetContributionRoleText(roleContribution.ContributionRole);

                                <div class="breakdown-item role-breakdown-item @(roleContribution.HasData ? string.Empty : "breakdown-item-nodata")">
                                    <div class="breakdown-header-row">
                                        <div class="role-breakdown-main">
                                            <div class="breakdown-node-label">@roleContribution.RoleLabel</div>
                                            <div class="breakdown-meta">
                                                @if (roleContribution.HasData)
                                                {
                                                    <span>@contributionRoleLabel · @roleContribution.ContributingNodeCount/@roleContribution.NodeCount nodes</span>
                                                }
                                                else
                                                {
                                                    <span>@roleContribution.NodeCount nodes without usable data.</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="breakdown-value-label">@FormatSigned(roleContribution.IntervalEnergyKwh, "N1") kWh</div>
                                    </div>
                                    @if (roleContribution.HasData)
                                    {
                                        <div class="breakdown-meta">
                                            share: @(roleContribution.SharePercent?.ToString("N1") ?? "0.0") %@(roleContribution.HasMixedSigns ? " · mixed-sign role" : string.Empty)
                                        </div>
                                    }
                                    @if (roleContribution.HasData)
                                    {
                                        <div class="breakdown-bar-track">
                                            <div class="breakdown-bar-fill" style="width: @(sharePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        @if (SelectionRoleBreakdownItems.Count > 6)
                        {
                            <div class="small text-muted mt-2">Showing the top 6 roles out of @SelectionRoleBreakdownItems.Count.</div>
                        }
                    }
                    else
                    {
                        <div class="small text-muted">Role breakdown appears once the selection contains supported nodes with data.</div>
                    }
                </div>

                <div class="overview-widget overview-widget-soft secondary-health-widget">
                    <h6>Operational Health</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Evaluating issue and anomaly signals...
                        </div>
                    }
                    else
                    {
                        var operationalHealth = SelectionOperationalHealth;
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge @GetOperationalStatusBadgeClass(operationalHealth.Status)">@GetOperationalStatusText(operationalHealth.Status)</span>
                            <span class="badge bg-light text-secondary border">Signals: @operationalHealth.Signals.Count</span>
                        </div>
                        <div class="small text-muted mb-2">@operationalHealth.Summary</div>
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Supported: @operationalHealth.SupportedNodeCount/@operationalHealth.SelectedNodeCount</span>
                            <span class="badge bg-light text-secondary border">Included: @operationalHealth.IncludedNodeCount/@operationalHealth.SupportedNodeCount</span>
                            <span class="badge bg-light text-secondary border">Deviation H/E: @operationalHealth.HighDeviationNodeCount/@operationalHealth.ElevatedDeviationNodeCount</span>
                            <span class="badge bg-light text-secondary border">Issue U/C/ND: @operationalHealth.UnsupportedNodeCount/@operationalHealth.ContextOnlyNodeCount/@operationalHealth.NoDataNodeCount</span>
                        </div>
                        <div class="operational-point-list">
                            @foreach (var point in BuildOperationalSignalPoints(operationalHealth).Take(4))
                            {
                                <div class="operational-point">@point</div>
                            }
                        </div>
                    }
                </div>

                <div class="overview-widget overview-widget-soft secondary-coverage-widget">
                    <h6>Source Map</h6>
                    @if (_isPreviewLoading)
                    {
                        <div class="text-muted d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Building the included and excluded source map...
                        </div>
                    }
                    else
                    {
                        var sourceMap = SelectionSourceMap;

                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge bg-light text-secondary border">Included: @sourceMap.IncludedMeasuredCount</span>
                            <span class="badge bg-light text-secondary border">Unsupported: @sourceMap.UnsupportedCount</span>
                            <span class="badge bg-light text-secondary border">No-data: @sourceMap.NoDataCount</span>
                            @if (sourceMap.ContextOnlyCount > 0)
                            {
                                <span class="badge bg-light text-secondary border">Context-only: @sourceMap.ContextOnlyCount</span>
                            }
                        </div>

                        <div class="small text-muted mb-2">@sourceMap.Summary</div>

                        @if (sourceMap.Items.Count > 0)
                        {
                            <div class="breakdown-list">
                                @foreach (var item in sourceMap.Items.Take(6))
                                {
                                    var categoryBadgeClass = GetSourceMapCategoryBadgeClass(item.Category);
                                    <div class="breakdown-item">
                                        <div class="breakdown-header-row">
                                            <div class="d-flex align-items-center gap-2 min-w-0">
                                                <div class="breakdown-node-label">@item.Label</div>
                                                <span class="badge @categoryBadgeClass">@item.CategoryLabel</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (sourceMap.Items.Count > 6)
                            {
                                <div class="small text-muted mt-2">Showing 6 items from the source map (@sourceMap.Items.Count total).</div>
                            }
                        }

                        <div class="aggregate-status-line mt-2">
                            Coverage ratio: @((SelectionOperationalHealth.IncludedCoverageRatio * 100.0).ToString("N0")) % of supported nodes are included analytically.
