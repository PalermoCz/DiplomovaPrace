    protected override async Task OnInitializedAsync()
    {
        await ReloadData();
        SessionService.OnSessionChanged += HandleSessionChanged;
        // Výchozí nástroj pro prohlížení schématu
        SessionService.SetActiveTool(EditorTool.Select);
    }

    private async Task ReloadData(bool preserveSelection = false, string? preferredFocusNodeKey = null)
    {
        var previousSelectionOrder = preserveSelection
            ? _selectionOrder.Where(_selectionSet.Contains).ToList()
            : [];
        var previousFocusNodeKey = preserveSelection
            ? preferredFocusNodeKey ?? SessionService.SelectedElementId
            : null;

        var facilityTask = FacilityQueryService.GetMainFacilityAsync();
        var editorStateTask = FacilityEditorStateService.GetNodeStatesByKeyAsync();
        var workingSetsTask = FacilityEditorStateService.GetWorkingSetsAsync();

        await Task.WhenAll(facilityTask, editorStateTask, workingSetsTask);

        _facility = BuildSchemaFacilityWithoutWeatherNode(facilityTask.Result);
        _schematicLayout = _facility is not null ? SchematicComposerV2.Compose(_facility) : null;
        SyncEditorNodeStateCache(editorStateTask.Result);
        SyncWorkingSetCache(workingSetsTask.Result);
        RebuildFacilityNodeIndexes();
        ClearSelectionSetState();
        ClearFocusNodeState();

        if (preserveSelection)
        {
            foreach (var nodeKey in previousSelectionOrder)
            {
                if (_nodesByKey.ContainsKey(nodeKey))
                {
                    AddNodeToSelectionSet(nodeKey);
                }
            }

            var nextFocusNodeKey = !string.IsNullOrWhiteSpace(previousFocusNodeKey) && _nodesByKey.ContainsKey(previousFocusNodeKey)
                ? previousFocusNodeKey
                : GetFallbackFocusNodeKey();

            if (previousSelectionOrder.Count > 1 && string.IsNullOrWhiteSpace(previousFocusNodeKey))
            {
                nextFocusNodeKey = null;
            }

            if (string.IsNullOrWhiteSpace(nextFocusNodeKey))
            {
                SessionService.ClearSelection();
            }
            else
            {
                ApplyFocusNode(nextFocusNodeKey);
            }
        }
        else
        {
            SessionService.ClearSelection();
        }

        await RefreshGlobalAlertSummaryAsync();
    }

    private async void HandleSessionChanged()
    {
        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _facility != null)
        {
            var selectedNodeId = SessionService.SelectedElementId;
            if (string.IsNullOrWhiteSpace(selectedNodeId) || !_nodesByKey.TryGetValue(selectedNodeId, out var focusedNode))
            {
                ClearFocusNodeState();
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (_selectedFacilityNode?.NodeKey != selectedNodeId)
            {
                _selectedFacilityNode = focusedNode;
                ClearPreviewState();
                _compareSetStatusMessage = null;
                _editorStatusMessage = null;
                EnsureFocusNodeInSelectionSetIfLeaf(_selectedFacilityNode);
                RestoreFocusedNodeEditorDraft();
                
                if (_selectedFacilityNode != null)
                {
                    _isCuratedNode = !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn)
                        || _selectedFacilityNode.NodeKey is "pv_main" or "chp_main" or "cooling_main" or "heating_main";
                    await ReloadPreviewDataAsync();
                }
                else
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        else
        {
            if (_isEditModeOpen && _selectionSet.Count > 0)
            {
                ClearFocusNodeState();
                _compareSetStatusMessage = null;
                await InvokeAsync(StateHasChanged);
                return;
