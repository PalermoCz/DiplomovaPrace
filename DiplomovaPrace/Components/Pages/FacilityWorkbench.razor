    private async Task ReloadData(bool preserveSelection = false, string? preferredFocusNodeKey = null)
    {
        var previousSelectionOrder = preserveSelection
            ? _selectionOrder.Where(_selectionSet.Contains).ToList()
            : [];
        var previousFocusNodeKey = preserveSelection
            ? preferredFocusNodeKey ?? SessionService.SelectedElementId
            : null;

        var facilityTask = FacilityQueryService.GetMainFacilityAsync();
        var editorStateTask = FacilityEditorStateService.GetNodeStatesByKeyAsync();
        var stylePresetsTask = FacilityEditorStateService.GetStylePresetsByKeyAsync();
        var workingSetsTask = FacilityEditorStateService.GetWorkingSetsAsync();

        await Task.WhenAll(facilityTask, editorStateTask, stylePresetsTask, workingSetsTask);

        _facility = BuildSchemaFacilityWithoutWeatherNode(facilityTask.Result);
        _schematicLayout = _facility is not null ? SchematicComposerV2.Compose(_facility) : null;
        SyncEditorNodeStateCache(editorStateTask.Result);
        SyncStylePresetCache(stylePresetsTask.Result);
        SyncWorkingSetCache(workingSetsTask.Result);
        RebuildFacilityNodeIndexes();
        ClearSelectionSetState();
        ClearFocusNodeState();

        if (preserveSelection)
        {
            foreach (var nodeKey in previousSelectionOrder)
            {
                if (_nodesByKey.ContainsKey(nodeKey))
                {
                    AddNodeToSelectionSet(nodeKey);
                }
            }

            var nextFocusNodeKey = !string.IsNullOrWhiteSpace(previousFocusNodeKey) && _nodesByKey.ContainsKey(previousFocusNodeKey)
                ? previousFocusNodeKey
                : GetFallbackFocusNodeKey();

            if (previousSelectionOrder.Count > 1 && string.IsNullOrWhiteSpace(previousFocusNodeKey))
            {
                nextFocusNodeKey = null;
            }

            if (string.IsNullOrWhiteSpace(nextFocusNodeKey))
            {
                SessionService.ClearSelection();
            }
            else
            {
                ApplyFocusNode(nextFocusNodeKey);
            }
        }
        else
        {
            SessionService.ClearSelection();
        }

    }

    private async void HandleSessionChanged()
    {
        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _facility != null)
        {
            var selectedNodeId = SessionService.SelectedElementId;
            if (string.IsNullOrWhiteSpace(selectedNodeId) || !_nodesByKey.TryGetValue(selectedNodeId, out var focusedNode))
            {
                ClearFocusNodeState();
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (_selectedFacilityNode?.NodeKey != selectedNodeId)
            {
                _selectedFacilityNode = focusedNode;
                ClearPreviewState();
                _compareSetStatusMessage = null;
                _editorStatusMessage = null;
                EnsureFocusNodeInSelectionSetIfLeaf(_selectedFacilityNode);
                RestoreFocusedNodeEditorDraft();
                
                if (_selectedFacilityNode != null)
                {
                    _isCuratedNode = IsCuratedNode(_selectedFacilityNode);
                    await ReloadPreviewDataAsync();
                }
                else
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        else
        {
            if (_isEditModeOpen && _selectionSet.Count > 0)
            {
                ClearFocusNodeState();
                _compareSetStatusMessage = null;
                await InvokeAsync(StateHasChanged);
                return;
            }

            ClearSelectionSetState();
            ClearFocusNodeState();
            _compareSetStatusMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool IsCompareSupportedNode(string? nodeKey)
    {
        return AnalyticsPreview.SupportsComparePreview(nodeKey);
    }

    private List<string> GetEffectiveCompareNodeKeysForSelectedNode()
    {
        if (_selectedFacilityNode is null)
        {
            return [];
        }

        var primaryNodeKey = _selectedFacilityNode.NodeKey;
        var seenNodeKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            primaryNodeKey
        };
        var keys = new List<string>();

        foreach (var item in _compareSet)
        {
            if (!IsCompareSupportedNode(item.NodeKey))
            {
                continue;
            }

            if (!seenNodeKeys.Add(item.NodeKey))
            {
                continue;
            }

            keys.Add(item.NodeKey);
        }

        return keys;
    }

    private async Task RefreshComparePreviewAfterCompareSetChangedAsync()
    {
        if (_selectedFacilityNode is not null && _isCuratedNode)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> GetSelectionCompareCandidates()
    {
        var candidates = new List<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>();

        foreach (var nodeKey in _selectionOrder)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            if (!_nodesByKey.TryGetValue(nodeKey, out var node))
            {
                continue;
            }

            if (!IsCompareSupportedNode(node.NodeKey))
            {
                continue;
            }

            candidates.Add(node);
        }

        return candidates;
    }

    private async Task AddSelectionSetToCompareSet()
    {
        if (_selectionSet.Count == 0)
        {
            _compareSetStatusMessage = "The selection set is empty. Select nodes in the schematic first.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var candidates = GetSelectionCompareCandidates();
        if (candidates.Count == 0)
        {
            _compareSetStatusMessage = "The current selection set does not contain nodes with dataset-backed compare capability.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var added = 0;
        var duplicates = 0;

        foreach (var node in candidates)
        {
            if (_compareSet.Any(x => x.NodeKey.Equals(node.NodeKey, StringComparison.OrdinalIgnoreCase)))
            {
                duplicates++;
                continue;
            }

            _compareSet.Add(new CompareSetItem
            {
                NodeKey = node.NodeKey,
                Label = node.Label,
                NodeType = node.NodeType
            });

            added++;
        }

        if (added > 0)
        {
            var statusParts = new List<string> { $"Added {added} node(s) from the selection set." };
            if (duplicates > 0)
            {
                statusParts.Add($"{duplicates} already present in the compare set.");
            }

            _compareSetStatusMessage = string.Join(" ", statusParts);
        }
        else if (duplicates > 0)
        {
            _compareSetStatusMessage = "All supported nodes from the selection set are already in the compare set.";
        }
        else
        {
            _compareSetStatusMessage = "No new nodes were added to the compare set.";
        }

        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private async Task RemoveNodeFromCompareSet(string nodeKey)
    {
        var removedCount = _compareSet.RemoveAll(x => x.NodeKey.Equals(nodeKey, StringComparison.OrdinalIgnoreCase));
        _compareSetStatusMessage = removedCount > 0
            ? "Node removed from the compare set."
            : "Node not found in the compare set.";

        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private async Task ClearCompareSet()
    {
        if (_compareSet.Count == 0)
        {
            _compareSetStatusMessage = "The compare set is already empty.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _compareSet.Clear();
        _compareSetStatusMessage = "Compare set cleared.";
        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

