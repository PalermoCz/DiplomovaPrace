    private void RebuildFacilityNodeIndexes()
    {
        _nodesByKey.Clear();
        _childrenByParentKey.Clear();

        if (_facility is null)
        {
            return;
        }

        foreach (var node in _facility.Nodes)
        {
            _nodesByKey[node.NodeKey] = node;
        }

        foreach (var node in _facility.Nodes)
        {
            if (string.IsNullOrWhiteSpace(node.ParentNodeKey))
            {
                continue;
            }

            if (!_childrenByParentKey.TryGetValue(node.ParentNodeKey, out var children))
            {
                children = [];
                _childrenByParentKey[node.ParentNodeKey] = children;
            }

            children.Add(node);
        }
    }

    private static DiplomovaPrace.Persistence.Schematic.FacilityEntity? BuildSchemaFacilityWithoutWeatherNode(
        DiplomovaPrace.Persistence.Schematic.FacilityEntity? facility)
    {
        if (facility is null)
        {
            return null;
        }

        var filteredNodes = facility.Nodes
            .Where(node => !IsWeatherNode(node.NodeKey))
            .ToList();
        var allowedNodeKeys = filteredNodes
            .Select(node => node.NodeKey)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var filteredEdges = facility.Edges
            .Where(edge => allowedNodeKeys.Contains(edge.SourceNodeKey) && allowedNodeKeys.Contains(edge.TargetNodeKey))
            .ToList();

        var weatherFilteredFacility = new DiplomovaPrace.Persistence.Schematic.FacilityEntity
        {
            Id = facility.Id,
            Name = facility.Name,
            Description = facility.Description,
            TimeZone = facility.TimeZone,
            Nodes = filteredNodes,
            Edges = filteredEdges
        };

        return weatherFilteredFacility;
    }

    private IReadOnlySet<string> GetSelectedSubtreeNodeKeysForCanvas()
    {
        if (_selectionSet.Count == 0)
        {
            return EmptyNodeKeySet;
        }

        // In multi-select mode, highlight only the actual selected set.
        // This keeps single and multi modes mutually exclusive and prevents
        // unrelated structural ancestors from appearing as selected.
        if (IsEditorMultiSelectActive)
        {
            return new HashSet<string>(_selectionSet, StringComparer.OrdinalIgnoreCase);
        }

        var result = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Step 1: If the focused node is structural, build its subtree highlight path (existing behavior).
        if (_selectedFacilityNode is not null && IsStructuralNode(_selectedFacilityNode.NodeKey))
        {
            var focusedNodeKey = _selectedFacilityNode.NodeKey;
            var reachableFromFocus = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { focusedNodeKey };

            var stack = new Stack<string>();
            stack.Push(focusedNodeKey);
            while (stack.Count > 0)
            {
                var curr = stack.Pop();
                if (_childrenByParentKey.TryGetValue(curr, out var ch))
                    foreach (var child in ch)
                        if (reachableFromFocus.Add(child.NodeKey))
                            stack.Push(child.NodeKey);
            }

            result.Add(focusedNodeKey);
            foreach (var selKey in _selectionSet.Where(reachableFromFocus.Contains))
            {
                var cursor = selKey;
                while (!string.IsNullOrWhiteSpace(cursor) && reachableFromFocus.Contains(cursor))
                {
                    if (!result.Add(cursor)) break;
                    if (!string.Equals(cursor, focusedNodeKey, StringComparison.OrdinalIgnoreCase)
                        && _nodesByKey.TryGetValue(cursor, out var n)
                        && !string.IsNullOrWhiteSpace(n.ParentNodeKey))
                    {
                        cursor = n.ParentNodeKey;
                        continue;
                    }
                    break;
                }
            }
        }

        // Step 2: For selected nodes outside the focused subtree, walk up to their nearest
        // structural ancestor and include it.
        foreach (var key in _selectionSet)
        {
            if (result.Contains(key)) continue; // Already covered by focused subtree path

            if (!_nodesByKey.TryGetValue(key, out var node)) continue;

            var parentKey = node.ParentNodeKey;
            while (!string.IsNullOrWhiteSpace(parentKey))
            {
                if (!_nodesByKey.TryGetValue(parentKey, out var ancestor)) break;

                result.Add(parentKey);

                // Stop at the first structural node (zone/area parent) to avoid
                // flooding the entire tree with subtree highlight colour.
                if (IsStructuralNode(parentKey)) break;

                parentKey = ancestor.ParentNodeKey;
            }
        }

        return result;
    }

