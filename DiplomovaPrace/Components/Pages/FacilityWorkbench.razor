                                    {
                                        <span class="badge bg-light text-secondary border">Unsupported: @SelectionAggregateUnsupportedCount</span>
                                    }
                                    @if (SelectionAggregateNoDataCount > 0)
                                    {
                                        <span class="badge bg-light text-secondary border">No-data: @SelectionAggregateNoDataCount</span>
                                    }
                                </div>
                                <div class="headline-kpi-grid">
                                    <div class="headline-kpi-cell"><div class="metric-caption">Consumption</div><div class="fw-semibold">@_selectionAggregateOverview.TotalConsumptionKwh.ToString("N1") kWh</div></div>
                                    <div class="headline-kpi-cell"><div class="metric-caption">Generation</div><div class="fw-semibold">@_selectionAggregateOverview.TotalGenerationKwh.ToString("N1") kWh</div></div>
                                    <div class="headline-kpi-cell"><div class="metric-caption">Net</div><div class="fw-semibold">@FormatSigned(_selectionAggregateOverview.NetEnergyKwh, "N1") kWh</div></div>
                                    <div class="headline-kpi-cell"><div class="metric-caption">Samples</div><div class="fw-semibold">@_selectionAggregateOverview.Summary.DataPoints.ToString("N0")</div></div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview.Message))
                                {
                                    <div class="aggregate-status-line mt-2">@_selectionAggregateOverview.Message</div>
                                }
                            }
                            else
                            {
                                <div class="small text-muted">No aggregate KPI is available for the current selection set.</div>
                                @if (!string.IsNullOrWhiteSpace(_selectionAggregateOverview?.Message))
                                {
                                    <div class="aggregate-status-line mt-2">@_selectionAggregateOverview.Message</div>
                                }
                            }
                        </div>

                        <div class="overview-widget overview-widget-soft main-detail-widget">
                            @if (ShouldShowSelectionScopeDetail)
                            {
                                @if (!string.IsNullOrWhiteSpace(_customIntervalValidationMessage))
                                {
                                    <h6>Selection Scope</h6>
                                    <div class="small text-muted">@_customIntervalValidationMessage</div>
                                }
                                else if (_isPreviewLoading)
                                {
                                    <h6>Selection Scope</h6>
                                    <div class="text-muted d-flex align-items-center">
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span> Resolving the aggregate analytics scope...
                                    </div>
                                }
