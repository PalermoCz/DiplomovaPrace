    private static IReadOnlyList<string> BuildForecastDiagnosticsPoints(CuratedSelectionForecastDiagnosticsSummary diagnostics)
    {
        var points = new List<string>();

        points.Add($"Forecast principle: {diagnostics.ForecastPrinciple}.");
        points.Add($"Coverage aligned bodu: {(diagnostics.AlignmentCoverageRatio * 100.0).ToString("N0")} % actual rady.");

        if (diagnostics.ForecastMissingNodeCount > 0)
        {
            points.Add($"Forecast reference chybi pro {diagnostics.ForecastMissingNodeCount}/{Math.Max(1, diagnostics.IncludedNodeCount)} analyticky zahrnutych uzlu.");
        }

        if (diagnostics.HasMixedSignedSelection)
        {
            points.Add("Mixed-sign selection: SMAPE neni pouzito, metriky jsou MAE/RMSE/Bias + WAPE nad |actual|.");
        }
        else
        {
            points.Add("Consumption/generation-only selection: MAE/RMSE/Bias + WAPE pro rychle cteni shody.");
        }

        if (points.Count == 0)
        {
            points.Add("Forecast diagnostika je zatim nedostupna.");
        }

        return points;
    }

    private static IReadOnlyList<string> BuildOperationalSignalPoints(CuratedSelectionOperationalHealthSummary health)
    {
        var points = new List<string>();

        if (health.HighDeviationNodeCount > 0)
        {
            points.Add($"Silna deviation: {health.HighDeviationNodeCount} uzlu.");
        }

        if (health.ElevatedDeviationNodeCount > 0)
        {
            points.Add($"Elevated deviation: {health.ElevatedDeviationNodeCount} uzlu.");
        }

        if (health.HasWeakCoverage)
        {
            points.Add($"Slabe coverage: {(health.IncludedCoverageRatio * 100.0).ToString("N0")} % podporovanych uzlu je zahrnuto.");
        }

        if (health.HasMixedSignedSelection)
        {
            points.Add("Mixed-sign selection: netto zahrnuje spotrebu i vyrobu.");
        }

        if (health.HasAbruptAggregateShift)
        {
            var abruptRatioText = health.AbruptShiftRatio.HasValue
                ? health.AbruptShiftRatio.Value.ToString("N1")
                : "N/A";
            points.Add($"Nahly skok aggregate rady (ratio {abruptRatioText}).");
        }

        if (health.UnsupportedNodeCount > 0 || health.ContextOnlyNodeCount > 0 || health.NoDataNodeCount > 0)
        {
            points.Add($"Datove omezeni: unsupported {health.UnsupportedNodeCount}, context-only {health.ContextOnlyNodeCount}, no-data {health.NoDataNodeCount}.");
        }

        if (points.Count == 0)
        {
            points.Add("Bez aktivnich issue signalu v aktualnim intervalu.");
        }

        return points;
    }

