</div>

@code {
    private static readonly string[] EnergyAlertNodeKeys = ["pv_main", "chp_main", "cooling_main", "heating_main"];
    private const int BaselineHistoricalYearsForValidation = 3;
    private const int MaxCompareSetSize = 4;
    private static readonly HashSet<string> CompareSetSupportedNodeKeys =
    [
        "heating_main",
        "cooling_main",
        "pv_main",
        "chp_main"
    ];
    private const string CompareSetSupportedNodeListText = "heating_main, cooling_main, pv_main, chp_main";
    private static readonly FacilitySemanticPreset[] SemanticPresetOptions = Enum.GetValues<FacilitySemanticPreset>();
    private static readonly FacilityNodeRole[] SemanticRoleOptions = Enum.GetValues<FacilityNodeRole>();
    private static readonly FacilityNodeSemanticType[] SemanticTypeOptions = Enum.GetValues<FacilityNodeSemanticType>();
    private static readonly SemanticSelectionMutationMode[] SemanticSelectionMutationModeOptions = Enum.GetValues<SemanticSelectionMutationMode>();

    private EditorCanvas? _canvas;
    private DiplomovaPrace.Persistence.Schematic.FacilityEntity? _facility;
    private readonly HashSet<string> _selectionSet = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<string> _selectionOrder = [];
    private readonly Dictionary<string, DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> _nodesByKey = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, List<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>> _childrenByParentKey = new(StringComparer.OrdinalIgnoreCase);
    private static readonly IReadOnlySet<string> EmptyNodeKeySet = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    
    // Facility Node State
    private DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity? _selectedFacilityNode;
    private DiplomovaPrace.Models.Kpi.MeterKpiResult? _nodePreviewData;
    private CuratedNodeSummary? _curatedPreviewData;
    private CuratedSelectionAggregateOverviewResult? _selectionAggregateOverview;
    private CuratedNodeDeviationSummary? _curatedDeviationData;
    private CuratedNodeTimeSeriesResult? _curatedTimeSeriesData;
    private CuratedNodeCompareTimeSeriesResult? _curatedCompareTimeSeriesData;
    private CuratedNodeTimeSeriesMode _timeSeriesMode = CuratedNodeTimeSeriesMode.Auto;
    private bool _showBaselineOverlay;
    private readonly List<CompareSetItem> _compareSet = [];
    private string? _compareSetStatusMessage;
    private FacilitySemanticPreset _semanticPreset = FacilitySemanticPreset.Hvac;
    private SemanticSelectionMutationMode _semanticSelectionMutationMode = SemanticSelectionMutationMode.Replace;
    private bool _semanticSelectionSupportedOnly = true;
    private string _semanticQueryRoleFilterValue = string.Empty;
    private string _semanticQueryTypeFilterValue = string.Empty;
    private string _semanticQueryTagInput = string.Empty;
    private string? _semanticSelectionStatusMessage;
    private bool _isPreviewLoading;
    private bool _isCuratedNode;
    
    // UI State
    private bool _isSchematicHidden = false;
    private string _selectedInterval = "last7d";
    private DateTime _customFromUtc = DateTime.UtcNow.Date.AddDays(-7);
    private DateTime _customToUtcExclusive = DateTime.UtcNow.Date.AddDays(1);
    private DateTime _presetAnchorUtc = DateTime.UtcNow;
    private string? _customIntervalValidationMessage;

    private (DateTime From, DateTime To) GetInterval()
    {
        var anchor = _presetAnchorUtc;

        return _selectedInterval switch
        {
            "last24h" => (anchor.AddHours(-24), anchor),
            "last7d" => (anchor.AddDays(-7), anchor),
            "last30d" => (anchor.AddDays(-30), anchor),
            "thisMonth" => (new DateTime(anchor.Year, anchor.Month, 1, 0, 0, 0, DateTimeKind.Utc), anchor),
            "custom" => GetSafeCustomInterval(),
            _ => (anchor.AddDays(-7), anchor)
        };
    }

    private async Task RefreshPresetAnchorAsync()
    {
        if (_selectedFacilityNode is null)
        {
            _presetAnchorUtc = DateTime.UtcNow;
            return;
        }

        if (!_isCuratedNode)
        {
            _presetAnchorUtc = DateTime.UtcNow;
            return;
        }

        var maxTimestamp = await AnalyticsPreview.GetCuratedNodeMaxTimestampUtcAsync(_selectedFacilityNode.NodeKey);
        _presetAnchorUtc = maxTimestamp ?? DateTime.UtcNow;
    }

    private (DateTime From, DateTime To) GetSafeCustomInterval()
    {
        var from = _customFromUtc;
        var to = _customToUtcExclusive;

        if (to <= from)
        {
            to = from.AddDays(1);
        }

        return (from, to);
    }

    private string CustomFromDateValue => _customFromUtc.ToString("yyyy-MM-dd");

    private string CustomToDateValue => _customToUtcExclusive.AddDays(-1).ToString("yyyy-MM-dd");

    private string DisplayIntervalFromTo
    {
        get
        {
            if (_selectedInterval == "custom")
            {
                var fromDate = _customFromUtc.Date;
                var toInclusiveDate = _customToUtcExclusive.AddDays(-1).Date;
                return $"{fromDate:dd.MM.yyyy} - {toInclusiveDate:dd.MM.yyyy}";
            }

            var interval = GetInterval();
            return $"{interval.From.ToLocalTime():dd.MM.yyyy HH:mm} - {interval.To.ToLocalTime():dd.MM.yyyy HH:mm}";
        }
    }

    private bool ShowPresetAnchorNote => _isCuratedNode && _selectedInterval != "custom";
    private string SelectedIntervalLabel => _selectedInterval switch
    {
        "last24h" => "24h",
        "last7d" => "7d",
        "last30d" => "30d",
        "thisMonth" => "Tento měsíc",
        "custom" => "Custom",
        _ => "7d"
    };
    private int ActiveAlertCount => GlobalAlertSummaryService.Current.HighCount + GlobalAlertSummaryService.Current.ElevatedCount;
    private int SelectionCount => _selectionSet.Count;
    private int SelectionAggregateSupportedCount => _selectionAggregateOverview?.SupportedNodeKeys.Count ?? 0;
    private int SelectionAggregateUnsupportedCount => _selectionAggregateOverview?.UnsupportedNodeKeys.Count ?? 0;
    private int SelectionAggregateContextOnlyCount => _selectionAggregateOverview?.ContextOnlyNodeKeys.Count ?? 0;
    private int SelectionAggregateNoDataCount => _selectionAggregateOverview?.NoDataNodeKeys.Count ?? 0;
    private int SelectionAggregateIncludedCount => _selectionAggregateOverview?.IncludedNodeKeys.Count ?? 0;
    private CuratedSelectionCoverageSummary SelectionCoverage => _selectionAggregateOverview?.Coverage ?? new CuratedSelectionCoverageSummary();
    private CuratedSelectionDisaggregationSummary SelectionDisaggregation => _selectionAggregateOverview?.Disaggregation ?? new CuratedSelectionDisaggregationSummary();
    private CuratedSelectionContributionIntelligenceSummary SelectionContributionIntelligence => _selectionAggregateOverview?.ContributionIntelligence ?? new CuratedSelectionContributionIntelligenceSummary();
    private CuratedSelectionSourceMapSummary SelectionSourceMap => _selectionAggregateOverview?.SourceMap ?? new CuratedSelectionSourceMapSummary();
    private CuratedSelectionOperationalHealthSummary SelectionOperationalHealth => _selectionAggregateOverview?.OperationalHealth ?? new CuratedSelectionOperationalHealthSummary();
    private CuratedNodeCompareTimeSeriesResult? SelectionForecastCompareTimeSeries => _selectionAggregateOverview?.ForecastCompareTimeSeries;
    private CuratedSelectionForecastDiagnosticsSummary SelectionForecastDiagnostics => _selectionAggregateOverview?.ForecastDiagnostics ?? new CuratedSelectionForecastDiagnosticsSummary();
    private CuratedSelectionLoadProfileSummary SelectionLoadProfile => _selectionAggregateOverview?.LoadProfile ?? new CuratedSelectionLoadProfileSummary();
    private CuratedSelectionPeakAnalysisSummary SelectionPeakAnalysis => _selectionAggregateOverview?.PeakAnalysis ?? new CuratedSelectionPeakAnalysisSummary();
    private CuratedSelectionOperatingRegimeSummary SelectionOperatingRegime => _selectionAggregateOverview?.OperatingRegime ?? new CuratedSelectionOperatingRegimeSummary();
    private CuratedSelectionEmsEvaluationSummary SelectionEmsEvaluation => _selectionAggregateOverview?.EmsEvaluation ?? new CuratedSelectionEmsEvaluationSummary();
    private IReadOnlyList<CuratedSelectionContributionItem> SelectionBreakdownItems => _selectionAggregateOverview?.Breakdown ?? [];
    private IReadOnlyList<CuratedSelectionRoleContributionItem> SelectionRoleBreakdownItems => _selectionAggregateOverview?.RoleBreakdown ?? [];
    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> SelectionSummaryItems => GetSelectionSummaryItems();
    private bool HasSelectedNodes => SelectionCount > 0;
    private int CompareSetRemainingCapacity => Math.Max(0, MaxCompareSetSize - _compareSet.Count);
    private int SelectionCompareSupportedCount => GetSelectionCompareCandidates().Count;
    private bool CanAddSelectionSetToCompareSet => GetSelectionCompareCandidates().Any(node => !_compareSet.Any(x => x.NodeKey.Equals(node.NodeKey, StringComparison.OrdinalIgnoreCase))) && !IsCompareSetAtCapacity;
    private bool IsCompareSetAtCapacity => _compareSet.Count >= MaxCompareSetSize;
    private bool IsSelectedNodeComparePreviewSupported => _selectedFacilityNode is not null && IsCompareSupportedNode(_selectedFacilityNode.NodeKey);
    private bool ShouldShowComparePreview => _isCuratedNode && IsSelectedNodeComparePreviewSupported && GetEffectiveCompareNodeKeysForSelectedNode().Count > 0;
    private IReadOnlySet<string> SelectedSubtreeNodeKeysForCanvas => GetSelectedSubtreeNodeKeysForCanvas();

    private IReadOnlyDictionary<string, NodeDeviationSeverity> AlertSeverityByNodeKey =>
        GlobalAlertSummaryService.Current.AlertedNodes
            .ToDictionary(x => x.NodeKey, x => x.Severity, StringComparer.OrdinalIgnoreCase);

    private sealed class CompareSetItem
    {
        public required string NodeKey { get; init; }
        public required string Label { get; init; }
        public string? NodeType { get; init; }
    }

    private enum SemanticSelectionMutationMode
    {
        Replace,
        Add,
        Remove
    }

    private readonly record struct SemanticSelectionMutationResult(int AddedCount, int RemovedCount)
    {
        public bool HasChanges => AddedCount > 0 || RemovedCount > 0;
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadData();
        SessionService.OnSessionChanged += HandleSessionChanged;
        // Výchozí nástroj pro prohlížení schématu
        SessionService.SetActiveTool(EditorTool.Select);
    }

    private async Task ReloadData()
    {
        var facility = await FacilityQueryService.GetMainFacilityAsync();
        _facility = BuildSchemaFacilityWithoutWeatherNode(facility);
        RebuildFacilityNodeIndexes();
        ClearSelectionSetState();
        ClearFocusNodeState();
        SessionService.ClearSelection();
        await RefreshGlobalAlertSummaryAsync();
    }

    private async void HandleSessionChanged()
    {
        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && _facility != null)
        {
            var selectedNodeId = SessionService.SelectedElementId;
            if (string.IsNullOrWhiteSpace(selectedNodeId) || !_nodesByKey.TryGetValue(selectedNodeId, out var focusedNode))
            {
                ClearFocusNodeState();
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (_selectedFacilityNode?.NodeKey != selectedNodeId)
            {
                _selectedFacilityNode = focusedNode;
                ClearPreviewState();
                _compareSetStatusMessage = null;
                EnsureFocusNodeInSelectionSetIfLeaf(_selectedFacilityNode);
                
                if (_selectedFacilityNode != null)
                {
                    _isCuratedNode = _selectedFacilityNode.NodeKey is "pv_main" or "chp_main" or "cooling_main" or "heating_main";
                    await ReloadPreviewDataAsync();
                }
                else
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        else
        {
            ClearSelectionSetState();
            ClearFocusNodeState();
            _compareSetStatusMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool IsCompareSupportedNode(string? nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            return false;
        }

        return CompareSetSupportedNodeKeys.Contains(nodeKey);
    }

    private List<string> GetEffectiveCompareNodeKeysForSelectedNode()
    {
        if (_selectedFacilityNode is null)
        {
            return [];
        }

        var primaryNodeKey = _selectedFacilityNode.NodeKey;
        var seenNodeKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            primaryNodeKey
        };
        var keys = new List<string>();

        foreach (var item in _compareSet)
        {
            if (!IsCompareSupportedNode(item.NodeKey))
            {
                continue;
            }

            if (!seenNodeKeys.Add(item.NodeKey))
            {
                continue;
            }

            keys.Add(item.NodeKey);
        }

        return keys;
    }

    private async Task RefreshComparePreviewAfterCompareSetChangedAsync()
    {
        if (_selectedFacilityNode is not null && _isCuratedNode)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> GetSelectionCompareCandidates()
    {
        var candidates = new List<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>();

        foreach (var nodeKey in _selectionOrder)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            if (!_nodesByKey.TryGetValue(nodeKey, out var node))
            {
                continue;
            }

            if (!IsCompareSupportedNode(node.NodeKey))
            {
                continue;
            }

            candidates.Add(node);
        }

        return candidates;
    }

    private async Task AddSelectionSetToCompareSet()
    {
        if (_selectionSet.Count == 0)
        {
            _compareSetStatusMessage = "Selection set je prázdný. Nejprve vyberte uzly ve schématu.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var candidates = GetSelectionCompareCandidates();
        if (candidates.Count == 0)
        {
            _compareSetStatusMessage = "V aktuálním selection setu nejsou uzly podporované pro compare set.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var added = 0;
        var duplicates = 0;
        var skippedByCapacity = 0;

        foreach (var node in candidates)
        {
            if (_compareSet.Any(x => x.NodeKey.Equals(node.NodeKey, StringComparison.OrdinalIgnoreCase)))
            {
                duplicates++;
                continue;
            }

            if (_compareSet.Count >= MaxCompareSetSize)
            {
                skippedByCapacity++;
                continue;
            }

            _compareSet.Add(new CompareSetItem
            {
                NodeKey = node.NodeKey,
                Label = node.Label,
                NodeType = node.NodeType
            });

            added++;
        }

        if (added > 0)
        {
            var statusParts = new List<string> { $"Přidáno {added} uzlů z selection setu." };
            if (duplicates > 0)
            {
                statusParts.Add($"{duplicates} už bylo v compare setu");
            }

            if (skippedByCapacity > 0)
            {
                statusParts.Add($"{skippedByCapacity} se nevešlo kvůli limitu");
            }

            _compareSetStatusMessage = string.Join(" ", statusParts);
        }
        else if (duplicates > 0)
        {
            _compareSetStatusMessage = "Všechny podporované uzly ze selection setu už v compare setu jsou.";
        }
        else
        {
            _compareSetStatusMessage = "Compare set je plný. Pro přidání dalších uzlů nejprve některé odeberte.";
        }

        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private async Task RemoveNodeFromCompareSet(string nodeKey)
    {
        var removedCount = _compareSet.RemoveAll(x => x.NodeKey.Equals(nodeKey, StringComparison.OrdinalIgnoreCase));
        _compareSetStatusMessage = removedCount > 0
            ? "Uzel byl odebrán z compare setu."
            : "Uzel v compare setu nebyl nalezen.";

        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private async Task ClearCompareSet()
    {
        if (_compareSet.Count == 0)
        {
            _compareSetStatusMessage = "Compare set je už prázdný.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _compareSet.Clear();
        _compareSetStatusMessage = "Compare set byl vyčištěn.";
        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private async Task ApplySemanticPresetAsync()
    {
        var presetQuery = FacilityNodeSemantics.GetPresetQuery(_semanticPreset);
        var query = new FacilityNodeSemanticQuery
        {
            Role = presetQuery.Role,
            SemanticType = presetQuery.SemanticType,
