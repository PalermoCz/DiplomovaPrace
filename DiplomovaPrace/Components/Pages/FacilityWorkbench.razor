    private async Task ImportSeriesForSelectedNodeAsync()
    {
        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _importStatusMessage = "Select one editable node before importing data.";
            _importErrors = [];
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_importSeriesFile is null)
        {
            _importStatusMessage = "Choose a CSV file before starting the import.";
            _importErrors = [];
            await InvokeAsync(StateHasChanged);
            return;
        }

        _isImportingSeries = true;
        _importStatusMessage = null;
        _importErrors = [];
        await InvokeAsync(StateHasChanged);

        try
        {
            await using var stream = _importSeriesFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var result = await NodeSeriesImportService.ImportAsync(
                stream,
                new FacilityNodeSeriesImportRequest(
                    _selectedFacilityNode.NodeKey,
                    _importExactSignalCodeInput,
                    _importUnitInput,
                    _importSeriesFile.Name,
                    NormalizeOptionalText(_importMeterUrnInput),
                    NormalizeOptionalText(_importSourceLabelInput)));

            _importStatusMessage = result.Message;
            _importErrors = result.Errors;

            if (result.Success)
            {
                _importSeriesFile = null;
                if (result.Binding is not null && string.IsNullOrWhiteSpace(_activeAnalyticsSignalCodeValue))
                {
                    _activeAnalyticsSignalCodeValue = result.Binding.ExactSignalCode;
                }

                _isCuratedNode = IsCuratedNode(_selectedFacilityNode);
                await ReloadPreviewDataAsync();
            }
        }
        catch (Exception ex)
        {
            _importStatusMessage = $"Import failed: {ex.Message}";
            _importErrors = [];
        }
        finally
        {
            _isImportingSeries = false;
            await InvokeAsync(StateHasChanged);
        }
    }

