            WeatherExplanationStatus.SupportedByWeather => "weather supports the explanation",
            WeatherExplanationStatus.NotSupportedByWeather => "weather does not support the explanation",
            WeatherExplanationStatus.WeatherChangeNeutral => "weather change is nearly neutral",
            _ => "explanation unavailable"
        };
    }

    private static string GetWeatherExplanationBadgeClass(WeatherExplanationStatus status)
    {
        return status switch
        {
            WeatherExplanationStatus.SupportedByWeather => "bg-info text-dark",
            WeatherExplanationStatus.NotSupportedByWeather => "bg-secondary",
            WeatherExplanationStatus.WeatherChangeNeutral => "bg-light text-dark border",
            _ => "bg-light text-dark border"
        };
    }

    private static string GetAlertStatusText(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "explanatory uzel";
        }

        if (deviation?.IsAvailable != true)
        {
            return "not evaluated";
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => "critical deviation",
            NodeDeviationSeverity.Elevated => "attention",
            _ => "normal"
        };
    }

    private static string GetAlertBadgeClass(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "bg-info text-dark";
        }

        if (deviation?.IsAvailable != true)
        {
            return "bg-secondary";
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => "bg-danger",
            NodeDeviationSeverity.Elevated => "bg-warning text-dark",
            _ => "bg-success"
        };
    }

    private static string GetAlertReasonText(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "The weather context node is only an explanatory factor in this sprint, so energy alerts are intentionally not evaluated here.";
        }

        if (deviation?.IsAvailable != true)
        {
            return deviation?.Message ?? "Baseline deviation is unavailable for the selected interval, so alert state cannot be evaluated yet.";
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => "Absolute relative deviation versus baseline is above 25%.",
            NodeDeviationSeverity.Elevated => "Absolute relative deviation versus baseline is between 10% and 25%.",
            _ => "Absolute relative deviation versus baseline is below 10%."
        };
    }

    private static string GetAlertSourceText(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return "The weather node is explicitly outside energy-alert evaluation. It remains explanatory context for the other systems.";
        }

        if (deviation?.IsAvailable == true)
        {
            return "Alert state maps directly from deviation severity: Normal -> normal, Elevated -> attention, High -> critical deviation. Severity is derived from |delta %| versus baseline (<10, 10-25, >25).";
        }

        return "Alert foundation is tied to the deviation and baseline layer. If deviation is unavailable, the node remains not evaluated without an improvised fallback alert.";
    }

    private static (string Token, string Hex) GetSchematicAlertColorHint(string? nodeKey, CuratedNodeDeviationSummary? deviation)
    {
        if (IsWeatherNode(nodeKey))
        {
            return ("informational / blue", "#0ea5e9");
        }

        if (deviation?.IsAvailable != true)
        {
            return ("neutral / slate", "#94a3b8");
        }

        return deviation.Severity switch
        {
            NodeDeviationSeverity.High => ("danger / red", "#dc2626"),
            NodeDeviationSeverity.Elevated => ("warning / amber", "#f59e0b"),
            _ => ("neutral / green-ish", "#22c55e")
        };
    }

    private static bool IsWeatherNode(string? nodeKey)
    {
        return FacilityNodeSemantics.IsWeatherContextNode(nodeKey);
    }

    private static bool TryParseCustomDateInput(string raw, out DateTime parsedDateUtc)
    {
        parsedDateUtc = default;

        if (string.IsNullOrWhiteSpace(raw))
        {
            return false;
        }

        // Accept both legacy dd.MM.yyyy and new yyyy-MM-dd formats
        if (DateTime.TryParseExact(raw.Trim(), new[] { "yyyy-MM-dd", "dd.MM.yyyy" }, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var parsed))
        {
            parsedDateUtc = DateTime.SpecifyKind(parsed.Date, DateTimeKind.Utc);
            return true;
        }

        return false;
    }

    private async Task<string?> ValidateCustomIntervalForAnalyticsAsync()
    {
        if (_customFromUtc == default || _customToUtcExclusive == default)
        {
            return "The custom interval is incomplete.";
        }

        if (_customToUtcExclusive <= _customFromUtc)
        {
            return "The end date must be later than the start date.";
        }

        if (_customFromUtc.Year <= BaselineHistoricalYearsForValidation)
        {
            return "The start date is too early for baseline comparison against previous years.";
        }

        var domain = await GetCurrentAnalyticsTimeDomainUtcAsync();
        if (!domain.MinUtc.HasValue || !domain.MaxUtc.HasValue)
        {
            return null;
        }

        var domainMin = domain.MinUtc.Value;
        var domainMaxExclusive = domain.MaxUtc.Value.AddMinutes(15);
        var hasOverlap = _customFromUtc < domainMaxExclusive && _customToUtcExclusive > domainMin;

        if (!hasOverlap)
        {
            var scopeLabel = ShouldUseAggregateAnalyticsIntervalScope
                ? "the current analytics scope"
                : $"node {_selectedFacilityNode?.NodeKey}";

            return $"The selected custom interval is outside the available data range for {scopeLabel} ({domainMin:dd.MM.yyyy} - {domain.MaxUtc.Value:dd.MM.yyyy}).";
        }

        return null;
    }

