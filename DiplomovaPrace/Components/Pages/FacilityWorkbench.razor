    {
        var query = BuildSemanticQueryFromFilters();
        await ApplySemanticSelectionAsync(query, "Semantic query");
    }

    private void ClearSemanticQueryFilters()
    {
        _semanticQueryRoleFilterValue = string.Empty;
        _semanticQueryTypeFilterValue = string.Empty;
        _semanticQueryTagInput = string.Empty;
        _semanticSelectionStatusMessage = "Filtry semantic query byly resetovány.";
    }

    private FacilityNodeSemanticQuery BuildSemanticQueryFromFilters()
    {
        FacilityNodeRole? roleFilter = null;
        if (Enum.TryParse<FacilityNodeRole>(_semanticQueryRoleFilterValue, out var parsedRoleFilter))
        {
            roleFilter = parsedRoleFilter;
        }

        FacilityNodeSemanticType? semanticTypeFilter = null;
        if (Enum.TryParse<FacilityNodeSemanticType>(_semanticQueryTypeFilterValue, out var parsedSemanticTypeFilter))
        {
            semanticTypeFilter = parsedSemanticTypeFilter;
        }

        return new FacilityNodeSemanticQuery
        {
            Role = roleFilter,
            SemanticType = semanticTypeFilter,
            Tags = FacilityNodeSemantics.ParseTagQuery(_semanticQueryTagInput),
            IncludeWeatherContext = false
        };
    }

    private async Task ApplySemanticSelectionAsync(FacilityNodeSemanticQuery query, string sourceLabel)
    {
        if (_facility is null || _facility.Nodes.Count == 0)
        {
            _semanticSelectionStatusMessage = "Facility data nejsou načtena. Semantic selection se nespustila.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var candidateNodes = _facility.Nodes
            .Where(IsLeafOrAnalyticNode)
            .ToList();
        var candidateNodeKeys = FacilityNodeSemantics
            .ResolveMatchingNodeKeys(candidateNodes, query)
            .Where(_nodesByKey.ContainsKey)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        string? supportedFilterNotice = null;
        if (_semanticSelectionSupportedOnly && candidateNodeKeys.Count > 0)
        {
            try
            {
                var supportedNodeKeys = await ResolveAnalyticsSupportedNodeKeysAsync(candidateNodeKeys);
                candidateNodeKeys = candidateNodeKeys
                    .Where(supportedNodeKeys.Contains)
                    .ToList();
            }
            catch
            {
                supportedFilterNotice = "Supported filtr nebyl dostupný, použil se plný výsledek query.";
            }
        }

        var mutationResult = MutateSelectionSet(candidateNodeKeys, _semanticSelectionMutationMode);
        _semanticSelectionStatusMessage = BuildSemanticSelectionStatusMessage(sourceLabel, candidateNodeKeys.Count, mutationResult, supportedFilterNotice);

        var nextFocusNodeKey = ResolveFocusNodeAfterSemanticMutation(_semanticSelectionMutationMode, mutationResult);
        var focusChanged = ApplyFocusNode(nextFocusNodeKey);
        if (!focusChanged)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<HashSet<string>> ResolveAnalyticsSupportedNodeKeysAsync(IReadOnlyList<string> candidateNodeKeys)
    {
        if (candidateNodeKeys.Count == 0)
        {
            return new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }

        var interval = GetInterval();
        var aggregate = await AnalyticsPreview.GetCuratedSelectionAggregateOverviewAsync(
            candidateNodeKeys,
            interval.From,
            interval.To,
            _timeSeriesMode,
            _showBaselineOverlay);

        return aggregate.SupportedNodeKeys.ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private SemanticSelectionMutationResult MutateSelectionSet(
        IReadOnlyList<string> nodeKeys,
        SemanticSelectionMutationMode mutationMode)
    {
        var uniqueNodeKeys = nodeKeys
            .Where(key => !string.IsNullOrWhiteSpace(key))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var addedCount = 0;
        var removedCount = 0;

        if (mutationMode == SemanticSelectionMutationMode.Replace)
        {
            var previousSelection = _selectionSet.ToHashSet(StringComparer.OrdinalIgnoreCase);
            ClearSelectionSetState();

            foreach (var nodeKey in uniqueNodeKeys)
            {
                AddNodeToSelectionSet(nodeKey);
            }

            var nextSelection = _selectionSet;
            addedCount = nextSelection.Count(nodeKey => !previousSelection.Contains(nodeKey));
            removedCount = previousSelection.Count(nodeKey => !nextSelection.Contains(nodeKey));
            return new SemanticSelectionMutationResult(addedCount, removedCount);
        }

        if (mutationMode == SemanticSelectionMutationMode.Add)
        {
            foreach (var nodeKey in uniqueNodeKeys)
            {
                if (_selectionSet.Contains(nodeKey))
                {
                    continue;
                }

                AddNodeToSelectionSet(nodeKey);
                addedCount++;
            }

            return new SemanticSelectionMutationResult(addedCount, 0);
        }

        foreach (var nodeKey in uniqueNodeKeys)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            RemoveNodeFromSelectionSet(nodeKey);
            removedCount++;
        }

        return new SemanticSelectionMutationResult(0, removedCount);
    }

    private string? ResolveFocusNodeAfterSemanticMutation(
        SemanticSelectionMutationMode mutationMode,
        SemanticSelectionMutationResult mutationResult)
    {
        if (_selectionSet.Count == 0)
        {
            return null;
        }

        if (mutationMode is SemanticSelectionMutationMode.Replace)
        {
            return GetFallbackFocusNodeKey();
        }

        if (mutationMode is SemanticSelectionMutationMode.Add && mutationResult.AddedCount > 0)
        {
            return GetFallbackFocusNodeKey();
        }

        if (!string.IsNullOrWhiteSpace(SessionService.SelectedElementId)
            && _selectionSet.Contains(SessionService.SelectedElementId))
        {
            return SessionService.SelectedElementId;
        }

        return GetFallbackFocusNodeKey();
    }

    private string BuildSemanticSelectionStatusMessage(
        string sourceLabel,
        int matchedCount,
        SemanticSelectionMutationResult mutationResult,
        string? note)
    {
        var scopeLabel = _semanticSelectionSupportedOnly ? "supported-only" : "full-scope";
        var mutationLabel = GetSemanticMutationModeLabel(_semanticSelectionMutationMode).ToLowerInvariant();

        string baseMessage;
        if (matchedCount == 0)
        {
            baseMessage = $"{sourceLabel}: žádné uzly neodpovídají ({scopeLabel}).";
        }
        else if (!mutationResult.HasChanges)
        {
            baseMessage = $"{sourceLabel}: nalezeno {matchedCount} uzlů ({scopeLabel}), selection beze změny ({mutationLabel}).";
        }
        else
        {
            baseMessage = $"{sourceLabel}: nalezeno {matchedCount} uzlů ({scopeLabel}), změna selection {mutationLabel}: +{mutationResult.AddedCount} / -{mutationResult.RemovedCount}.";
        }

        if (string.IsNullOrWhiteSpace(note))
        {
            return baseMessage;
        }

        return $"{baseMessage} {note}";
    }

    private static string GetSemanticMutationModeLabel(SemanticSelectionMutationMode mode)
    {
        return mode switch
        {
            SemanticSelectionMutationMode.Replace => "Replace",
            SemanticSelectionMutationMode.Add => "Add",
            SemanticSelectionMutationMode.Remove => "Remove",
            _ => "Replace"
        };
    }

    private async Task OnIntervalChanged(ChangeEventArgs e)
    {
        if (e.Value is string s)
        {
            _selectedInterval = s;
            await ReloadPreviewDataAsync();
        }
    }

    private async Task OnCustomFromChanged(ChangeEventArgs e)
    {
        if (e.Value is not string raw || !TryParseHtmlDate(raw, out var parsedDateUtc))
        {
            _customIntervalValidationMessage = "Custom interval není ve validním formátu data.";
            return;
        }

        _customFromUtc = parsedDateUtc;
        if (_customToUtcExclusive <= _customFromUtc)
        {
            _customToUtcExclusive = _customFromUtc.AddDays(1);
        }

        _customIntervalValidationMessage = null;
        await ReloadPreviewDataAsync();
    }

    private async Task OnCustomToChanged(ChangeEventArgs e)
    {
        if (e.Value is not string raw || !TryParseHtmlDate(raw, out var parsedDateUtc))
        {
            _customIntervalValidationMessage = "Custom interval není ve validním formátu data.";
            return;
        }

        if (parsedDateUtc.Date >= DateTime.MaxValue.Date)
        {
            _customIntervalValidationMessage = "Zadané datum je mimo reprezentovatelný rozsah.";
            return;
        }

        _customToUtcExclusive = DateTime.SpecifyKind(parsedDateUtc.Date.AddDays(1), DateTimeKind.Utc);
        if (_customToUtcExclusive <= _customFromUtc)
        {
            _customToUtcExclusive = _customFromUtc.AddDays(1);
        }

        _customIntervalValidationMessage = null;
        await ReloadPreviewDataAsync();
    }

    private async Task OnTimeSeriesModeChanged(CuratedNodeTimeSeriesMode mode)
    {
        if (_timeSeriesMode == mode)
        {
            return;
        }

        _timeSeriesMode = mode;

        if (HasSelectedNodes || (_selectedFacilityNode is not null && _isCuratedNode))
        {
            await ReloadPreviewDataAsync();
        }
    }

    private async Task OnShowBaselineOverlayChanged(bool enabled)
    {
        if (_showBaselineOverlay == enabled)
        {
            return;
        }

        _showBaselineOverlay = enabled;

        if (HasSelectedNodes || (_selectedFacilityNode is not null && _isCuratedNode))
        {
            await ReloadPreviewDataAsync();
        }
    }

    private async Task ReloadPreviewDataAsync()
    {
        var hasSelectionContext = HasSelectedNodes;
        var hasFocusAnalyticsContext = _selectedFacilityNode != null && (_isCuratedNode || !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn));

        if (!hasSelectionContext && !hasFocusAnalyticsContext)
        {
            _selectionAggregateOverview = null;
            await RefreshGlobalAlertSummaryAsync();
            await InvokeAsync(StateHasChanged);
            return;
        }

        _isPreviewLoading = true;
        await InvokeAsync(StateHasChanged);
        var skipPostRefresh = false;

        try
        {
            await RefreshPresetAnchorAsync();
            var interval = GetInterval();
            var aggregateNodeKeys = GetSelectionAggregateNodeKeys();
            Task<CuratedSelectionAggregateOverviewResult>? aggregateTask = null;

            if (_selectedInterval == "custom")
            {
                var customValidationMessage = await ValidateCustomIntervalForAnalyticsAsync();
                if (!string.IsNullOrWhiteSpace(customValidationMessage))
                {
                    _customIntervalValidationMessage = customValidationMessage;
                    _nodePreviewData = null;
                    _curatedPreviewData = null;
                    _curatedTimeSeriesData = null;
                    _curatedCompareTimeSeriesData = null;
                    _selectionAggregateOverview = new CuratedSelectionAggregateOverviewResult
                    {
                        Message = customValidationMessage
                    };

                    if (_isCuratedNode)
                    {
                        _curatedDeviationData = new CuratedNodeDeviationSummary
                        {
                            IsAvailable = false,
                            Message = customValidationMessage,
                            Methodology = "Validace custom intervalu: analytika se spouští pouze pro validní a datově smysluplný rozsah."
                        };
                    }
                    else
                    {
                        _curatedDeviationData = null;
                    }

                    skipPostRefresh = true;
                }

                if (!skipPostRefresh)
                {
                    _customIntervalValidationMessage = null;
                }
            }

            if (!skipPostRefresh && aggregateNodeKeys.Count > 0)
            {
                aggregateTask = AnalyticsPreview.GetCuratedSelectionAggregateOverviewAsync(
                    aggregateNodeKeys,
                    interval.From,
                    interval.To,
                    _timeSeriesMode,
                    _showBaselineOverlay);
            }

            if (!skipPostRefresh && _isCuratedNode)
            {
                var focusNode = _selectedFacilityNode;
                if (focusNode is not null)
                {
                    var summaryTask = AnalyticsPreview.GetCuratedSummaryAsync(focusNode.NodeKey, interval.From, interval.To);
                    var deviationTask = AnalyticsPreview.GetCuratedDeviationSummaryAsync(focusNode.NodeKey, interval.From, interval.To);
                    var timeSeriesTask = AnalyticsPreview.GetCuratedTimeSeriesAsync(
                        focusNode.NodeKey,
                        interval.From,
                        interval.To,
                        _timeSeriesMode,
                        _showBaselineOverlay);
                    var effectiveCompareNodeKeys = GetEffectiveCompareNodeKeysForSelectedNode();
                    Task<CuratedNodeCompareTimeSeriesResult?>? compareTask = null;

                    if (IsSelectedNodeComparePreviewSupported && effectiveCompareNodeKeys.Count > 0)
                    {
                        compareTask = AnalyticsPreview.GetCuratedCompareTimeSeriesAsync(
                            focusNode.NodeKey,
                            effectiveCompareNodeKeys,
                            interval.From,
                            interval.To,
                            _timeSeriesMode);
                    }

                    var loadTasks = new List<Task> { summaryTask, deviationTask, timeSeriesTask };
                    if (compareTask is not null)
                    {
                        loadTasks.Add(compareTask);
                    }

                    if (aggregateTask is not null)
                    {
                        loadTasks.Add(aggregateTask);
                    }

                    await Task.WhenAll(loadTasks);
                    _curatedPreviewData = summaryTask.Result;
                    _curatedDeviationData = deviationTask.Result;
                    _curatedTimeSeriesData = timeSeriesTask.Result;
                    _curatedCompareTimeSeriesData = compareTask?.Result;
                    _selectionAggregateOverview = aggregateTask?.Result;
                }
                else
                {
                    _curatedPreviewData = null;
                    _curatedDeviationData = null;
                    _curatedTimeSeriesData = null;
                    _curatedCompareTimeSeriesData = null;
                    _selectionAggregateOverview = aggregateTask is not null
                        ? await aggregateTask
                        : null;
                }
            }
            else if (!skipPostRefresh && _selectedFacilityNode is not null && !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn))
            {
                _curatedDeviationData = null;
                _curatedTimeSeriesData = null;
                _curatedCompareTimeSeriesData = null;
                _nodePreviewData = await AnalyticsPreview.GetPreviewDataAsync(_selectedFacilityNode.MeterUrn!, interval.From, interval.To);
                _selectionAggregateOverview = aggregateTask is not null
                    ? await aggregateTask
                    : null;
            }
            else if (!skipPostRefresh)
            {
                _nodePreviewData = null;
                _curatedPreviewData = null;
                _curatedDeviationData = null;
                _curatedTimeSeriesData = null;
                _curatedCompareTimeSeriesData = null;
                _selectionAggregateOverview = aggregateTask is not null
                    ? await aggregateTask
                    : null;
            }
        }
        finally
        {
            _isPreviewLoading = false;
        }

        if (skipPostRefresh)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await RefreshGlobalAlertSummaryAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshGlobalAlertSummaryAsync(CancellationToken ct = default)
    {
        try
        {
            // Global summary musí používat stejný aktuální analysis window jako detail/schéma.
            var interval = GetInterval();

            var deviationTasks = EnergyAlertNodeKeys.Select(async nodeKey =>
            {
                var deviation = await AnalyticsPreview.GetCuratedDeviationSummaryAsync(nodeKey, interval.From, interval.To, ct);
                return (NodeKey: nodeKey, Deviation: deviation);
            }).ToArray();

            await Task.WhenAll(deviationTasks);

            var labelByNodeKey = _facility?.Nodes
                .ToDictionary(n => n.NodeKey, n => n.Label, StringComparer.OrdinalIgnoreCase)
                ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            var facilityName = !string.IsNullOrWhiteSpace(_facility?.Name)
                ? _facility!.Name
                : "Smart Company Facility";

            var alertedNodes = new List<FacilityAlertNodeSummaryItem>();
            foreach (var task in deviationTasks)
            {
                var result = task.Result;
                if (result.Deviation.IsAvailable != true)
                {
                    continue;
                }

                if (result.Deviation.Severity is not (NodeDeviationSeverity.High or NodeDeviationSeverity.Elevated))
                {
                    continue;
                }

                alertedNodes.Add(new FacilityAlertNodeSummaryItem
                {
                    NodeKey = result.NodeKey,
                    Label = labelByNodeKey.TryGetValue(result.NodeKey, out var label) && !string.IsNullOrWhiteSpace(label)
                        ? label
                        : result.NodeKey,
                    FacilityName = facilityName,
                    Severity = result.Deviation.Severity!.Value
                });
            }

            var orderedNodes = alertedNodes
                .OrderByDescending(n => n.Severity)
                .ThenBy(n => n.Label, StringComparer.CurrentCulture)
                .ToList();

            GlobalAlertSummaryService.Update(new FacilityGlobalAlertSummary
            {
                HighCount = orderedNodes.Count(n => n.Severity == NodeDeviationSeverity.High),
                ElevatedCount = orderedNodes.Count(n => n.Severity == NodeDeviationSeverity.Elevated),
                ActiveFacilityName = facilityName,
                AlertedNodes = orderedNodes,
                UpdatedUtc = DateTime.UtcNow
            });
        }
        catch
        {
            GlobalAlertSummaryService.Update(new FacilityGlobalAlertSummary
            {
                HighCount = 0,
                ElevatedCount = 0,
                ActiveFacilityName = _facility?.Name ?? "Smart Company Facility",
                AlertedNodes = []
            });
        }
    }

    private void HandleElementSelected((string Id, EditorSelectionType Type) args)
    {
        if (args.Type == EditorSelectionType.FacilityNode && !string.IsNullOrWhiteSpace(args.Id))
        {
            HandleFacilityNodeClicked(args.Id);
            return;
        }

        if (string.IsNullOrEmpty(args.Id))
        {
            ClearWorkspaceSelection();
            return;
        }

        SessionService.SelectElement(args.Id, args.Type);
    }

    private void HandleCanvasClicked((double X, double Y) pos)
    {
        ClearWorkspaceSelection();
    }

    private void HandleFacilityNodeClicked(string nodeKey)
    {
        if (!_nodesByKey.TryGetValue(nodeKey, out var node))
        {
            ClearWorkspaceSelection();
            return;
        }

        string? nextFocusNodeKey;

        if (IsStructuralNode(node.NodeKey))
        {
            ToggleStructuralSubtreeSelection(node);
            nextFocusNodeKey = _selectionSet.Count == 0 ? null : node.NodeKey;
        }
        else
        {
            var wasRemoved = ToggleLeafSelection(node.NodeKey);
            if (!wasRemoved)
            {
                nextFocusNodeKey = node.NodeKey;
            }
            else if (string.Equals(SessionService.SelectedElementId, node.NodeKey, StringComparison.OrdinalIgnoreCase))
            {
                nextFocusNodeKey = GetFallbackFocusNodeKey();
            }
            else
            {
                nextFocusNodeKey = SessionService.SelectedElementId;
            }

            if (_selectionSet.Count == 0)
            {
                nextFocusNodeKey = null;
            }
        }

        var focusChanged = ApplyFocusNode(nextFocusNodeKey);
        if (!focusChanged)
        {
            InvokeAsync(async () => await ReloadPreviewDataAsync());
        }
    }

    private IReadOnlyList<string> GetSelectionAggregateNodeKeys()
    {
        var nodeKeys = new List<string>();

        foreach (var nodeKey in _selectionOrder)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            if (IsWeatherNode(nodeKey))
            {
                continue;
            }

            nodeKeys.Add(nodeKey);
        }

        return nodeKeys;
    }

    private void ClearWorkspaceSelection()
    {
        ClearSelectionSetState();

        var focusChanged = ApplyFocusNode(null);
        if (!focusChanged)
        {
            ClearFocusNodeState();
            InvokeAsync(StateHasChanged);
        }
    }

    private bool ApplyFocusNode(string? nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            if (SessionService.SelectedElementType == EditorSelectionType.None && string.IsNullOrWhiteSpace(SessionService.SelectedElementId))
            {
                return false;
            }

            SessionService.ClearSelection();
            return true;
        }

        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && string.Equals(SessionService.SelectedElementId, nodeKey, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        SessionService.SelectElement(nodeKey, EditorSelectionType.FacilityNode);
        return true;
    }

    private bool ToggleLeafSelection(string nodeKey)
    {
        if (_selectionSet.Contains(nodeKey))
        {
            RemoveNodeFromSelectionSet(nodeKey);
            return true;
        }

        AddNodeToSelectionSet(nodeKey);
        return false;
    }

    private void ToggleStructuralSubtreeSelection(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity structuralNode)
    {
        var descendantLeafNodes = GetDescendantLeafOrAnalyticNodes(structuralNode.NodeKey);
        if (descendantLeafNodes.Count == 0)
        {
            return;
        }

        var areAllDescendantsSelected = descendantLeafNodes.All(node => _selectionSet.Contains(node.NodeKey));
        foreach (var descendant in descendantLeafNodes)
        {
            if (areAllDescendantsSelected)
            {
                RemoveNodeFromSelectionSet(descendant.NodeKey);
            }
            else
            {
                AddNodeToSelectionSet(descendant.NodeKey);
            }
        }
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> GetDescendantLeafOrAnalyticNodes(string parentNodeKey)
    {
        if (!_childrenByParentKey.TryGetValue(parentNodeKey, out var directChildren) || directChildren.Count == 0)
        {
            return [];
        }

        var descendants = new List<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>();
        var stack = new Stack<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>(directChildren);
        var visited = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        while (stack.Count > 0)
        {
            var current = stack.Pop();
            if (!visited.Add(current.NodeKey))
            {
                continue;
            }

            if (IsLeafOrAnalyticNode(current))
            {
                descendants.Add(current);
            }

            if (_childrenByParentKey.TryGetValue(current.NodeKey, out var children) && children.Count > 0)
            {
                foreach (var child in children)
                {
                    stack.Push(child);
                }
            }
        }

        return descendants
            .OrderBy(node => node.Label ?? node.NodeKey, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private bool IsLeafOrAnalyticNode(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity node)
    {
        return !IsStructuralNode(node.NodeKey) || !string.IsNullOrWhiteSpace(node.MeterUrn);
    }

    private bool IsStructuralNode(string nodeKey)
    {
        return _childrenByParentKey.TryGetValue(nodeKey, out var children) && children.Count > 0;
    }

    private string? GetFallbackFocusNodeKey()
    {
        if (_selectionOrder.Count == 0)
        {
            return null;
        }

        return _selectionOrder[^1];
    }

    private void AddNodeToSelectionSet(string nodeKey)
    {
        if (!_selectionSet.Add(nodeKey))
        {
            _selectionOrder.RemoveAll(item => item.Equals(nodeKey, StringComparison.OrdinalIgnoreCase));
            _selectionOrder.Add(nodeKey);
            return;
        }

        _selectionOrder.Add(nodeKey);
    }

    private void RemoveNodeFromSelectionSet(string nodeKey)
    {
        if (!_selectionSet.Remove(nodeKey))
        {
            return;
        }

        _selectionOrder.RemoveAll(item => item.Equals(nodeKey, StringComparison.OrdinalIgnoreCase));
    }

    private void ClearSelectionSetState()
    {
        _selectionSet.Clear();
        _selectionOrder.Clear();
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> GetSelectionSummaryItems()
    {
        var items = new List<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>();

        foreach (var nodeKey in _selectionOrder)
        {
            if (_nodesByKey.TryGetValue(nodeKey, out var node))
            {
                items.Add(node);
            }
        }

        return items;
    }

    private void EnsureFocusNodeInSelectionSetIfLeaf(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity focusedNode)
    {
        if (!IsStructuralNode(focusedNode.NodeKey))
        {
            AddNodeToSelectionSet(focusedNode.NodeKey);
        }
    }

    private void RebuildFacilityNodeIndexes()
    {
        _nodesByKey.Clear();
        _childrenByParentKey.Clear();

        if (_facility is null)
        {
            return;
        }

        foreach (var node in _facility.Nodes)
        {
            _nodesByKey[node.NodeKey] = node;
        }

        foreach (var node in _facility.Nodes)
        {
            if (string.IsNullOrWhiteSpace(node.ParentNodeKey))
            {
                continue;
            }

            if (!_childrenByParentKey.TryGetValue(node.ParentNodeKey, out var children))
            {
                children = [];
                _childrenByParentKey[node.ParentNodeKey] = children;
            }

            children.Add(node);
        }
    }

    private static DiplomovaPrace.Persistence.Schematic.FacilityEntity? BuildSchemaFacilityWithoutWeatherNode(
        DiplomovaPrace.Persistence.Schematic.FacilityEntity? facility)
    {
        if (facility is null)
        {
            return null;
        }

        var filteredNodes = facility.Nodes
            .Where(node => !IsWeatherNode(node.NodeKey))
            .ToList();
        var allowedNodeKeys = filteredNodes
            .Select(node => node.NodeKey)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var filteredEdges = facility.Edges
            .Where(edge => allowedNodeKeys.Contains(edge.SourceNodeKey) && allowedNodeKeys.Contains(edge.TargetNodeKey))
            .ToList();

        var weatherFilteredFacility = new DiplomovaPrace.Persistence.Schematic.FacilityEntity
        {
            Id = facility.Id,
            Name = facility.Name,
            Description = facility.Description,
            TimeZone = facility.TimeZone,
            Nodes = filteredNodes,
            Edges = filteredEdges
        };

        return FacilitySchematicLayoutService.BuildReadableLayout(weatherFilteredFacility);
    }

    private IReadOnlySet<string> GetSelectedSubtreeNodeKeysForCanvas()
    {
        if (_selectionSet.Count == 0 || _selectedFacilityNode is null || !IsStructuralNode(_selectedFacilityNode.NodeKey))
        {
            return EmptyNodeKeySet;
        }

        var subtreeNodeKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            _selectedFacilityNode.NodeKey
        };

        var stack = new Stack<string>();
        stack.Push(_selectedFacilityNode.NodeKey);

        while (stack.Count > 0)
        {
            var currentNodeKey = stack.Pop();
            if (!_childrenByParentKey.TryGetValue(currentNodeKey, out var children) || children.Count == 0)
            {
                continue;
            }

            foreach (var child in children)
            {
                if (subtreeNodeKeys.Add(child.NodeKey))
                {
                    stack.Push(child.NodeKey);
                }
            }
        }

        return subtreeNodeKeys;
    }

