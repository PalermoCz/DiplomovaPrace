    private IReadOnlyList<(string Key, string Label, bool IsAggregate)> BuildAnalysisDataSourceOptions()
    {
        var options = new List<(string Key, string Label, bool IsAggregate)>
        {
            (AnalysisDataSourceSelection, "Selection (aggregate)", true)
        };

        foreach (var nodeKey in SelectionNodeKeysWithAnyData)
        {
            var label = GetNodeDisplayLabel(nodeKey);
            options.Add((nodeKey, label, false));
        }

        return options;
    }

    private IReadOnlyList<string> GetAnalysisSelectedNodeKeysWithAnyData()
    {
        return GetSelectionAggregateNodeKeys()
            .Where(NodeHasAnyAnalysisData)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(GetNodeDisplayLabel, StringComparer.OrdinalIgnoreCase)
            .ThenBy(nodeKey => nodeKey, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private bool NodeHasAnyAnalysisData(string? nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey) || IsWeatherNode(nodeKey))
        {
            return false;
        }

        if (BindingRegistry.GetPrimaryBinding(nodeKey) is not null)
        {
            return true;
        }

        if (BindingRegistry.IsSupported(nodeKey))
        {
            return true;
        }

        return _nodesByKey.TryGetValue(nodeKey, out var node)
            && (!string.IsNullOrWhiteSpace(node.MeterUrn) || IsCuratedNode(node));
    }

