    private async Task OnActiveAnalyticsSignalChanged(ChangeEventArgs e)
    {
        var nextValue = e.Value?.ToString()?.Trim() ?? string.Empty;
        if (string.Equals(_activeAnalyticsSignalCodeValue, nextValue, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _activeAnalyticsSignalCodeValue = nextValue;
        SyncSelectionSignalAvailability(nextValue);

        if (!string.IsNullOrWhiteSpace(_activeAnalyticsSignalCodeValue)
            && ResolveActiveAnalysisSourceNodeKeys().Count > 0)
        {
            await RefreshSelectionSignalAnalyticsAsync(GetInterval(), "analysis-signal-change");
        }
        else
        {
            _selectionSignalAnalyticsResult = null;
            _selectionSignalTrendCore = null;
            _selectionSignalAuxiliaryModules = null;
            _isSelectionSignalTrendLoading = false;
            _isSelectionSignalAuxiliaryLoading = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAnalysisDataSourceChanged(ChangeEventArgs e)
    {
        var nextKey = e.Value?.ToString()?.Trim() ?? AnalysisDataSourceSelection;
        if (string.Equals(_analysisDataSourceKey, nextKey, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _analysisDataSourceKey = nextKey;
        SyncSelectionSignalAvailability();

        if (!string.IsNullOrWhiteSpace(_activeAnalyticsSignalCodeValue))
        {
            await RefreshSelectionSignalAnalyticsAsync(GetInterval(), "analysis-source-change");
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnShowBaselineOverlayChanged(bool enabled)
    {
        if (_showBaselineOverlay == enabled)
        {
            return;
        }

        _showBaselineOverlay = enabled;

        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadPreviewDataAsync(string operationType = "full-overview-refresh",string? preferredAnalyticsSignalCode = null)
    {
        var hasSelectionContext = HasSelectedNodes;
        var hasFocusAnalyticsContext = _selectedFacilityNode != null && (_isCuratedNode || !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn));

        if (!hasSelectionContext && !hasFocusAnalyticsContext)
        {
            _selectionSignalAvailability = new();
            _selectionSignalAnalyticsResult = null;
            _selectionSignalTrendCore = null;
            _selectionSignalAuxiliaryModules = null;
            _isSelectionSignalTrendLoading = false;
            _isSelectionSignalAuxiliaryLoading = false;
            _selectionSignalAnalysisLoadVersion++;
            _selectionSignalAnalysisCts?.Cancel();
            _selectionSignalAnalysisCts?.Dispose();
            _selectionSignalAnalysisCts = null;
            _activeAnalyticsSignalCodeValue = string.Empty;
            _curatedPreviewData = null;
            _curatedDeviationData = null;
            _curatedTimeSeriesData = null;
            _curatedCompareTimeSeriesData = null;
            _selectionAggregateOverview = null;
            _overviewChartTimeSeriesData = null;
            _overviewHoveredContributorOverlayTimeSeries = null;
            _overviewHoveredContributorNodeKey = null;
            _overviewPinnedContributorNodeKeys.Clear();
            _overviewPinnedContributorOverlayByNodeKey.Clear();
            _isOverviewContributorOverlayLoading = false;
            _overviewContributorOverlayLoadVersion++;
            _isOverviewChartLoading = false;
            _overviewChartLoadVersion++;
            ClearAnalyticsLoadingState();
            await InvokeAsync(StateHasChanged);
            return;
        }

        await RefreshPresetAnchorAsync();
        var interval = GetInterval();
        var aggregateNodeKeys = GetSelectionAggregateNodeKeys();
        var analyticsTrace = BeginAnalyticsTrace(operationType, true, new
        {
            intervalFromUtc = interval.From,
            intervalToUtc = interval.To,
            scopeNodeCount = aggregateNodeKeys.Count,
            scopeNodeSample = aggregateNodeKeys.Take(6).ToArray(),
            fullRefresh = true
        });

        var analyticsLoadingVersion = BeginAnalyticsLoadingOperation(
            operationType,
            "Refreshing analytics workspace",
            "Resolving scope",
            "Preparing overview and analysis for the current selection.",
            0);

        
        var shouldLoadAggregateOverview = aggregateNodeKeys.Count > 0;
        var shouldLoadCuratedFocusPreview = _isCuratedNode && _selectedFacilityNode is not null;
        var hasPotentialSignalAnalytics = GetSignalAnalyticsScopeNodeKeys().Count > 0;
        var shouldRefreshOverviewChart = aggregateNodeKeys.Count > 0 && CurrentOverviewSemanticsMode != OverviewAggregateSemanticsMode.Net;
        var loadingScopes = new Dictionary<string, (int CompletedSteps, int TotalSteps)>(StringComparer.OrdinalIgnoreCase)
        {
            ["scope"] = (0, 1),
            ["overview"] = (0, shouldLoadAggregateOverview ? 6 : 0),
            ["focus-preview"] = (0, shouldLoadCuratedFocusPreview ? 1 : 0),
            ["analysis"] = (0, hasPotentialSignalAnalytics ? 6 : 0),
            ["visual-chart"] = (0, shouldRefreshOverviewChart ? 1 : 0),
            ["visual-overlay"] = (0, 1)
        };

        void RecalculateLoadingPercent(string phaseLabel, string detail)
        {
            if (analyticsLoadingVersion != _analyticsLoadingOperationVersion)
            {
                return;
            }

            var totalSteps = loadingScopes.Values.Sum(scope => Math.Max(0, scope.TotalSteps));
            var completedSteps = loadingScopes.Values.Sum(scope => Math.Clamp(scope.CompletedSteps, 0, Math.Max(0, scope.TotalSteps)));
            UpdateAnalyticsLoadingOperation(
                analyticsLoadingVersion,
                phaseLabel,
                detail,
                CalculateAnalyticsMilestonePercent(completedSteps, totalSteps));
        }

        void SetLoadingScopeProgress(string scopeKey, string phaseLabel, string detail, int completedSteps, int? totalSteps = null)
        {
            if (!loadingScopes.TryGetValue(scopeKey, out var currentScope))
            {
                currentScope = (0, Math.Max(0, totalSteps ?? 0));
            }

            var effectiveTotalSteps = Math.Max(0, totalSteps ?? currentScope.TotalSteps);
            if (effectiveTotalSteps == 0)
            {
                loadingScopes[scopeKey] = (0, 0);
                RecalculateLoadingPercent(phaseLabel, detail);
                return;
            }

            var effectiveCompletedSteps = Math.Clamp(completedSteps, 0, effectiveTotalSteps);
            if (effectiveCompletedSteps < currentScope.CompletedSteps)
            {
                effectiveCompletedSteps = currentScope.CompletedSteps;
            }

            loadingScopes[scopeKey] = (effectiveCompletedSteps, effectiveTotalSteps);
            RecalculateLoadingPercent(phaseLabel, detail);
        }

        IProgress<AnalyticsProgressUpdate>? CreateLoadingScopeProgress(string scopeKey)
        {
            if (!loadingScopes.TryGetValue(scopeKey, out var scope) || scope.TotalSteps <= 0)
            {
                return null;
            }

            return new Progress<AnalyticsProgressUpdate>(update =>
            {
                SetLoadingScopeProgress(
                    scopeKey,
                    string.IsNullOrWhiteSpace(update.PhaseLabel) ? _analyticsLoadingPhaseLabel : update.PhaseLabel,
                    string.IsNullOrWhiteSpace(update.Detail) ? _analyticsLoadingDetail : update.Detail,
                    update.CompletedSteps,
                    update.TotalSteps > 0 ? update.TotalSteps : scope.TotalSteps);
            });
        }

        _isPreviewLoading = true;
        _isOverviewChartLoading = false;
        _overviewChartLoadVersion++;
        await InvokeAsync(StateHasChanged);
        var skipPostRefresh = false;
        var loadFailed = false;
        string? failureMessage = null;

        try
        {
            
            SetLoadingScopeProgress("scope", "Resolving scope", "Prepared analytics scope and refresh anchor for the current selection.", 1);
            Task<CuratedSelectionAggregateOverviewResult>? aggregateTask = null;

            LogAnalyticsTracePhase(
                analyticsTrace,
                "Resolving scope",
                _analyticsLoadingPercent,
                AnalyticsLoadingDisplayPercent,
                new
                {
                    aggregateNodeCount = aggregateNodeKeys.Count,
                    focusNodeKey = _selectedFacilityNode?.NodeKey,
                    hasCuratedFocus = _isCuratedNode
                });

            if (_selectedInterval == "custom")
            {
                var customValidationMessage = await ValidateCustomIntervalForAnalyticsAsync();
                if (!string.IsNullOrWhiteSpace(customValidationMessage))
                {
                    _customIntervalValidationMessage = customValidationMessage;
                    _curatedPreviewData = null;
                    _curatedTimeSeriesData = null;
                    _curatedCompareTimeSeriesData = null;
                    _overviewChartTimeSeriesData = null;
                    _overviewHoveredContributorOverlayTimeSeries = null;
                    _overviewPinnedContributorOverlayByNodeKey.Clear();
                    _selectionAggregateOverview = new CuratedSelectionAggregateOverviewResult
                    {
                        Message = customValidationMessage
                    };

                    if (_isCuratedNode)
                    {
                        _curatedDeviationData = new CuratedNodeDeviationSummary
                        {
                            IsAvailable = false,
                            Message = customValidationMessage,
                            Methodology = "Custom interval validation: analytics runs only for a valid and data-meaningful range."
                        };
                    }
                    else
                    {
                        _curatedDeviationData = null;
                    }

                    UpdateAnalyticsLoadingOperation(
                        analyticsLoadingVersion,
                        "Interval validation",
                        customValidationMessage,
                        100);

                    LogAnalyticsTracePhase(
                        analyticsTrace,
                        "Interval validation",
                        _analyticsLoadingPercent,
                        AnalyticsLoadingDisplayPercent,
                        new
                        {
                            validationMessage = customValidationMessage,
                            validationOutcome = "blocked"
                        });

                    skipPostRefresh = true;
                }

                if (!skipPostRefresh)
                {
                    _customIntervalValidationMessage = null;
                }
            }

            if (!skipPostRefresh && aggregateNodeKeys.Count > 0)
            {
                aggregateTask = AnalyticsPreview.GetCuratedSelectionAggregateOverviewAsync(
                    aggregateNodeKeys,
                    interval.From,
                    interval.To,
                    _timeSeriesMode,
                    includeBaselineOverlay: false,
                    CurrentAggregateRequestOptions,
                    progress: CreateLoadingScopeProgress("overview"));
            }

            _curatedPreviewData = null;
            _curatedDeviationData = null;
            _curatedTimeSeriesData = null;
            _curatedCompareTimeSeriesData = null;
            _overviewChartTimeSeriesData = skipPostRefresh ? _overviewChartTimeSeriesData : null;
            _selectionAggregateOverview = skipPostRefresh ? _selectionAggregateOverview : null;

            if (!skipPostRefresh && _isCuratedNode)
            {
                var focusNode = _selectedFacilityNode;
                if (focusNode is not null)
                {
                    var summaryTask = AnalyticsPreview.GetCuratedSummaryAsync(focusNode.NodeKey, interval.From, interval.To);
                    var deviationTask = AnalyticsPreview.GetCuratedDeviationSummaryAsync(focusNode.NodeKey, interval.From, interval.To);
                    var timeSeriesTask = AnalyticsPreview.GetCuratedTimeSeriesAsync(
                        focusNode.NodeKey,
                        interval.From,
                        interval.To,
                        _timeSeriesMode,
                        _showBaselineOverlay);
                    var effectiveCompareNodeKeys = GetEffectiveCompareNodeKeysForSelectedNode();
                    Task<CuratedNodeCompareTimeSeriesResult?>? compareTask = null;

                    if (IsCompareTabActivated && IsSelectedNodeComparePreviewSupported && effectiveCompareNodeKeys.Count > 0)
                    {
                        compareTask = AnalyticsPreview.GetCuratedCompareTimeSeriesAsync(
                            focusNode.NodeKey,
                            effectiveCompareNodeKeys,
                            interval.From,
                            interval.To,
                            _timeSeriesMode);
                    }

                    var loadTasks = new List<Task> { summaryTask, deviationTask, timeSeriesTask };
                    if (compareTask is not null)
                    {
                        loadTasks.Add(compareTask);
                    }

                    if (aggregateTask is not null)
                    {
                        loadTasks.Add(aggregateTask);
                    }

                    await Task.WhenAll(loadTasks);

                    _curatedPreviewData = summaryTask.Result;
                    _curatedDeviationData = deviationTask.Result;
                    _curatedTimeSeriesData = timeSeriesTask.Result;
                    _curatedCompareTimeSeriesData = compareTask?.Result;
                    _selectionAggregateOverview = aggregateTask?.Result;
                    SetLoadingScopeProgress("focus-preview", "Loading overview", "Loaded selected node summary, deviation, and trend datasets.", 1);
                    NormalizeOverviewSemanticsMode();
                    _overviewChartTimeSeriesData = CurrentOverviewSemanticsMode == OverviewAggregateSemanticsMode.Net
                        ? _selectionAggregateOverview?.TimeSeries
                        : null;
                    SeedOverviewChartCache(aggregateNodeKeys, interval.From, interval.To, _timeSeriesMode, OverviewAggregateSemanticsMode.Net, _selectionAggregateOverview?.TimeSeries);
                    NormalizeOverviewContributorSelection();
                }
            }
            else if (!skipPostRefresh)
            {
                _selectionAggregateOverview = aggregateTask is not null
                    ? await aggregateTask
                    : null;
                NormalizeOverviewSemanticsMode();
                _overviewChartTimeSeriesData = CurrentOverviewSemanticsMode == OverviewAggregateSemanticsMode.Net
                    ? _selectionAggregateOverview?.TimeSeries
                    : null;
                SeedOverviewChartCache(aggregateNodeKeys, interval.From, interval.To, _timeSeriesMode, OverviewAggregateSemanticsMode.Net, _selectionAggregateOverview?.TimeSeries);
                NormalizeOverviewContributorSelection();
            }

            LogAnalyticsTracePhase(
                analyticsTrace,
                "Loading overview",
                _analyticsLoadingPercent,
                AnalyticsLoadingDisplayPercent,
                new
                {
                    overviewAvailable = _selectionAggregateOverview is not null,
                    overviewMessage = _selectionAggregateOverview?.Message,
                    chartSeeded = _overviewChartTimeSeriesData is not null,
                    pinnedContributorCount = _overviewPinnedContributorNodeKeys.Count
                });

            SyncSelectionSignalAvailability(preferredAnalyticsSignalCode);

            var signalAnalyticsScopeNodeKeys = ResolveActiveAnalysisSourceNodeKeys();
            var shouldLoadSignalAnalytics = !skipPostRefresh && !ActiveSelectionSignalCode.IsEmpty && signalAnalyticsScopeNodeKeys.Count > 0;

            if (!shouldLoadSignalAnalytics)
            {
                SetLoadingScopeProgress("analysis", "Loading analysis", "No exact-signal analysis was required for the current selection.", 0, 0);
                _selectionSignalTrendCore = null;
                _selectionSignalAuxiliaryModules = null;
                _selectionSignalAnalyticsResult = null;
                _isSelectionSignalTrendLoading = false;
                _isSelectionSignalAuxiliaryLoading = false;
            }

            if (shouldLoadSignalAnalytics)
            {
                SetLoadingScopeProgress("analysis", "Loading analysis", "Resolving trend core first for the active exact signal.", 1, 2);
                await RefreshSelectionSignalAnalyticsAsync(interval, "analysis-refresh");
                SetLoadingScopeProgress("analysis", "Loading analysis", "Trend core is ready; auxiliary modules continue in the background.", 2, 2);
            }

            LogAnalyticsTracePhase(
                analyticsTrace,
                "Loading analysis",
                _analyticsLoadingPercent,
                AnalyticsLoadingDisplayPercent,
                new
                {
                    activeSignalCode = ActiveSelectionSignalCode.Value,
                    analysisAvailable = _selectionSignalAnalyticsResult is not null,
                    scopeNodeCount = signalAnalyticsScopeNodeKeys.Count
                });

            if (!skipPostRefresh
                && aggregateNodeKeys.Count > 0
                && CurrentOverviewSemanticsMode != OverviewAggregateSemanticsMode.Net)
            {
                SetLoadingScopeProgress("visual-chart", "Finalizing visuals", "Refreshing the overview chart for the active semantics.", 0);
                await ReloadOverviewChartAsync(
                    aggregateNodeKeys,
                    interval.From,
                    interval.To,
                    _timeSeriesMode,
                    CurrentOverviewSemanticsMode,
                    showLoadingIndicator: false);
                SetLoadingScopeProgress("visual-chart", "Finalizing visuals", "Overview chart refreshed for the active semantics.", 1);
            }
            else
            {
                SetLoadingScopeProgress("visual-chart", "Finalizing visuals", "Overview chart reuse remained valid for the active semantics.", 0, 0);
            }

            SetLoadingScopeProgress("visual-overlay", "Finalizing visuals", "Refreshing contributor overlays for the current overview context.", 0);
            await RefreshOverviewContributorOverlayForCurrentContextAsync(showLoadingIndicator: false);
            SetLoadingScopeProgress("visual-overlay", "Finalizing visuals", "Contributor overlays refreshed for the current overview context.", 1);

            LogAnalyticsTracePhase(
                analyticsTrace,
                "Finalizing visuals",
                _analyticsLoadingPercent,
                AnalyticsLoadingDisplayPercent,
                new
                {
                    staleOverviewHidden = _isOverviewChartLoading,
                    chartMode = CurrentOverviewSemanticsMode.ToString(),
                    previewedContributor = _overviewHoveredContributorNodeKey,
                    pinnedContributorCount = _overviewPinnedContributorNodeKeys.Count
                });
        }
        catch (Exception ex)
        {
            loadFailed = true;
            failureMessage = ex.Message;
            throw;
        }
        finally
        {
            _isPreviewLoading = false;
            CompleteAnalyticsLoadingOperation(analyticsLoadingVersion);
            LogAnalyticsTraceEnd(
                analyticsTrace,
                "loading-pill dismiss scheduled after operation completion",
                loadFailed ? "failed" : "completed",
                _analyticsLoadingPercent,
                AnalyticsLoadingDisplayPercent,
                new
                {
                    skippedPostRefresh = skipPostRefresh,
                    staleOverviewHidden = _isOverviewChartLoading,
                    failureMessage
                });
            await InvokeAsync(StateHasChanged);
        }
    }

    
    private void NormalizeOverviewContributorSelection()
{
    var visibleNodeKeys = OverviewTreemapLayout.VisibleItems
        .Select(item => item.NodeKey)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    var tailNodeKeys = OverviewTreemapLayout.TailItems
        .Select(item => item.NodeKey)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    var validNodeKeys = new HashSet<string>(visibleNodeKeys, StringComparer.OrdinalIgnoreCase);
    validNodeKeys.UnionWith(tailNodeKeys);

    if (OverviewTreemapLayout.TailItems.Count == 0)
    {
        _isOverviewOtherContributorDrillInOpen = false;
    }

    _overviewPinnedContributorNodeKeys.RemoveAll(nodeKey => !validNodeKeys.Contains(nodeKey));

    foreach (var cachedNodeKey in _overviewPinnedContributorOverlayByNodeKey.Keys.ToList())
    {
        if (!validNodeKeys.Contains(cachedNodeKey))
        {
            _overviewPinnedContributorOverlayByNodeKey.Remove(cachedNodeKey);
        }
    }

    if (!string.IsNullOrWhiteSpace(_overviewHoveredContributorNodeKey) &&
        !validNodeKeys.Contains(_overviewHoveredContributorNodeKey))
    {
        _overviewHoveredContributorNodeKey = null;
        _overviewHoveredContributorOverlayTimeSeries = null;
    }
}


    private async Task OnOverviewContributorTileHoveredAsync(OverviewTreemapTile tile)
    {
        LogOverviewTreemapInteraction("treemap-tile", "hover", tile.NodeKey, tile.Label, tile.IsSyntheticGroup);

        if (tile.IsSyntheticGroup)
        {
            CancelPendingOverviewHoverPreview();
            await SetOverviewHoveredContributorAsync(null);
            return;
        }

        await QueueOverviewHoveredContributorAsync(tile.NodeKey);
    }

    private async Task OnOverviewContributorTileExitedAsync(OverviewTreemapTile tile)
    {
        LogOverviewTreemapInteraction("treemap-tile", "hover end", tile.NodeKey, tile.Label, tile.IsSyntheticGroup);
        CancelPendingOverviewHoverPreview();
        await SetOverviewHoveredContributorAsync(null);
    }

    private async Task OnOverviewContributorTileClickedAsync(OverviewTreemapTile tile)
    {
        LogOverviewTreemapInteraction("treemap-tile", "click", tile.NodeKey, tile.Label, tile.IsSyntheticGroup);

        if (tile.IsSyntheticGroup)
        {
            if (IsOverviewOtherContributorDrillInOpen)
            {
                await CloseOverviewOtherContributorDrillInAsync("toggle");
                return;
            }

            CancelPendingOverviewHoverPreview();
            _isOverviewOtherContributorDrillInOpen = true;
            LogOverviewDrillInVisibility("open", "clicked Other tile");
            await InvokeAsync(StateHasChanged);
            return;
        }

        CancelPendingOverviewHoverPreview();
        var wasPinned = IsOverviewContributorPinned(tile.NodeKey);
        LogOverviewTreemapInteraction("treemap-tile", wasPinned ? "unpin" : "pin", tile.NodeKey, tile.Label, false);
        await TogglePinnedOverviewContributorAsync(tile.NodeKey);
    }

    private async Task OnOverviewOtherContributorHoveredAsync(OverviewTreemapContributorItem contributor)
    {
        _isOverviewOtherContributorDrillInOpen = true;
        LogOverviewTreemapInteraction("drill-in-row", "preview start", contributor.NodeKey, contributor.Label, false);
        await QueueOverviewHoveredContributorAsync(contributor.NodeKey);
    }

    private async Task OnOverviewOtherContributorExitedAsync(OverviewTreemapContributorItem contributor)
    {
        LogOverviewTreemapInteraction("drill-in-row", "preview end", contributor.NodeKey, contributor.Label, false);
        CancelPendingOverviewHoverPreview();
        await SetOverviewHoveredContributorAsync(null);
    }

    private async Task OnOverviewOtherContributorClickedAsync(OverviewTreemapContributorItem contributor)
    {
        _isOverviewOtherContributorDrillInOpen = true;
        CancelPendingOverviewHoverPreview();
        var wasPinned = IsOverviewContributorPinned(contributor.NodeKey);
        LogOverviewTreemapInteraction("drill-in-row", wasPinned ? "unpin" : "pin", contributor.NodeKey, contributor.Label, false);
        await TogglePinnedOverviewContributorAsync(contributor.NodeKey);
    }

    private async Task QueueOverviewHoveredContributorAsync(string? nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            CancelPendingOverviewHoverPreview();
            await SetOverviewHoveredContributorAsync(null);
            return;
        }

        CancelPendingOverviewHoverPreview();
        var hoverCts = new System.Threading.CancellationTokenSource();
        _overviewHoverPreviewCts = hoverCts;

        try
        {
            await Task.Delay(150, hoverCts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (hoverCts.IsCancellationRequested || !ReferenceEquals(_overviewHoverPreviewCts, hoverCts))
        {
            return;
        }

        await SetOverviewHoveredContributorAsync(nodeKey);
    }

    private void CancelPendingOverviewHoverPreview()
    {
        if (_overviewHoverPreviewCts is null)
        {
            return;
        }

        _overviewHoverPreviewCts.Cancel();
        _overviewHoverPreviewCts.Dispose();
        _overviewHoverPreviewCts = null;
    }

    private Task CloseOverviewOtherContributorDrillInFromBackdropAsync()
        => CloseOverviewOtherContributorDrillInAsync("outside-click");

    private Task CloseOverviewOtherContributorDrillInExplicitAsync()
        => CloseOverviewOtherContributorDrillInAsync("explicit-close");

    private async Task CloseOverviewOtherContributorDrillInAsync(string reason)
    {
        CancelPendingOverviewHoverPreview();
        _isOverviewOtherContributorDrillInOpen = false;

        if (!string.IsNullOrWhiteSpace(_overviewHoveredContributorNodeKey)
            && OverviewOtherContributorItems.Any(item => string.Equals(item.NodeKey, _overviewHoveredContributorNodeKey, StringComparison.OrdinalIgnoreCase))
            && !IsOverviewContributorPinned(_overviewHoveredContributorNodeKey))
        {
            LogOverviewDrillInVisibility("close", reason);
            await SetOverviewHoveredContributorAsync(null);
            await InvokeAsync(StateHasChanged);
            return;
        }

        LogOverviewDrillInVisibility("close", reason);
        LogOverviewContributorState("drill-in-close");
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetOverviewHoveredContributorAsync(string? nodeKey)
    {
        if (string.Equals(_overviewHoveredContributorNodeKey, nodeKey, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _overviewHoveredContributorNodeKey = nodeKey;
        LogOverviewContributorState("preview-changed");

        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            _overviewHoveredContributorOverlayTimeSeries = null;
            await RefreshOverviewContributorOverlayForCurrentContextAsync(showLoadingIndicator: false);
            return;
        }

        await RefreshOverviewContributorOverlayForCurrentContextAsync(showLoadingIndicator: false);
    }

    private async Task TogglePinnedOverviewContributorAsync(string nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            return;
        }

        if (IsOverviewContributorPinned(nodeKey))
        {
            _overviewPinnedContributorNodeKeys.RemoveAll(existingNodeKey => string.Equals(existingNodeKey, nodeKey, StringComparison.OrdinalIgnoreCase));
            _overviewPinnedContributorOverlayByNodeKey.Remove(nodeKey);
        }
        else
        {
            _overviewPinnedContributorNodeKeys.Add(nodeKey);
        }

        _overviewHoveredContributorNodeKey = nodeKey;
        LogOverviewContributorState("pin-state-changed");
        await RefreshOverviewContributorOverlayForCurrentContextAsync(showLoadingIndicator: false);
    }

    private async Task RemovePinnedOverviewContributorAsync(string nodeKey)
    {
        if (!IsOverviewContributorPinned(nodeKey))
        {
            return;
        }

        CancelPendingOverviewHoverPreview();
        _overviewPinnedContributorNodeKeys.RemoveAll(existingNodeKey => string.Equals(existingNodeKey, nodeKey, StringComparison.OrdinalIgnoreCase));
        _overviewPinnedContributorOverlayByNodeKey.Remove(nodeKey);

        if (string.Equals(_overviewHoveredContributorNodeKey, nodeKey, StringComparison.OrdinalIgnoreCase))
        {
            _overviewHoveredContributorNodeKey = null;
            _overviewHoveredContributorOverlayTimeSeries = null;
        }

        LogOverviewContributorState("pin-state-removed");
        await RefreshOverviewContributorOverlayForCurrentContextAsync(showLoadingIndicator: false);
    }

    private void ClearOverviewContributorOverlayState()
    {
        _overviewHoveredContributorOverlayTimeSeries = null;
        _overviewPinnedContributorOverlayByNodeKey.Clear();
        _isOverviewContributorOverlayLoading = false;
        _overviewContributorOverlayLoadVersion++;
    }

    private async Task ClearPinnedOverviewContributorAsync()
    {
        if (_overviewPinnedContributorNodeKeys.Count == 0)
        {
            return;
        }

        _overviewPinnedContributorNodeKeys.Clear();
        _overviewPinnedContributorOverlayByNodeKey.Clear();
        LogOverviewContributorState("pin-state-cleared");

        if (string.IsNullOrWhiteSpace(_overviewHoveredContributorNodeKey))
        {
            ClearOverviewContributorOverlayState();
            await InvokeAsync(StateHasChanged);
            return;
        }

        await RefreshOverviewContributorOverlayForCurrentContextAsync(showLoadingIndicator: false);
    }

    private async Task RefreshOverviewContributorOverlayForCurrentContextAsync(bool showLoadingIndicator)
    {
        NormalizeOverviewContributorSelection();

        if ((_overviewPinnedContributorNodeKeys.Count == 0 && string.IsNullOrWhiteSpace(_overviewHoveredContributorNodeKey))
            || !HasSelectedNodes
            || !string.IsNullOrWhiteSpace(_customIntervalValidationMessage))
        {
            ClearOverviewContributorOverlayState();
            await InvokeAsync(StateHasChanged);
            return;
        }

        var interval = GetInterval();
        await ReloadOverviewContributorOverlaysAsync(
            _overviewPinnedContributorNodeKeys,
            _overviewHoveredContributorNodeKey,
            interval.From,
            interval.To,
            _timeSeriesMode,
            CurrentOverviewSemanticsMode,
            showLoadingIndicator);
    }

    private async Task ReloadOverviewContributorOverlaysAsync(
        IReadOnlyList<string> pinnedNodeKeys,
        string? hoveredNodeKey,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode,
        OverviewAggregateSemanticsMode semanticsMode,
        bool showLoadingIndicator,
        string operationType = "contributor-overlay-refresh")
    {
        var distinctPinnedNodeKeys = pinnedNodeKeys
            .Where(nodeKey => !string.IsNullOrWhiteSpace(nodeKey))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        var previewNodeKey = !string.IsNullOrWhiteSpace(hoveredNodeKey)
            && !distinctPinnedNodeKeys.Contains(hoveredNodeKey, StringComparer.OrdinalIgnoreCase)
                ? hoveredNodeKey
                : null;
        var pinnedCacheHits = distinctPinnedNodeKeys.Count(nodeKey => _overviewContributorOverlayCache.ContainsKey(new OverviewContributorOverlayCacheKey(nodeKey, from.Ticks, to.Ticks, mode, semanticsMode)));
        var previewCacheHit = !string.IsNullOrWhiteSpace(previewNodeKey)
            && _overviewContributorOverlayCache.ContainsKey(new OverviewContributorOverlayCacheKey(previewNodeKey, from.Ticks, to.Ticks, mode, semanticsMode));
        var analyticsTrace = BeginAnalyticsTrace(operationType, false, new
        {
            intervalFromUtc = from,
            intervalToUtc = to,
            pinnedNodeCount = distinctPinnedNodeKeys.Count,
            previewNodeKey,
            semanticsMode = semanticsMode.ToString(),
            chartGranularity = mode.ToString(),
            cacheHitCount = pinnedCacheHits,
            previewCacheHit
        });
        var loadFailed = false;
        string? failureMessage = null;

        if (distinctPinnedNodeKeys.Count == 0 && string.IsNullOrWhiteSpace(previewNodeKey))
        {
            _overviewHoveredContributorOverlayTimeSeries = null;
            _overviewPinnedContributorOverlayByNodeKey.Clear();
            _isOverviewContributorOverlayLoading = false;
            LogAnalyticsTraceEnd(
                analyticsTrace,
                "no overlay requested",
                finalInternalPercent: null,
                finalDisplayedPercent: null,
                context: new
                {
                    pinnedNodeCount = 0,
                    previewNodeKey = (string?)null
                });
            await InvokeAsync(StateHasChanged);
            return;
        }

        var loadVersion = ++_overviewContributorOverlayLoadVersion;

        if (showLoadingIndicator)
        {
            _isOverviewContributorOverlayLoading = true;
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            LogAnalyticsTracePhase(
                analyticsTrace,
                "Requesting contributor overlays",
                null,
                null,
                new
                {
                    pinnedNodeCount = distinctPinnedNodeKeys.Count,
                    previewNodeKey,
                    cacheHitCount = pinnedCacheHits,
                    previewCacheHit
                });

            var pinnedTasks = distinctPinnedNodeKeys.ToDictionary(
                nodeKey => nodeKey,
                nodeKey => GetOverviewContributorOverlayAsync(nodeKey, from, to, mode, semanticsMode),
                StringComparer.OrdinalIgnoreCase);
            Task<CuratedNodeTimeSeriesResult?>? previewTask = !string.IsNullOrWhiteSpace(previewNodeKey)
                ? GetOverviewContributorOverlayAsync(previewNodeKey, from, to, mode, semanticsMode)
                : null;

            var tasksToAwait = pinnedTasks.Values.Cast<Task>().ToList();
            if (previewTask is not null)
            {
                tasksToAwait.Add(previewTask);
            }

            await Task.WhenAll(tasksToAwait);

            if (loadVersion != _overviewContributorOverlayLoadVersion)
            {
                return;
            }

            _overviewPinnedContributorOverlayByNodeKey.Clear();
            foreach (var pinnedTask in pinnedTasks)
            {
                _overviewPinnedContributorOverlayByNodeKey[pinnedTask.Key] = pinnedTask.Value.Result;
            }

            _overviewHoveredContributorOverlayTimeSeries = previewTask?.Result;

            LogAnalyticsTracePhase(
                analyticsTrace,
                "Contributor overlays ready",
                null,
                null,
                new
                {
                    pinnedSeriesCount = _overviewPinnedContributorOverlayByNodeKey.Count,
                    hasPreviewSeries = _overviewHoveredContributorOverlayTimeSeries is not null,
                    previewNodeKey
                });
        }
        catch (Exception ex)
        {
            loadFailed = true;
            failureMessage = ex.Message;
            throw;
        }
        finally
        {
            if (loadVersion == _overviewContributorOverlayLoadVersion)
            {
                _isOverviewContributorOverlayLoading = false;
                await InvokeAsync(StateHasChanged);
            }

            LogAnalyticsTraceEnd(
                analyticsTrace,
                "no loading pill for contributor overlays",
                loadFailed ? "failed" : "completed",
                finalInternalPercent: null,
                finalDisplayedPercent: null,
                context: new
                {
                    pinnedSeriesCount = _overviewPinnedContributorOverlayByNodeKey.Count,
                    hasPreviewSeries = _overviewHoveredContributorOverlayTimeSeries is not null,
                    failureMessage
                });
        }
    }

    private async Task<CuratedNodeTimeSeriesResult?> GetOverviewContributorOverlayAsync(
        string nodeKey,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode,
        OverviewAggregateSemanticsMode semanticsMode)
    {
        var cacheKey = new OverviewContributorOverlayCacheKey(nodeKey, from.Ticks, to.Ticks, mode, semanticsMode);
        if (_overviewContributorOverlayCache.TryGetValue(cacheKey, out var cachedTimeSeries))
        {
            return cachedTimeSeries;
        }

        var timeSeries = await AnalyticsPreview.GetCuratedSelectionAggregateTimeSeriesAsync(
            [nodeKey],
            from,
            to,
            mode,
            includeBaselineOverlay: false,
            semanticsMode: semanticsMode);

        _overviewContributorOverlayCache[cacheKey] = timeSeries;
        return timeSeries;
    }

    private async Task ReloadOverviewChartAsync(
        IReadOnlyList<string> aggregateNodeKeys,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode,
        OverviewAggregateSemanticsMode semanticsMode,
        bool showLoadingIndicator,
        string operationType = "overview-chart-refresh")
    {
        var analyticsTrace = BeginAnalyticsTrace(operationType, showLoadingIndicator, new
        {
            intervalFromUtc = from,
            intervalToUtc = to,
            scopeNodeCount = aggregateNodeKeys.Count,
            scopeNodeSample = aggregateNodeKeys.Take(6).ToArray(),
            semanticsMode = semanticsMode.ToString(),
            chartGranularity = mode.ToString(),
            fullRefresh = false
        });
        var analyticsLoadingVersion = showLoadingIndicator
            ? BeginAnalyticsLoadingOperation(
                operationType,
                "Refreshing overview chart",
                "Loading trend surface",
                "Replacing the visible chart for the active semantics and interval.",
                0)
            : 0;
        var loadingScopes = showLoadingIndicator
            ? new Dictionary<string, (int CompletedSteps, int TotalSteps)>(StringComparer.OrdinalIgnoreCase)
            {
                ["chart-data"] = (0, 5),
                ["chart-render"] = (0, 1)
            }
            : null;

        void RecalculateChartLoadingPercent(string phaseLabel, string detail)
        {
            if (!showLoadingIndicator || analyticsLoadingVersion != _analyticsLoadingOperationVersion || loadingScopes is null)
            {
                return;
            }

            var totalSteps = loadingScopes.Values.Sum(scope => Math.Max(0, scope.TotalSteps));
            var completedSteps = loadingScopes.Values.Sum(scope => Math.Clamp(scope.CompletedSteps, 0, Math.Max(0, scope.TotalSteps)));
            UpdateAnalyticsLoadingOperation(
                analyticsLoadingVersion,
                phaseLabel,
                detail,
                CalculateAnalyticsMilestonePercent(completedSteps, totalSteps));
        }

        void SetChartLoadingScopeProgress(string scopeKey, string phaseLabel, string detail, int completedSteps, int? totalSteps = null)
        {
            if (!showLoadingIndicator || loadingScopes is null)
            {
                return;
            }

            if (!loadingScopes.TryGetValue(scopeKey, out var currentScope))
            {
                currentScope = (0, Math.Max(0, totalSteps ?? 0));
            }

            var effectiveTotalSteps = Math.Max(0, totalSteps ?? currentScope.TotalSteps);
            if (effectiveTotalSteps == 0)
            {
                loadingScopes[scopeKey] = (0, 0);
                RecalculateChartLoadingPercent(phaseLabel, detail);
                return;
            }

            var effectiveCompletedSteps = Math.Clamp(completedSteps, 0, effectiveTotalSteps);
            if (effectiveCompletedSteps < currentScope.CompletedSteps)
            {
                effectiveCompletedSteps = currentScope.CompletedSteps;
            }

            loadingScopes[scopeKey] = (effectiveCompletedSteps, effectiveTotalSteps);
            RecalculateChartLoadingPercent(phaseLabel, detail);
        }

        IProgress<AnalyticsProgressUpdate>? CreateChartLoadingProgress()
        {
            if (!showLoadingIndicator || loadingScopes is null || loadingScopes["chart-data"].TotalSteps <= 0)
            {
                return null;
            }

            return new Progress<AnalyticsProgressUpdate>(update =>
            {
                SetChartLoadingScopeProgress(
                    "chart-data",
                    string.IsNullOrWhiteSpace(update.PhaseLabel) ? _analyticsLoadingPhaseLabel : update.PhaseLabel,
                    string.IsNullOrWhiteSpace(update.Detail) ? _analyticsLoadingDetail : update.Detail,
                    update.CompletedSteps,
                    update.TotalSteps > 0 ? update.TotalSteps : loadingScopes["chart-data"].TotalSteps);
            });
        }

        if (aggregateNodeKeys.Count == 0)
        {
            _overviewChartTimeSeriesData = null;
            _isOverviewChartLoading = false;
            if (showLoadingIndicator)
            {
                CompleteAnalyticsLoadingOperation(analyticsLoadingVersion);
            }
            LogAnalyticsTraceEnd(
                analyticsTrace,
                showLoadingIndicator ? "loading-pill dismiss scheduled after empty scope" : "no loading pill for empty scope",
                finalInternalPercent: showLoadingIndicator ? _analyticsLoadingPercent : null,
                finalDisplayedPercent: showLoadingIndicator ? AnalyticsLoadingDisplayPercent : null,
                context: new
                {
                    scopeNodeCount = 0
                });
            await InvokeAsync(StateHasChanged);
            return;
        }

        var loadVersion = ++_overviewChartLoadVersion;
        var cacheKey = CreateOverviewChartCacheKey(aggregateNodeKeys, from, to, mode, semanticsMode);
        var loadFailed = false;
        string? failureMessage = null;

        if (_overviewChartCache.TryGetValue(cacheKey, out var cachedTimeSeries))
        {
            _overviewChartTimeSeriesData = cachedTimeSeries;
            _isOverviewChartLoading = false;
            if (showLoadingIndicator)
            {
                SetChartLoadingScopeProgress("chart-data", "Loading trend surface", "Reused cached overview chart data for the active semantics and interval.", 5);
                SetChartLoadingScopeProgress("chart-render", "Rendering trend surface", "Applied cached overview series to the visible chart surface.", 1);
                CompleteAnalyticsLoadingOperation(analyticsLoadingVersion);
            }
            LogAnalyticsTracePhase(
                analyticsTrace,
                "Overview chart cache reuse",
                showLoadingIndicator ? _analyticsLoadingPercent : null,
                showLoadingIndicator ? AnalyticsLoadingDisplayPercent : null,
                new
                {
                    cache = "hit",
                    chartReused = true
                });
            LogAnalyticsTraceEnd(
                analyticsTrace,
                showLoadingIndicator ? "loading-pill dismiss scheduled after cache hit" : "no loading pill for cache hit",
                finalInternalPercent: showLoadingIndicator ? _analyticsLoadingPercent : null,
                finalDisplayedPercent: showLoadingIndicator ? AnalyticsLoadingDisplayPercent : null,
                context: new
                {
                    cache = "hit",
                    chartReused = true
                });
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (showLoadingIndicator)
        {
            _isOverviewChartLoading = true;
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            LogAnalyticsTracePhase(
                analyticsTrace,
                "Loading trend surface",
                showLoadingIndicator ? _analyticsLoadingPercent : null,
                showLoadingIndicator ? AnalyticsLoadingDisplayPercent : null,
                new
                {
                    cache = "miss",
                    chartReused = false
                });

            var timeSeries = await AnalyticsPreview.GetCuratedSelectionAggregateTimeSeriesAsync(
                aggregateNodeKeys,
                from,
                to,
                mode,
                includeBaselineOverlay: false,
                semanticsMode: semanticsMode,
                progress: CreateChartLoadingProgress());

            if (showLoadingIndicator)
            {
                SetChartLoadingScopeProgress(
                    "chart-render",
                    "Rendering trend surface",
                    "Applying the refreshed overview series and replacing the stale chart.",
                    0);

                LogAnalyticsTracePhase(
                    analyticsTrace,
                    "Rendering trend surface",
                    _analyticsLoadingPercent,
                    AnalyticsLoadingDisplayPercent,
                    new
                    {
                        cache = "miss",
                        chartReused = false
                    });
            }

            if (loadVersion != _overviewChartLoadVersion)
            {
                return;
            }

            _overviewChartCache[cacheKey] = timeSeries;
            _overviewChartTimeSeriesData = timeSeries;

            if (showLoadingIndicator)
            {
                SetChartLoadingScopeProgress(
                    "chart-render",
                    "Rendering trend surface",
                    "Applied the refreshed overview series and replaced the stale chart.",
                    1);
            }
        }
        catch (Exception ex)
        {
            loadFailed = true;
            failureMessage = ex.Message;
            throw;
        }
        finally
        {
            if (loadVersion == _overviewChartLoadVersion)
            {
                _isOverviewChartLoading = false;
                if (showLoadingIndicator)
                {
                    CompleteAnalyticsLoadingOperation(analyticsLoadingVersion);
                }
                LogAnalyticsTraceEnd(
                    analyticsTrace,
                    showLoadingIndicator ? "loading-pill dismiss scheduled after chart refresh" : "no loading pill for chart refresh",
                    loadFailed ? "failed" : "completed",
                    showLoadingIndicator ? _analyticsLoadingPercent : null,
                    showLoadingIndicator ? AnalyticsLoadingDisplayPercent : null,
                    new
                    {
                        cache = _overviewChartCache.ContainsKey(cacheKey) ? "populated" : "miss",
                        chartReused = false,
                        failureMessage
                    });
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private OverviewChartCacheKey CreateOverviewChartCacheKey(
        IReadOnlyList<string> aggregateNodeKeys,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode,
        OverviewAggregateSemanticsMode semanticsMode)
    {
        var aggregateNodeSignature = string.Join(
            "||",
            aggregateNodeKeys
                .Where(key => !string.IsNullOrWhiteSpace(key))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(key => key, StringComparer.OrdinalIgnoreCase));

        return new OverviewChartCacheKey(aggregateNodeSignature, from.Ticks, to.Ticks, mode, semanticsMode);
    }

    private void SeedOverviewChartCache(
        IReadOnlyList<string> aggregateNodeKeys,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode,
        OverviewAggregateSemanticsMode semanticsMode,
        CuratedNodeTimeSeriesResult? timeSeries)
    {
        if (aggregateNodeKeys.Count == 0)
        {
            return;
        }

        _overviewChartCache[CreateOverviewChartCacheKey(aggregateNodeKeys, from, to, mode, semanticsMode)] = timeSeries;
    }

