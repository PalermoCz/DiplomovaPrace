    private async Task OnCustomFromChanged(ChangeEventArgs e)
    {
        if (e.Value is not string raw || !TryParseHtmlDate(raw, out var parsedDateUtc))
        {
            _customIntervalValidationMessage = "Custom interval není ve validním formátu data.";
            return;
        }

        _customFromUtc = parsedDateUtc;
        if (_customToUtcExclusive <= _customFromUtc)
        {
            _customToUtcExclusive = _customFromUtc.AddDays(1);
        }

        _customIntervalValidationMessage = null;
        await ReloadPreviewDataAsync();
    }

    private async Task OnCustomToChanged(ChangeEventArgs e)
    {
        if (e.Value is not string raw || !TryParseHtmlDate(raw, out var parsedDateUtc))
        {
            _customIntervalValidationMessage = "Custom interval není ve validním formátu data.";
            return;
        }

        if (parsedDateUtc.Date >= DateTime.MaxValue.Date)
        {
            _customIntervalValidationMessage = "Zadané datum je mimo reprezentovatelný rozsah.";
            return;
        }

        _customToUtcExclusive = DateTime.SpecifyKind(parsedDateUtc.Date.AddDays(1), DateTimeKind.Utc);
        if (_customToUtcExclusive <= _customFromUtc)
        {
            _customToUtcExclusive = _customFromUtc.AddDays(1);
        }

        _customIntervalValidationMessage = null;
        await ReloadPreviewDataAsync();
    }

