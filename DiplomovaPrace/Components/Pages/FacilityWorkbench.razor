    private static bool TryParseHtmlDate(string raw, out DateTime parsedDateUtc)
    {
        parsedDateUtc = default;

        if (!DateTime.TryParseExact(raw, "yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var parsed))
        {
            return false;
        }

        parsedDateUtc = DateTime.SpecifyKind(parsed.Date, DateTimeKind.Utc);
        return true;
    }

    private async Task<string?> ValidateCustomIntervalForAnalyticsAsync()
    {
        if (_customFromUtc == default || _customToUtcExclusive == default)
        {
            return "Custom interval není kompletně vyplněný.";
        }

        if (_customToUtcExclusive <= _customFromUtc)
        {
            return "Koncové datum musí být později než počáteční datum.";
        }

        if (_customFromUtc.Year <= BaselineHistoricalYearsForValidation)
        {
            return "Počáteční datum je příliš brzké pro baseline porovnání vůči minulým letům.";
        }

        if (_selectedFacilityNode is null || !_isCuratedNode)
        {
            return null;
        }

        var domain = await AnalyticsPreview.GetCuratedNodeTimeDomainUtcAsync(_selectedFacilityNode.NodeKey);
        if (!domain.MinUtc.HasValue || !domain.MaxUtc.HasValue)
        {
            return null;
        }

        var domainMin = domain.MinUtc.Value;
        var domainMaxExclusive = domain.MaxUtc.Value.AddMinutes(15);
        var hasOverlap = _customFromUtc < domainMaxExclusive && _customToUtcExclusive > domainMin;

        if (!hasOverlap)
        {
            return $"Vybraný custom interval je mimo dostupný rozsah dat pro uzel {_selectedFacilityNode.NodeKey} ({domainMin:dd.MM.yyyy} - {domain.MaxUtc.Value:dd.MM.yyyy}).";
        }

        return null;
    }

