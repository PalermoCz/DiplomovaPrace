    private (DateTime From, DateTime To) GetInterval()
    {
        var anchor = _presetAnchorUtc;

        return _selectedInterval switch
        {
            "last24h" => (anchor.AddHours(-24), anchor),
            "last7d" => (anchor.AddDays(-7), anchor),
            "last30d" => (anchor.AddDays(-30), anchor),
            "thisMonth" => (new DateTime(anchor.Year, anchor.Month, 1, 0, 0, 0, DateTimeKind.Utc), anchor),
            "custom" => GetSafeCustomInterval(),
            _ => (anchor.AddDays(-7), anchor)
        };
    }

    private async Task RefreshPresetAnchorAsync()
    {
        _presetAnchorNoteText = null;
        var anchor = await GetCurrentPresetAnchorUtcAsync();
        _presetAnchorUtc = anchor ?? DateTime.UtcNow;
    }

    private async Task<DateTime?> GetCurrentPresetAnchorUtcAsync()
    {
        var activeSignalCode = ActiveSelectionSignalCode;
        var signalScopeNodeKeys = GetSignalAnalyticsScopeNodeKeys();
        if (!activeSignalCode.IsEmpty && signalScopeNodeKeys.Count > 0)
        {
            var signalDomain = await AnalyticsPreview.GetCuratedSelectionTimeDomainUtcAsync(signalScopeNodeKeys, activeSignalCode);
            if (signalDomain.MaxUtc.HasValue)
            {
                _presetAnchorNoteText = "Anchor: latest data in the active signal scope";
                return signalDomain.MaxUtc.Value;
            }
        }

        if (ShouldUseAggregateAnalyticsIntervalScope)
        {
            var domain = await AnalyticsPreview.GetCuratedSelectionTimeDomainUtcAsync(GetSelectionAggregateNodeKeys());
            if (domain.MaxUtc.HasValue)
            {
                _presetAnchorNoteText = "Anchor: latest supported data in the current analytics scope";
                return domain.MaxUtc.Value;
            }

            _presetAnchorNoteText = null;
            return null;
        }

        if (_selectedFacilityNode is null || !_isCuratedNode)
        {
            _presetAnchorNoteText = null;
            return null;
        }

        var maxTimestamp = await AnalyticsPreview.GetCuratedNodeMaxTimestampUtcAsync(_selectedFacilityNode.NodeKey);
        _presetAnchorNoteText = maxTimestamp.HasValue
            ? "Anchor: latest data point for the focused node"
            : null;
        return maxTimestamp;
    }

    private async Task<(DateTime? MinUtc, DateTime? MaxUtc)> GetCurrentAnalyticsTimeDomainUtcAsync()
    {
        var activeSignalCode = ActiveSelectionSignalCode;
        var signalScopeNodeKeys = GetSignalAnalyticsScopeNodeKeys();
        if (!activeSignalCode.IsEmpty && signalScopeNodeKeys.Count > 0)
        {
            return await AnalyticsPreview.GetCuratedSelectionTimeDomainUtcAsync(signalScopeNodeKeys, activeSignalCode);
        }

        if (ShouldUseAggregateAnalyticsIntervalScope)
        {
            return await AnalyticsPreview.GetCuratedSelectionTimeDomainUtcAsync(GetSelectionAggregateNodeKeys());
        }

        if (_selectedFacilityNode is null || !_isCuratedNode)
        {
            return (null, null);
        }

        return await AnalyticsPreview.GetCuratedNodeTimeDomainUtcAsync(_selectedFacilityNode.NodeKey);
    }

    private FacilitySignalCode ActiveSelectionSignalCode => FacilitySignalTaxonomy.NormalizeExactCode(_activeAnalyticsSignalCodeValue);

    private SelectionSignalAvailabilityItem? ActiveSelectionSignalAvailability => _selectionSignalAvailability.Options
        .FirstOrDefault(option => string.Equals(option.ExactSignalCode.Value, _activeAnalyticsSignalCodeValue, StringComparison.OrdinalIgnoreCase));

    private bool ActiveSelectionSignalUsesDerivedIntervalView => ActiveSelectionSignalAvailability is not null
        && FacilitySignalTaxonomy.ResolveSeriesSemantics(ActiveSelectionSignalAvailability.ExactSignalCode) == FacilitySignalSeriesSemantics.CumulativeCounter;

    private string? ActiveSelectionSignalSeriesStatusMessage => _selectionSignalAnalyticsResult?.TimeSeries?.SeriesStatusMessage;

    private string SelectionSignalScopeDescription
    {
        get
        {
            var scopeNodeCount = GetSignalAnalyticsScopeNodeKeys().Count;
            if (scopeNodeCount == 0)
            {
                return "No analytics scope is resolved yet.";
            }

            return ShouldUseAggregateAnalyticsIntervalScope
                ? $"Exact signal availability is resolved across {scopeNodeCount} nodes in the current selection scope."
                : "Exact signal availability is resolved for the current focused node.";
        }
    }

    private string ActiveSelectionSignalHelperText
    {
        get
        {
            if (_selectionSignalAvailability.Options.Count == 0)
            {
                return _selectionSignalAvailability.Message ?? "No exact signal bindings are available in the current scope.";
            }

            if (ActiveSelectionSignalAvailability is null)
            {
                return _selectionSignalAvailability.Options.Count == 1
                    ? "The only compatible exact signal code was auto-selected for this scope."
                    : "Choose an exact signal code to render trend and basic stats for this scope.";
            }

            return ActiveSelectionSignalAvailability.AvailabilityMessage;
        }
    }

    private IReadOnlyList<string> GetSignalAnalyticsScopeNodeKeys()
    {
        var selectionScope = GetSelectionAggregateNodeKeys();
        if (selectionScope.Count > 0)
        {
            return selectionScope;
        }

        if (_selectedFacilityNode is not null && !IsWeatherNode(_selectedFacilityNode.NodeKey))
        {
            return [_selectedFacilityNode.NodeKey];
        }

        return [];
    }

    private void SyncSelectionSignalAvailability()
    {
        _selectionSignalAvailability = AnalyticsPreview.GetSelectionSignalAvailability(GetSignalAnalyticsScopeNodeKeys());

        if (_selectionSignalAvailability.Options.Count == 0)
        {
            _activeAnalyticsSignalCodeValue = string.Empty;
            _selectionSignalAnalyticsResult = null;
            return;
        }

        var hasCurrentSelection = _selectionSignalAvailability.Options.Any(option =>
            string.Equals(option.ExactSignalCode.Value, _activeAnalyticsSignalCodeValue, StringComparison.OrdinalIgnoreCase));

        if (!hasCurrentSelection)
        {
            _activeAnalyticsSignalCodeValue = _selectionSignalAvailability.Options.Count == 1
                ? _selectionSignalAvailability.Options[0].ExactSignalCode.Value
                : string.Empty;
        }

        if (string.IsNullOrWhiteSpace(_activeAnalyticsSignalCodeValue))
        {
            _selectionSignalAnalyticsResult = null;
        }
    }

    private async Task RefreshSelectionSignalAnalyticsAsync((DateTime From, DateTime To) interval)
    {
        var activeSignalCode = ActiveSelectionSignalCode;
        var scopeNodeKeys = GetSignalAnalyticsScopeNodeKeys();

        if (activeSignalCode.IsEmpty || scopeNodeKeys.Count == 0 || !string.IsNullOrWhiteSpace(_customIntervalValidationMessage))
        {
            _selectionSignalAnalyticsResult = null;
            return;
        }

        _selectionSignalAnalyticsResult = await AnalyticsPreview.GetSelectionSignalAnalyticsAsync(
            scopeNodeKeys,
            activeSignalCode,
            interval.From,
            interval.To,
            _selectionSignalTimeSeriesMode,
            _selectedFacilityNode?.NodeKey);
    }

    private static string FormatSelectionSignalStatValue(double value, string unit)
        => string.IsNullOrWhiteSpace(unit)
            ? value.ToString("N2")
            : $"{value:N2} {unit}";

    private static string FormatSelectionPowerMetricValue(SelectionPowerMetricSummary metric)
    {
        if (!metric.Value.HasValue)
        {
            return "N/A";
        }

        return metric.Unit switch
        {
            "x" => $"{metric.Value.Value:N2}x",
            _ when string.IsNullOrWhiteSpace(metric.Unit) => metric.Value.Value.ToString("N2"),
            _ => $"{metric.Value.Value:N2} {metric.Unit}"
        };
    }

    private static string FormatSelectionPowerDurationValue(SelectionPowerDurationSummary metric)
    {
        if (!metric.DurationHours.HasValue)
        {
            return "N/A";
        }

        var durationHours = metric.DurationHours.Value;
        return durationHours >= 24d
            ? $"{durationHours / 24d:N1} d"
            : $"{durationHours:N1} h";
    }

    private static string FormatSelectionPowerThresholdValue(double? value, string unit)
    {
        if (!value.HasValue)
        {
            return "N/A";
        }

        return string.IsNullOrWhiteSpace(unit)
            ? value.Value.ToString("N2")
            : $"{value.Value:N2} {unit}";
    }

    private static string FormatSelectionBaselineValue(double? value, string unit)
    {
        if (!value.HasValue)
        {
            return "N/A";
        }

        return string.IsNullOrWhiteSpace(unit)
            ? value.Value.ToString("N2")
            : $"{value.Value:N2} {unit}";
    }

    private static string FormatSelectionBaselineSignedValue(double? value, string unit)
    {
        if (!value.HasValue)
        {
            return "N/A";
        }

        var number = FormatSigned(value, "N2");
        return string.IsNullOrWhiteSpace(unit)
            ? number
            : $"{number} {unit}";
    }

    private static string FormatSelectionBaselinePercent(double? value)
    {
        if (!value.HasValue)
        {
            return "N/A";
        }

        return $"{FormatSigned(value, "N2")} %";
    }

    private static string FormatSelectionEnergyValue(double? value)
        => value.HasValue
            ? $"{value.Value:N2} kWh"
            : "N/A";

    private static string FormatSelectionFloorAreaValue(double? value)
        => value.HasValue
            ? $"{value.Value:N2} m²"
            : "N/A";

    private static string FormatSelectionEuiValue(double? value)
        => value.HasValue
            ? $"{value.Value:N3} kWh/m²"
            : "N/A";

    private static string FormatSelectionSignalCoverage(SelectionSignalBasicStats stats)
    {
        if (!stats.FirstTimestampUtc.HasValue || !stats.LastTimestampUtc.HasValue)
        {
            return "N/A";
        }

        return $"{stats.FirstTimestampUtc.Value.ToLocalTime():dd/MM/yyyy HH:mm} - {stats.LastTimestampUtc.Value.ToLocalTime():dd/MM/yyyy HH:mm}";
    }

    private (DateTime From, DateTime To) GetSafeCustomInterval()
    {
        var from = _customFromUtc;
        var to = _customToUtcExclusive;

        if (to <= from)
        {
            to = from.AddDays(1);
        }

        return (from, to);
    }

    private string DisplayIntervalFromTo
    {
        get
        {
            if (_selectedInterval == "custom")
            {
                return $"{_customFromUtc.ToString("dd'/'MM'/'yyyy HH:mm")} - {_customToUtcExclusive.AddMinutes(-1).ToString("dd'/'MM'/'yyyy HH:mm")}";
            }

            var interval = GetInterval();
