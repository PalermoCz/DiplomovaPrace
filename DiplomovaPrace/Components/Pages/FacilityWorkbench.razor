    private static IReadOnlyList<string> BuildForecastDiagnosticsPoints(CuratedSelectionForecastDiagnosticsSummary diagnostics)
    {
        var points = new List<string>();

        points.Add($"Forecast principle: {diagnostics.ForecastPrinciple}.");
        points.Add($"Aligned coverage: {(diagnostics.AlignmentCoverageRatio * 100.0).ToString("N0")} % of the actual series.");

        if (diagnostics.ForecastMissingNodeCount > 0)
        {
            points.Add($"Forecast reference missing for {diagnostics.ForecastMissingNodeCount}/{Math.Max(1, diagnostics.IncludedNodeCount)} analytically included nodes.");
        }

        if (diagnostics.HasMixedSignedSelection)
        {
            points.Add("Mixed-sign selection: SMAPE is skipped, so the tab uses MAE/RMSE/Bias plus WAPE over |actual|.");
        }
        else
        {
            points.Add("Consumption-only or generation-only selection: MAE/RMSE/Bias plus WAPE for a quick fit readout.");
        }

        if (points.Count == 0)
        {
            points.Add("Forecast diagnostics are not available yet.");
        }

        return points;
    }

    private static IReadOnlyList<string> BuildOperationalSignalPoints(CuratedSelectionOperationalHealthSummary health)
    {
        var points = new List<string>();

        if (health.HighDeviationNodeCount > 0)
        {
            points.Add($"High deviation: {health.HighDeviationNodeCount} nodes.");
        }

        if (health.ElevatedDeviationNodeCount > 0)
        {
            points.Add($"Elevated deviation: {health.ElevatedDeviationNodeCount} nodes.");
        }

        if (health.HasWeakCoverage)
        {
            points.Add($"Weak coverage: {(health.IncludedCoverageRatio * 100.0).ToString("N0")} % of supported nodes are included.");
        }

        if (health.HasMixedSignedSelection)
        {
            points.Add("Mixed-sign selection: the net view includes both consumption and generation.");
        }

        if (health.HasAbruptAggregateShift)
        {
            var abruptRatioText = health.AbruptShiftRatio.HasValue
                ? health.AbruptShiftRatio.Value.ToString("N1")
                : "N/A";
            points.Add($"Abrupt aggregate-series shift detected (ratio {abruptRatioText}).");
        }

        if (health.UnsupportedNodeCount > 0 || health.ContextOnlyNodeCount > 0 || health.NoDataNodeCount > 0)
        {
            points.Add($"Data constraints: unsupported {health.UnsupportedNodeCount}, context-only {health.ContextOnlyNodeCount}, no-data {health.NoDataNodeCount}.");
        }

        if (points.Count == 0)
        {
            points.Add("No active issue signals in the current interval.");
        }

        return points;
    }

    private static IReadOnlyList<string> BuildOperatingRegimeSignalPoints(CuratedSelectionOperatingRegimeSummary regime)
    {
        var points = new List<string>();

        foreach (var signal in regime.Signals)
        {
            switch (signal)
            {
                case "high_peak_to_average":
                    points.Add("Peak-to-average ratio is high, which points to a peak-driven regime.");
                    break;
                case "high_variability":
                    points.Add("Variability stays high even after normalizing to |kW|.");
                    break;
                case "elevated_variability":
                    points.Add("Variability is elevated and changes the daily operating pattern.");
                    break;
                case "stable_baseload_shape":
                    points.Add("The baseload proxy is relatively high versus the average level.");
                    break;
                case "weekday_weekend_split":
                    points.Add("The split between weekday and weekend behavior is meaningful.");
                    break;
                case "mixed_sign_selection":
                    points.Add("Mixed-sign selection: regime metrics are computed over absolute magnitude.");
                    break;
            }
        }

        if (points.Count == 0)
        {
            points.Add("No strong operating signal stands out beyond the usual band.");
        }

        return points;
    }

