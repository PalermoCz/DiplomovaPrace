    private string? ResolveEffectiveEditorNodeTypeForDraft(string? draftNodeType = null)
    {
        var normalizedDraft = NormalizeOptionalText(draftNodeType ?? _editorNodeTypeInput);
        if (!string.IsNullOrWhiteSpace(normalizedDraft))
        {
            return normalizedDraft;
        }

        if (_selectedFacilityNode is not null && _editorNodeStatesByKey.TryGetValue(_selectedFacilityNode.NodeKey, out var existingState))
        {
            var stateNodeType = NormalizeOptionalText(existingState.NodeType);
            if (!string.IsNullOrWhiteSpace(stateNodeType))
