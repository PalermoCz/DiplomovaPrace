    private CuratedSelectionAfterHoursLoadSummary ActivePowerOffHoursSummary =>
        IsAggregateAnalysisDataSource
            ? SelectionAfterHoursLoad
            : BuildSingleNodeOffHoursSummary(ActiveTrendCoreTimeSeries);

    private static CuratedSelectionAfterHoursLoadSummary BuildSingleNodeOffHoursSummary(CuratedNodeTimeSeriesResult? timeSeries)
    {
        if (timeSeries is null || timeSeries.Points.Count == 0)
        {
            return new CuratedSelectionAfterHoursLoadSummary
            {
                IsAvailable = false,
                State = CuratedPerformanceKpiState.Unavailable,
                Summary = "Off-hours is unavailable because the active source has no usable time-series points.",
                EvaluationBasis = "Evaluation basis: active source signal time series.",
                Methodology = "After-hours uses fixed schedule windows: weekday active hours 07:00-19:00 UTC versus all remaining timestamps."
            };
        }

        if (timeSeries.Granularity == CuratedNodeTimeSeriesGranularity.DailyAverage)
        {
            return new CuratedSelectionAfterHoursLoadSummary
            {
                IsAvailable = false,
                State = CuratedPerformanceKpiState.Unavailable,
                Summary = "Off-hours requires sub-daily points and is unavailable for daily-only series.",
                EvaluationBasis = "Evaluation basis: active source signal time series.",
                Methodology = "After-hours uses fixed schedule windows: weekday active hours 07:00-19:00 UTC versus all remaining timestamps."
            };
        }

        static bool IsWeekend(DateTime timestampUtc) => timestampUtc.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
        static bool IsActiveWeekday(DateTime timestampUtc) => !IsWeekend(timestampUtc) && timestampUtc.Hour >= 7 && timestampUtc.Hour < 19;
        static bool IsNightWeekday(DateTime timestampUtc) => !IsWeekend(timestampUtc) && !IsActiveWeekday(timestampUtc);

        var demandPoints = timeSeries.Points
            .Select(point => new CuratedNodeTimeSeriesPoint
            {
                TimestampUtc = point.TimestampUtc,
                Value = Math.Max(0d, point.Value)
            })
            .ToList();

        var activeWeekdayValues = demandPoints
            .Where(point => IsActiveWeekday(point.TimestampUtc))
            .Select(point => point.Value)
            .ToList();
        var afterHoursValues = demandPoints
            .Where(point => !IsActiveWeekday(point.TimestampUtc))
            .Select(point => point.Value)
            .ToList();
        var nightValues = demandPoints
            .Where(point => IsNightWeekday(point.TimestampUtc))
            .Select(point => point.Value)
            .ToList();
        var weekendValues = demandPoints
            .Where(point => IsWeekend(point.TimestampUtc))
            .Select(point => point.Value)
            .ToList();

        var minimumBucketSamples = GetMinimumOffHoursBucketSampleCount(timeSeries.Granularity);
        if (activeWeekdayValues.Count < minimumBucketSamples || afterHoursValues.Count < minimumBucketSamples)
        {
            return new CuratedSelectionAfterHoursLoadSummary
            {
                IsAvailable = false,
                State = CuratedPerformanceKpiState.Unavailable,
                Summary = $"Off-hours needs enough active and after-hours samples. Current source has {activeWeekdayValues.Count} active and {afterHoursValues.Count} after-hours points; at least {minimumBucketSamples} are required in each bucket.",
                EvaluationBasis = DescribeOffHoursEvaluationBasis(timeSeries.Granularity),
                Methodology = "After-hours uses fixed schedule windows: weekday active hours 07:00-19:00 UTC versus all remaining timestamps.",
                ActiveWeekdaySampleCount = activeWeekdayValues.Count,
                AfterHoursSampleCount = afterHoursValues.Count,
                NightSampleCount = nightValues.Count,
                WeekendSampleCount = weekendValues.Count
            };
        }

        var activeWeekdayAverage = activeWeekdayValues.Average();
        var afterHoursAverage = afterHoursValues.Average();
        var referenceDemand = Math.Max(0.15d, activeWeekdayAverage);
        var usesReferenceFloor = activeWeekdayAverage < 0.15d;
        var afterHoursRatio = afterHoursAverage / referenceDemand;

        var notes = new List<string>();
        if (usesReferenceFloor)
        {
            notes.Add("Ratios use a 0.15 kW reference floor when active weekday demand is very low.");
        }

        double? nightAverage = null;
        double? nightRatio = null;
        var minimumSubratioSamples = GetMinimumOffHoursSubratioSampleCount(timeSeries.Granularity);
        if (nightValues.Count >= minimumSubratioSamples)
        {
            nightAverage = nightValues.Average();
            nightRatio = nightAverage.Value / referenceDemand;
        }

        double? weekendAverage = null;
        double? weekendRatio = null;
        if (weekendValues.Count >= minimumSubratioSamples)
        {
            weekendAverage = weekendValues.Average();
            weekendRatio = weekendAverage.Value / referenceDemand;
        }

        var summary = $"Single-node schedule split: after-hours demand equals {(afterHoursRatio * 100.0):N0} % of the active-weekday reference.";
        if (nightRatio.HasValue)
        {
            summary += $" Night ratio is {(nightRatio.Value * 100.0):N0} %.";
        }

        if (weekendRatio.HasValue)
        {
            summary += $" Weekend ratio is {(weekendRatio.Value * 100.0):N0} %.";
        }

        return new CuratedSelectionAfterHoursLoadSummary
        {
            IsAvailable = true,
            State = CuratedPerformanceKpiState.Indicative,
            StateReason = "Schedule heuristic with fixed weekday 07:00-19:00 UTC active hours.",
            EvaluationBasis = DescribeOffHoursEvaluationBasis(timeSeries.Granularity),
            Notes = notes,
            AverageActiveWeekdayDemandKw = activeWeekdayAverage,
            AverageAfterHoursDemandKw = afterHoursAverage,
            AfterHoursRatio = afterHoursRatio,
            AverageNightDemandKw = nightAverage,
            NightRatio = nightRatio,
            AverageWeekendDemandKw = weekendAverage,
            WeekendRatio = weekendRatio,
            UsesReferenceFloor = usesReferenceFloor,
            ActiveWeekdaySampleCount = activeWeekdayValues.Count,
            AfterHoursSampleCount = afterHoursValues.Count,
            NightSampleCount = nightValues.Count,
            WeekendSampleCount = weekendValues.Count,
            Summary = summary,
            Methodology = "After-hours uses fixed schedule windows over the active source series: weekday active hours 07:00-19:00 UTC, night as weekday off-hours, and weekend as Saturday/Sunday."
        };
    }

    private static int GetMinimumOffHoursBucketSampleCount(CuratedNodeTimeSeriesGranularity granularity)
    {
        return granularity switch
        {
            CuratedNodeTimeSeriesGranularity.Raw15Min => 16,
            CuratedNodeTimeSeriesGranularity.HourlyAverage => 8,
            _ => int.MaxValue
        };
    }

    private static int GetMinimumOffHoursSubratioSampleCount(CuratedNodeTimeSeriesGranularity granularity)
    {
        return granularity switch
        {
            CuratedNodeTimeSeriesGranularity.Raw15Min => 8,
            CuratedNodeTimeSeriesGranularity.HourlyAverage => 4,
            _ => int.MaxValue
        };
    }

    private static string DescribeOffHoursEvaluationBasis(CuratedNodeTimeSeriesGranularity granularity)
    {
        return granularity switch
        {
            CuratedNodeTimeSeriesGranularity.Raw15Min => "Evaluation basis: 15-minute active source series.",
            CuratedNodeTimeSeriesGranularity.HourlyAverage => "Evaluation basis: hourly-average active source series.",
            CuratedNodeTimeSeriesGranularity.DailyAverage => "Evaluation basis: daily-average active source series (off-hours requires sub-daily data).",
            _ => "Evaluation basis: active source signal time series."
        };
    }

