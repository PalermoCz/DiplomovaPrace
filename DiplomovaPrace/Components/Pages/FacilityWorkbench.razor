    private bool CanDeleteSelectedStylePreset()
    {
        return GetDeleteSelectedStylePresetBlockReason() is null;
    }

    private string? GetDeleteSelectedStylePresetBlockReason()
    {
        var resolvedPresetKey = FacilityNodeStyleSystem.ResolvePresetKey(_styleAssignmentPresetKeyInput, _stylePresetsByKey);
        if (resolvedPresetKey.Equals(FacilityNodeStyleSystem.DefaultPresetKey, StringComparison.OrdinalIgnoreCase))
        {
            return "The default fallback preset cannot be deleted.";
        }

        var persistedUsageCount = GetPersistedStylePresetUsageCount(resolvedPresetKey);
        if (persistedUsageCount > 0)
        {
            return $"This preset cannot be deleted because it is still used by {persistedUsageCount} node{(persistedUsageCount == 1 ? string.Empty : "s")}.";
        }

        return null;
    }

