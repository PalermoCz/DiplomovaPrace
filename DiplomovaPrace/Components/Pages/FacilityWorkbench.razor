            if (_customToUtcExclusive <= _customFromUtc)
                _customToUtcExclusive = _customFromUtc.AddDays(1);
        }
        _customIntervalValidationMessage = null;
        await ReloadPreviewDataAsync();
    }

    private async Task OnCustomToPickerChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            var to = DateTime.SpecifyKind(value.Value, DateTimeKind.Utc).AddMinutes(1);
            if (to.Date >= DateTime.MaxValue.Date)
            {
                _customIntervalValidationMessage = "The entered date is outside the supported range.";
                return;
            }
            _customToUtcExclusive = to;
            if (_customToUtcExclusive <= _customFromUtc)
                _customToUtcExclusive = _customFromUtc.AddDays(1);
        }
        _customIntervalValidationMessage = null;
        await ReloadPreviewDataAsync();
    }

