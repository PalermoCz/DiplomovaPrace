    private void PushEditUndoSnapshot(string snapshot, string description)
    {
        _editUndoStack.Add((snapshot, description));
        if (_editUndoStack.Count > 50)
            _editUndoStack.RemoveAt(0);
        _editRedoStack.Clear();
    }

    private async Task UndoEditAsync()
    {
        if (_editUndoStack.Count == 0) return;
        var currentJson = await FacilityEditorStateService.GetRawStateAsync();
        var entry = _editUndoStack[^1];
        _editUndoStack.RemoveAt(_editUndoStack.Count - 1);
        _editRedoStack.Add((currentJson, entry.Description));
        await FacilityEditorStateService.RestoreFromRawStateAsync(entry.Json);
        await ReloadData(preserveSelection: true);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RedoEditAsync()
    {
        if (_editRedoStack.Count == 0) return;
        var currentJson = await FacilityEditorStateService.GetRawStateAsync();
        var entry = _editRedoStack[^1];
        _editRedoStack.RemoveAt(_editRedoStack.Count - 1);
        _editUndoStack.Add((currentJson, entry.Description));
        await FacilityEditorStateService.RestoreFromRawStateAsync(entry.Json);
        await ReloadData(preserveSelection: true);
        await InvokeAsync(StateHasChanged);
    }



