    private IReadOnlyList<string> GetSignalAnalyticsScopeNodeKeys()
    {
        var consumptionBasisNodeKeys = GetConsumptionBasisNodeKeys();
        if (consumptionBasisNodeKeys.Count > 0)
        {
            return consumptionBasisNodeKeys;
        }

        if (_selectedFacilityNode is not null
            && !IsWeatherNode(_selectedFacilityNode.NodeKey)
            && GetSelectionAggregateNodeKeys().Count <= 1)
        {
            return [_selectedFacilityNode.NodeKey];
        }

        return [];
    }

    private IReadOnlyList<string> GetConsumptionBasisNodeKeys()
    {
        if (_selectionAggregateOverview is not null)
        {
            if (_selectionAggregateOverview.TotalConsumptionKwh <= 0.0001d)
            {
                return [];
            }

            var breakdownKeys = _selectionAggregateOverview.Breakdown
                .Where(item => item.HasData && item.IntervalEnergyKwh > 0.0001d)
                .Select(item => item.NodeKey)
                .Where(nodeKey => !string.IsNullOrWhiteSpace(nodeKey))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (breakdownKeys.Count > 0)
            {
                return breakdownKeys;
            }
        }

        if (_selectedFacilityNode is not null
            && !IsWeatherNode(_selectedFacilityNode.NodeKey)
            && GetSelectionAggregateNodeKeys().Count <= 1)
        {
            return [_selectedFacilityNode.NodeKey];
        }

        return [];
    }

    private void SyncSelectionSignalAvailability(string? preferredSignalCodeValue = null)
    {
        var preferredSignalCode = preferredSignalCodeValue?.Trim() ?? string.Empty;

        // Reset data source if the selected node is no longer in the scope
        if (!IsAggregateAnalysisDataSource)
        {
            var fullScopeKeys = SelectionNodeKeysWithAnyData;
            if (!fullScopeKeys.Contains(_analysisDataSourceKey, StringComparer.OrdinalIgnoreCase))
            {
                _analysisDataSourceKey = AnalysisDataSourceSelection;
            }
        }

        _selectionSignalAvailability = AnalyticsPreview.GetSelectionSignalAvailability(ResolveActiveAnalysisSourceNodeKeys());
        if (_selectionSignalAvailability.Options.Count == 0)
        {
            _activeAnalyticsSignalCodeValue = string.Empty;
            _selectionSignalAnalyticsResult = null;
            _selectionSignalTrendCore = null;
            _selectionSignalAuxiliaryModules = null;
            return;
        }

        var availablePrimaryOptions = AnalysisPrimarySignalOptions;
        if (availablePrimaryOptions.Count == 0)
        {
            _activeAnalyticsSignalCodeValue = string.Empty;
            _selectionSignalAnalyticsResult = null;
            _selectionSignalTrendCore = null;
            _selectionSignalAuxiliaryModules = null;
            return;
        }

        var candidateSignalCode = !string.IsNullOrWhiteSpace(preferredSignalCode)
            ? preferredSignalCode
            : _activeAnalyticsSignalCodeValue;

        var matchedPrimaryOption = availablePrimaryOptions.FirstOrDefault(option =>
            string.Equals(option.ExactSignalCode.Value, candidateSignalCode, StringComparison.OrdinalIgnoreCase));

        var hasCurrentSelection = matchedPrimaryOption is not null;

        if (!hasCurrentSelection)
        {
            _activeAnalyticsSignalCodeValue = availablePrimaryOptions.Count == 1
                ? availablePrimaryOptions[0].ExactSignalCode.Value
                : string.Empty;
        }
        else
        {
            _activeAnalyticsSignalCodeValue = matchedPrimaryOption!.ExactSignalCode.Value;
        }

        if (string.IsNullOrWhiteSpace(_activeAnalyticsSignalCodeValue))
        {
            _selectionSignalAnalyticsResult = null;
            _selectionSignalTrendCore = null;
            _selectionSignalAuxiliaryModules = null;
        }
    }

