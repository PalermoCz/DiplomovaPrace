            .Where(edge => edge is not null
                && !edge.IsLayoutEdge
                && !string.Equals(edge.RelationshipKind, SchematicRelationshipKinds.LayoutPrimary, StringComparison.OrdinalIgnoreCase))
            .Select(edge => new FacilityAdditionalRelationship
            {
                SourceNodeKey = edge.SourceNodeKey,
                TargetNodeKey = edge.TargetNodeKey,
                RelationshipKind = NormalizeOptionalText(edge.RelationshipKind)?.ToLowerInvariant() ?? SchematicRelationshipKinds.AdditionalLink,
                Note = NormalizeOptionalText(edge.Note),
                UpdatedUtc = DateTime.UtcNow
            })
            .ToList();
    }

    private sealed record AdditionalLinkListItem(
        string CounterpartyNodeKey,
        string CounterpartyLabel,
        string SourceNodeKey,
        string TargetNodeKey,
        string StoredRelationshipKind,
        string? Note);

    private IReadOnlyList<AdditionalLinkListItem> GetFocusedNodeAdditionalLinks()
    {
        if (_selectedFacilityNode is null || _facility?.Edges is null)
        {
            return [];
        }

        return _facility.Edges
            .Where(edge => edge is not null
                && !edge.IsLayoutEdge
                && !string.Equals(edge.RelationshipKind, SchematicRelationshipKinds.LayoutPrimary, StringComparison.OrdinalIgnoreCase)
                && (string.Equals(edge.SourceNodeKey, _selectedFacilityNode.NodeKey, StringComparison.OrdinalIgnoreCase)
                    || string.Equals(edge.TargetNodeKey, _selectedFacilityNode.NodeKey, StringComparison.OrdinalIgnoreCase)))
            .Select(edge =>
            {
                var counterpartyNodeKey = string.Equals(edge.SourceNodeKey, _selectedFacilityNode.NodeKey, StringComparison.OrdinalIgnoreCase)
                    ? edge.TargetNodeKey
                    : edge.SourceNodeKey;

                return new AdditionalLinkListItem(
                    counterpartyNodeKey,
                    GetNodeDisplayLabel(counterpartyNodeKey),
                    edge.SourceNodeKey,
                    edge.TargetNodeKey,
                    NormalizeOptionalText(edge.RelationshipKind)?.ToLowerInvariant() ?? SchematicRelationshipKinds.AdditionalLink,
                    NormalizeOptionalText(edge.Note));
            })
            .OrderBy(item => item.CounterpartyLabel, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(item => item.CounterpartyNodeKey, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

