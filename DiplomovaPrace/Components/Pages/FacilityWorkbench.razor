    private async Task RefreshSelectionSignalAnalyticsAsync((DateTime From, DateTime To) interval, string operationType = "analysis-refresh")
    {
        var activeSignalCode = ActiveSelectionSignalCode;
        var scopeNodeKeys = ResolveActiveAnalysisSourceNodeKeys();
        _selectionSignalAnalysisLoadVersion++;
        var loadVersion = _selectionSignalAnalysisLoadVersion;

        _selectionSignalAnalysisCts?.Cancel();
        _selectionSignalAnalysisCts?.Dispose();
        _selectionSignalAnalysisCts = new System.Threading.CancellationTokenSource();
        var cancellationToken = _selectionSignalAnalysisCts.Token;

        _isSelectionSignalTrendLoading = true;
        _isSelectionSignalAuxiliaryLoading = true;
        _selectionSignalTrendCore = null;
        _selectionSignalAuxiliaryModules = null;
        _selectionSignalAnalyticsResult = null;

        var analyticsTrace = BeginAnalyticsTrace(operationType, false, new
        {
            intervalFromUtc = interval.From,
            intervalToUtc = interval.To,
            signalCode = activeSignalCode.Value,
            scopeNodeCount = scopeNodeKeys.Count,
            chartGranularity = _selectionSignalTimeSeriesMode.ToString()
        });

        var loadFailed = false;
        string? failureMessage = null;

        if (activeSignalCode.IsEmpty || scopeNodeKeys.Count == 0 || !string.IsNullOrWhiteSpace(_customIntervalValidationMessage))
        {
            _selectionSignalAnalyticsResult = null;
            _selectionSignalTrendCore = null;
            _selectionSignalAuxiliaryModules = null;
            _isSelectionSignalTrendLoading = false;
            _isSelectionSignalAuxiliaryLoading = false;
            LogAnalyticsTraceEnd(
                analyticsTrace,
                "analysis refresh skipped due to missing signal scope or invalid interval",
                finalInternalPercent: null,
                finalDisplayedPercent: null,
                context: new
                {
                    signalCode = activeSignalCode.Value,
                    scopeNodeCount = scopeNodeKeys.Count,
                    validationMessage = _customIntervalValidationMessage
                });
            return;
        }

        try
        {
            LogAnalyticsTracePhase(
                analyticsTrace,
                "Requesting trend core",
                null,
                null,
                new
                {
                    signalCode = activeSignalCode.Value,
                    scopeNodeCount = scopeNodeKeys.Count
                });

            var trendCore = await AnalyticsPreview.GetSelectionSignalTrendCoreAsync(
                scopeNodeKeys,
                activeSignalCode,
                interval.From,
                interval.To,
                _selectionSignalTimeSeriesMode,
                _selectedFacilityNode?.NodeKey,
                cancellationToken);

            if (cancellationToken.IsCancellationRequested || loadVersion != _selectionSignalAnalysisLoadVersion)
            {
                return;
            }

            _selectionSignalTrendCore = trendCore;
            _selectionSignalAnalyticsResult = ComposeSelectionSignalAnalyticsResult(trendCore, null);
            _isSelectionSignalTrendLoading = false;

            await InvokeAsync(StateHasChanged);

            _ = LoadSelectionSignalAuxiliaryModulesAsync(
                scopeNodeKeys,
                activeSignalCode,
                interval,
                _selectionSignalTimeSeriesMode,
                _selectedFacilityNode?.NodeKey,
                loadVersion,
                cancellationToken,
                analyticsTrace);

            LogAnalyticsTracePhase(
                analyticsTrace,
                "Trend core ready",
                null,
                null,
                new
                {
                    signalCode = activeSignalCode.Value,
                    hasTrendCore = _selectionSignalTrendCore is not null
                });
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            loadFailed = true;
            failureMessage = ex.Message;
            _isSelectionSignalTrendLoading = false;
            _isSelectionSignalAuxiliaryLoading = false;
            throw;
        }
        finally
        {
            if (loadVersion == _selectionSignalAnalysisLoadVersion)
            {
                _isSelectionSignalTrendLoading = false;
            }

            LogAnalyticsTraceEnd(
                analyticsTrace,
                "no loading pill for analysis refresh",
                loadFailed ? "failed" : "completed",
                finalInternalPercent: null,
                finalDisplayedPercent: null,
                context: new
                {
                    signalCode = activeSignalCode.Value,
                    hasResult = _selectionSignalAnalyticsResult is not null,
                    failureMessage
                });
        }
    }

    private async Task LoadSelectionSignalAuxiliaryModulesAsync(
        IReadOnlyList<string> scopeNodeKeys,
        FacilitySignalCode activeSignalCode,
        (DateTime From, DateTime To) interval,
        CuratedNodeTimeSeriesMode mode,
        string? scopeAnchorNodeKey,
        int loadVersion,
        CancellationToken ct,
        AnalyticsOperationTrace analyticsTrace)
    {
        try
        {
            var auxiliary = await AnalyticsPreview.GetSelectionSignalAuxiliaryModulesAsync(
                scopeNodeKeys,
                activeSignalCode,
                interval.From,
                interval.To,
                mode,
                scopeAnchorNodeKey,
                ct);

            if (ct.IsCancellationRequested || loadVersion != _selectionSignalAnalysisLoadVersion)
            {
                return;
            }

            _selectionSignalAuxiliaryModules = auxiliary;
            _selectionSignalAnalyticsResult = ComposeSelectionSignalAnalyticsResult(_selectionSignalTrendCore, auxiliary);
            _isSelectionSignalAuxiliaryLoading = false;

            LogAnalyticsTracePhase(
                analyticsTrace,
                "Auxiliary modules ready",
                null,
                null,
                new
                {
                    signalCode = activeSignalCode.Value,
                    auxiliaryReady = true
                });

            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
        }
        catch
        {
            if (ct.IsCancellationRequested || loadVersion != _selectionSignalAnalysisLoadVersion)
            {
                return;
            }

            _isSelectionSignalAuxiliaryLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static SelectionSignalAnalyticsResult? ComposeSelectionSignalAnalyticsResult(
        SelectionSignalTrendCoreResult? trendCore,
        SelectionSignalAuxiliaryModulesResult? auxiliary)
    {
        if (trendCore is null && auxiliary is null)
        {
            return null;
        }

        return new SelectionSignalAnalyticsResult
        {
            SelectionSignal = trendCore?.SelectionSignal,
            TimeSeries = trendCore?.TimeSeries,
            BasicStats = trendCore?.BasicStats,
            PowerAnalytics = auxiliary?.PowerAnalytics ?? new SelectionPowerAnalyticsResult(),
            Eui = auxiliary?.Eui ?? new SelectionEuiResult(),
            WeatherAwareBaseline = auxiliary?.WeatherAwareBaseline ?? new SelectionWeatherAwareBaselineResult(),
            TemperatureLoadScatter = auxiliary?.TemperatureLoadScatter ?? new SelectionTemperatureLoadScatterResult(),
            IsAvailable = trendCore?.IsAvailable ?? false,
            IsAggregate = trendCore?.IsAggregate ?? false,
            Message = trendCore?.Message ?? string.Empty,
            ContributingNodeKeys = trendCore?.ContributingNodeKeys ?? []
        };
    }

