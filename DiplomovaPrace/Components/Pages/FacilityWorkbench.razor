    private async Task DeleteSelectedNodeBindingAsync(string bindingId)
    {
        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _importStatusMessage = "Select one editable node before deleting a binding.";
            _importErrors = [];
            await InvokeAsync(StateHasChanged);
            return;
        }

        var binding = GetSelectedNodeBindingsForPreview()
            .FirstOrDefault(existing => existing.BindingId.Equals(bindingId, StringComparison.OrdinalIgnoreCase));

        if (binding is null)
        {
            _importStatusMessage = "Delete failed: binding was not found in the current node preview.";
            _importErrors = [];
            await InvokeAsync(StateHasChanged);
            return;
        }

        var result = await NodeSeriesImportService.DeleteBindingAsync(binding);
        _importStatusMessage = result.Message;
        _importErrors = [];

        if (result.Success)
        {
            _isCuratedNode = IsCuratedNode(_selectedFacilityNode);
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

