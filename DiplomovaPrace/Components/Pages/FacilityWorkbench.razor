    private IReadOnlyList<string> GetEditableAdditionalRelationshipKinds()
    {
        var kinds = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            SchematicRelationshipKinds.AdditionalLink,
            SchematicRelationshipKinds.Semantic,
            SchematicRelationshipKinds.Membership
        };

        foreach (var edge in _facility?.Edges ?? [])
        {
            if (edge is null || edge.IsLayoutEdge)
            {
                continue;
            }

            if (string.Equals(edge.RelationshipKind, SchematicRelationshipKinds.LayoutPrimary, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var normalizedKind = NormalizeOptionalText(edge.RelationshipKind)?.ToLowerInvariant();
            if (!string.IsNullOrWhiteSpace(normalizedKind))
            {
                kinds.Add(normalizedKind);
            }
        }

        return kinds
            .OrderBy(kind => kind.Equals(SchematicRelationshipKinds.AdditionalLink, StringComparison.OrdinalIgnoreCase) ? 0 :
                kind.Equals(SchematicRelationshipKinds.Semantic, StringComparison.OrdinalIgnoreCase) ? 1 :
                kind.Equals(SchematicRelationshipKinds.Membership, StringComparison.OrdinalIgnoreCase) ? 2 : 3)
            .ThenBy(kind => kind, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private string GetDefaultAdditionalRelationshipKind()
    {
        var kinds = GetEditableAdditionalRelationshipKinds();
        return kinds.FirstOrDefault(kind => kind.Equals(SchematicRelationshipKinds.AdditionalLink, StringComparison.OrdinalIgnoreCase))
               ?? kinds.FirstOrDefault()
               ?? SchematicRelationshipKinds.AdditionalLink;
    }

