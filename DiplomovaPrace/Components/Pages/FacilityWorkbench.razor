    private IReadOnlyList<FacilityNodeStylePreset> GetOrderedStylePresets()
    {
        var currentAssignment = _styleAssignmentPresetKeyInput;
        return _stylePresetsByKey.Values
            .Where(p => !FacilityNodeStyleSystem.SystemPresetKeys.Contains(p.Key)
                        || p.Key.Equals(currentAssignment, StringComparison.OrdinalIgnoreCase))
            .OrderBy(preset => preset.Key.Equals(FacilityNodeStyleSystem.DefaultPresetKey, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .ThenBy(preset => preset.Name, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(preset => preset.Key, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string GetStylePresetLabel(FacilityNodeStylePreset preset)
    {
        return string.IsNullOrWhiteSpace(preset.Name)
            ? preset.Key
            : preset.Name;
