    private async Task GoHomeAsync()
    {
        if (_schematicLayout?.Nodes.Count > 0)
        {
            var rootNode = ResolveHomeTargetNode(_schematicLayout.Nodes);
            if (rootNode is not null)
            {
                await JSRuntime.InvokeVoidAsync("editorCanvas.panToNode", rootNode.X, rootNode.Y, 1.4);
