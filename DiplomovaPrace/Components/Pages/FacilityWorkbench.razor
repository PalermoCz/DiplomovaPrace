    private sealed record SelectionDonutSegment(string Label, int Count, string Color, string Tooltip, string? DetailText = null);

    private int SupportedSelectionSummaryCount => SelectionSummaryClassification.SupportedNodeKeys.Count;

    private IReadOnlyList<SelectionDonutSegment> GetSelectionDonutSegments()
    {
        var selectionSummaryClassification = SelectionSummaryClassification;
        var supportedItems = selectionSummaryClassification.SupportedSummaryItems;
        if (supportedItems.Count == 0)
        {
            return [];
        }

        var groups = supportedItems
            .GroupBy(item => string.IsNullOrWhiteSpace(item.NodeType) ? "Unknown" : item.NodeType.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(group => new
            {
                Label = group.Key,
                Count = group.Count(),
                Nodes = group.ToList()
            })
            .OrderByDescending(group => group.Count)
            .ThenBy(group => group.Label, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var segments = new List<SelectionDonutSegment>();
        var totalCount = supportedItems.Count;

        foreach (var group in groups)
        {
            var percentage = (double)group.Count / totalCount;
            segments.Add(new SelectionDonutSegment(
                group.Label,
                group.Count,
                ResolveNodeTypeFillColor(group.Nodes),
                $"{group.Label}: {group.Count} nodes ({percentage:P0})"));
        }

        return segments;
    }

    private static string DescribeDonutSlicePath(double centerX, double centerY, double outerRadius, double innerRadius, double startAngleDeg, double sweepAngleDeg)
    {
        if (sweepAngleDeg <= 0d)
        {
            return string.Empty;
        }

        if (sweepAngleDeg >= 359.999d)
        {
            return FormattableString.Invariant(
                $"M {centerX - outerRadius:F3} {centerY:F3} A {outerRadius:F3} {outerRadius:F3} 0 1 0 {centerX + outerRadius:F3} {centerY:F3} A {outerRadius:F3} {outerRadius:F3} 0 1 0 {centerX - outerRadius:F3} {centerY:F3} M {centerX - innerRadius:F3} {centerY:F3} A {innerRadius:F3} {innerRadius:F3} 0 1 1 {centerX + innerRadius:F3} {centerY:F3} A {innerRadius:F3} {innerRadius:F3} 0 1 1 {centerX - innerRadius:F3} {centerY:F3} Z");
        }

        var startRad = DegreesToRadians(startAngleDeg);
        var endRad = DegreesToRadians(startAngleDeg + sweepAngleDeg);

        var outerStartX = centerX + (outerRadius * Math.Cos(startRad));
        var outerStartY = centerY + (outerRadius * Math.Sin(startRad));
        var outerEndX = centerX + (outerRadius * Math.Cos(endRad));
        var outerEndY = centerY + (outerRadius * Math.Sin(endRad));
        var innerStartX = centerX + (innerRadius * Math.Cos(startRad));
        var innerStartY = centerY + (innerRadius * Math.Sin(startRad));
        var innerEndX = centerX + (innerRadius * Math.Cos(endRad));
        var innerEndY = centerY + (innerRadius * Math.Sin(endRad));
        var largeArcFlag = sweepAngleDeg > 180d ? 1 : 0;

        return FormattableString.Invariant(
            $"M {outerStartX:F3} {outerStartY:F3} A {outerRadius:F3} {outerRadius:F3} 0 {largeArcFlag} 1 {outerEndX:F3} {outerEndY:F3} L {innerEndX:F3} {innerEndY:F3} A {innerRadius:F3} {innerRadius:F3} 0 {largeArcFlag} 0 {innerStartX:F3} {innerStartY:F3} Z");
    }

    private static double DegreesToRadians(double degrees)
    {
        return degrees * Math.PI / 180d;
    }

