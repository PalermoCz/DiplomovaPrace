    private async Task HandleNodeDragEndAsync((string NodeKey, double X, double Y) args)
    {
        // Drag positioning only applies inside editor mode.
        if (!_isEditModeOpen) return;

        // Snapshot before change so the move is undoable and marks the graph dirty.
        var snapshot = await SnapshotEditStateAsync();

        var existing = _editorNodeStatesByKey.TryGetValue(args.NodeKey, out var cached) ? cached : null;
        var updated = new FacilityNodeEditorState
        {
            NodeKey = args.NodeKey,
            Label = existing?.Label,
            NodeType = existing?.NodeType,
            Zone = existing?.Zone,
            FloorAreaM2 = existing?.FloorAreaM2,
            StylePresetKey = existing?.StylePresetKey,
            Note = existing?.Note,
            Tags = existing?.Tags ?? [],
            // XHint/YHint > 1.0 are treated as absolute pixel positions by SchematicComposerV2.
            XHint = Math.Round(args.X, 1),
            YHint = Math.Round(args.Y, 1),
        };
        await FacilityEditorStateService.SaveNodeStatesAsync([updated]);

        // Push to undo stack → marks EditModeDirty = true → orange save diskette activates.
        PushEditUndoSnapshot(snapshot, $"Move \"{args.NodeKey}\"");

        await ReloadData(preserveSelection: true);
    }

    private async Task HandleRectSelectEndAsync((double X1, double Y1, double X2, double Y2, bool Additive) args)
    {
        if (!_isEditModeOpen || _schematicLayout is null) return;

        ResetSelectionTraversalMode();

        if (!args.Additive)
            ClearSelectionSetState();

        foreach (var node in _schematicLayout.Nodes)
        {
            if (node.X >= args.X1 && node.X <= args.X2 && node.Y >= args.Y1 && node.Y <= args.Y2)
                AddNodeToSelectionSet(node.NodeKey);
        }

        SyncEditorFocusFromSelectionSet();

        await SyncEditorSelectionToJsAsync();
        if (_selectionSet.Count > 1)
            SwitchEditorTab("layout");
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleGroupDragEndAsync((double DeltaX, double DeltaY) args)
{
    if (!_isEditModeOpen || _selectionSet.Count == 0 || _schematicLayout is null)
        return;

    // Explicitly preserve current selection, because ReloadData(...) still
    // ends up clearing it before SyncEditorSelectionToJsAsync() runs.
    var preservedSelection = _selectionSet.ToArray();

    var snapshot = await SnapshotEditStateAsync();

    var nodesByKey = _schematicLayout.Nodes.ToDictionary(n => n.NodeKey, StringComparer.OrdinalIgnoreCase);
    var updatedStates = new List<FacilityNodeEditorState>();

    foreach (var nodeKey in preservedSelection)
    {
        if (!nodesByKey.TryGetValue(nodeKey, out var layoutNode))
            continue;

        var existing = _editorNodeStatesByKey.TryGetValue(nodeKey, out var c) ? c : null;

        updatedStates.Add(new FacilityNodeEditorState
        {
            NodeKey = nodeKey,
            Label = existing?.Label,
            NodeType = existing?.NodeType,
            Zone = existing?.Zone,
            FloorAreaM2 = existing?.FloorAreaM2,
            StylePresetKey = existing?.StylePresetKey,
            Note = existing?.Note,
            Tags = existing?.Tags ?? [],
            XHint = Math.Round(layoutNode.X + args.DeltaX, 1),
            YHint = Math.Round(layoutNode.Y + args.DeltaY, 1),
        });
    }

    if (updatedStates.Count == 0)
        return;

    await FacilityEditorStateService.SaveNodeStatesAsync(updatedStates);

    PushEditUndoSnapshot(snapshot, $"Move group ({preservedSelection.Length} nodes)");

    await ReloadData(preserveSelection: true);

    // Hard-restore selection after reload.
    ClearSelectionSetState();

    if (_schematicLayout is not null)
    {
        var validKeys = new HashSet<string>(
            _schematicLayout.Nodes.Select(n => n.NodeKey),
            StringComparer.OrdinalIgnoreCase);

        foreach (var key in preservedSelection)
        {
            if (validKeys.Contains(key))
                AddNodeToSelectionSet(key);
        }
    }

    SyncEditorFocusFromSelectionSet();

    if (_selectionSet.Count > 1)
        SwitchEditorTab("layout");

    await SyncEditorSelectionToJsAsync();
    await InvokeAsync(StateHasChanged);
    }

    private async Task HandleNodeCtrlClickedAsync(string nodeKey)
    {
        if (!_isEditModeOpen) return;

        ResetSelectionTraversalMode();

        if (_selectionSet.Contains(nodeKey))
        {
            RemoveNodeFromSelectionSet(nodeKey);
        }
        else
        {
            AddNodeToSelectionSet(nodeKey);
        }

        SyncEditorFocusFromSelectionSet();

        await SyncEditorSelectionToJsAsync();
        if (_selectionSet.Count > 1)
            SwitchEditorTab("layout");
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyboardShortcutAsync(string shortcut)
    {
        if (shortcut == "undo")
        {
            await UndoEditAsync();
        }
        else if (shortcut == "redo")
        {
            await RedoEditAsync();
        }
        else if (shortcut == "escape" && _isEditModeOpen)
        {
            ClearSelectionSetState();
            ApplyFocusNode(null);
            await SyncEditorSelectionToJsAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SyncEditorSelectionToJsAsync()
    {
        await JSRuntime.InvokeVoidAsync("editorCanvas.setSelectedNodes", _selectionSet.ToArray());
    }

    private async Task AlignSelectedNodesAsync(string direction)
    {
        if (!_isEditModeOpen || _selectionSet.Count < 2 || _schematicLayout is null) return;

        var snapshot = await SnapshotEditStateAsync();
        var selectedLayouts = _schematicLayout.Nodes.Where(n => _selectionSet.Contains(n.NodeKey)).ToList();
        if (selectedLayouts.Count < 2) return;

        double alignValue = direction switch
        {
            "center-h" => selectedLayouts.Average(n => n.X),
            "center-v" => selectedLayouts.Average(n => n.Y),
            _ => double.NaN
        };

        if (double.IsNaN(alignValue)) return;
        alignValue = SnapToEditorGrid(alignValue);

        bool alignX = direction == "center-h";

        var updatedStates = selectedLayouts.Select(layoutNode =>
        {
            var existing = _editorNodeStatesByKey.TryGetValue(layoutNode.NodeKey, out var ex) ? ex : null;
            return new FacilityNodeEditorState
            {
                NodeKey = layoutNode.NodeKey,
                Label = existing?.Label, NodeType = existing?.NodeType,
                Zone = existing?.Zone, FloorAreaM2 = existing?.FloorAreaM2, StylePresetKey = existing?.StylePresetKey, Note = existing?.Note, Tags = existing?.Tags ?? [],
                XHint = alignX ? Math.Round(alignValue, 1) : Math.Round(layoutNode.X, 1),
                YHint = alignX ? Math.Round(layoutNode.Y, 1) : Math.Round(alignValue, 1),
            };
        }).ToList();

        await FacilityEditorStateService.SaveNodeStatesAsync(updatedStates);
        PushEditUndoSnapshot(snapshot, $"Align {direction} ({_selectionSet.Count} nodes)");
        await ReloadData(preserveSelection: true);
        await SyncEditorSelectionToJsAsync();
    }

    private async Task DistributeSelectedNodesAsync(string direction)
    {
        if (!_isEditModeOpen || _selectionSet.Count < 3 || _schematicLayout is null) return;

        var snapshot = await SnapshotEditStateAsync();
        var selectedLayouts = _schematicLayout.Nodes.Where(n => _selectionSet.Contains(n.NodeKey)).ToList();
        if (selectedLayouts.Count < 3) return;

        List<FacilityNodeEditorState> updatedStates;

        if (direction == "horizontal")
        {
            var sorted = selectedLayouts.OrderBy(n => n.X).ToList();
            var minX = sorted.First().X;
            var maxX = sorted.Last().X;
            var step = (maxX - minX) / (sorted.Count - 1);
            updatedStates = sorted.Select((n, i) =>
            {
                var existing = _editorNodeStatesByKey.TryGetValue(n.NodeKey, out var ex) ? ex : null;
                return new FacilityNodeEditorState
                {
                    NodeKey = n.NodeKey,
                    Label = existing?.Label, NodeType = existing?.NodeType,
                    Zone = existing?.Zone, FloorAreaM2 = existing?.FloorAreaM2, StylePresetKey = existing?.StylePresetKey, Note = existing?.Note, Tags = existing?.Tags ?? [],
                    XHint = Math.Round(SnapToEditorGrid(minX + step * i), 1),
                    YHint = Math.Round(n.Y, 1)
                };
            }).ToList();
        }
        else // vertical
        {
            var sorted = selectedLayouts.OrderBy(n => n.Y).ToList();
            var minY = sorted.First().Y;
            var maxY = sorted.Last().Y;
            var step = (maxY - minY) / (sorted.Count - 1);
            updatedStates = sorted.Select((n, i) =>
            {
                var existing = _editorNodeStatesByKey.TryGetValue(n.NodeKey, out var ex) ? ex : null;
                return new FacilityNodeEditorState
                {
                    NodeKey = n.NodeKey,
                    Label = existing?.Label, NodeType = existing?.NodeType,
                    Zone = existing?.Zone, FloorAreaM2 = existing?.FloorAreaM2, StylePresetKey = existing?.StylePresetKey, Note = existing?.Note, Tags = existing?.Tags ?? [],
                    XHint = Math.Round(n.X, 1),
                    YHint = Math.Round(SnapToEditorGrid(minY + step * i), 1)
                };
            }).ToList();
        }

        await FacilityEditorStateService.SaveNodeStatesAsync(updatedStates);
        PushEditUndoSnapshot(snapshot, $"Distribute {direction} ({_selectionSet.Count} nodes)");
        await ReloadData(preserveSelection: true);
        await SyncEditorSelectionToJsAsync();
    }

    private void HandleFacilityNodeClicked(string nodeKey)
    {
        if (!_nodesByKey.TryGetValue(nodeKey, out var node))
        {
            ClearWorkspaceSelection();
            return;
        }

        // V edit mode: single-select (Ctrl+click additive goes through HandleNodeCtrlClickedAsync)
        if (_isEditModeOpen)
        {
            ResetSelectionTraversalMode();
            ClearSelectionSetState();
            AddNodeToSelectionSet(nodeKey);
            _editorActiveTab = "edit";
            var editFocusChanged = ApplyFocusNode(nodeKey);
            if (!editFocusChanged)
            {
                InvokeAsync(async () => await ReloadPreviewDataAsync());
            }
            InvokeAsync(SyncEditorSelectionToJsAsync);
            return;
        }

        ResetSelectionTraversalMode();

        string? nextFocusNodeKey;

        if (ShouldUseExpandedTraversalOnClick(node))
        {
            _selectionTraversalMode = FacilitySelectionTraversalMode.ExpandedSubtree;
            ToggleExpandedTraversalSelection(node);
            nextFocusNodeKey = _selectionSet.Count == 0 ? null : node.NodeKey;
        }
        else
        {
            var wasRemoved = ToggleLeafSelection(node.NodeKey);
            if (!wasRemoved)
            {
                nextFocusNodeKey = node.NodeKey;
            }
            else if (string.Equals(SessionService.SelectedElementId, node.NodeKey, StringComparison.OrdinalIgnoreCase))
            {
                nextFocusNodeKey = GetFallbackFocusNodeKey();
            }
            else
            {
                nextFocusNodeKey = SessionService.SelectedElementId;
            }

            if (_selectionSet.Count == 0)
            {
                nextFocusNodeKey = null;
            }
        }

        var focusChanged = ApplyFocusNode(nextFocusNodeKey);
        if (!focusChanged)
        {
            InvokeAsync(async () => await ReloadPreviewDataAsync());
        }
    }

    private bool ShouldUseExpandedTraversalOnClick(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity node)
    {
        return IsStructuralNode(node.NodeKey) || HasTraversableOutgoingExplicitRelationship(node.NodeKey);
    }

    private bool HasTraversableOutgoingExplicitRelationship(string nodeKey)
    {
        if (_facility?.Edges is null)
        {
            return false;
        }

        foreach (var edge in _facility.Edges)
        {
            if (edge is null
                || edge.IsLayoutEdge
                || string.IsNullOrWhiteSpace(edge.SourceNodeKey)
                || string.IsNullOrWhiteSpace(edge.TargetNodeKey)
                || string.IsNullOrWhiteSpace(edge.RelationshipKind)
                || !edge.SourceNodeKey.Equals(nodeKey, StringComparison.OrdinalIgnoreCase)
                || edge.RelationshipKind.Equals(SchematicRelationshipKinds.LayoutPrimary, StringComparison.OrdinalIgnoreCase)
                || !ExpandedSubtreeAllowedRelationshipKinds.Contains(edge.RelationshipKind))
            {
                continue;
            }

            return true;
        }

        return false;
    }

    private IReadOnlyList<string> GetSelectionAggregateNodeKeys()
    {
        var nodeKeys = new List<string>();

        foreach (var nodeKey in _selectionOrder)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            if (IsWeatherNode(nodeKey))
            {
                continue;
            }

            nodeKeys.Add(nodeKey);
        }

        return nodeKeys;
    }

    private void ClearWorkspaceSelection()
    {
        ClearSelectionSetState();

        var focusChanged = ApplyFocusNode(null);
        if (!focusChanged)
        {
            ClearFocusNodeState();
            InvokeAsync(StateHasChanged);
        }
    }

    private bool ApplyFocusNode(string? nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            if (SessionService.SelectedElementType == EditorSelectionType.None && string.IsNullOrWhiteSpace(SessionService.SelectedElementId))
            {
                return false;
            }

            SessionService.ClearSelection();
            return true;
        }

        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && string.Equals(SessionService.SelectedElementId, nodeKey, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        SessionService.SelectElement(nodeKey, EditorSelectionType.FacilityNode);
        return true;
    }

    private bool SyncEditorFocusFromSelectionSet()
    {
        if (_selectionSet.Count == 1)
        {
            if (_editorActiveTab == "layout")
                _editorActiveTab = "edit";
            var focusedKey = _selectionOrder.LastOrDefault(k => _selectionSet.Contains(k));
            return ApplyFocusNode(focusedKey);
        }

        if (_selectionSet.Count > 1)
            _editorActiveTab = "layout";

        var changed = ApplyFocusNode(null);
        if (_selectionSet.Count > 1)
            ClearFocusNodeState();
        return changed;
    }

    private bool ToggleLeafSelection(string nodeKey)
    {
        if (_selectionSet.Contains(nodeKey))
        {
            RemoveNodeFromSelectionSet(nodeKey);
            return true;
        }

        AddNodeToSelectionSet(nodeKey);
        return false;
    }

    private void ToggleExpandedTraversalSelection(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity rootNode)
    {
        var subtreeSelection = ResolveSelectionTraversal(rootNode.NodeKey, FacilitySelectionTraversalMode.ExpandedSubtree);
        var traversedNodeKeys = subtreeSelection.IncludedNodeKeys
            .Where(_nodesByKey.ContainsKey)
            .Select(nodeKey => _nodesByKey[nodeKey])
            .OrderBy(node => node.Label ?? node.NodeKey, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase)
            .Select(node => node.NodeKey)
            .ToList();

        if (traversedNodeKeys.Count == 0)
        {
            return;
        }

        var areAllDescendantsSelected = traversedNodeKeys.All(_selectionSet.Contains);
        foreach (var descendantNodeKey in traversedNodeKeys)
        {
            if (areAllDescendantsSelected)
            {
                RemoveNodeFromSelectionSet(descendantNodeKey);
            }
            else
            {
                AddNodeToSelectionSet(descendantNodeKey);
            }
        }
    }

    private bool IsLeafOrAnalyticNode(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity node)
    {
        return !IsStructuralNode(node.NodeKey) || !string.IsNullOrWhiteSpace(node.MeterUrn);
    }

    private bool IsStructuralNode(string nodeKey)
    {
        return _childrenByParentKey.TryGetValue(nodeKey, out var children) && children.Count > 0;
    }

    private string? GetFallbackFocusNodeKey()
    {
        if (_selectionOrder.Count == 0)
        {
            return null;
        }

        return _selectionOrder[^1];
    }

    private void AddNodeToSelectionSet(string nodeKey)
    {
        if (!_selectionSet.Add(nodeKey))
        {
            _selectionOrder.RemoveAll(item => item.Equals(nodeKey, StringComparison.OrdinalIgnoreCase));
            _selectionOrder.Add(nodeKey);
            return;
        }

        _selectionOrder.Add(nodeKey);
    }

    private void RemoveNodeFromSelectionSet(string nodeKey)
    {
        if (!_selectionSet.Remove(nodeKey))
        {
            return;
        }

        _selectionOrder.RemoveAll(item => item.Equals(nodeKey, StringComparison.OrdinalIgnoreCase));
    }

    private void ClearSelectionSetState()
    {
        _selectionSet.Clear();
        _selectionOrder.Clear();
        ResetSelectionTraversalMode();
    }

    private FacilitySelectionTraversalResult ResolveSelectionTraversal(string rootNodeKey, FacilitySelectionTraversalMode mode)
    {
        return FacilitySelectionTraversal.Resolve(
            rootNodeKey,
            _nodesByKey,
            _childrenByParentKey,
            _facility?.Edges ?? [],
            mode,
            ExpandedSubtreeAllowedRelationshipKinds,
            IsLeafOrAnalyticNode);
    }

    private void ResetSelectionTraversalMode()
    {
        _selectionTraversalMode = FacilitySelectionTraversalMode.StrictLayoutSubtree;
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> GetSelectionSummaryItems()
    {
        var items = new List<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>();

        foreach (var nodeKey in _selectionOrder)
        {
            if (_nodesByKey.TryGetValue(nodeKey, out var node))
            {
                items.Add(node);
            }
        }

        return items;
    }

    private void EnsureFocusNodeInSelectionSetIfLeaf(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity focusedNode)
    {
        if (!IsStructuralNode(focusedNode.NodeKey))
        {
            AddNodeToSelectionSet(focusedNode.NodeKey);
        }
    }

    private void RebuildFacilityNodeIndexes()
    {
        _nodesByKey.Clear();
        _childrenByParentKey.Clear();

        if (_facility is null)
        {
            _availableNodeTypes.Clear();
            _availableZones.Clear();
            _availableTagChips.Clear();
            return;
        }

        foreach (var node in _facility.Nodes)
        {
            _nodesByKey[node.NodeKey] = node;
        }

        foreach (var node in _facility.Nodes)
        {
            if (string.IsNullOrWhiteSpace(node.ParentNodeKey))
            {
                continue;
            }

            if (!_childrenByParentKey.TryGetValue(node.ParentNodeKey, out var children))
            {
                children = [];
                _childrenByParentKey[node.ParentNodeKey] = children;
            }

            children.Add(node);
        }

        _availableNodeTypes = _facility.Nodes
            .Select(n => n.NodeType)
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToList()!;

        _availableZones = _facility.Nodes
            .Select(n => n.Zone)
            .Where(z => !string.IsNullOrWhiteSpace(z))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToList()!;

        var allTags = _editorNodeStatesByKey.Values
            .SelectMany(s => s.Tags)
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _allDistinctTags = allTags;
        _availableTagChips = allTags.Take(20).ToList();
    }

    private static DiplomovaPrace.Persistence.Schematic.FacilityEntity? BuildSchemaFacilityWithoutWeatherNode(
        DiplomovaPrace.Persistence.Schematic.FacilityEntity? facility)
    {
        if (facility is null)
        {
            return null;
        }

        var filteredNodes = facility.Nodes
            .Where(node => !IsWeatherNode(node.NodeKey))
            .ToList();
        var allowedNodeKeys = filteredNodes
            .Select(node => node.NodeKey)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var filteredEdges = facility.Edges
            .Where(edge => allowedNodeKeys.Contains(edge.SourceNodeKey) && allowedNodeKeys.Contains(edge.TargetNodeKey))
            .ToList();

        var weatherFilteredFacility = new DiplomovaPrace.Persistence.Schematic.FacilityEntity
        {
            Id = facility.Id,
            Name = facility.Name,
            Description = facility.Description,
            TimeZone = facility.TimeZone,
            Nodes = filteredNodes,
            Edges = filteredEdges
        };

        return weatherFilteredFacility;
    }

    private IReadOnlySet<string> GetVisualHighlightNodeKeysForCanvas()
    {
        if (_selectionSet.Count == 0)
        {
            return EmptyNodeKeySet;
        }

        if (_selectionTraversalMode == FacilitySelectionTraversalMode.ExpandedSubtree)
        {
            return new HashSet<string>(_selectionSet, StringComparer.OrdinalIgnoreCase);
        }

        // In multi-select mode, highlight only the actual selected set.
        // This keeps single and multi modes mutually exclusive and prevents
        // unrelated structural ancestors from appearing as selected.
        if (IsEditorMultiSelectActive)
        {
            return new HashSet<string>(_selectionSet, StringComparer.OrdinalIgnoreCase);
        }

        if (_isEditModeOpen && _selectionSet.Count == 1)
        {
            return new HashSet<string>(_selectionSet, StringComparer.OrdinalIgnoreCase);
        }

        var result = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Step 1: If the focused node is structural, build its subtree highlight path (existing behavior).
        if (_selectedFacilityNode is not null && IsStructuralNode(_selectedFacilityNode.NodeKey))
        {
            var focusedNodeKey = _selectedFacilityNode.NodeKey;
            var reachableFromFocus = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { focusedNodeKey };

            var stack = new Stack<string>();
            stack.Push(focusedNodeKey);
            while (stack.Count > 0)
            {
                var curr = stack.Pop();
                if (_childrenByParentKey.TryGetValue(curr, out var ch))
                    foreach (var child in ch)
                        if (reachableFromFocus.Add(child.NodeKey))
                            stack.Push(child.NodeKey);
            }

            result.Add(focusedNodeKey);
            foreach (var selKey in _selectionSet.Where(reachableFromFocus.Contains))
            {
                var cursor = selKey;
                while (!string.IsNullOrWhiteSpace(cursor) && reachableFromFocus.Contains(cursor))
                {
                    if (!result.Add(cursor)) break;
                    if (!string.Equals(cursor, focusedNodeKey, StringComparison.OrdinalIgnoreCase)
                        && _nodesByKey.TryGetValue(cursor, out var n)
                        && !string.IsNullOrWhiteSpace(n.ParentNodeKey))
                    {
                        cursor = n.ParentNodeKey;
                        continue;
                    }
                    break;
                }
            }
        }

        // Step 2: For selected nodes outside the focused subtree, walk up to their nearest
        // structural ancestor and include it.
        foreach (var key in _selectionSet)
        {
            if (result.Contains(key)) continue; // Already covered by focused subtree path

            if (!_nodesByKey.TryGetValue(key, out var node)) continue;

            var parentKey = node.ParentNodeKey;
            while (!string.IsNullOrWhiteSpace(parentKey))
            {
                if (!_nodesByKey.TryGetValue(parentKey, out var ancestor)) break;

                result.Add(parentKey);

                // Stop at the first structural node (zone/area parent) to avoid
                // flooding the entire tree with subtree highlight colour.
                if (IsStructuralNode(parentKey)) break;

                parentKey = ancestor.ParentNodeKey;
            }
        }

        return result;
    }

    private IReadOnlySet<string> GetContextOnlyHighlightNodeKeysForCanvas()
    {
        if (_selectionSet.Count == 0)
        {
            return EmptyNodeKeySet;
        }

        var contextOnlyNodeKeys = new HashSet<string>(VisualHighlightNodeKeysForCanvas, StringComparer.OrdinalIgnoreCase);
        contextOnlyNodeKeys.ExceptWith(_selectionSet);
        return contextOnlyNodeKeys;
    }

    private RelationshipInspectorViewModel? BuildSelectedRelationshipInspector()
    {
        if (_selectedFacilityNode is null || _nodesByKey.Count == 0)
        {
            return null;
        }

        RelationshipInspectorNodeSummary? primaryLayoutParent = null;
        if (!string.IsNullOrWhiteSpace(_selectedFacilityNode.ParentNodeKey)
            && _nodesByKey.TryGetValue(_selectedFacilityNode.ParentNodeKey, out var parentNode))
        {
            primaryLayoutParent = ToRelationshipInspectorNodeSummary(parentNode);
        }

        var layoutChildren = _childrenByParentKey.TryGetValue(_selectedFacilityNode.NodeKey, out var children)
            ? children
                .OrderBy(child => child.Label ?? child.NodeKey, StringComparer.CurrentCultureIgnoreCase)
                .ThenBy(child => child.NodeKey, StringComparer.OrdinalIgnoreCase)
                .Select(ToRelationshipInspectorNodeSummary)
                .ToList()
            : [];

        var explicitEdges = (_facility?.Edges ?? [])
            .Where(edge => edge is not null
                && !edge.IsLayoutEdge
                && !edge.RelationshipKind.Equals(DiplomovaPrace.Persistence.Schematic.SchematicRelationshipKinds.LayoutPrimary, StringComparison.OrdinalIgnoreCase))
            .ToList();

        var incomingRelationships = explicitEdges
            .Where(edge => edge.TargetNodeKey.Equals(_selectedFacilityNode.NodeKey, StringComparison.OrdinalIgnoreCase))
            .OrderBy(edge => ResolveRelationshipCounterpartyLabel(edge.SourceNodeKey), StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(edge => edge.SourceNodeKey, StringComparer.OrdinalIgnoreCase)
            .Select(edge => ToRelationshipInspectorEdgeSummary(edge.SourceNodeKey, edge.TargetNodeKey, edge.SourceNodeKey, edge.RelationshipKind, edge.Note))
            .ToList();

        var outgoingRelationships = explicitEdges
            .Where(edge => edge.SourceNodeKey.Equals(_selectedFacilityNode.NodeKey, StringComparison.OrdinalIgnoreCase))
            .OrderBy(edge => ResolveRelationshipCounterpartyLabel(edge.TargetNodeKey), StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(edge => edge.TargetNodeKey, StringComparer.OrdinalIgnoreCase)
            .Select(edge => ToRelationshipInspectorEdgeSummary(edge.SourceNodeKey, edge.TargetNodeKey, edge.TargetNodeKey, edge.RelationshipKind, edge.Note))
            .ToList();

        var contextOnlyHighlightedNodes = ContextOnlyHighlightNodeKeysForCanvas
            .Where(_nodesByKey.ContainsKey)
            .Select(nodeKey => _nodesByKey[nodeKey])
            .OrderBy(node => node.Label ?? node.NodeKey, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase)
            .Select(ToRelationshipInspectorNodeSummary)
            .ToList();

        return new RelationshipInspectorViewModel(
            primaryLayoutParent,
            layoutChildren,
            incomingRelationships,
            outgoingRelationships,
            contextOnlyHighlightedNodes,
            SelectionCount,
            VisualHighlightCount);
    }

    private RelationshipInspectorNodeSummary ToRelationshipInspectorNodeSummary(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity node)
    {
        return new RelationshipInspectorNodeSummary(node.NodeKey, node.Label, node.NodeType);
    }

    private RelationshipInspectorEdgeSummary ToRelationshipInspectorEdgeSummary(
        string sourceNodeKey,
        string targetNodeKey,
        string counterpartyNodeKey,
        string relationshipKind,
        string? note)
    {
        var counterpartyLabel = ResolveRelationshipCounterpartyLabel(counterpartyNodeKey);
        var counterpartyNodeType = _nodesByKey.TryGetValue(counterpartyNodeKey, out var counterpartyNode)
            ? counterpartyNode.NodeType
            : null;

        return new RelationshipInspectorEdgeSummary(
            sourceNodeKey,
            targetNodeKey,
            counterpartyNodeKey,
            counterpartyLabel,
            counterpartyNodeType,
            relationshipKind,
            note);
    }

    private string ResolveRelationshipCounterpartyLabel(string nodeKey)
    {
        return _nodesByKey.TryGetValue(nodeKey, out var node)
            ? node.Label
            : nodeKey;
    }

