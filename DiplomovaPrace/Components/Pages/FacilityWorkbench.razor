    private async Task HandleNodeDragEndAsync((string NodeKey, double X, double Y) args)
    {
        // Drag positioning only applies inside editor mode.
        if (!_isEditModeOpen) return;

        // Snapshot before change so the move is undoable and marks the graph dirty.
        var snapshot = await SnapshotEditStateAsync();

        var existing = _editorNodeStatesByKey.TryGetValue(args.NodeKey, out var cached) ? cached : null;
        var updated = new FacilityNodeEditorState
        {
            NodeKey = args.NodeKey,
            Label = existing?.Label,
            NodeType = existing?.NodeType,
            Zone = existing?.Zone,
            FloorAreaM2 = existing?.FloorAreaM2,
            StylePresetKey = existing?.StylePresetKey,
            Note = existing?.Note,
            Tags = existing?.Tags ?? [],
            // XHint/YHint > 1.0 are treated as absolute pixel positions by SchematicComposerV2.
            XHint = Math.Round(args.X, 1),
            YHint = Math.Round(args.Y, 1),
        };
        await FacilityEditorStateService.SaveNodeStatesAsync([updated]);

        // Push to undo stack � marks EditModeDirty = true � orange save diskette activates.
        PushEditUndoSnapshot(snapshot, $"Move \"{args.NodeKey}\"");

        await ReloadData(preserveSelection: true);
    }

    private async Task HandleRectSelectEndAsync((double X1, double Y1, double X2, double Y2, bool Additive) args)
    {
        if (!_isEditModeOpen || _schematicLayout is null) return;

        ResetSelectionTraversalMode();

        if (!args.Additive)
            ClearSelectionSetState();

        foreach (var node in _schematicLayout.Nodes)
        {
            if (node.X >= args.X1 && node.X <= args.X2 && node.Y >= args.Y1 && node.Y <= args.Y2)
                AddNodeToSelectionSet(node.NodeKey);
        }

        SyncEditorFocusFromSelectionSet();

        await SyncEditorSelectionToJsAsync();
        if (_selectionSet.Count > 1)
            SwitchEditorTab("layout");
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleGroupDragEndAsync((double DeltaX, double DeltaY) args)
{
    if (!_isEditModeOpen || _selectionSet.Count == 0 || _schematicLayout is null)
        return;

    // Explicitly preserve current selection, because ReloadData(...) still
    // ends up clearing it before SyncEditorSelectionToJsAsync() runs.
    var preservedSelection = _selectionSet.ToArray();

    var snapshot = await SnapshotEditStateAsync();

    var nodesByKey = _schematicLayout.Nodes.ToDictionary(n => n.NodeKey, StringComparer.OrdinalIgnoreCase);
    var updatedStates = new List<FacilityNodeEditorState>();

    foreach (var nodeKey in preservedSelection)
    {
        if (!nodesByKey.TryGetValue(nodeKey, out var layoutNode))
            continue;

        var existing = _editorNodeStatesByKey.TryGetValue(nodeKey, out var c) ? c : null;

        updatedStates.Add(new FacilityNodeEditorState
        {
            NodeKey = nodeKey,
            Label = existing?.Label,
            NodeType = existing?.NodeType,
            Zone = existing?.Zone,
            FloorAreaM2 = existing?.FloorAreaM2,
            StylePresetKey = existing?.StylePresetKey,
            Note = existing?.Note,
            Tags = existing?.Tags ?? [],
            XHint = Math.Round(layoutNode.X + args.DeltaX, 1),
            YHint = Math.Round(layoutNode.Y + args.DeltaY, 1),
        });
    }

    if (updatedStates.Count == 0)
        return;

    await FacilityEditorStateService.SaveNodeStatesAsync(updatedStates);

    PushEditUndoSnapshot(snapshot, $"Move group ({preservedSelection.Length} nodes)");

    await ReloadData(preserveSelection: true);

    // Hard-restore selection after reload.
    ClearSelectionSetState();

    if (_schematicLayout is not null)
    {
        var validKeys = new HashSet<string>(
            _schematicLayout.Nodes.Select(n => n.NodeKey),
            StringComparer.OrdinalIgnoreCase);

        foreach (var key in preservedSelection)
        {
            if (validKeys.Contains(key))
                AddNodeToSelectionSet(key);
        }
    }

    SyncEditorFocusFromSelectionSet();

    if (_selectionSet.Count > 1)
        SwitchEditorTab("layout");

    await SyncEditorSelectionToJsAsync();
    await InvokeAsync(StateHasChanged);
    }

    private async Task HandleNodeCtrlClickedAsync(string nodeKey)
    {
        if (!_isEditModeOpen) return;

        ResetSelectionTraversalMode();

        if (_selectionSet.Contains(nodeKey))
        {
            RemoveNodeFromSelectionSet(nodeKey);
        }
        else
        {
            AddNodeToSelectionSet(nodeKey);
        }

        SyncEditorFocusFromSelectionSet();

        await SyncEditorSelectionToJsAsync();
        if (_selectionSet.Count > 1)
            SwitchEditorTab("layout");
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyboardShortcutAsync(string shortcut)
    {
        if (shortcut == "undo")
        {
            await UndoEditAsync();
        }
        else if (shortcut == "redo")
        {
            await RedoEditAsync();
        }
        else if (shortcut == "escape" && _isEditModeOpen)
        {
            ClearSelectionSetState();
            ApplyFocusNode(null);
            await SyncEditorSelectionToJsAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SyncEditorSelectionToJsAsync()
    {
        await JSRuntime.InvokeVoidAsync("editorCanvas.setSelectedNodes", _selectionSet.ToArray());
    }

    private async Task AlignSelectedNodesAsync(string direction)
    {
        if (!_isEditModeOpen || _selectionSet.Count < 2 || _schematicLayout is null) return;

        var snapshot = await SnapshotEditStateAsync();
        var selectedLayouts = _schematicLayout.Nodes.Where(n => _selectionSet.Contains(n.NodeKey)).ToList();
        if (selectedLayouts.Count < 2) return;

        double alignValue = direction switch
        {
            "center-h" => selectedLayouts.Average(n => n.X),
            "center-v" => selectedLayouts.Average(n => n.Y),
            _ => double.NaN
        };

        if (double.IsNaN(alignValue)) return;
        alignValue = SnapToEditorGrid(alignValue);

        bool alignX = direction == "center-h";

        var updatedStates = selectedLayouts.Select(layoutNode =>
        {
            var existing = _editorNodeStatesByKey.TryGetValue(layoutNode.NodeKey, out var ex) ? ex : null;
            return new FacilityNodeEditorState
            {
                NodeKey = layoutNode.NodeKey,
                Label = existing?.Label, NodeType = existing?.NodeType,
                Zone = existing?.Zone, FloorAreaM2 = existing?.FloorAreaM2, StylePresetKey = existing?.StylePresetKey, Note = existing?.Note, Tags = existing?.Tags ?? [],
                XHint = alignX ? Math.Round(alignValue, 1) : Math.Round(layoutNode.X, 1),
                YHint = alignX ? Math.Round(layoutNode.Y, 1) : Math.Round(alignValue, 1),
            };
        }).ToList();

        await FacilityEditorStateService.SaveNodeStatesAsync(updatedStates);
        PushEditUndoSnapshot(snapshot, $"Align {direction} ({_selectionSet.Count} nodes)");
        await ReloadData(preserveSelection: true);
        await SyncEditorSelectionToJsAsync();
    }

    private async Task DistributeSelectedNodesAsync(string direction)
    {
        if (!_isEditModeOpen || _selectionSet.Count < 3 || _schematicLayout is null) return;

        var snapshot = await SnapshotEditStateAsync();
        var selectedLayouts = _schematicLayout.Nodes.Where(n => _selectionSet.Contains(n.NodeKey)).ToList();
        if (selectedLayouts.Count < 3) return;

        List<FacilityNodeEditorState> updatedStates;

        if (direction == "horizontal")
        {
            var sorted = selectedLayouts.OrderBy(n => n.X).ToList();
            var minX = sorted.First().X;
            var maxX = sorted.Last().X;
            var step = (maxX - minX) / (sorted.Count - 1);
            updatedStates = sorted.Select((n, i) =>
            {
                var existing = _editorNodeStatesByKey.TryGetValue(n.NodeKey, out var ex) ? ex : null;
                return new FacilityNodeEditorState
                {
                    NodeKey = n.NodeKey,
                    Label = existing?.Label, NodeType = existing?.NodeType,
                    Zone = existing?.Zone, FloorAreaM2 = existing?.FloorAreaM2, StylePresetKey = existing?.StylePresetKey, Note = existing?.Note, Tags = existing?.Tags ?? [],
                    XHint = Math.Round(SnapToEditorGrid(minX + step * i), 1),
                    YHint = Math.Round(n.Y, 1)
                };
            }).ToList();
        }
        else // vertical
        {
            var sorted = selectedLayouts.OrderBy(n => n.Y).ToList();
            var minY = sorted.First().Y;
            var maxY = sorted.Last().Y;
            var step = (maxY - minY) / (sorted.Count - 1);
            updatedStates = sorted.Select((n, i) =>
            {
                var existing = _editorNodeStatesByKey.TryGetValue(n.NodeKey, out var ex) ? ex : null;
                return new FacilityNodeEditorState
                {
                    NodeKey = n.NodeKey,
                    Label = existing?.Label, NodeType = existing?.NodeType,
                    Zone = existing?.Zone, FloorAreaM2 = existing?.FloorAreaM2, StylePresetKey = existing?.StylePresetKey, Note = existing?.Note, Tags = existing?.Tags ?? [],
                    XHint = Math.Round(n.X, 1),
                    YHint = Math.Round(SnapToEditorGrid(minY + step * i), 1)
                };
            }).ToList();
        }

        await FacilityEditorStateService.SaveNodeStatesAsync(updatedStates);
        PushEditUndoSnapshot(snapshot, $"Distribute {direction} ({_selectionSet.Count} nodes)");
        await ReloadData(preserveSelection: true);
        await SyncEditorSelectionToJsAsync();
    }

    private void HandleFacilityNodeClicked(string nodeKey)
    {
        if (!_nodesByKey.TryGetValue(nodeKey, out var node))
        {
            ClearWorkspaceSelection();
            return;
        }

        // V edit mode: single-select (Ctrl+click additive goes through HandleNodeCtrlClickedAsync)
        if (_isEditModeOpen)
        {
            ResetSelectionTraversalMode();
            ClearSelectionSetState();
            AddNodeToSelectionSet(nodeKey);
            _editorActiveTab = "edit";
            var editFocusChanged = ApplyFocusNode(nodeKey);
            if (!editFocusChanged)
            {
                InvokeAsync(async () => await ReloadPreviewDataAsync());
            }
            InvokeAsync(SyncEditorSelectionToJsAsync);
            return;
        }

        ResetSelectionTraversalMode();

        string? nextFocusNodeKey;

        if (ShouldUseExpandedTraversalOnClick(node))
        {
            _selectionTraversalMode = FacilitySelectionTraversalMode.ExpandedSubtree;
            ToggleExpandedTraversalSelection(node);
            nextFocusNodeKey = _selectionSet.Count == 0 ? null : node.NodeKey;
        }
        else
        {
            var wasRemoved = ToggleLeafSelection(node.NodeKey);
            if (!wasRemoved)
            {
                nextFocusNodeKey = node.NodeKey;
            }
            else if (string.Equals(SessionService.SelectedElementId, node.NodeKey, StringComparison.OrdinalIgnoreCase))
            {
                nextFocusNodeKey = GetFallbackFocusNodeKey();
            }
            else
            {
                nextFocusNodeKey = SessionService.SelectedElementId;
            }

            if (_selectionSet.Count == 0)
            {
                nextFocusNodeKey = null;
            }
        }

        var focusChanged = ApplyFocusNode(nextFocusNodeKey);
        if (!focusChanged)
        {
            InvokeAsync(async () => await ReloadPreviewDataAsync());
        }
    }

    private bool ShouldUseExpandedTraversalOnClick(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity node)
    {
        return IsStructuralNode(node.NodeKey) || HasTraversableOutgoingExplicitRelationship(node.NodeKey);
    }

    private bool HasTraversableOutgoingExplicitRelationship(string nodeKey)
    {
        if (_facility?.Edges is null)
        {
            return false;
        }

        foreach (var edge in _facility.Edges)
        {
            if (edge is null
                || edge.IsLayoutEdge
                || string.IsNullOrWhiteSpace(edge.SourceNodeKey)
                || string.IsNullOrWhiteSpace(edge.TargetNodeKey)
                || string.IsNullOrWhiteSpace(edge.RelationshipKind)
                || !edge.SourceNodeKey.Equals(nodeKey, StringComparison.OrdinalIgnoreCase)
                || edge.RelationshipKind.Equals(SchematicRelationshipKinds.LayoutPrimary, StringComparison.OrdinalIgnoreCase)
                || !ExpandedSubtreeAllowedRelationshipKinds.Contains(edge.RelationshipKind))
            {
                continue;
            }

            return true;
        }

        return false;
    }

    private IReadOnlyList<string> GetSelectionAggregateNodeKeys()
    {
        return _selectionOrder
            .Where(_selectionSet.Contains)
            .Where(nodeKey => !string.IsNullOrWhiteSpace(nodeKey))
            .Where(nodeKey => !IsWeatherNode(nodeKey))
            .Where(NodeHasAnyAnalysisData)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void ClearWorkspaceSelection()
    {
        ClearSelectionSetState();

        var focusChanged = ApplyFocusNode(null);
        if (!focusChanged)
        {
            ClearFocusNodeState();
            InvokeAsync(StateHasChanged);
        }
    }

    private bool ApplyFocusNode(string? nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            if (SessionService.SelectedElementType == EditorSelectionType.None && string.IsNullOrWhiteSpace(SessionService.SelectedElementId))
            {
                return false;
            }

            SessionService.ClearSelection();
            return true;
        }

        if (SessionService.SelectedElementType == EditorSelectionType.FacilityNode && string.Equals(SessionService.SelectedElementId, nodeKey, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        SessionService.SelectElement(nodeKey, EditorSelectionType.FacilityNode);
        return true;
    }

    private bool SyncEditorFocusFromSelectionSet()
    {
        if (_selectionSet.Count == 1)
        {
            if (_editorActiveTab == "layout")
                _editorActiveTab = "edit";
            var focusedKey = _selectionOrder.LastOrDefault(k => _selectionSet.Contains(k));
            return ApplyFocusNode(focusedKey);
        }

        if (_selectionSet.Count > 1)
            _editorActiveTab = "layout";

        var changed = ApplyFocusNode(null);
        if (_selectionSet.Count > 1)
            ClearFocusNodeState();
        return changed;
    }

    private bool ToggleLeafSelection(string nodeKey)
    {
        if (_selectionSet.Contains(nodeKey))
        {
            RemoveNodeFromSelectionSet(nodeKey);
            return true;
        }

        AddNodeToSelectionSet(nodeKey);
        return false;
    }

    private void ToggleExpandedTraversalSelection(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity rootNode)
    {
        var subtreeSelection = ResolveSelectionTraversal(rootNode.NodeKey, FacilitySelectionTraversalMode.ExpandedSubtree);
        var traversedNodeKeys = subtreeSelection.IncludedNodeKeys
            .Where(_nodesByKey.ContainsKey)
            .Select(nodeKey => _nodesByKey[nodeKey])
            .OrderBy(node => node.Label ?? node.NodeKey, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase)
            .Select(node => node.NodeKey)
            .ToList();

        if (traversedNodeKeys.Count == 0)
        {
            return;
        }

        var areAllDescendantsSelected = traversedNodeKeys.All(_selectionSet.Contains);
        foreach (var descendantNodeKey in traversedNodeKeys)
        {
            if (areAllDescendantsSelected)
            {
                RemoveNodeFromSelectionSet(descendantNodeKey);
            }
            else
            {
                AddNodeToSelectionSet(descendantNodeKey);
            }
        }
    }

    private bool IsLeafOrAnalyticNode(DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity node)
    {
        return !IsStructuralNode(node.NodeKey) || !string.IsNullOrWhiteSpace(node.MeterUrn);
    }

    private bool IsStructuralNode(string nodeKey)
    {
        return _childrenByParentKey.TryGetValue(nodeKey, out var children) && children.Count > 0;
    }

    private string? GetFallbackFocusNodeKey()
    {
