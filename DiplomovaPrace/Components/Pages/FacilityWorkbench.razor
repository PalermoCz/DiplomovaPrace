            ClearSelectionSetState();
            ClearFocusNodeState();
            _compareSetStatusMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool IsCompareSupportedNode(string? nodeKey)
    {
        if (string.IsNullOrWhiteSpace(nodeKey))
        {
            return false;
        }

        return CompareSetSupportedNodeKeys.Contains(nodeKey);
    }

    private List<string> GetEffectiveCompareNodeKeysForSelectedNode()
    {
        if (_selectedFacilityNode is null)
        {
            return [];
        }

        var primaryNodeKey = _selectedFacilityNode.NodeKey;
        var seenNodeKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            primaryNodeKey
        };
        var keys = new List<string>();

        foreach (var item in _compareSet)
        {
            if (!IsCompareSupportedNode(item.NodeKey))
            {
                continue;
            }

            if (!seenNodeKeys.Add(item.NodeKey))
            {
                continue;
            }

            keys.Add(item.NodeKey);
        }

        return keys;
    }

    private async Task RefreshComparePreviewAfterCompareSetChangedAsync()
    {
        if (_selectedFacilityNode is not null && _isCuratedNode)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> GetSelectionCompareCandidates()
    {
        var candidates = new List<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity>();

        foreach (var nodeKey in _selectionOrder)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            if (!_nodesByKey.TryGetValue(nodeKey, out var node))
            {
                continue;
            }

            if (!IsCompareSupportedNode(node.NodeKey))
            {
                continue;
            }

            candidates.Add(node);
        }

        return candidates;
    }

    private async Task AddSelectionSetToCompareSet()
    {
        if (_selectionSet.Count == 0)
        {
            _compareSetStatusMessage = "Selection set je prázdný. Nejprve vyberte uzly ve schématu.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var candidates = GetSelectionCompareCandidates();
        if (candidates.Count == 0)
        {
            _compareSetStatusMessage = "V aktuálním selection setu nejsou uzly podporované pro compare set.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var added = 0;
        var duplicates = 0;
        var skippedByCapacity = 0;

        foreach (var node in candidates)
        {
            if (_compareSet.Any(x => x.NodeKey.Equals(node.NodeKey, StringComparison.OrdinalIgnoreCase)))
            {
                duplicates++;
                continue;
            }

            if (_compareSet.Count >= MaxCompareSetSize)
            {
                skippedByCapacity++;
                continue;
            }

            _compareSet.Add(new CompareSetItem
            {
                NodeKey = node.NodeKey,
                Label = node.Label,
                NodeType = node.NodeType
            });

            added++;
        }

        if (added > 0)
        {
            var statusParts = new List<string> { $"Přidáno {added} uzlů z selection setu." };
            if (duplicates > 0)
            {
                statusParts.Add($"{duplicates} už bylo v compare setu");
            }

            if (skippedByCapacity > 0)
            {
                statusParts.Add($"{skippedByCapacity} se nevešlo kvůli limitu");
            }

            _compareSetStatusMessage = string.Join(" ", statusParts);
        }
        else if (duplicates > 0)
        {
            _compareSetStatusMessage = "Všechny podporované uzly ze selection setu už v compare setu jsou.";
        }
        else
        {
            _compareSetStatusMessage = "Compare set je plný. Pro přidání dalších uzlů nejprve některé odeberte.";
        }

        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private async Task RemoveNodeFromCompareSet(string nodeKey)
    {
        var removedCount = _compareSet.RemoveAll(x => x.NodeKey.Equals(nodeKey, StringComparison.OrdinalIgnoreCase));
        _compareSetStatusMessage = removedCount > 0
            ? "Uzel byl odebrán z compare setu."
            : "Uzel v compare setu nebyl nalezen.";

        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private async Task ClearCompareSet()
    {
        if (_compareSet.Count == 0)
        {
            _compareSetStatusMessage = "Compare set je už prázdný.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _compareSet.Clear();
        _compareSetStatusMessage = "Compare set byl vyčištěn.";
        await RefreshComparePreviewAfterCompareSetChangedAsync();
    }

    private void ToggleSchematicEditorMode()
    {
        _isSchematicEditorEnabled = !_isSchematicEditorEnabled;
        _isReconnectMode = false;
        _editorStatusMessage = _isSchematicEditorEnabled
            ? "Schema editor je zapnutý. Drag uzlů a metadata změny se budou ukládat."
            : "Schema editor je vypnutý.";
        _structureStatusMessage = _isSchematicEditorEnabled
            ? "Structure editing je připravené: reconnect, add node, remove leaf."
            : null;
    }

    private void ToggleReconnectMode()
    {
        if (!_isSchematicEditorEnabled || !CanEditFocusedNode || _selectedFacilityNode is null)
        {
            _structureStatusMessage = "Reconnect režim je dostupný jen při aktivním editor mode a focus uzlu.";
            return;
        }

        _isReconnectMode = !_isReconnectMode;
        _reconnectParentNodeKeyInput = _selectedFacilityNode.ParentNodeKey ?? string.Empty;
        _structureStatusMessage = _isReconnectMode
            ? "Reconnect režim zapnutý. Vyberte nový parent a potvrďte reconnect."
            : "Reconnect režim vypnutý.";
    }

    private async Task ToggleReconnectModeAndScrollAsync()
    {
        ToggleReconnectMode();
        if (_isReconnectMode)
        {
            StateHasChanged();
            await Task.Delay(60);
            await JSRuntime.InvokeVoidAsync("eval",
                "document.getElementById('editor-reconnect-section')?.scrollIntoView({behavior:'smooth', block:'start'})");
        }
    }

    private async Task ReconnectFocusedNodeAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _structureStatusMessage = "Nejprve zapněte editor mode.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _structureStatusMessage = "Pro reconnect vyberte editovatelný focus uzel.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var parentMap = BuildCurrentParentMap();
        var nodeKey = _selectedFacilityNode.NodeKey;
        var nodeLabel = _selectedFacilityNode.Label ?? nodeKey;

        // Snapshot před operací pro undo
        var snapshot = await SnapshotEditStateAsync();

        var reconnectResult = await FacilityEditorStateService.TryReconnectNodeAsync(
            nodeKey,
            NormalizeOptionalText(_reconnectParentNodeKeyInput),
            parentMap);

        _structureStatusMessage = reconnectResult.Message;
        if (!reconnectResult.Success)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        PushEditUndoSnapshot(snapshot, $"Reconnect \"{nodeLabel}\"");

        await ReloadData(preserveSelection: true, preferredFocusNodeKey: nodeKey);
        _isReconnectMode = false;
        _reconnectChildrenWarningConfirmed = false;
        await ReloadPreviewDataAsync();
    }

    private async Task AddNodeAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _structureStatusMessage = "Nejprve zapněte editor mode.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var nodeKey = NormalizeOptionalText(_newNodeKeyInput);
        var label = NormalizeOptionalText(_newNodeLabelInput);

        if (string.IsNullOrWhiteSpace(nodeKey) || string.IsNullOrWhiteSpace(label))
        {
            _structureStatusMessage = "Pro add node vyplňte NodeKey i Label.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (FacilityNodeSemantics.IsWeatherContextNode(nodeKey))
        {
            _structureStatusMessage = "weather_main je context-only uzel a nelze ho přidat přes schema editor.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Auto-set parent z vybraného uzlu pokud ještě není nastavený
        var parentKey = NormalizeOptionalText(_newNodeParentNodeKeyInput);
        if (string.IsNullOrWhiteSpace(parentKey) && _selectedFacilityNode is not null)
            parentKey = _selectedFacilityNode.NodeKey;
        var nodeType = NormalizeOptionalText(_newNodeTypeInput) ?? "subzone";
        var zone = NormalizeOptionalText(_newNodeZoneInput);
        var meterUrn = NormalizeOptionalText(_newNodeMeterUrnInput);
        var (xHint, yHint) = ResolveNewNodeLayoutHint(parentKey);

        // Snapshot před operací pro undo
        var snapshot = await SnapshotEditStateAsync();

        var addResult = await FacilityEditorStateService.TryAddNodeAsync(
            new FacilityStructureNode
            {
                NodeKey = nodeKey,
                Label = label,
                NodeType = nodeType,
                Zone = zone,
                MeterUrn = meterUrn,
                ParentNodeKey = parentKey,
                XHint = xHint,
                YHint = yHint,
                UpdatedUtc = DateTime.UtcNow
            },
            BuildCurrentParentMap());

        _structureStatusMessage = addResult.Message;
        if (!addResult.Success)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        PushEditUndoSnapshot(snapshot, $"Přidat uzel \"{label}\"");

        // Nový node dostane baseline tagy podle metadata/type, aby semantic query fungovala ihned.
        var baselineTags = FacilityNodeSemantics.DeriveTags(nodeKey, nodeType, label, zone, meterUrn);
        var initialNodeState = new FacilityNodeEditorState
        {
            NodeKey = nodeKey,
            Label = label,
            Tags = baselineTags,
            Note = null,
            XHint = xHint,
            YHint = yHint,
            UpdatedUtc = DateTime.UtcNow
        };
        await FacilityEditorStateService.SaveNodeStatesAsync([initialNodeState]);

        _newNodeKeyInput = string.Empty;
        _newNodeLabelInput = string.Empty;
        _newNodeMeterUrnInput = string.Empty;
        _newNodeTypeInput = string.Empty;
        _newNodeZoneInput = string.Empty;

        await ReloadData(preserveSelection: true, preferredFocusNodeKey: nodeKey);
        _editorStatusMessage = $"Uzel {nodeKey} přidán — upravte metadata níže.";
        await ReloadPreviewDataAsync();
        // Scroll na metadata nového uzlu
        await Task.Delay(80);
        await JSRuntime.InvokeVoidAsync("eval",
            "document.getElementById('editor-metadata-section')?.scrollIntoView({behavior:'smooth', block:'start'})");
    }

    private async Task RemoveFocusedLeafNodeAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _structureStatusMessage = "Nejprve zapněte editor mode.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null)
        {
            _structureStatusMessage = "Pro remove node vyberte focus uzel.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var removedNodeKey = _selectedFacilityNode.NodeKey;
        var removedLabel = _selectedFacilityNode.Label ?? removedNodeKey;

        // Snapshot před operací pro undo
        var snapshot = await SnapshotEditStateAsync();

        var removeResult = await FacilityEditorStateService.TryRemoveLeafNodeAsync(
            removedNodeKey,
            BuildCurrentParentMap());

        _structureStatusMessage = removeResult.Message;
        if (!removeResult.Success)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        PushEditUndoSnapshot(snapshot, $"Smazat uzel \"{removedLabel}\"");

        await ReloadData(preserveSelection: true);
        await ReloadPreviewDataAsync();
    }

    private IReadOnlyList<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> GetReconnectParentCandidates(string? excludedNodeKey)
    {
        return _nodesByKey.Values
            .Where(node => !FacilityNodeSemantics.IsWeatherContextNode(node.NodeKey))
            .Where(node => string.IsNullOrWhiteSpace(excludedNodeKey)
                || !node.NodeKey.Equals(excludedNodeKey, StringComparison.OrdinalIgnoreCase))
            .OrderBy(node => node.Label ?? node.NodeKey, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(node => node.NodeKey, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private (double XHint, double YHint) ResolveNewNodeLayoutHint(string? parentNodeKey)
    {
        if (!string.IsNullOrWhiteSpace(parentNodeKey) && _nodesByKey.TryGetValue(parentNodeKey, out var parentNode))
        {
            var parentX = parentNode.XHint ?? 0.5;
            var parentY = parentNode.YHint ?? 0.5;
            return (Math.Clamp(parentX + 0.06, 0.05, 0.95), Math.Clamp(parentY + 0.04, 0.05, 0.95));
        }

        return (0.5, 0.5);
    }

    private Dictionary<string, string?> BuildCurrentParentMap()
    {
        return _nodesByKey.Values
            .ToDictionary(node => node.NodeKey, node => NormalizeOptionalText(node.ParentNodeKey), StringComparer.OrdinalIgnoreCase);
    }

    private bool HasChildren(string nodeKey)
    {
        return _childrenByParentKey.TryGetValue(nodeKey, out var children) && children.Count > 0;
    }

    private void RestoreFocusedNodeEditorDraft()
    {
        if (_selectedFacilityNode is null)
        {
            _editorLabelInput = string.Empty;
            _editorNodeTypeInput = string.Empty;
            _editorZoneInput = string.Empty;
            _editorTagsInput = string.Empty;
            _editorNoteInput = string.Empty;
            _reconnectParentNodeKeyInput = string.Empty;
            return;
        }

        _editorLabelInput = _selectedFacilityNode.Label ?? string.Empty;
        _editorNodeTypeInput = _selectedFacilityNode.NodeType ?? string.Empty;
        _editorZoneInput = _selectedFacilityNode.Zone ?? string.Empty;
        _reconnectParentNodeKeyInput = _selectedFacilityNode.ParentNodeKey ?? string.Empty;

        if (_editorNodeStatesByKey.TryGetValue(_selectedFacilityNode.NodeKey, out var nodeState))
        {
            if (!string.IsNullOrWhiteSpace(nodeState.Label))
                _editorLabelInput = nodeState.Label;

            if (!string.IsNullOrWhiteSpace(nodeState.NodeType))
                _editorNodeTypeInput = nodeState.NodeType;

            if (!string.IsNullOrWhiteSpace(nodeState.Zone))
                _editorZoneInput = nodeState.Zone;

            _editorTagsInput = string.Join(", ", nodeState.Tags);
            _editorNoteInput = nodeState.Note ?? string.Empty;
            return;
        }

        _editorTagsInput = string.Empty;
        _editorNoteInput = string.Empty;
    }

    private async Task SaveFocusedNodeMetadataAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _editorStatusMessage = "Schema editor je vypnutý. Zapněte editor před uložením.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null)
        {
            _editorStatusMessage = "Nejprve vyberte focus uzel.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!CanEditFocusedNode)
        {
            _editorStatusMessage = "Tento uzel je kontextový a jeho metadata se v editoru nemění.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var nodeKey = _selectedFacilityNode.NodeKey;
        var label = NormalizeOptionalText(_editorLabelInput) ?? _selectedFacilityNode.Label;
        var nodeType = NormalizeOptionalText(_editorNodeTypeInput);
        var zone = NormalizeOptionalText(_editorZoneInput);
        var tags = FacilityNodeSemantics.ParseTagQuery(_editorTagsInput);
        var note = NormalizeOptionalText(_editorNoteInput);

        _editorNodeStatesByKey.TryGetValue(nodeKey, out var existingState);

        var nextState = new FacilityNodeEditorState
        {
            NodeKey = nodeKey,
            Label = label,
            NodeType = nodeType,
            Zone = zone,
            Tags = tags,
            Note = note,
            XHint = existingState?.XHint ?? _selectedFacilityNode.XHint,
            YHint = existingState?.YHint ?? _selectedFacilityNode.YHint,
            UpdatedUtc = DateTime.UtcNow
        };

        // Snapshot před uložením metadat pro undo
        var snapshot = await SnapshotEditStateAsync();

        await FacilityEditorStateService.SaveNodeStatesAsync([nextState]);

        // Handle parent change if it differs from current
        var requestedParent = NormalizeOptionalText(_reconnectParentNodeKeyInput);
        var currentParent = NormalizeOptionalText(_selectedFacilityNode.ParentNodeKey);
        if (!string.Equals(requestedParent ?? string.Empty, currentParent ?? string.Empty, StringComparison.OrdinalIgnoreCase))
        {
            var parentMap = BuildCurrentParentMap();
            var reconnectResult = await FacilityEditorStateService.TryReconnectNodeAsync(
                nodeKey,
                requestedParent,
                parentMap);

            if (!reconnectResult.Success)
            {
                _editorStatusMessage = $"Metadata uložena, ale změna parenta selhala: {reconnectResult.Message}";
                await InvokeAsync(StateHasChanged);
                return;
            }
            _reconnectChildrenWarningConfirmed = false;
        }

        PushEditUndoSnapshot(snapshot, $"Metadata \"{label ?? nodeKey}\"");

        if (HasNodeStatePayload(nextState))
        {
            _editorNodeStatesByKey[nodeKey] = nextState;
        }
        else
        {
            _editorNodeStatesByKey.Remove(nodeKey);
        }

        if (!string.IsNullOrWhiteSpace(label))
        {
            _selectedFacilityNode.Label = label;
            if (_nodesByKey.TryGetValue(nodeKey, out var indexedNode))
            {
                indexedNode.Label = label;
            }

            _editorLabelInput = label;
        }

        await ReloadData(preserveSelection: true, preferredFocusNodeKey: nodeKey);
        _editorStatusMessage = $"Uzel {nodeKey} byl uložen.";
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleFacilityNodeMovedAsync((string NodeKey, double XHint, double YHint) move)
    {
        if (!_isSchematicEditorEnabled || IsWeatherNode(move.NodeKey))
        {
            return;
        }

        if (!_nodesByKey.TryGetValue(move.NodeKey, out var node))
        {
            return;
        }

        var xHint = Math.Clamp(move.XHint, 0.0, 1.0);
        var yHint = Math.Clamp(move.YHint, 0.0, 1.0);

        node.XHint = xHint;
        node.YHint = yHint;

        if (_selectedFacilityNode is not null && _selectedFacilityNode.NodeKey.Equals(move.NodeKey, StringComparison.OrdinalIgnoreCase))
        {
            _selectedFacilityNode.XHint = xHint;
            _selectedFacilityNode.YHint = yHint;
        }

        _editorNodeStatesByKey.TryGetValue(move.NodeKey, out var existingState);
        var nextState = new FacilityNodeEditorState
        {
            NodeKey = move.NodeKey,
            Label = existingState?.Label,
            Tags = existingState?.Tags ?? [],
            Note = existingState?.Note,
            XHint = xHint,
            YHint = yHint,
            UpdatedUtc = DateTime.UtcNow
        };

        await FacilityEditorStateService.SaveNodeStatesAsync([nextState]);

        if (HasNodeStatePayload(nextState))
        {
            _editorNodeStatesByKey[move.NodeKey] = nextState;
        }
        else
        {
            _editorNodeStatesByKey.Remove(move.NodeKey);
        }

        _editorStatusMessage = $"Pozice uzlu {move.NodeKey} byla uložena.";
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveCurrentWorkingSetAsync()
    {
        var workingSetName = NormalizeOptionalText(_workingSetNameInput);
        if (string.IsNullOrWhiteSpace(workingSetName))
        {
            _workingSetStatusMessage = "Zadejte název working setu.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var nodeKeys = _selectionOrder
            .Where(_selectionSet.Contains)
            .Where(_nodesByKey.ContainsKey)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (nodeKeys.Count == 0)
        {
            _workingSetStatusMessage = "Selection set je prázdný. Nejprve vyberte uzly ve schématu.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var workingSet = new FacilitySavedWorkingSet
        {
            Name = workingSetName,
            Description = NormalizeOptionalText(_workingSetDescriptionInput),
            NodeKeys = nodeKeys,
            SemanticQuery = BuildWorkingSetSemanticSnapshot(),
            UpdatedUtc = DateTime.UtcNow
        };

        await FacilityEditorStateService.SaveWorkingSetAsync(workingSet);
        await ReloadWorkingSetsAsync();

        _workingSetNameInput = workingSet.Name;
        _workingSetStatusMessage = $"Working set {workingSet.Name} byl uložen ({workingSet.NodeKeys.Count} uzlů).";
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyWorkingSetAsync(string workingSetName)
    {
        if (string.IsNullOrWhiteSpace(workingSetName))
        {
            return;
        }

        var workingSet = _savedWorkingSets.FirstOrDefault(item => item.Name.Equals(workingSetName, StringComparison.OrdinalIgnoreCase));
        if (workingSet is null)
        {
            _workingSetStatusMessage = "Working set nebyl nalezen.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var nodeKeys = workingSet.NodeKeys
            .Where(_nodesByKey.ContainsKey)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (nodeKeys.Count == 0)
        {
            _workingSetStatusMessage = "Working set neobsahuje žádné aktuálně dostupné uzly.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (workingSet.SemanticQuery is not null)
        {
            ApplySemanticFiltersFromQuery(workingSet.SemanticQuery);
        }

        var mutationResult = MutateSelectionSet(nodeKeys, SemanticSelectionMutationMode.Replace);
        var nextFocusNodeKey = ResolveFocusNodeAfterSemanticMutation(SemanticSelectionMutationMode.Replace, mutationResult);
        var focusChanged = ApplyFocusNode(nextFocusNodeKey);

        var unavailableCount = Math.Max(0, workingSet.NodeKeys.Count - nodeKeys.Count);
        _workingSetStatusMessage = unavailableCount > 0
            ? $"Working set {workingSet.Name} aplikován. {unavailableCount} uzlů už není ve schématu dostupných."
            : $"Working set {workingSet.Name} aplikován ({nodeKeys.Count} uzlů).";

        if (!focusChanged)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteWorkingSetAsync(string workingSetName)
    {
        var removed = await FacilityEditorStateService.DeleteWorkingSetAsync(workingSetName);
        if (!removed)
        {
            _workingSetStatusMessage = "Working set se nepodařilo odstranit (nenalezen).";
            await InvokeAsync(StateHasChanged);
            return;
        }

        await ReloadWorkingSetsAsync();
        _workingSetStatusMessage = $"Working set {workingSetName} byl smazán.";
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadWorkingSetsAsync()
    {
        var workingSets = await FacilityEditorStateService.GetWorkingSetsAsync();
        SyncWorkingSetCache(workingSets);
    }

    private FacilityNodeSemanticQuery? BuildWorkingSetSemanticSnapshot()
    {
        var hasRoleFilter = !string.IsNullOrWhiteSpace(_semanticQueryRoleFilterValue);
        var hasTypeFilter = !string.IsNullOrWhiteSpace(_semanticQueryTypeFilterValue);
        var hasTagFilter = !string.IsNullOrWhiteSpace(_semanticQueryTagInput);

        if (!hasRoleFilter && !hasTypeFilter && !hasTagFilter)
        {
            return null;
        }

        return BuildSemanticQueryFromFilters();
    }

    private void ApplySemanticFiltersFromQuery(FacilityNodeSemanticQuery query)
    {
        _semanticQueryRoleFilterValue = query.Role?.ToString() ?? string.Empty;
        _semanticQueryTypeFilterValue = query.SemanticType?.ToString() ?? string.Empty;
        _semanticQueryTagInput = string.Join(", ", query.Tags);
    }

    private IReadOnlyList<string> GetEditorTags(string nodeKey)
    {
        if (_editorNodeStatesByKey.TryGetValue(nodeKey, out var nodeState))
        {
            return nodeState.Tags;
        }

        return [];
    }

    private void SyncEditorNodeStateCache(IReadOnlyDictionary<string, FacilityNodeEditorState> states)
    {
        _editorNodeStatesByKey.Clear();

        foreach (var pair in states)
        {
            _editorNodeStatesByKey[pair.Key] = pair.Value;
        }
    }

    private void SyncWorkingSetCache(IReadOnlyList<FacilitySavedWorkingSet> workingSets)
    {
        _savedWorkingSets.Clear();
        _savedWorkingSets.AddRange(workingSets.OrderBy(item => item.Name, StringComparer.CurrentCultureIgnoreCase));
    }

    private static string? NormalizeOptionalText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return value.Trim();
    }

    private static bool HasNodeStatePayload(FacilityNodeEditorState nodeState)
    {
        return !string.IsNullOrWhiteSpace(nodeState.Label)
            || nodeState.XHint.HasValue
            || nodeState.YHint.HasValue
            || !string.IsNullOrWhiteSpace(nodeState.Note)
            || nodeState.Tags.Count > 0;
    }

    private async Task ApplySemanticPresetAsync()
    {
        var presetQuery = FacilityNodeSemantics.GetPresetQuery(_semanticPreset);
        var query = new FacilityNodeSemanticQuery
        {
            Role = presetQuery.Role,
            SemanticType = presetQuery.SemanticType,
            Tags = presetQuery.Tags,
            IncludeWeatherContext = false
        };

        await ApplySemanticSelectionAsync(query, $"Preset {FacilityNodeSemantics.GetPresetLabel(_semanticPreset)}");
    }

    private async Task ApplySemanticQueryAsync()
    {
        var query = BuildSemanticQueryFromFilters();
        await ApplySemanticSelectionAsync(query, "Semantic query");
    }

    private void ClearSemanticQueryFilters()
    {
        _semanticQueryRoleFilterValue = string.Empty;
        _semanticQueryTypeFilterValue = string.Empty;
        _semanticQueryTagInput = string.Empty;
        _semanticSelectionStatusMessage = "Filtry semantic query byly resetovány.";
    }

    private FacilityNodeSemanticQuery BuildSemanticQueryFromFilters()
    {
        FacilityNodeRole? roleFilter = null;
        if (Enum.TryParse<FacilityNodeRole>(_semanticQueryRoleFilterValue, out var parsedRoleFilter))
        {
            roleFilter = parsedRoleFilter;
        }

        FacilityNodeSemanticType? semanticTypeFilter = null;
        if (Enum.TryParse<FacilityNodeSemanticType>(_semanticQueryTypeFilterValue, out var parsedSemanticTypeFilter))
        {
            semanticTypeFilter = parsedSemanticTypeFilter;
        }

        return new FacilityNodeSemanticQuery
        {
            Role = roleFilter,
            SemanticType = semanticTypeFilter,
            Tags = FacilityNodeSemantics.ParseTagQuery(_semanticQueryTagInput),
            IncludeWeatherContext = false
        };
    }

    private async Task ApplySemanticSelectionAsync(FacilityNodeSemanticQuery query, string sourceLabel)
    {
        if (_facility is null || _facility.Nodes.Count == 0)
        {
            _semanticSelectionStatusMessage = "Facility data nejsou načtena. Semantic selection se nespustila.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var candidateNodes = _facility.Nodes
            .Where(IsLeafOrAnalyticNode)
            .ToList();
        var candidateNodeKeys = FacilityNodeSemantics
            .ResolveMatchingNodeKeys(candidateNodes, query, node => GetEditorTags(node.NodeKey))
            .Where(_nodesByKey.ContainsKey)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        string? supportedFilterNotice = null;
        if (_semanticSelectionSupportedOnly && candidateNodeKeys.Count > 0)
        {
            try
            {
                var supportedNodeKeys = await ResolveAnalyticsSupportedNodeKeysAsync(candidateNodeKeys);
                candidateNodeKeys = candidateNodeKeys
                    .Where(supportedNodeKeys.Contains)
                    .ToList();
            }
            catch
            {
                supportedFilterNotice = "Supported filtr nebyl dostupný, použil se plný výsledek query.";
            }
        }

        var mutationResult = MutateSelectionSet(candidateNodeKeys, _semanticSelectionMutationMode);
        _semanticSelectionStatusMessage = BuildSemanticSelectionStatusMessage(sourceLabel, candidateNodeKeys.Count, mutationResult, supportedFilterNotice);

        var nextFocusNodeKey = ResolveFocusNodeAfterSemanticMutation(_semanticSelectionMutationMode, mutationResult);
        var focusChanged = ApplyFocusNode(nextFocusNodeKey);
        if (!focusChanged)
        {
            await ReloadPreviewDataAsync();
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<HashSet<string>> ResolveAnalyticsSupportedNodeKeysAsync(IReadOnlyList<string> candidateNodeKeys)
    {
        if (candidateNodeKeys.Count == 0)
        {
            return new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }

        var interval = GetInterval();
        var aggregate = await AnalyticsPreview.GetCuratedSelectionAggregateOverviewAsync(
            candidateNodeKeys,
            interval.From,
            interval.To,
            _timeSeriesMode,
            _showBaselineOverlay);

        return aggregate.SupportedNodeKeys.ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private SemanticSelectionMutationResult MutateSelectionSet(
        IReadOnlyList<string> nodeKeys,
        SemanticSelectionMutationMode mutationMode)
    {
        var uniqueNodeKeys = nodeKeys
            .Where(key => !string.IsNullOrWhiteSpace(key))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var addedCount = 0;
        var removedCount = 0;

        if (mutationMode == SemanticSelectionMutationMode.Replace)
        {
            var previousSelection = _selectionSet.ToHashSet(StringComparer.OrdinalIgnoreCase);
            ClearSelectionSetState();

            foreach (var nodeKey in uniqueNodeKeys)
            {
                AddNodeToSelectionSet(nodeKey);
            }

            var nextSelection = _selectionSet;
            addedCount = nextSelection.Count(nodeKey => !previousSelection.Contains(nodeKey));
            removedCount = previousSelection.Count(nodeKey => !nextSelection.Contains(nodeKey));
            return new SemanticSelectionMutationResult(addedCount, removedCount);
        }

        if (mutationMode == SemanticSelectionMutationMode.Add)
        {
            foreach (var nodeKey in uniqueNodeKeys)
            {
                if (_selectionSet.Contains(nodeKey))
                {
                    continue;
                }

                AddNodeToSelectionSet(nodeKey);
                addedCount++;
            }

            return new SemanticSelectionMutationResult(addedCount, 0);
        }

        foreach (var nodeKey in uniqueNodeKeys)
        {
            if (!_selectionSet.Contains(nodeKey))
            {
                continue;
            }

            RemoveNodeFromSelectionSet(nodeKey);
            removedCount++;
        }

        return new SemanticSelectionMutationResult(0, removedCount);
    }

    private string? ResolveFocusNodeAfterSemanticMutation(
        SemanticSelectionMutationMode mutationMode,
        SemanticSelectionMutationResult mutationResult)
    {
        if (_selectionSet.Count == 0)
        {
            return null;
        }

        if (mutationMode is SemanticSelectionMutationMode.Replace)
        {
            return GetFallbackFocusNodeKey();
        }

        if (mutationMode is SemanticSelectionMutationMode.Add && mutationResult.AddedCount > 0)
        {
            return GetFallbackFocusNodeKey();
        }

        if (!string.IsNullOrWhiteSpace(SessionService.SelectedElementId)
            && _selectionSet.Contains(SessionService.SelectedElementId))
        {
            return SessionService.SelectedElementId;
        }

        return GetFallbackFocusNodeKey();
    }

    private string BuildSemanticSelectionStatusMessage(
        string sourceLabel,
        int matchedCount,
        SemanticSelectionMutationResult mutationResult,
        string? note)
    {
        var scopeLabel = _semanticSelectionSupportedOnly ? "supported-only" : "full-scope";
        var mutationLabel = GetSemanticMutationModeLabel(_semanticSelectionMutationMode).ToLowerInvariant();

        string baseMessage;
        if (matchedCount == 0)
        {
            baseMessage = $"{sourceLabel}: žádné uzly neodpovídají ({scopeLabel}).";
        }
        else if (!mutationResult.HasChanges)
        {
            baseMessage = $"{sourceLabel}: nalezeno {matchedCount} uzlů ({scopeLabel}), selection beze změny ({mutationLabel}).";
        }
        else
        {
            baseMessage = $"{sourceLabel}: nalezeno {matchedCount} uzlů ({scopeLabel}), změna selection {mutationLabel}: +{mutationResult.AddedCount} / -{mutationResult.RemovedCount}.";
        }

        if (string.IsNullOrWhiteSpace(note))
        {
            return baseMessage;
        }

        return $"{baseMessage} {note}";
    }

    private static string GetSemanticMutationModeLabel(SemanticSelectionMutationMode mode)
    {
        return mode switch
        {
            SemanticSelectionMutationMode.Replace => "Replace",
            SemanticSelectionMutationMode.Add => "Add",
            SemanticSelectionMutationMode.Remove => "Remove",
            _ => "Replace"
        };
    }

