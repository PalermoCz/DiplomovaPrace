    private string ResolveNodeTypeFillColor(IEnumerable<DiplomovaPrace.Persistence.Schematic.SchematicNodeEntity> nodes)
    {
        var fillCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var effectivePresetKeys = EffectiveNodeStylePresetKeysForCanvas;
        var effectivePresets = EffectiveStylePresetsForCanvas;

        foreach (var node in nodes)
        {
            var assignedKey = effectivePresetKeys.TryGetValue(node.NodeKey, out var nodePresetKey)
                ? nodePresetKey
                : null;
            var style = FacilityNodeStyleSystem.ResolveStyle(assignedKey, effectivePresets);
            var fill = string.IsNullOrWhiteSpace(style.FillColor) ? "#cbd5e1" : style.FillColor;
            fillCounts.TryGetValue(fill, out var current);
            fillCounts[fill] = current + 1;
        }

        return fillCounts
            .OrderByDescending(pair => pair.Value)
            .ThenBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase)
            .Select(pair => pair.Key)
            .FirstOrDefault() ?? "#cbd5e1";
    }

