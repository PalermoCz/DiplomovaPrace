    private IReadOnlyList<OverviewTreemapTile> BuildOverviewTreemapTiles()
{
    var layout = OverviewTreemapLayout;

    if (layout.VisibleItems.Count == 0)
    {
        return [];
    }

    var tiles = new List<OverviewTreemapTile>(layout.VisibleItems.Count);

    for (var index = 0; index < layout.VisibleItems.Count; index++)
    {
        var item = layout.VisibleItems[index];
        var rect = layout.VisibleRects[index];

        var visualStyle = ResolveOverviewTreemapVisualStyle(item.NodeKey, false);
        var textMode = ResolveOverviewTreemapTextMode(rect);

        var style = string.Join(' ',
            $"--tile-left:{FormatCssPercent(rect.LeftPercent)};",
            $"--tile-top:{FormatCssPercent(rect.TopPercent)};",
            $"--tile-width:{FormatCssPercent(rect.WidthPercent)};",
            $"--tile-height:{FormatCssPercent(rect.HeightPercent)};",
            $"--tile-fill:{visualStyle.Fill};",
            $"--tile-accent:{visualStyle.Accent};",
            $"--tile-text:{visualStyle.Text};");

        tiles.Add(new OverviewTreemapTile(
            item.NodeKey,
            item.Label,
            item.RoleLabel,
            item.DisplayValue,
            $"{item.SharePercent:N1}%",
            item.SemanticsLabel,
            item.TooltipDetail,
            style,
            false,
            textMode,
            null));
    }

    if (layout.TailItems.Count > 0)
    {
        var tailValue = layout.TailItems.Sum(item => item.ValueKwh);
        var tailShare = layout.TailItems.Sum(item => item.SharePercent);

        var tailRect = FindTailRect(layout.VisibleRects);

        var tailStyle = string.Join(' ',
            $"--tile-left:{FormatCssPercent(tailRect.LeftPercent)};",
            $"--tile-top:{FormatCssPercent(tailRect.TopPercent)};",
            $"--tile-width:{FormatCssPercent(tailRect.WidthPercent)};",
            $"--tile-height:{FormatCssPercent(tailRect.HeightPercent)};",
            $"--tile-fill:#cbd5e1;",
            $"--tile-accent:#64748b;",
            $"--tile-text:#0f172a;");

        tiles.Add(new OverviewTreemapTile(
            "__overview_other__",
            "Other contributors",
            $"{layout.TailItems.Count} smaller contributors",
            FormatOverviewEnergyValue(tailValue),
            $"{tailShare:N1}%",
            OverviewCurrentSemanticsLabel,
            $"Grouped tail of {layout.TailItems.Count} smaller contributors.",
            tailStyle,
            true,
            ResolveOverviewTreemapTextMode(tailRect),
            layout.TailItems
                .Select(item => new OverviewTreemapContributorItem(
                    item.NodeKey,
                    item.Label,
                    item.RoleLabel,
                    item.ValueKwh,
                    item.SharePercent,
                    item.DisplayValue,
                    $"{item.SharePercent:N1}%",
                    item.SemanticsLabel,
                    item.TooltipDetail))
                .ToList()));
    }

    return tiles;
    }


    private IReadOnlyList<OverviewContributorUniverseItem> BuildOverviewContributorUniverse()
    {
    var contributingItems = SelectionBreakdownItems
        .Where(item => item.HasData)
        .ToList();

    if (contributingItems.Count == 0)
    {
        return [];
    }

    var semanticsLabel = OverviewCurrentSemanticsLabel;
    var universe = new List<OverviewContributorUniverseItem>();

    foreach (var item in contributingItems)
    {
        switch (CurrentOverviewSemanticsMode)
        {
            case OverviewAggregateSemanticsMode.Consumption
                when item.IntervalEnergyKwh > 0.0001d:
                universe.Add(new OverviewContributorUniverseItem(
                    item.NodeKey,
                    item.Label,
                    item.NodeRoleLabel,
                    item.IntervalEnergyKwh,
                    0d,
                    FormatOverviewEnergyValue(item.IntervalEnergyKwh),
                    semanticsLabel,
                    item.NodeRoleLabel));
                break;

            case OverviewAggregateSemanticsMode.Production
                when item.IntervalEnergyKwh < -0.0001d:
                universe.Add(new OverviewContributorUniverseItem(
                    item.NodeKey,
                    item.Label,
                    item.NodeRoleLabel,
                    Math.Abs(item.IntervalEnergyKwh),
                    0d,
                    FormatOverviewEnergyValue(Math.Abs(item.IntervalEnergyKwh)),
                    semanticsLabel,
                    item.NodeRoleLabel));
                break;

            case OverviewAggregateSemanticsMode.Net
                when Math.Abs(item.IntervalEnergyKwh) > 0.0001d:
                universe.Add(new OverviewContributorUniverseItem(
                    item.NodeKey,
                    item.Label,
                    item.NodeRoleLabel,
                    Math.Abs(item.IntervalEnergyKwh),
                    0d,
                    FormatOverviewSignedEnergyValue(item.IntervalEnergyKwh),
                    semanticsLabel,
                    item.NodeRoleLabel));
                break;
        }
    }

    if (universe.Count == 0)
    {
        return [];
    }

    var totalValue = universe.Sum(item => item.ValueKwh);
    if (totalValue <= 0.0001d)
    {
        return [];
    }

    return universe
        .OrderByDescending(item => item.ValueKwh)
        .ThenBy(item => item.Label, StringComparer.OrdinalIgnoreCase)
        .Select(item => item with
        {
            SharePercent = totalValue > 0d ? item.ValueKwh / totalValue * 100d : 0d
        })
        .ToList();
    }

    private OverviewTreemapLayoutResult BuildOverviewTreemapLayoutResult()
    {
    var universe = BuildOverviewContributorUniverse();

    if (universe.Count == 0)
    {
        return new OverviewTreemapLayoutResult([], [], []);
    }

    var shouldForceOtherContributors = ShouldForceOverviewOtherContributors(universe.Count);
    var maxVisibleCount = Math.Min(universe.Count, ResolveOverviewTreemapVisibleTileSoftCap(universe.Count));
    if (shouldForceOtherContributors && universe.Count > 1)
    {
        maxVisibleCount = Math.Min(maxVisibleCount, universe.Count - 1);
    }
    var bestVisibleCount = universe.Count;
    IReadOnlyList<OverviewTreemapRect> bestRects = [];

    for (var visibleCount = 1; visibleCount <= maxVisibleCount; visibleCount++)
    {
        var visibleItems = universe.Take(visibleCount).ToList();
        var tailItems = universe.Skip(visibleCount).ToList();

        

        var itemsForLayout = new List<OverviewContributorUniverseItem>(visibleItems);

        if (tailItems.Count > 0)
        {
            var tailValue = tailItems.Sum(item => item.ValueKwh);
            var tailShare = tailItems.Sum(item => item.SharePercent);

            itemsForLayout.Add(new OverviewContributorUniverseItem(
                "__overview_other__",
                "Other contributors",
                $"{tailItems.Count} smaller contributors",
                tailValue,
                tailShare,
                FormatOverviewEnergyValue(tailValue),
                OverviewCurrentSemanticsLabel,
                $"Grouped tail of {tailItems.Count} smaller contributors."));
        }

        var rects = BuildOverviewTreemapRects(itemsForLayout);

        if (rects.Count != itemsForLayout.Count)
        {
            break;
        }

        if (!IsTreemapPrefixReadable(itemsForLayout, rects))
        {
            break;
        }

        bestVisibleCount = visibleCount;
        bestRects = rects;
    }

    var finalVisible = universe.Take(bestVisibleCount).ToList();
    var finalTail = universe.Skip(bestVisibleCount).ToList();

    var finalLayoutItems = new List<OverviewContributorUniverseItem>(finalVisible);
    if (finalTail.Count > 0)
    {
        var tailValue = finalTail.Sum(item => item.ValueKwh);
        var tailShare = finalTail.Sum(item => item.SharePercent);

        finalLayoutItems.Add(new OverviewContributorUniverseItem(
            "__overview_other__",
            "Other contributors",
            $"{finalTail.Count} smaller contributors",
            tailValue,
            tailShare,
            FormatOverviewEnergyValue(tailValue),
            OverviewCurrentSemanticsLabel,
            $"Grouped tail of {finalTail.Count} smaller contributors."));
    }

    var finalRects = bestRects.Count == finalLayoutItems.Count
        ? bestRects
        : BuildOverviewTreemapRects(finalLayoutItems);

    return new OverviewTreemapLayoutResult(finalVisible, finalTail, finalRects);
    }

    private static int ResolveOverviewTreemapVisibleTileSoftCap(int contributorCount)
    {
        if (contributorCount >= 48)
        {
            return 14;
        }

        if (contributorCount >= 28)
        {
            return 16;
        }

        if (contributorCount >= 18)
        {
            return 18;
        }

        return contributorCount;
    }

    private static bool ShouldForceOverviewOtherContributors(int contributorCount)
    {
        return contributorCount >= 8;
    }

    private static string BuildOverviewTreemapInlineLabel(string label, string shareLabel)
    {
        if (string.IsNullOrWhiteSpace(shareLabel))
        {
            return label;
        }

        return $"{label} ({shareLabel})";
    }

    private static bool IsTreemapPrefixReadable(
    IReadOnlyList<OverviewContributorUniverseItem> items,
    IReadOnlyList<OverviewTreemapRect> rects)
{
    if (items.Count != rects.Count)
    {
        return false;
    }

    for (var i = 0; i < items.Count; i++)
    {
        var item = items[i];
        var rect = rects[i];

        var minShortSide = item.NodeKey == "__overview_other__" ? 7.4d : 8.8d;
        var maxAspectRatio = item.NodeKey == "__overview_other__" ? 5.8d : 4.6d;

        var shorterSide = Math.Min(rect.WidthPercent, rect.HeightPercent);
        var longerSide = Math.Max(rect.WidthPercent, rect.HeightPercent);
        var aspectRatio = shorterSide <= 0.0001d ? longerSide : longerSide / shorterSide;

        if (shorterSide < minShortSide)
        {
            return false;
        }

        if (aspectRatio > maxAspectRatio)
        {
            return false;
        }
    }

    return true;
}

    private static int ResolveOverviewDirectContributorCount(IReadOnlyList<OverviewTreemapMetric> orderedMetrics)
    {
        if (orderedMetrics.Count == 0)
        {
            return 0;
        }

        const double otherShareTargetPercent = 15d;
        const double minimumReadableDirectSharePercent = 1.6d;

        var directContributorCount = 0;

        while (directContributorCount < orderedMetrics.Count)
        {
            var nextDirectContributor = orderedMetrics[directContributorCount];
            if (directContributorCount > 0 && nextDirectContributor.SharePercent < minimumReadableDirectSharePercent)
            {
                break;
            }

            directContributorCount++;

            var otherShare = orderedMetrics
                .Skip(directContributorCount)
                .Sum(item => item.SharePercent);

            if (otherShare <= otherShareTargetPercent)
            {
                break;
            }
        }

        return Math.Max(1, directContributorCount);
    }



private static IReadOnlyList<OverviewTreemapRect> BuildOverviewTreemapRects(
    IReadOnlyList<OverviewContributorUniverseItem> items)
{
    var rects = new OverviewTreemapRect[items.Count];

    if (items.Count == 0)
    {
        return rects;
    }

    var workItems = items
        .Select((item, index) => new TreemapLayoutWorkItem(index, Math.Max(0.0001d, item.ValueKwh)))
        .ToList();

    if (ShouldUseHeroTile(items))
    {
        var heroLayout = BuildHeroTreemapLayout(workItems, 0d, 0d, 100d, 100d);
        for (var i = 0; i < heroLayout.Rects.Count; i++)
        {
            rects[i] = heroLayout.Rects[i];
        }
        return rects;
    }

    LayoutBalancedTreemap(workItems, rects, 0d, 0d, 100d, 100d);
    return rects;
}

private static bool ShouldUseHeroTile(IReadOnlyList<OverviewContributorUniverseItem> items)
{
    if (items.Count < 3)
    {
        return false;
    }

    return items[0].SharePercent >= 35d;
}

private static HeroLayoutCandidate BuildHeroTreemapLayout(
    IReadOnlyList<TreemapLayoutWorkItem> items,
    double left,
    double top,
    double width,
    double height)
{
    var totalWeight = items.Sum(item => item.Weight);
    var heroWeight = items[0].Weight;
    var heroRatio = heroWeight / totalWeight;

    var heroLeftWidth = width * heroRatio;
    var leftRects = new OverviewTreemapRect[items.Count];
    leftRects[items[0].Index] = new OverviewTreemapRect(left, top, heroLeftWidth, height);

    var leftRemainder = items.Skip(1).ToList();
    if (leftRemainder.Count > 0)
    {
        LayoutBalancedTreemap(
            leftRemainder,
            leftRects,
            left + heroLeftWidth,
            top,
            width - heroLeftWidth,
            height);
    }

    var leftScore = ScoreTreemapLayout(leftRects);

    var heroTopHeight = height * heroRatio;
    var topRects = new OverviewTreemapRect[items.Count];
    topRects[items[0].Index] = new OverviewTreemapRect(left, top, width, heroTopHeight);

    var topRemainder = items.Skip(1).ToList();
    if (topRemainder.Count > 0)
    {
        LayoutBalancedTreemap(
            topRemainder,
            topRects,
            left,
            top + heroTopHeight,
            width,
            height - heroTopHeight);
    }

    var topScore = ScoreTreemapLayout(topRects);

    return leftScore <= topScore
        ? new HeroLayoutCandidate(true, leftScore, leftRects)
        : new HeroLayoutCandidate(false, topScore, topRects);
}

private static void LayoutBalancedTreemap(
    IReadOnlyList<TreemapLayoutWorkItem> items,
    OverviewTreemapRect[] rects,
    double left,
    double top,
    double width,
    double height)
{
    if (items.Count == 0 || width <= 0d || height <= 0d)
    {
        return;
    }

    if (items.Count == 1)
    {
        rects[items[0].Index] = new OverviewTreemapRect(left, top, width, height);
        return;
    }

    if (items.Count <= 6)
    {
        LayoutSmallTreemap(items, rects, left, top, width, height);
        return;
    }

    var split = FindBestTreemapSplit(items, width, height);

    if (split.Index <= 0 || split.Index >= items.Count)
    {
        LayoutSmallTreemap(items, rects, left, top, width, height);
        return;
    }

    var first = items.Take(split.Index).ToList();
    var second = items.Skip(split.Index).ToList();

    var total = items.Sum(item => item.Weight);
    var firstWeight = first.Sum(item => item.Weight);
    var ratio = firstWeight / total;

    if (split.SplitVertical)
    {
        var firstWidth = width * ratio;
        LayoutBalancedTreemap(first, rects, left, top, firstWidth, height);
        LayoutBalancedTreemap(second, rects, left + firstWidth, top, width - firstWidth, height);
    }
    else
    {
        var firstHeight = height * ratio;
        LayoutBalancedTreemap(first, rects, left, top, width, firstHeight);
        LayoutBalancedTreemap(second, rects, left, top + firstHeight, width, height - firstHeight);
    }
}

private static TreemapSplitChoice FindBestTreemapSplit(
    IReadOnlyList<TreemapLayoutWorkItem> items,
    double width,
    double height)
{
    var total = items.Sum(item => item.Weight);
    var cumulative = 0d;

    TreemapSplitChoice? best = null;

    for (var i = 1; i < items.Count; i++)
    {
        cumulative += items[i - 1].Weight;
        var firstWeight = cumulative;
        var secondWeight = total - firstWeight;

        if (firstWeight <= 0d || secondWeight <= 0d)
        {
            continue;
        }

        var firstWidth = width * (firstWeight / total);
        var secondWidth = width - firstWidth;
        var verticalScore =
            ScoreTreemapRect(firstWidth, height) +
            ScoreTreemapRect(secondWidth, height) +
            ScoreTreemapBalance(firstWeight, secondWeight);

        best = ChooseBetterSplit(best, new TreemapSplitChoice(i, true, verticalScore));

        var firstHeight = height * (firstWeight / total);
        var secondHeight = height - firstHeight;
        var horizontalScore =
            ScoreTreemapRect(width, firstHeight) +
            ScoreTreemapRect(width, secondHeight) +
            ScoreTreemapBalance(firstWeight, secondWeight);

        best = ChooseBetterSplit(best, new TreemapSplitChoice(i, false, horizontalScore));
    }

    return best ?? new TreemapSplitChoice(items.Count / 2, width >= height, 0d);
}

private static TreemapSplitChoice ChooseBetterSplit(TreemapSplitChoice? current, TreemapSplitChoice candidate)
{
    if (current is null)
    {
        return candidate;
    }

    return candidate.Score < current.Value.Score ? candidate : current.Value;
}

private static double ScoreTreemapRect(double width, double height)
{
    var shortSide = Math.Max(0.0001d, Math.Min(width, height));
    var longSide = Math.Max(width, height);
    var aspectRatio = longSide / shortSide;

    var score = aspectRatio;

    if (aspectRatio > 4.0d)
    {
        score += (aspectRatio - 4.0d) * 8.0d;
    }
    else if (aspectRatio > 2.8d)
    {
        score += (aspectRatio - 2.8d) * 3.0d;
    }

    if (shortSide < 7.0d)
    {
        score += (7.0d - shortSide) * 2.8d;
    }

    if (shortSide < 4.0d)
    {
        score += 20.0d;
    }

    var targetRatio = 1.7d;
    score += Math.Abs(aspectRatio - targetRatio) * 0.35d;

    return score;
}

private static double ScoreTreemapBalance(double firstWeight, double secondWeight)
{
    var total = firstWeight + secondWeight;
    if (total <= 0d)
    {
        return 0d;
    }

    var ratio = Math.Abs(firstWeight - secondWeight) / total;
    return ratio * 1.6d;
}

private static double ScoreTreemapLayout(IReadOnlyList<OverviewTreemapRect> rects)
{
    var score = 0d;
    foreach (var rect in rects)
    {
        if (rect.WidthPercent <= 0d || rect.HeightPercent <= 0d)
        {
            continue;
        }

        score += ScoreTreemapRect(rect.WidthPercent, rect.HeightPercent);
    }

    return score;
}

private static void LayoutSmallTreemap(
    IReadOnlyList<TreemapLayoutWorkItem> items,
    OverviewTreemapRect[] rects,
    double left,
    double top,
    double width,
    double height)
{
    var candidates = new List<(Action Apply, double Score)>();

    candidates.Add((
        () =>
        {
            var rowTotal = items.Sum(item => item.Weight);
            var cursor = left;
            foreach (var item in items)
            {
                var itemWidth = width * (item.Weight / rowTotal);
                rects[item.Index] = new OverviewTreemapRect(cursor, top, itemWidth, height);
                cursor += itemWidth;
            }
        },
        ScoreTreemapRow(items, width, height, horizontal: true)));

    candidates.Add((
        () =>
        {
            var columnTotal = items.Sum(item => item.Weight);
            var cursor = top;
            foreach (var item in items)
            {
                var itemHeight = height * (item.Weight / columnTotal);
                rects[item.Index] = new OverviewTreemapRect(left, cursor, width, itemHeight);
                cursor += itemHeight;
            }
        },
        ScoreTreemapRow(items, width, height, horizontal: false)));

    if (items.Count >= 2)
    {
        candidates.Add((
            () =>
            {
                var split = FindBestTreemapSplit(items, width, height);

                if (split.Index <= 0 || split.Index >= items.Count)
                {
                    var fallbackTotal = items.Sum(item => item.Weight);
                    var cursor = left;

                    foreach (var item in items)
                    {
                        var itemWidth = width * (item.Weight / fallbackTotal);
                        rects[item.Index] = new OverviewTreemapRect(cursor, top, itemWidth, height);
                        cursor += itemWidth;
                    }

                    return;
                }

                var first = items.Take(split.Index).ToList();
                var second = items.Skip(split.Index).ToList();

                var splitTotal = items.Sum(item => item.Weight);
                var firstWeight = first.Sum(item => item.Weight);
                var ratio = firstWeight / splitTotal;

                if (split.SplitVertical)
                {
                    var firstWidth = width * ratio;
                    LayoutBalancedTreemap(first, rects, left, top, firstWidth, height);
                    LayoutBalancedTreemap(second, rects, left + firstWidth, top, width - firstWidth, height);
                }
                else
                {
                    var firstHeight = height * ratio;
                    LayoutBalancedTreemap(first, rects, left, top, width, firstHeight);
                    LayoutBalancedTreemap(second, rects, left, top + firstHeight, width, height - firstHeight);
                }
            },
            FindBestTreemapSplit(items, width, height).Score));
    }

    var best = candidates.OrderBy(candidate => candidate.Score).First();
    best.Apply();
}

private static double ScoreTreemapRow(
    IReadOnlyList<TreemapLayoutWorkItem> items,
    double width,
    double height,
    bool horizontal)
{
    var total = items.Sum(item => item.Weight);
    if (total <= 0d)
    {
        return double.MaxValue;
    }

    var score = 0d;

    foreach (var item in items)
    {
        if (horizontal)
        {
            var itemWidth = width * (item.Weight / total);
            score += ScoreTreemapRect(itemWidth, height);
        }
        else
        {
            var itemHeight = height * (item.Weight / total);
            score += ScoreTreemapRect(width, itemHeight);
        }
    }

    return score;
}

