    private static string? NormalizeOptionalText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return value.Trim();
    }

    private static bool HasNodeStatePayload(FacilityNodeEditorState nodeState)
    {
        return !string.IsNullOrWhiteSpace(nodeState.Label)
            || !string.IsNullOrWhiteSpace(nodeState.NodeType)
            || !string.IsNullOrWhiteSpace(nodeState.Zone)
            || nodeState.FloorAreaM2.HasValue
            || !string.IsNullOrWhiteSpace(nodeState.StylePresetKey)
            || nodeState.XHint.HasValue
            || nodeState.YHint.HasValue
            || !string.IsNullOrWhiteSpace(nodeState.Note)
            || nodeState.Tags.Count > 0;
    }

    private IReadOnlyDictionary<string, FacilityNodeStylePreset> BuildEffectiveStylePresetsForCanvas()
    {
        var effective = FacilityNodeStyleSystem.NormalizePresetLibrary(_stylePresetsByKey.Values)
            .ToDictionary(pair => pair.Key, pair => pair.Value, StringComparer.OrdinalIgnoreCase);

        if (_isEditModeOpen && !IsEditorMultiSelectActive && _selectedFacilityNode is not null)
        {
            var draftPreset = BuildCurrentStylePresetDraft();
            effective[draftPreset.Key] = draftPreset;
        }

        return effective;
    }

    private IReadOnlyDictionary<string, string> BuildEffectiveNodeStylePresetKeysForCanvas()
    {
        var effective = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var pair in _editorNodeStatesByKey)
        {
            if (!string.IsNullOrWhiteSpace(pair.Value.StylePresetKey))
            {
                effective[pair.Key] = pair.Value.StylePresetKey!;
            }
        }

        if (_isEditModeOpen && !IsEditorMultiSelectActive && _selectedFacilityNode is not null)
        {
            effective[_selectedFacilityNode.NodeKey] = FacilityNodeStyleSystem.ResolvePresetKey(_styleAssignmentPresetKeyInput, _stylePresetsByKey);
        }

        return effective;
    }

    private IReadOnlyDictionary<string, string> BuildEffectiveNodeStylePresetLabelsForCanvas()
    {
        var effective = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var effectivePresetKeys = BuildEffectiveNodeStylePresetKeysForCanvas();
        var effectivePresets = BuildEffectiveStylePresetsForCanvas();

        foreach (var node in _nodesByKey.Values)
        {
            var presetKey = effectivePresetKeys.TryGetValue(node.NodeKey, out var assignedPresetKey)
                ? assignedPresetKey
                : FacilityNodeStyleSystem.DefaultPresetKey;

            var resolvedPresetKey = FacilityNodeStyleSystem.ResolvePresetKey(presetKey, effectivePresets);
            if (!effectivePresets.TryGetValue(resolvedPresetKey, out var preset))
            {
                effective[node.NodeKey] = resolvedPresetKey;
                continue;
            }

            effective[node.NodeKey] = string.IsNullOrWhiteSpace(preset.Name)
                ? preset.Key
                : preset.Name;
        }

        return effective;
    }

    private IReadOnlyDictionary<string, string> BuildEffectiveNodeTagPreviewForCanvas()
    {
        var effective = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var node in _nodesByKey.Values)
        {
            var userTags = GetEditorTags(node.NodeKey)
                .Where(IsUserFacingTag)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (userTags.Count == 0)
            {
                continue;
            }

            effective[node.NodeKey] = string.Join(",", userTags);
        }

        return effective;
    }

    private IReadOnlyDictionary<string, string> BuildEffectiveNodeNotePreviewForCanvas()
    {
        var effective = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var node in _nodesByKey.Values)
        {
            var note = GetEditorNote(node.NodeKey);
            if (!string.IsNullOrWhiteSpace(note))
            {
                effective[node.NodeKey] = note;
            }
        }

        return effective;
    }

