    private void RestoreFocusedNodeEditorDraft()
    {
        if (_selectedFacilityNode is null)
        {
            _editorLabelInput = string.Empty;
            _editorNodeTypeInput = string.Empty;
            _editorZoneInput = string.Empty;
            _editorFloorAreaInput = string.Empty;
            _editorFloorAreaValidationMessage = null;
            _editorTagsInput = string.Empty;
            _editorTagsSelected.Clear();
            _editorReservedTagsHidden.Clear();
            _editorTagSearchInput = string.Empty;
            _editorNoteInput = string.Empty;
            _reconnectParentNodeKeyInput = string.Empty;
            _reconnectParentSearchInput = string.Empty;
            _isReconnectParentPickerOpen = false;
            ResetAdditionalRelationshipDraft();
            ResetImportDraft();
            RestoreFocusedNodeStyleDraft();
            return;
        }

        _editorLabelInput = _selectedFacilityNode.Label ?? string.Empty;
        _editorNodeTypeInput = _selectedFacilityNode.NodeType ?? string.Empty;
        _editorZoneInput = _selectedFacilityNode.Zone ?? string.Empty;
        _editorFloorAreaInput = string.Empty;
        _editorFloorAreaValidationMessage = null;
        _reconnectParentNodeKeyInput = _selectedFacilityNode.ParentNodeKey ?? string.Empty;
        _reconnectParentSearchInput = string.Empty;
        _isReconnectParentPickerOpen = false;
        ResetAdditionalRelationshipDraft();

        if (_editorNodeStatesByKey.TryGetValue(_selectedFacilityNode.NodeKey, out var nodeState))
        {
            if (!string.IsNullOrWhiteSpace(nodeState.Label))
                _editorLabelInput = nodeState.Label;

            if (!string.IsNullOrWhiteSpace(nodeState.NodeType))
                _editorNodeTypeInput = nodeState.NodeType;

            if (!string.IsNullOrWhiteSpace(nodeState.Zone))
                _editorZoneInput = nodeState.Zone;

            _editorFloorAreaInput = FormatFloorAreaInput(nodeState.FloorAreaM2);

            _editorTagsSelected.Clear();
            _editorReservedTagsHidden.Clear();
            foreach (var t in nodeState.Tags)
            {
                if (IsReservedSystemTag(t))
                    _editorReservedTagsHidden.Add(t);
                else
                    _editorTagsSelected.Add(t);
            }
            SyncEditorTagsInputFromSelected();
            _editorTagSearchInput = string.Empty;
            _editorNoteInput = nodeState.Note ?? string.Empty;
            ResetImportDraft();
            RestoreFocusedNodeStyleDraft();
            return;
        }

        _editorTagsInput = string.Empty;
        _editorTagsSelected.Clear();
        _editorReservedTagsHidden.Clear();
        _editorTagSearchInput = string.Empty;
        _editorNoteInput = string.Empty;
        _editorFloorAreaInput = string.Empty;
        _editorFloorAreaValidationMessage = null;
        ResetImportDraft();
        RestoreFocusedNodeStyleDraft();
    }

