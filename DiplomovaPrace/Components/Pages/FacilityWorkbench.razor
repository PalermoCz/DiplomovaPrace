        }
    }

    private async Task AddEditorTagFromSearchInput()
    {
        var candidate = _editorTagSearchInput.Trim();
        if (string.IsNullOrWhiteSpace(candidate))
        {
            return;
        }

        if (candidate.Any(char.IsWhiteSpace) || candidate.Contains('.'))
        {
            _editorStatusMessage = "Tag cannot contain spaces or dots";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (IsReservedSystemTag(candidate))
        {
            _editorStatusMessage = "System tags are reserved and cannot be added";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_editorTagsSelected.Contains(candidate))
        {
            _editorStatusMessage = "Tag already selected";
            _editorTagSearchInput = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_editorTagsSelected.Count >= MaxTagsPerNode)
        {
            _editorStatusMessage = "Maximum 3 tags allowed";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _editorTagsSelected.Add(candidate);
        SyncEditorTagsInputFromSelected();
        _editorTagSearchInput = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private void SyncEditorTagsInputFromSelected()
    {
        _editorTagsInput = string.Join(", ", _editorTagsSelected.Order(StringComparer.OrdinalIgnoreCase));
    }

    private static bool IsReservedSystemTag(string? tag)
    {
        if (string.IsNullOrWhiteSpace(tag))
        {
            return false;
        }

        var normalized = tag.Trim();
        return ReservedSystemTagPrefixes.Any(prefix =>
            prefix.EndsWith(":", StringComparison.Ordinal)
                ? normalized.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
                : normalized.Equals(prefix, StringComparison.OrdinalIgnoreCase));
    }

    private static bool IsUserFacingTag(string? tag)
    {
        return !IsReservedSystemTag(tag);
    }

    private List<string> GetFilteredUserFacingTags(string? searchInput)
    {
        var filtered = _allDistinctTags
            .Where(IsUserFacingTag)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(searchInput))
        {
            return filtered.ToList();
        }

        return filtered
            .Where(tag => tag.Contains(searchInput.Trim(), StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

