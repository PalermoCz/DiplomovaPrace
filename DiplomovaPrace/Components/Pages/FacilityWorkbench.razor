    private async Task ReloadPreviewDataAsync()
    {
        var hasSelectionContext = HasSelectedNodes;
        var hasFocusAnalyticsContext = _selectedFacilityNode != null && (_isCuratedNode || !string.IsNullOrEmpty(_selectedFacilityNode.MeterUrn));

        if (!hasSelectionContext && !hasFocusAnalyticsContext)
        {
            _selectionSignalAvailability = new();
            _selectionSignalAnalyticsResult = null;
            _activeAnalyticsSignalCodeValue = string.Empty;
            _nodePreviewData = null;
            _curatedPreviewData = null;
            _curatedDeviationData = null;
            _curatedTimeSeriesData = null;
            _curatedCompareTimeSeriesData = null;
            _selectionAggregateOverview = null;
            _overviewChartTimeSeriesData = null;
            _isOverviewChartLoading = false;
            _overviewChartLoadVersion++;
            await InvokeAsync(StateHasChanged);
            return;
        }

        SyncSelectionSignalAvailability();

        _isPreviewLoading = true;
        _isOverviewChartLoading = false;
        _overviewChartLoadVersion++;
        await InvokeAsync(StateHasChanged);
        var skipPostRefresh = false;

        try
        {
            await RefreshPresetAnchorAsync();
            var interval = GetInterval();
            var aggregateNodeKeys = GetSelectionAggregateNodeKeys();
            Task<CuratedSelectionAggregateOverviewResult>? aggregateTask = null;
            Task<SelectionSignalAnalyticsResult>? selectionSignalTask = null;

            if (_selectedInterval == "custom")
            {
                var customValidationMessage = await ValidateCustomIntervalForAnalyticsAsync();
                if (!string.IsNullOrWhiteSpace(customValidationMessage))
                {
                    _customIntervalValidationMessage = customValidationMessage;
                    _nodePreviewData = null;
                    _curatedPreviewData = null;
                    _curatedTimeSeriesData = null;
                    _curatedCompareTimeSeriesData = null;
                    _overviewChartTimeSeriesData = null;
                    _selectionAggregateOverview = new CuratedSelectionAggregateOverviewResult
                    {
                        Message = customValidationMessage
                    };

                    if (_isCuratedNode)
                    {
                        _curatedDeviationData = new CuratedNodeDeviationSummary
                        {
                            IsAvailable = false,
                            Message = customValidationMessage,
                            Methodology = "Custom interval validation: analytics runs only for a valid and data-meaningful range."
                        };
                    }
                    else
                    {
                        _curatedDeviationData = null;
                    }

                    skipPostRefresh = true;
                }

                if (!skipPostRefresh)
                {
                    _customIntervalValidationMessage = null;
                }
            }

            if (!skipPostRefresh && !ActiveSelectionSignalCode.IsEmpty && GetSignalAnalyticsScopeNodeKeys().Count > 0)
            {
                selectionSignalTask = AnalyticsPreview.GetSelectionSignalAnalyticsAsync(
                    GetSignalAnalyticsScopeNodeKeys(),
                    ActiveSelectionSignalCode,
                    interval.From,
                    interval.To,
                    _selectionSignalTimeSeriesMode,
                    _selectedFacilityNode?.NodeKey);
            }

            if (!skipPostRefresh && aggregateNodeKeys.Count > 0)
            {
                aggregateTask = AnalyticsPreview.GetCuratedSelectionAggregateOverviewAsync(
                    aggregateNodeKeys,
                    interval.From,
                    interval.To,
                    _timeSeriesMode,
                    includeBaselineOverlay: true,
                    CurrentAggregateRequestOptions);
            }

                    _nodePreviewData = null;
                    _curatedPreviewData = null;
                    _curatedDeviationData = null;
                    _curatedTimeSeriesData = null;
                    _curatedCompareTimeSeriesData = null;
                    _overviewChartTimeSeriesData = skipPostRefresh ? _overviewChartTimeSeriesData : null;
                    _selectionAggregateOverview = skipPostRefresh ? _selectionAggregateOverview : null;

            if (!skipPostRefresh && _isCuratedNode)
            {
                var focusNode = _selectedFacilityNode;
                if (focusNode is not null)
                {
                    var summaryTask = AnalyticsPreview.GetCuratedSummaryAsync(focusNode.NodeKey, interval.From, interval.To);
                    var deviationTask = AnalyticsPreview.GetCuratedDeviationSummaryAsync(focusNode.NodeKey, interval.From, interval.To);
                    var timeSeriesTask = AnalyticsPreview.GetCuratedTimeSeriesAsync(
                        focusNode.NodeKey,
                        interval.From,
                        interval.To,
                        _timeSeriesMode,
                        _showBaselineOverlay);
                    var effectiveCompareNodeKeys = GetEffectiveCompareNodeKeysForSelectedNode();
                    Task<CuratedNodeCompareTimeSeriesResult?>? compareTask = null;

                    if (IsCompareTabActivated && IsSelectedNodeComparePreviewSupported && effectiveCompareNodeKeys.Count > 0)
                    {
                        compareTask = AnalyticsPreview.GetCuratedCompareTimeSeriesAsync(
                            focusNode.NodeKey,
                            effectiveCompareNodeKeys,
                            interval.From,
                            interval.To,
                            _timeSeriesMode);
                    }

                    var loadTasks = new List<Task> { summaryTask, deviationTask, timeSeriesTask };
                    if (compareTask is not null)
                    {
                        loadTasks.Add(compareTask);
                    }

                    if (aggregateTask is not null)
                    {
                        loadTasks.Add(aggregateTask);
                    }

                    await Task.WhenAll(loadTasks);

                    _curatedPreviewData = summaryTask.Result;
                    _curatedDeviationData = deviationTask.Result;
                    _curatedTimeSeriesData = timeSeriesTask.Result;
                    _curatedCompareTimeSeriesData = compareTask?.Result;
                    _selectionAggregateOverview = aggregateTask?.Result;
                    _overviewChartTimeSeriesData = _selectionAggregateOverview?.TimeSeries;
                    SeedOverviewChartCache(aggregateNodeKeys, interval.From, interval.To, _timeSeriesMode, _overviewChartTimeSeriesData);
                }
            }
            else if (!skipPostRefresh && _selectedFacilityNode is not null && !string.IsNullOrWhiteSpace(_selectedFacilityNode.MeterUrn))
            {
                var previewTask = AnalyticsPreview.GetPreviewDataAsync(_selectedFacilityNode.MeterUrn, interval.From, interval.To);

                if (aggregateTask is not null)
                {
                    await Task.WhenAll(previewTask, aggregateTask);
                    _selectionAggregateOverview = aggregateTask.Result;
                }
                else
                {
                    _selectionAggregateOverview = null;
                    await previewTask;
                }

                _nodePreviewData = previewTask.Result;
                _overviewChartTimeSeriesData = _selectionAggregateOverview?.TimeSeries;
                SeedOverviewChartCache(aggregateNodeKeys, interval.From, interval.To, _timeSeriesMode, _overviewChartTimeSeriesData);
            }
            else if (!skipPostRefresh)
            {
                _selectionAggregateOverview = aggregateTask is not null
                    ? await aggregateTask
                    : null;
                _overviewChartTimeSeriesData = _selectionAggregateOverview?.TimeSeries;
                SeedOverviewChartCache(aggregateNodeKeys, interval.From, interval.To, _timeSeriesMode, _overviewChartTimeSeriesData);
            }

            _selectionSignalAnalyticsResult = !skipPostRefresh && selectionSignalTask is not null
                ? await selectionSignalTask
                : null;
        }
        finally
        {
            _isPreviewLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadOverviewChartAsync(
        IReadOnlyList<string> aggregateNodeKeys,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode,
        bool showLoadingIndicator)
    {
        if (aggregateNodeKeys.Count == 0)
        {
            _overviewChartTimeSeriesData = null;
            _isOverviewChartLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var loadVersion = ++_overviewChartLoadVersion;
        var cacheKey = CreateOverviewChartCacheKey(aggregateNodeKeys, from, to, mode);

        if (_overviewChartCache.TryGetValue(cacheKey, out var cachedTimeSeries))
        {
            _overviewChartTimeSeriesData = cachedTimeSeries;
            _isOverviewChartLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (showLoadingIndicator)
        {
            _isOverviewChartLoading = true;
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            var timeSeries = await AnalyticsPreview.GetCuratedSelectionAggregateTimeSeriesAsync(
                aggregateNodeKeys,
                from,
                to,
                mode,
                includeBaselineOverlay: true);

            if (loadVersion != _overviewChartLoadVersion)
            {
                return;
            }

            _overviewChartCache[cacheKey] = timeSeries;
            _overviewChartTimeSeriesData = timeSeries;
        }
        finally
        {
            if (loadVersion == _overviewChartLoadVersion)
            {
                _isOverviewChartLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private OverviewChartCacheKey CreateOverviewChartCacheKey(
        IReadOnlyList<string> aggregateNodeKeys,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode)
    {
        var aggregateNodeSignature = string.Join(
            "||",
            aggregateNodeKeys
                .Where(key => !string.IsNullOrWhiteSpace(key))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(key => key, StringComparer.OrdinalIgnoreCase));

        return new OverviewChartCacheKey(aggregateNodeSignature, from.Ticks, to.Ticks, mode);
    }

    private void SeedOverviewChartCache(
        IReadOnlyList<string> aggregateNodeKeys,
        DateTime from,
        DateTime to,
        CuratedNodeTimeSeriesMode mode,
        CuratedNodeTimeSeriesResult? timeSeries)
    {
        if (aggregateNodeKeys.Count == 0)
        {
            return;
        }

        _overviewChartCache[CreateOverviewChartCacheKey(aggregateNodeKeys, from, to, mode)] = timeSeries;
    }

