    private async Task GoHomeAsync()
    {
        if (_schematicLayout?.Nodes.Count > 0)
        {
            var rootNode = ResolveHomeTargetNode(_schematicLayout.Nodes);
            if (rootNode is not null)
            {
                await JSRuntime.InvokeVoidAsync("editorCanvas.panToNode", rootNode.X, rootNode.Y, 1.4);
                return;
            }
        }
        await JSRuntime.InvokeVoidAsync("editorCanvas.goHome");
    }

    private static SchematicNodeLayoutV2? ResolveHomeTargetNode(IReadOnlyList<SchematicNodeLayoutV2> nodes)
    {
        if (nodes.Count == 0)
            return null;

        var nodeByKey = nodes.ToDictionary(n => n.NodeKey, StringComparer.OrdinalIgnoreCase);
        var childrenByParent = new Dictionary<string, List<SchematicNodeLayoutV2>>(StringComparer.OrdinalIgnoreCase);

        foreach (var node in nodes)
        {
            if (string.IsNullOrWhiteSpace(node.ParentNodeKey) || !nodeByKey.ContainsKey(node.ParentNodeKey))
                continue;

            if (!childrenByParent.TryGetValue(node.ParentNodeKey, out var children))
            {
                children = [];
                childrenByParent[node.ParentNodeKey] = children;
            }

            children.Add(node);
        }

        var roots = nodes
            .Where(n => string.IsNullOrWhiteSpace(n.ParentNodeKey) || !nodeByKey.ContainsKey(n.ParentNodeKey))
            .OrderBy(n => n.Y)
            .ThenBy(n => n.X)
            .ToList();

        if (roots.Count == 0)
            return nodes.OrderBy(n => n.Y).ThenBy(n => n.X).FirstOrDefault();

        var current = roots[0];
        var visited = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { current.NodeKey };
        while (childrenByParent.TryGetValue(current.NodeKey, out var nextChildren) && nextChildren.Count == 1)
        {
            var next = nextChildren[0];
            if (!visited.Add(next.NodeKey))
                break;

            current = next;
        }

        return current;
    }

