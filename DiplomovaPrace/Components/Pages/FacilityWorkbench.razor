    private int GetStylePresetUsageCount(string presetKey)
    {
        var resolvedPresetKey = FacilityNodeStyleSystem.ResolvePresetKey(presetKey, _stylePresetsByKey);
        return _nodesByKey.Keys.Count(nodeKey =>
            FacilityNodeStyleSystem.ResolvePresetKey(
                _isEditModeOpen && _selectedFacilityNode is not null && nodeKey.Equals(_selectedFacilityNode.NodeKey, StringComparison.OrdinalIgnoreCase)
                    ? _styleAssignmentPresetKeyInput
                    : _editorNodeStatesByKey.TryGetValue(nodeKey, out var nodeState)
                        ? nodeState.StylePresetKey
                        : null,
                _stylePresetsByKey).Equals(resolvedPresetKey, StringComparison.OrdinalIgnoreCase));
    }

    private int GetPersistedStylePresetUsageCount(string presetKey)
    {
        var resolvedPresetKey = FacilityNodeStyleSystem.ResolvePresetKey(presetKey, _stylePresetsByKey);
        return _editorNodeStatesByKey.Values.Count(nodeState =>
            FacilityNodeStyleSystem.ResolvePresetKey(nodeState.StylePresetKey, _stylePresetsByKey)
                .Equals(resolvedPresetKey, StringComparison.OrdinalIgnoreCase));
    }

    private bool CanDeleteSelectedStylePreset()
    {
        return GetDeleteSelectedStylePresetBlockReason() is null;
    }

    private string? GetDeleteSelectedStylePresetBlockReason()
    {
        var resolvedPresetKey = FacilityNodeStyleSystem.ResolvePresetKey(_styleAssignmentPresetKeyInput, _stylePresetsByKey);
        if (resolvedPresetKey.Equals(FacilityNodeStyleSystem.DefaultPresetKey, StringComparison.OrdinalIgnoreCase))
        {
            return "The default fallback preset cannot be deleted.";
        }

        var persistedUsageCount = GetPersistedStylePresetUsageCount(resolvedPresetKey);
        if (persistedUsageCount > 0)
        {
            return $"This preset cannot be deleted because it is still used by {persistedUsageCount} node{(persistedUsageCount == 1 ? string.Empty : "s")}.";
        }

        return null;
    }

    private async Task ApplySelectedNodeStylePresetAsync()
    {
        if (!_isSchematicEditorEnabled)
        {
            _styleStatusMessage = "Schematic editor is disabled. Enable edit mode before changing the preset.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedFacilityNode is null || !CanEditFocusedNode)
        {
            _styleStatusMessage = "Select an editable node.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var snapshot = await SnapshotEditStateAsync();
        _editorNodeStatesByKey.TryGetValue(_selectedFacilityNode.NodeKey, out var existingState);
        var resolvedPresetKey = FacilityNodeStyleSystem.ResolvePresetKey(_styleAssignmentPresetKeyInput, _stylePresetsByKey);
        var nextState = new FacilityNodeEditorState
        {
            NodeKey = _selectedFacilityNode.NodeKey,
            Label = existingState?.Label,
            NodeType = existingState?.NodeType,
            Zone = existingState?.Zone,
            FloorAreaM2 = existingState?.FloorAreaM2,
            StylePresetKey = resolvedPresetKey,
            Tags = existingState?.Tags ?? [],
            Note = existingState?.Note,
            XHint = existingState?.XHint ?? _selectedFacilityNode.XHint,
            YHint = existingState?.YHint ?? _selectedFacilityNode.YHint,
            UpdatedUtc = DateTime.UtcNow
        };

        await FacilityEditorStateService.SaveNodeStatesAsync([nextState]);
        PushEditUndoSnapshot(snapshot, $"Node style \"{_selectedFacilityNode.Label}\"");
