    private void ToggleSchematicFullscreen()
    {
        _isSchematicFullscreen = !_isSchematicFullscreen;
        if (_isSchematicFullscreen)
            _isEditModeOpen = false;
        StateHasChanged();
        if (_isSchematicFullscreen)
        {
            Task.Delay(80).ContinueWith(_ => InvokeAsync(async () =>
                await GoHomeAsync()));
        }
        else
        {
            Task.Delay(80).ContinueWith(_ => InvokeAsync(GoHomeAsync));
        }
    }

    private async Task ToggleEditMode()
    {
        _isEditModeOpen = !_isEditModeOpen;
        _isSchematicEditorEnabled = _isEditModeOpen;
        _editorActiveTool = "select";
        _editorActiveTab = _selectionSet.Count > 1 ? "layout" : "edit";
        if (_isEditModeOpen)
        {
            _isSchematicFullscreen = false;
            // Pořídíme snapshot stavu před prvním editem pro cancel/restore
            _editModeDraftSnapshot = await FacilityEditorStateService.GetRawStateAsync();
            _editUndoStack.Clear();
            _editRedoStack.Clear();
            _showDiscardGuard = false;
        }
        StateHasChanged();
        var enteringEdit = _isEditModeOpen;
        if (enteringEdit)
        {
            _ = Task.Delay(80).ContinueWith(_ => InvokeAsync(async () =>
            {
                await JSRuntime.InvokeVoidAsync("editorCanvas.setGrid", true, 20);
                await JSRuntime.InvokeVoidAsync("editorCanvas.setFacilityNodeDragEnabled", true);
                await GoHomeAsync();
            }));
        }
        else
        {
            _ = Task.Delay(80).ContinueWith(_ => InvokeAsync(async () =>
