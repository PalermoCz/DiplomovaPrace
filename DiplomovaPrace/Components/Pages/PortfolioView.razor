@page "/portfolio"
@using DiplomovaPrace.Models.Kpi
@using DiplomovaPrace.Services
@inject IPortfolioAnalyticsService PortfolioAnalyticsService

<PageTitle>Portfolio Benchmark & Alerts</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0"><i class="bi bi-buildings me-2"></i>Portfolio Benchmark</h2>
            <p class="text-muted mb-0">Analytický přehled a odchylky v rámci celého portfolia budov.</p>
        </div>
        <div>
            @if (_isLoading)
            {
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Vyhodnocování...</span>
                </div>
            }
        </div>
    </div>

    <!-- Filtry -->
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light rounded d-flex gap-3 align-items-end">
            <div>
                <label class="form-label text-muted small fw-bold mb-1">Období od</label>
                <input type="date" class="form-control" @bind="_fromDate" />
            </div>
            <div>
                <label class="form-label text-muted small fw-bold mb-1">Období do</label>
                <input type="date" class="form-control" @bind="_toDate" />
            </div>
            <button class="btn btn-primary px-4 shadow-sm" @onclick="LoadPortfolioAsync" disabled="@_isLoading">
                <i class="bi bi-play-fill me-1"></i> Vyhodnotit období
            </button>
        </div>
    </div>

    @if (_result != null && !_isLoading)
    {
        var validBuildings = _result.Buildings.Where(b => b.Baseline.IsSuccess).ToList();
        var problemBuildings = validBuildings.Where(b => b.Insights.Any(i => i.Level == PortfolioAlertLevel.Critical || i.Level == PortfolioAlertLevel.Warning)).ToList();

        <!-- Top Insights -->
        @if (problemBuildings.Any())
        {
            <div class="alert alert-warning shadow-sm border-0 mb-4 rounded-3">
                <h5 class="alert-heading fw-bold mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>Pozornost vyžadují tyto budovy:</h5>
                <div class="row g-3">
                    @foreach (var building in problemBuildings.OrderByDescending(b => b.Insights.Max(i => (int)i.Level)))
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-warning border-opacity-50 shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-title fw-bold text-dark mb-1">@building.BuildingName</h6>
                                    <p class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i>@(building.PrimaryUse ?? "Neznámá lokalita")</p>
                                    
                                    <ul class="list-unstyled mb-0">
                                        @foreach (var insight in building.Insights.OrderByDescending(i => i.Level))
                                        {
                                            <li class="small mb-1 d-flex align-items-start">
                                                @if (insight.Level == PortfolioAlertLevel.Critical)
                                                {
                                                    <i class="bi bi-x-circle-fill text-danger me-2 mt-1"></i>
                                                    <span class="text-danger fw-bold">@insight.Message</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-exclamation-circle-fill text-warning me-2 mt-1"></i>
                                                    <span class="text-dark">@insight.Message</span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Benchmark Table -->
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h5 class="fw-bold"><i class="bi bi-bar-chart-line me-2"></i>Žebříček budov</h5>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-muted small">
                        <tr>
                            <th>Budova</th>
                            <th>Typ (Site)</th>
                            <th class="text-end">Spotřeba (kWh)</th>
                            <th class="text-end">Specifická (kWh/m²)</th>
                            <th class="text-end">Mimo prac. dobu (%)</th>
                            <th class="text-end">Odchylka od normálu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_result.Buildings.Any())
                        {
                            @foreach (var building in _result.Buildings.OrderByDescending(b => b.DeviationPercent ?? -999))
                            {
                                <tr>
                                    <td class="fw-bold text-dark">@building.BuildingName</td>
                                    <td><span class="badge bg-secondary bg-opacity-10 text-secondary">@building.PrimaryUse</span></td>
                                    
                                    <td class="text-end font-monospace">
                                        @(building.ActualConsumption?.ToString("N1") ?? "-")
                                    </td>
                                    
                                    <td class="text-end font-monospace">
                                        @(building.SpecificConsumption?.ToString("N2") ?? "-")
                                    </td>

                                    <td class="text-end font-monospace">
                                        @{
                                            var offHoursRatio = (building.ActualConsumption > 0 && building.OffHoursConsumption.HasValue) 
                                                ? (building.OffHoursConsumption.Value / building.ActualConsumption.Value) * 100 
                                                : (double?)null;
                                        }
                                        @if (offHoursRatio.HasValue)
                                        {
                                            <span class="@(offHoursRatio > 40 ? "text-danger fw-bold" : "text-muted")">
                                                @offHoursRatio.Value.ToString("N1") %
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td class="text-end">
                                        @if (building.DeviationPercent.HasValue && building.Baseline.IsSuccess)
                                        {
                                            var dev = building.DeviationPercent.Value;
                                            var badgeClass = dev > 20 ? "bg-danger" 
                                                           : dev > 10 ? "bg-warning text-dark" 
                                                           : dev < -20 ? "bg-info text-dark" 
                                                           : dev < -10 ? "bg-primary" 
                                                           : "bg-success";
                                            var sign = dev > 0 ? "+" : "";

                                            <span class="badge @badgeClass fs-6 px-3 py-2 rounded-pill shadow-sm">
                                                @sign@dev.ToString("N1") %
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small" title="@building.Baseline.ErrorMessage">
                                                @(string.IsNullOrEmpty(building.Baseline.ErrorMessage) ? "Nedostatek dat" : building.Baseline.ErrorMessage)
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-2 d-block mb-3"></i>
                                    Zvolenému období neodpovídají žádná relevantní data.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool _isLoading;
    private PortfolioBenchmarkResult? _result;

    // Use a time range which likely hits the BDG2 imported data range for demo purposes (year 2016).
    private DateTime _fromDate = new DateTime(2016, 5, 1);
    private DateTime _toDate = new DateTime(2016, 5, 30);

    protected override async Task OnInitializedAsync()
    {
        await LoadPortfolioAsync();
    }

    private async Task LoadPortfolioAsync()
    {
        _isLoading = true;
        StateHasChanged();

        // Zajistíme přepočet na UTC konce dne atd jako na Dashboardu (zde jen jednoduše).
        var fromUtc = DateTime.SpecifyKind(_fromDate, DateTimeKind.Utc);
        var toUtc = DateTime.SpecifyKind(_toDate, DateTimeKind.Utc).AddDays(1).AddSeconds(-1);

        try
        {
            _result = await PortfolioAnalyticsService.GetPortfolioBenchmarkAsync(fromUtc, toUtc);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
