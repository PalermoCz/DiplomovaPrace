{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (Facility)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/DiplomovaPrace/bin/Debug/net10.0/DiplomovaPrace.dll",
      "args": [],
      "cwd": "${workspaceFolder}/DiplomovaPrace",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Launch Facility in Integrated Browser",
      "type": "editor-browser",
      "request": "launch",
      "url": "http://localhost:5016/facility"
    },
    {
      "name": "Attach to Facility Tab in Integrated Browser",
      "type": "editor-browser",
      "request": "attach",
      "urlFilter": "http://localhost:5016/*"
    }
  ],
  "compounds": [
    {
      "name": "Facility + Integrated Browser",
      "configurations": [
        ".NET Core Launch (Facility)",
        "Launch Facility in Integrated Browser"
      ],
      "stopAll": true
    }
  ]
}