{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (Facility)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/DiplomovaPrace/bin/Debug/net10.0/DiplomovaPrace.dll",
      "args": [],
      "cwd": "${workspaceFolder}/DiplomovaPrace",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5016"
      },
      "console": "integratedTerminal"
    }
  ]
}